# ─────────────────────────────────────────────────────────────────
# RELIGIO PRO — Environment configuration
# Copy this file to `.env` and adjust values for your machine.
# Vars marked [prod] are required when NODE_ENV=production
# (boot fails fast otherwise — see src/env.js).
# ─────────────────────────────────────────────────────────────────

NODE_ENV=development
HOST=localhost
PORT=3000

# ── Database ────────────────────────────────────────────────────
# Required [prod]. Create database first:
#   mysql> CREATE DATABASE religio_pro CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# DATABASE_URL="mysql://root:password@localhost:3306/religio_pro"

# ── Auth ────────────────────────────────────────────────────────
# Required [prod]. Min 32 chars random:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET=
JWT_TTL=7d

# In production these MUST be set to your real domain + true (HTTPS).
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Public URLs ─────────────────────────────────────────────────
# Absolute origin used in notification deep links (booking links etc.)
# PUBLIC_BASE_URL=https://religio.pro

# ── Rate limit backend ──────────────────────────────────────────
# When set, rate limiter uses Redis (multi-instance safe). Unset =
# in-memory bucket (single-instance only).
# REDIS_URL=redis://localhost:6379

# ── Payment gateway — Midtrans Snap ─────────────────────────────
# Without MIDTRANS_SERVER_KEY the gateway runs in fake mode (local
# /payments/midtrans/fake handler simulates webhooks — fine for
# dev/staging, NEVER deploy fake mode to production).
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_PRODUCTION=false

# ── Notifications — WhatsApp (Fonnte) ───────────────────────────
# Without FONNTE_TOKEN the WA channel falls back to console sender.
# Get device token from https://fonnte.com dashboard.
# FONNTE_TOKEN=
# FONNTE_BASE_URL=https://api.fonnte.com

# ── Notifications — Email (SMTP via nodemailer) ─────────────────
# Without SMTP_HOST the EMAIL channel falls back to console sender.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Religio Pro <noreply@religio.pro>"
# SMTP_SECURE=false

# ── Notification worker ─────────────────────────────────────────
# In production with cron/systemd driving the queue, set this true so
# the in-process worker doesn't double-dispatch.
# NOTIF_WORKER_DISABLED=true
# NOTIF_WORKER_INTERVAL_MS=30000

# ── Web Push (VAPID) — Stage 17/93 ──────────────────────────────
# Without VAPID_PUBLIC the push sender falls back to console (logs payloads
# instead of sending). Generate keys with: npm run vapid:generate
# VAPID_PUBLIC=
# VAPID_PRIVATE=
# VAPID_CONTACT=mailto:admin@religio.pro

# ── Public admin contacts — Stage 354 quick-contact panel ───────
# Surfaced to jemaah on /saya/bookings/:id as fallback contact when
# their assigned agent has no WhatsApp configured. Both optional —
# panel hides gracefully if both unset.
# PUBLIC_ADMIN_WA=628123456789       # digits only, 8-15 chars, country code
# PUBLIC_ADMIN_PHONE=+62 21 0000 0000  # any human-readable format, min 8 chars

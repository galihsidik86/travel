# ─────────────────────────────────────────────────────────────────
# RELIGIO PRO — Environment configuration
# Copy this file to `.env` and adjust values for your machine.
# ─────────────────────────────────────────────────────────────────

NODE_ENV=development
HOST=localhost
PORT=3000

# ── Step 2 · MySQL (akan diaktifkan ketika Prisma di-wire) ──────
# Buat database terlebih dahulu:
#   mysql> CREATE DATABASE religio_pro CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# DATABASE_URL="mysql://root:password@localhost:3306/religio_pro"

# ── Step 3 · JWT auth (min. 32 karakter acak) ───────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET=
JWT_TTL=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

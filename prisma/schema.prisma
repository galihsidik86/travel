// =============================================================
// RELIGIO PRO — Prisma schema
// MySQL · utf8mb4_unicode_ci
//
// Step 2 focus: cover Auth (User+Role), Paket detail (Paket,
// PaketHotel, PaketHarga, PaketDay), Booking + Payment with
// agent attribution, dan AuditLog permanen.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  OWNER
  SUPERADMIN
  MANAJER_OPS
  KASIR
  SALES
  AGEN
  MUTHAWWIF
  JEMAAH
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PaketStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum KamarClass {
  QUAD
  TRIPLE
  DOUBLE
  VVIP
}

enum HotelCity {
  MADINAH
  MEKKAH
  JEDDAH
  AQSA
  PETRA
  AMMAN
  ISTANBUL
  CAIRO
  DUBAI
  JAKARTA
}

enum BookingStatus {
  PENDING // baru daftar
  BOOKED // booking fee dibayar
  DP_PAID // DP minimum lunas
  PARTIAL // sebagian cicilan
  LUNAS // pelunasan selesai
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  VA
  QRIS
  EWALLET
  CARD
  TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum Currency {
  IDR
  USD
  SAR
}

enum KomisiStatus {
  PENDING // booking belum lunas
  EARNED // booking lunas, komisi tercatat
  PAID // sudah ditransfer ke wallet agen
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  WA // WhatsApp
  CONSOLE // dev/dry-run only — never use in production
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED // intentionally not dispatched (e.g. recipient missing)
}

enum NotificationType {
  BOOKING_CREATED
  PAYMENT_RECEIVED
  BOOKING_LUNAS
  REFUND_ISSUED
  CANCEL_REQUESTED // jemaah → admin (5ii)
  PAYMENT_SETTLED_ADMIN // gateway settlement → admin fan-out (5yy)
  PAYOUT_CREATED
  DOC_VERIFIED
  INCIDENT_REPORTED // crew SOS / emergency → admin fan-out
  DAILY_DIGEST_OWNER // daily activity digest → OWNER (Stage 27)
  WEEKLY_DIGEST_OWNER // weekly summary → OWNER (Stage 33)
  AGENT_WEEKLY_DIGEST // weekly summary → individual AGEN (Stage 36)
  PAYOUT_REMINDER_OWNER // weekly reminder of overdue payout candidates → admins (Stage 37)
  WAITLIST_SLOT_FREED // cancel freed a seat with WAITING candidates → admin (Stage 42)
  AGENT_STALLED_LEADS // daily nudge → agen with cold lead pipeline (Stage 46)
  TRAFFIC_ANOMALY_OWNER // paket view drop ≥50% vs 7d avg → admins (Stage 53)
  LANDING_SLOW_OWNER // /p/:slug 95p latency > budget → admins (Stage 56)
  CREW_WEEKLY_DIGEST // weekly attendance + upcoming assignments → MUTHAWWIF (Stage 65)
  TESTIMONIAL_PUBLISHED // admin promoted jemaah's testimonial → jemaah (Stage 70)
  FIRST_PAYMENT_THANKS // first PAID payment lands → jemaah (Stage 75)
  GENERIC // catch-all for ad-hoc notifs
}

enum DocumentType {
  PASSPORT
  VISA_UMROH
  MANASIK_CERT
  HEALTH_CERT
  VACCINE_MENINGITIS
  MARRIAGE_CERT
  FAMILY_CARD
  OTHER
}

enum DocumentStatus {
  PENDING // di-track, perlu jemaah submit
  SUBMITTED // jemaah sudah upload/serahkan, perlu staff verifikasi
  VERIFIED // staff sudah verifikasi
  REJECTED // staff tolak, perlu re-submit
  EXPIRED // dokumen lewat masa berlaku
}

enum LeadStatus {
  COLD
  WARM
  CONVERTED // sudah jadi Booking
  LOST // tidak jadi
}

enum LeadSource {
  WA
  IG
  FB
  TIKTOK
  WALK_IN
  REFERRAL
  AD
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PRICE_CHANGE
  STATUS_CHANGE
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REFUND_ISSUED
  PERMISSION_GRANT
  PERMISSION_REVOKE
  EXPORT
}

// ─── Identity ────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role
  status       UserStatus @default(ACTIVE)
  fullName     String
  phone        String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  agent  AgentProfile?
  jemaah JemaahProfile?
  staff  StaffProfile?
  crew   CrewProfile?

  auditLogs         AuditLog[]         @relation("AuditActor")
  bookings          Booking[]          @relation("BookingJemaahUser")
  paketCreated      Paket[]            @relation("PaketCreator")
  docsVerified      JemaahDocument[]   @relation("DocumentVerifier")
  payoutsPaid       KomisiPayout[]     @relation("PayoutPaidBy")
  crewAssignments   PaketCrew[]        @relation("CrewAssignedToPaket")
  attendanceMarks   AttendanceMark[]   @relation("AttendanceMarkedBy")
  incidentsCreated  Incident[]         @relation("IncidentCreator")
  incidentsAcked    Incident[]         @relation("IncidentAcker")
  incidentsResolved Incident[]         @relation("IncidentResolver")
  pushSubscriptions PushSubscription[]
  testimonials      Testimonial[]      @relation("TestimonialSubmitter")

  @@index([role])
  @@index([deletedAt])
}

// Web Push subscriptions (stage 17). One row per (user × browser/device).
// Endpoint is globally unique per browser install — re-registering returns
// the same endpoint, so we upsert on conflict to refresh p256dh/auth/UA.
//
// Cascade on user delete so a SUSPENDED + deleted admin can't keep
// receiving SOS pushes on a stale device.
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Endpoint URL is too long for a MySQL @unique on TEXT — store the URL
  // verbatim and key uniqueness off the sha-256 hash. Service layer is
  // responsible for computing endpointHash before upsert.
  endpoint     String   @db.Text
  endpointHash String   @unique @db.VarChar(64)
  p256dh       String   @db.Text
  auth         String   @db.Text
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@index([userId])
}

model AgentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // dipakai di URL /p/<paketSlug>?a=<slug>
  slug               String   @unique
  displayName        String
  igHandle           String?
  whatsapp           String
  bio                String?  @db.Text
  // Stage 74 — public profile photo. When set with bio + isVerified, the
  // /a/:slug public page renders. Opt-in by default (no photo → no page).
  photoUrl           String?  @db.VarChar(255)
  tier               String?
  joinedAt           DateTime @default(now())
  isVerified         Boolean  @default(false)
  // Optional per-agent komisi rate; when set, wins over Paket.komisiRate (5v)
  komisiRateOverride Decimal? @db.Decimal(5, 4)

  bookings       Booking[]          @relation("BookingAgent")
  komisi         Komisi[]
  payouts        KomisiPayout[]
  leads          Lead[]
  paketOverrides AgentPaketKomisi[]

  @@index([slug])
}

// Per-paket × per-agent komisi override (stage 14). Composite PK is the
// natural upsert key — admin sets a row per (agent, paket) tuple.
// Precedence: AgentPaketKomisi → AgentProfile.komisiRateOverride →
// Paket.komisiRate → DEFAULT_KOMISI_RATE. The rate at LUNAS transition
// is locked into Komisi.amount; later edits to this table never recompute
// historical rows (mirrors 5u/5v invariant for the global rates).
model AgentPaketKomisi {
  agentId   String
  agent     AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  paketId   String
  paket     Paket        @relation(fields: [paketId], references: [id], onDelete: Cascade)
  rate      Decimal      @db.Decimal(5, 4)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@id([agentId, paketId])
  @@index([paketId])
}

model JemaahProfile {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName         String
  nik              String?   @unique
  passportNo       String?   @unique
  passportExpiry   DateTime?
  birthDate        DateTime?
  gender           String?
  phone            String
  email            String?
  address          String?   @db.Text
  emergencyContact String?
  notes            String?   @db.Text

  // Notif opt-out per channel (5jj). Defaults to opt-in (true).
  notifEmail Boolean @default(true)
  notifWa    Boolean @default(true)

  bookings       Booking[]
  documents      JemaahDocument[]
  notifTypePrefs JemaahNotifPref[]

  @@index([phone])
  @@index([passportExpiry])
}

// Per-type notif opt-out. Absence = enabled (default opt-in).
// Composite PK (jemaahId, type) makes the toggle a natural upsert.
//
// Interaction with per-channel opt-out (JemaahProfile.notifEmail/notifWa):
//   Both apply independently — a row is SKIPPED if EITHER the channel is
//   opted out OR this type is disabled. Per-type wins for the skip-reason
//   text (more actionable for the jemaah).
model JemaahNotifPref {
  jemaahId  String
  jemaah    JemaahProfile    @relation(fields: [jemaahId], references: [id], onDelete: Cascade)
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt

  @@id([jemaahId, type])
  @@index([jemaahId])
}

model StaffProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?
  position   String?
}

model CrewProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  languages  String?
  experience Int?
  // Stage 71 — public profile fields. `slug` is the URL path on /c/:slug
  // (admin sets, lowercase a-z/0-9/dash). Bio + photo opt-in: when both
  // null, the public route 404s so the crew can stay private.
  slug        String? @unique @db.VarChar(120)
  titlePrefix String? @db.VarChar(40)  // mis. "Ustadz", "H.", "KH."
  bio         String? @db.Text
  photoUrl    String? @db.VarChar(255)
}

// 5oo: M2M between Paket and MUTHAWWIF users — drives the crew portal manifest.
// Assignment is admin-managed via the Paket edit form. Crew assignment to a
// CANCELLED/ARCHIVED paket is allowed (admin may need to keep a record) but
// the /crew dashboard filters those out.
model PaketCrew {
  paketId    String
  paket      Paket    @relation(fields: [paketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("CrewAssignedToPaket", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([paketId, userId])
  @@index([userId])
  @@index([paketId])
}

// ─── Paket ───────────────────────────────────────────────────

model Paket {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  subtitle        String?
  heroTitleHtml   String? @db.Text // trusted HTML with <em> & <br>; admin-curated
  arabicTagline   String? @db.Text
  translitTagline String? @db.Text

  departureDate DateTime
  returnDate    DateTime
  durationDays  Int

  airline     String?
  airlineCode String?
  routeFrom   String?
  routeTo     String?

  heroDescription String? @db.LongText
  // Stage 50 — optional variant B for hero title A/B test. When set, the
  // public landing serves A or B 50/50 (deterministic per visitor cookie).
  heroTitleHtmlVariantB String? @db.Text
  // Stage 52 — optional CTA button text variants. Reuses the same heroVariant
  // bucketing so one A/B run can test both surfaces at once. Both null →
  // hardcoded default "BOOK SEKARANG" (no test running).
  ctaTextVariantA String? @db.VarChar(60)
  ctaTextVariantB String? @db.VarChar(60)
  inclusions      Json
  exclusions      Json
  trustBadges     Json?

  kursiTotal       Int       @default(45)
  kursiTerisi      Int       @default(0)
  manifestClosesAt DateTime?
  komisiRate       Decimal   @default(0.06) @db.Decimal(5, 4) // 0.0000-1.0000; agent komisi % on LUNAS

  // Stage 22 — per-pax fully-loaded vendor cost (hotel + flight + visa + ops).
  // Optional. When set, the admin leaderboard computes net margin per paket:
  //   netMargin = lunasRevenue − (lunasPaxCount × costPerPaxIdr) − komisiLiability
  // Left null = leaderboard skips the margin column for this paket (no
  // misleading "0%" or "100%" when costs aren't tracked yet).
  costPerPaxIdr Decimal? @db.Decimal(15, 2)
  costNotes     String?  @db.Text
  // Stage 61 — total ads spend allocated to this paket. Optional; when set,
  // leaderboard computes ROI = lunasRevenue / adsSpend. Null = "tidak
  // dilacak" (most paket promoted organically) — leaderboard renders "—"
  // rather than 0% (avoid misleading "no ads → infinite ROI" reading).
  adsSpendIdr   Decimal? @db.Decimal(15, 2)
  adsNotes      String?  @db.Text

  // Stage 34 — paket clone lineage (S18 created the clone flow; this is the
  // back-reference column). Null when the paket is an original. Populated by
  // the clone service so the YoY leaderboard can compare this season to the
  // one it was cloned from without scraping AuditLog.
  clonedFromId String?
  clonedFrom   Paket?   @relation("PaketLineage", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones       Paket[]  @relation("PaketLineage")

  status      PaketStatus @default(DRAFT)
  publishedAt DateTime?

  createdById String?
  createdBy   User?     @relation("PaketCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  hotels          PaketHotel[]
  prices          PaketHarga[]
  days            PaketDay[]
  bookings        Booking[]
  rooms           Room[]
  crewAssignments PaketCrew[]
  incidents       Incident[]
  agentOverrides  AgentPaketKomisi[]
  waitlist        PaketWaitlist[]
  views           PaketView[]
  testimonials    Testimonial[]

  @@index([slug])
  @@index([status])
  @@index([departureDate])
  @@index([deletedAt])
  @@index([clonedFromId])
}

// Stage 63 — testimonial. Admin-curated; optionally tied to a paket
// (jemaah X tells story about Aqsa trip 2026). DRAFT keeps it off the
// public page until admin reviews; PUBLISHED renders on /p/:slug. No
// soft-delete — testimonials are admin-authored, removable cleanly.
enum TestimonialStatus {
  DRAFT
  PUBLISHED
}

model Testimonial {
  id        String            @id @default(cuid())
  // Nullable paket FK: testimonial may be paket-specific (renders on that
  // landing) or generic (admin shows across all paket).
  paketId   String?
  paket     Paket?            @relation(fields: [paketId], references: [id], onDelete: SetNull)

  // Stage 69/70 — populated when a jemaah self-submits via /saya/bookings/
  // :id/testimonial. Null when an admin authored it manually. S70 fires a
  // notif to this user when admin flips DRAFT → PUBLISHED.
  submittedByUserId String?
  submittedBy       User?    @relation("TestimonialSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)

  jemaahName String           @db.VarChar(120)
  jemaahCity String?          @db.VarChar(120)
  body       String           @db.Text
  rating     Int              @default(5) // 1-5; defaults to 5 (no neutral testimonials shown publicly)

  // Public-facing photo lives in /uploads/testimonials/ (the design package's
  // public asset dir, so no auth gating). Optional — text testimonials work too.
  photoUrl   String?          @db.VarChar(255)

  status     TestimonialStatus @default(DRAFT)
  // Sort order on the landing. Admin picks. Lower = first.
  sortOrder  Int               @default(0)

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status, sortOrder])
  @@index([paketId])
}

// Stage 26 — paket waitlist. When kursi penuh, jemaah can leave name +
// phone to be queued; admin promotes them when a slot opens (typically
// after a cancellation). PROMOTED rows carry the booking they spawned.
//
// Status machine: WAITING → PROMOTED (terminal) | CANCELLED (terminal).
// No back-transitions — a promoted row stays as the audit trail of
// "this jemaah came from the waitlist".
enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
}

// Stage 77 — email click tracking. Links in notification bodies are
// rewritten through `/r/<token>` where <token> is a short-lived HMAC of
// (notifId, targetUrl). The redirect handler upserts an EmailClick row
// and 302s to the target. `firstClickAt` is the canonical conversion
// signal — repeat clicks just bump the counter so admin can see "5
// clicks across 3 days" patterns.
//
// Not pruned by stage 14 retention — admin needs the full history to
// compute per-notif-type CTR over arbitrary windows.
model EmailClick {
  id              String   @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  targetUrl       String   @db.VarChar(500)
  ipAddress       String?  @db.VarChar(45)
  userAgent       String?  @db.VarChar(255)
  firstClickAt    DateTime @default(now())
  lastClickAt     DateTime @default(now())
  clickCount      Int      @default(1)

  @@unique([notificationId, targetUrl])
  @@index([notificationId])
}

// Stage 48 — public paket landing page visit counter. Used to compute
// conversion rate (bookings ÷ unique visits) per paket. Identified by
// a non-httpOnly cookie `rp_vis` (32-hex random) set on first visit; the
// route upserts on `(paketId, visitorId, dayKey)` so refreshes within
// the same day don't bloat the count. Cookie persists 1 year.
model PaketView {
  id        String   @id @default(cuid())
  paketId   String
  paket     Paket    @relation(fields: [paketId], references: [id], onDelete: Cascade)
  visitorId String   // random 32-hex from rp_vis cookie
  dayKey    String   // YYYY-MM-DD local date so multi-refresh per day = 1 row
  agentSlug String?  // captured from `?a=` query, if present
  // Stage 50 — which hero variant was served on this visit ('A' or 'B').
  // Null when the paket has no variant B set (no test running).
  heroVariant String? @db.VarChar(1)
  // Stage 51 — UTM tags captured from the landing query (first-touch).
  // Stored on the first visit row per (paket, visitor); later visits keep
  // the original attribution via the upsert update-no-op pattern.
  utmSource   String? @db.VarChar(80)
  utmMedium   String? @db.VarChar(80)
  utmCampaign String? @db.VarChar(120)
  // Stage 56 — server-side render time in ms. Captured per visit so the
  // admin can compute 95p latency without a separate metrics table.
  // Null on rows pre-S56 (legacy data).
  renderMs    Int?
  createdAt DateTime @default(now())

  @@unique([paketId, visitorId, dayKey])
  @@index([paketId, createdAt])
}

model PaketWaitlist {
  id        String         @id @default(cuid())
  paketId   String
  paket     Paket          @relation(fields: [paketId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String
  notes     String?        @db.Text
  status    WaitlistStatus @default(WAITING)
  createdAt DateTime       @default(now())

  promotedAt        DateTime?
  promotedBookingId String?
  cancelledAt       DateTime?

  @@unique([paketId, phone])
  @@index([paketId, status])
  @@index([status, createdAt])
}

model PaketHotel {
  id      String @id @default(cuid())
  paketId String
  paket   Paket  @relation(fields: [paketId], references: [id], onDelete: Cascade)

  city        HotelCity
  name        String
  stars       Int
  distance    String?
  description String?   @db.Text
  nights      Int
  order       Int       @default(0)

  @@index([paketId])
}

model PaketHarga {
  id      String @id @default(cuid())
  paketId String
  paket   Paket  @relation(fields: [paketId], references: [id], onDelete: Cascade)

  kelas         KamarClass
  label         String? // "Suite Eksekutif", "Dua / kamar", dst.
  caption       String? // "Sharing 2 jemaah · untuk pasangan suami-istri"
  priceIdr      Decimal    @db.Decimal(15, 2)
  cicilanIdr    Decimal?   @db.Decimal(15, 2)
  cicilanMonths Int?
  perks         Json?
  isFeatured    Boolean    @default(false)

  @@unique([paketId, kelas])
  @@index([paketId])
}

model PaketDay {
  id              String  @id @default(cuid())
  paketId         String
  paket           Paket   @relation(fields: [paketId], references: [id], onDelete: Cascade)
  dayNumber       Int
  dayRange        String?
  dateLabel       String?
  monthLabel      String?
  title           String
  description     String  @db.Text
  tags            Json?
  highlight       Boolean @default(false)
  pembimbingTitle String?
  pembimbingNote  String? @db.Text

  attendanceMarks AttendanceMark[]

  @@unique([paketId, dayNumber])
  @@index([paketId])
}

// 5ww: per-day attendance tracking — crew (muthawwif) checks off who showed
// up to each itinerary day's activity. One mark per (booking, day) — re-marking
// just toggles `present` + updates `markedByUserId/markedAt`.
//
// Cascade on Booking delete (booking cancelled → marks gone), but PaketDay
// cascade isn't strictly required — paket admins won't typically delete days
// after a trip starts. Both cascades kept for cleanup safety.
model AttendanceMark {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paketDayId String
  paketDay   PaketDay @relation(fields: [paketDayId], references: [id], onDelete: Cascade)

  present Boolean @default(true)
  notes   String? @db.Text

  markedByUserId String
  markedBy       User     @relation("AttendanceMarkedBy", fields: [markedByUserId], references: [id])
  markedAt       DateTime @default(now())

  @@unique([bookingId, paketDayId])
  @@index([paketDayId])
  @@index([bookingId])
}

// ─── Crew incidents (SOS / emergency alerts) ────────────────
//
// Lightweight ticketing for in-field emergencies raised by MUTHAWWIF
// during a trip. Status machine: OPEN → ACKED → RESOLVED. Notif fan-out
// to ACTIVE OWNER/SUPERADMIN/MANAJER_OPS happens on creation (admin gets
// pinged the moment the SOS arrives, ack stays internal — no jemaah-side
// notif since jemaah might be the subject of the incident).

enum IncidentType {
  SOS // life-threatening
  MEDICAL // health emergency
  LOST_JEMAAH // jemaah missing
  SECURITY // theft / assault / harassment
  LOGISTICAL // transport / hotel breakdown
  OTHER
}

enum IncidentStatus {
  OPEN
  ACKED
  RESOLVED
}

model Incident {
  id String @id @default(cuid())

  paketId String?
  paket   Paket?  @relation(fields: [paketId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("IncidentCreator", fields: [createdById], references: [id])

  type          IncidentType
  message       String?      @db.Text
  locationLabel String?

  status       IncidentStatus @default(OPEN)
  ackedById    String?
  ackedBy      User?          @relation("IncidentAcker", fields: [ackedById], references: [id], onDelete: SetNull)
  ackedAt      DateTime?
  resolvedById String?
  resolvedBy   User?          @relation("IncidentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  resolution   String?        @db.Text

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@index([paketId, createdAt])
}

// ─── Bunking (room assignment) ───────────────────────────────

model Room {
  id      String @id @default(cuid())
  paketId String
  paket   Paket  @relation(fields: [paketId], references: [id], onDelete: Cascade)

  roomNo   String // mis. "M-401" / "M-501"
  floor    Int? // 4, 5, ...
  wing     String? // "Selatan" / "Utara"
  kelas    KamarClass
  capacity Int // QUAD=4 / TRIPLE=3 / DOUBLE=2 / VVIP=1 (atau custom)
  notes    String?    @db.Text

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paketId, roomNo])
  @@index([paketId])
  @@index([kelas])
}

// ─── Booking & Payment ───────────────────────────────────────

model Booking {
  id        String @id @default(cuid())
  bookingNo String @unique

  paketId String
  paket   Paket  @relation(fields: [paketId], references: [id])

  jemaahId String
  jemaah   JemaahProfile @relation(fields: [jemaahId], references: [id])

  jemaahUserId String?
  jemaahUser   User?   @relation("BookingJemaahUser", fields: [jemaahUserId], references: [id], onDelete: SetNull)

  // capture dari ?a=<slug>
  agentId      String?
  agent        AgentProfile? @relation("BookingAgent", fields: [agentId], references: [id])
  agentSlugCap String? // snapshot slug saat booking (untuk audit kalau slug berubah)

  // Stage 49/50/51 — visit attribution snapshot at booking time. Resolved
  // from the rp_vis cookie at /api/booking POST and stamped here. Mutable
  // never — these reflect "how did this booking come to be".
  firstViewAt     DateTime?
  viewCount       Int     @default(0)
  heroVariant     String? @db.VarChar(1)
  utmSource       String? @db.VarChar(80)
  utmMedium       String? @db.VarChar(80)
  utmCampaign     String? @db.VarChar(120)

  // bunking assignment (NULL = belum di-assign ke kamar)
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  kelas    KamarClass
  paxCount Int        @default(1)
  notes    String?    @db.Text

  totalAmount Decimal  @db.Decimal(15, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(15, 2)
  currency    Currency @default(IDR)

  status       BookingStatus @default(PENDING)
  bookingFeeAt DateTime?
  dpDueAt      DateTime?
  lunasDueAt   DateTime?
  cancelledAt  DateTime?
  cancelReason String?       @db.Text

  // Jemaah-initiated cancel request (5ff) — admin still has to approve via cancelBooking.
  cancelRequested     Boolean   @default(false)
  cancelRequestedAt   DateTime?
  cancelRequestReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments        Payment[]
  komisi          Komisi[]
  paymentIntents  PaymentIntent[]
  attendanceMarks AttendanceMark[]

  @@index([paketId])
  @@index([agentId])
  @@index([status])
  @@index([jemaahId])
  // jemaahUserId index is auto-created by the FK on this column; not
  // re-declared here so prisma migrate stops trying to rename it.
  @@index([createdAt])
  @@index([roomId])
}

model Payment {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  amount       Decimal  @db.Decimal(15, 2)
  currency     Currency @default(IDR)
  exchangeRate Decimal? @db.Decimal(15, 6)
  amountIdrEq  Decimal? @db.Decimal(15, 2)

  method     PaymentMethod
  gatewayRef String?       @unique
  vaNumber   String?

  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  expiresAt DateTime?

  notes String? @db.Text

  // 5pp: back-reference to PaymentIntent (nullable — direct admin-recorded payments have none)
  intent PaymentIntent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
}

// 5pp: Gateway intent — durable record of "we asked Midtrans to take payment".
// Lifecycle CREATED → PENDING (jemaah started) → SETTLED (materialized to Payment)
// or EXPIRED/CANCELLED/FAILED (terminal, no Payment).
// Separate from `Payment` because intents can fail without ever producing a
// money movement; keeping them apart preserves the append-only invariant on Payment.
model PaymentIntent {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  provider        String  @default("MIDTRANS")
  orderId         String  @unique // what we send to Midtrans; format: PI-<intentId>
  snapToken       String? @db.Text
  snapRedirectUrl String? @db.Text

  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("IDR")

  status         PaymentIntentStatus @default(CREATED)
  gatewayStatus  String? // raw status from Midtrans (e.g. "settlement", "pending", "deny")
  gatewayPayload Json? // last webhook payload — debug + audit

  paymentId String?  @unique // FK once SETTLED → matching Payment row
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  // Drives /admin/payment-intents global list (createdAt desc) + the
  // expire-intents sweep (status IN (CREATED, PENDING) AND expiresAt < now).
  @@index([createdAt])
  @@index([status, expiresAt])
}

enum PaymentIntentStatus {
  CREATED // intent registered, snap token returned, awaiting jemaah action
  PENDING // jemaah triggered payment, gateway still confirming
  SETTLED // gateway confirmed, Payment materialized (terminal happy path)
  EXPIRED // intent expired before jemaah completed payment
  CANCELLED // operator/jemaah cancelled before settlement
  FAILED // gateway returned denial / charge failure
}

model Komisi {
  id        String       @id @default(cuid())
  bookingId String
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agentId   String
  agent     AgentProfile @relation(fields: [agentId], references: [id])

  amount   Decimal      @db.Decimal(15, 2)
  currency Currency     @default(IDR)
  status   KomisiStatus @default(PENDING)
  earnedAt DateTime?
  paidAt   DateTime?

  // Disbursement bundle (5x) — populated when admin runs a payout
  payoutId String?
  payout   KomisiPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([bookingId])
  @@index([status])
  @@index([payoutId])
}

// Bundle of komisi rows paid out together (5x).
// payoutNo scheme: PO-YYYY-NNNNN (mirrors RP-YYYY-NNNNN bookingNo).
model KomisiPayout {
  id       String       @id @default(cuid())
  payoutNo String       @unique
  agentId  String
  agent    AgentProfile @relation(fields: [agentId], references: [id])

  amount    Decimal  @db.Decimal(15, 2) // snapshot at creation
  currency  Currency @default(IDR)
  method    String // "TRANSFER" / "CASH" / "EWALLET" / "QRIS" — free string for ops flexibility
  reference String? // bank transfer ref / receipt no.
  notes     String?  @db.Text

  paidAt   DateTime @default(now())
  paidById String?
  paidBy   User?    @relation("PayoutPaidBy", fields: [paidById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  komisi Komisi[]

  @@index([agentId])
  @@index([paidAt])
}

// ─── Jemaah documents (visa, paspor, sertifikat) ─────────────

model JemaahDocument {
  id       String        @id @default(cuid())
  jemaahId String
  jemaah   JemaahProfile @relation(fields: [jemaahId], references: [id], onDelete: Cascade)

  type   DocumentType
  status DocumentStatus @default(PENDING)

  refNumber String? // nomor visa/sertifikat/dst.
  expiresAt DateTime? // untuk dokumen yang punya masa berlaku
  notes     String?   @db.Text

  // 5mm: file attachment. One file per doc — re-upload replaces the previous one.
  // Path is relative to project root (e.g. "private/docs/<jemaahId>/<docId>__paspor.pdf").
  filePath       String?
  fileName       String? // original sanitised basename, used for download Content-Disposition
  fileSize       Int? // bytes
  mimeType       String?
  fileUploadedAt DateTime?

  submittedAt  DateTime?
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?     @relation("DocumentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jemaahId, type]) // 1 doc per type per jemaah
  @@index([jemaahId])
  @@index([status])
  @@index([type])
}

// ─── CRM Leads (pre-booking) ─────────────────────────────────

model Lead {
  id      String       @id @default(cuid())
  agentId String
  agent   AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)

  fullName String
  phone    String
  email    String?
  notes    String? @db.Text

  source LeadSource @default(OTHER)
  status LeadStatus @default(COLD)

  // Interest (optional — agen mungkin belum tahu)
  interestedPaketSlug String?
  interestedKelas     KamarClass?
  estPaxCount         Int?
  estValueIdr         Decimal?    @db.Decimal(15, 2)

  // Tracking
  score      Int? // 0-100, dipakai untuk progress bar di kartu
  followUpAt DateTime?

  // Konversi ke Booking (untuk audit kalau sudah convert)
  convertedAt        DateTime?
  convertedBookingId String?   @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([agentId, status])
  @@index([followUpAt])
  @@index([deletedAt])
}

// ─── Notifications (queue + dispatch log) ────────────────────

model Notification {
  id      String              @id @default(cuid())
  type    NotificationType
  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  recipientEmail  String?
  recipientPhone  String? // for WA
  recipientUserId String? // 5ll: optional link to User so /saya/notifications can filter to the jemaah's own rows
  subject         String? @db.Text
  body            String  @db.Text
  payload         Json? // structured data for templating

  // Optional link to source entity for cross-reference
  relatedEntity   String? // 'Booking' / 'Payment' / 'KomisiPayout' / ...
  relatedEntityId String?

  sentAt DateTime?
  error  String?   @db.Text // populated when status=FAILED

  // 5nn: retry-with-backoff state.
  //   attemptCount: 0 before first dispatch; incremented after each FAILED attempt.
  //   nextRetryAt:  scheduled time of the next attempt; null when terminal (SENT/SKIPPED, or FAILED at max attempts).
  //   lastAttemptAt: stamp of the most recent dispatch (success or failure).
  attemptCount  Int       @default(0)
  nextRetryAt   DateTime?
  lastAttemptAt DateTime?

  // 5rr: read receipt for the jemaah-side inbox. Null = unread. Stamped on
  // first visit to /saya/notifications. Independent of dispatch status —
  // a SKIPPED row can still be "read" by the jemaah seeing it in their inbox.
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stage 77 — email click tracking back-relation
  clicks EmailClick[]

  @@index([status])
  @@index([type])
  @@index([channel])
  @@index([relatedEntity, relatedEntityId])
  @@index([recipientUserId, createdAt])
  @@index([recipientUserId, readAt]) // 5rr: drives the unread-badge count query
  @@index([status, nextRetryAt]) // 5nn: drives the "ready to retry" query
  @@index([createdAt])
}

// ─── JobRun (ops job execution log; powers /api/health freshness) ────
//
// One row per CLI/HTTP-triggered run of an ops job (expire-docs,
// expire-intents, send-notifications, etc.). Tests don't write here —
// they call services directly, bypassing the runJob wrapper.
model JobRun {
  id         String    @id @default(cuid())
  name       String // 'expire-docs' | 'expire-intents' | 'send-notifications'
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  ok         Boolean   @default(false)

  // Generic counters — interpretation depends on job:
  //   scanned  — rows considered (e.g. notif queue length)
  //   affected — rows changed (expired, sent, ...)
  //   errors   — per-row failure count (job itself still succeeded)
  scanned  Int?
  affected Int?
  errors   Int  @default(0)

  durationMs Int?
  detail     Json? // job-specific extra (e.g. sent/failed/skipped breakdown)
  error      String? @db.Text // populated when ok=false (job itself threw)

  @@index([name, finishedAt])
  @@index([startedAt])
}

// ─── Audit (permanent, no deletes) ───────────────────────────

model AuditLog {
  id          String  @id @default(cuid())
  actorUserId String?
  actor       User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String? // snapshot kalau user dihapus
  actorRole   Role?

  action   AuditAction
  entity   String
  entityId String?

  before Json?
  after  Json?

  ip        String?
  userAgent String? @db.Text

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([action])
  // 5gg / activity sparkline + per-entity audit drill-downs benefit from a
  // compound (entity, createdAt) — filter by entity, sort by time in one pass.
  @@index([entity, createdAt])
}

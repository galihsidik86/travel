<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Crew · <%= paket.title %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 40px 80px; }

  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }

  .head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 20px; gap: 20px; flex-wrap: wrap; }
  .head h1 { font-family: var(--font-display); font-size: 30px; font-weight: 500; color: var(--cream-100); margin: 0; letter-spacing: -0.015em; }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.08em; margin-top: 8px; }

  .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 26px; }
  .kpi { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 16px 18px; }
  .kpi .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
  .kpi .v { font-family: var(--font-display); font-size: 26px; color: var(--cream-100); margin-top: 6px; font-weight: 500; }
  .kpi .v.gold { color: var(--gold-300); }

  .tbl { width: 100%; border-collapse: collapse; background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); overflow: hidden; }
  .tbl thead th { text-align: left; padding: 12px 14px; background: var(--ink-1000); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); font-weight: 500; border-bottom: var(--hairline); }
  .tbl tbody td { padding: 12px 14px; border-bottom: var(--hairline-soft); font-size: 12.5px; color: var(--cream-200); vertical-align: top; }
  .tbl tbody tr:hover td { background: var(--ink-850); }
  .tbl .id { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .tbl .nm { color: var(--cream-100); font-weight: 500; }
  .tbl .sx { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; letter-spacing: 0.04em; }

  .status-tag {
    padding: 3px 8px; font-family: var(--font-mono); font-size: 9.5px;
    border-radius: 3px; letter-spacing: 0.1em; border: 1px solid;
  }
  .status-tag.pending   { color: var(--amber); border-color: var(--amber); }
  .status-tag.booked    { color: var(--sapphire); border-color: var(--sapphire); }
  .status-tag.dp_paid   { color: var(--gold-300); border-color: var(--gold-300); }
  .status-tag.partial   { color: var(--gold-300); border-color: rgba(212,175,55,0.5); }
  .status-tag.lunas     { color: var(--emerald); border-color: var(--emerald); background: rgba(74,143,109,0.08); }

  .doc-strip { display: flex; gap: 3px; flex-wrap: wrap; }
  .doc-pill {
    display: inline-block; padding: 2px 6px; font-family: var(--font-mono); font-size: 9px;
    border-radius: 2px; border: 1px solid;
  }
  .doc-pill.state-verified  { color: var(--emerald); border-color: rgba(74,143,109,0.5); background: rgba(74,143,109,0.08); }
  .doc-pill.state-submitted { color: var(--amber);   border-color: rgba(201,147,59,0.5); background: rgba(201,147,59,0.08); }
  .doc-pill.state-pending   { color: var(--ink-200); border-color: var(--ink-500); }
  .doc-pill.state-rejected  { color: var(--ruby);    border-color: rgba(181,86,74,0.5); background: rgba(181,86,74,0.08); }
  .doc-pill.state-expired   { color: var(--ruby);    border-color: var(--ruby);          background: rgba(181,86,74,0.15); }
  .doc-pill.state-missing   { color: var(--ink-300); border-color: var(--ink-500); border-style: dashed; }

  .empty { padding: 40px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); }

  @media (max-width: 720px) {
    .kpi-row { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .head { flex-direction: column; align-items: stretch; }
    .head .head-actions, .head > div:last-child { display: flex; gap: 8px; flex-wrap: wrap; }
    .tbl { font-size: 11.5px; }
    .tbl thead th { padding: 8px 10px; }
    .tbl tbody td { padding: 8px 10px; }
  }
</style>
</head>
<body data-screen-label="05 Crew · Manifest" class="has-m-tabs">
<div class="wrap">
  <div class="crumb">
    <a href="/crew">← KEMBALI KE DAFTAR PAKET</a>
  </div>

  <div class="head">
    <div>
      <h1><em><%= paket.title %></em></h1>
      <div class="sub">
        <%= paket.slug %> · DEP <%= fmt.dateLong(paket.departureDate) %> · <%= paket.durationDays %> hari
      </div>
    </div>
    <div style="display:flex;gap:10px;">
      <%# 5ww: per-day attendance grid %>
      <a href="/crew/paket/<%= paket.slug %>/attendance"
         style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-100);text-decoration:none;border:var(--hairline-soft);padding:8px 16px;border-radius:var(--r-sm);"
         title="Attendance per hari (itinerary)">
        ✓ Absensi
      </a>
      <%# 5ss: offline-friendly export — open in any spreadsheet on a laptop/phone %>
      <a href="/crew/paket/<%= paket.slug %>/export.csv"
         style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-300);text-decoration:none;border:1px solid var(--gold-300);padding:8px 16px;border-radius:var(--r-sm);"
         title="Download manifest sebagai CSV (untuk referensi offline)">
        ⬇ Export CSV
      </a>
      <%# Stage 244 — on-demand dietary brief CSV. Renders only when at
          least one non-REGULAR jemaah exists (dietarySummary already
          gates that panel). %>
      <% if (typeof paket.dietarySummary !== 'undefined' && paket.dietarySummary && paket.dietarySummary.specials.length > 0) { %>
        <a href="/crew/paket/<%= paket.slug %>/dietary.csv"
           style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-300);text-decoration:none;border:1px solid var(--gold-300);padding:8px 16px;border-radius:var(--r-sm);"
           title="Brief diet untuk kitchen hotel">
          🍽 Diet CSV
        </a>
      <% } %>
      <%# Stage 222 — WA group invite for trip coordination. Crew uses
          the same group jemaah do — no separate role-scoped link. %>
      <% if (paket.waGroupUrl) { %>
        <a href="<%= paket.waGroupUrl %>" target="_blank" rel="noopener nofollow"
           style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-1000);background:var(--emerald);text-decoration:none;border:1px solid var(--emerald);padding:8px 16px;border-radius:var(--r-sm);font-weight:600;"
           title="Buka grup WhatsApp koordinasi paket">
          💬 Grup WA
        </a>
      <% } %>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi"><div class="l">Jemaah aktif</div><div class="v gold"><%= paket.bookings.length %></div></div>
    <div class="kpi"><div class="l">Kursi terisi</div><div class="v"><%= paket.kursiTerisi %> / <%= paket.kursiTotal %></div></div>
    <div class="kpi">
      <div class="l">Doc verified</div>
      <div class="v">
        <% const allDocs = paket.bookings.flatMap((b) => (b.docPills || [])); %>
        <% const verifiedCount = allDocs.filter((p) => p.state === 'verified').length; %>
        <%= verifiedCount %>
      </div>
    </div>
    <div class="kpi">
      <div class="l">LUNAS</div>
      <div class="v"><%= paket.bookings.filter((b) => b.status === 'LUNAS').length %></div>
    </div>
  </div>

  <%# Stage 218 — paket announcements (S192). Crew sees the same
      updates jemaah do; renders gold-bordered with 📢 prefix above
      the dietary panel so urgent operational news comes first. %>
  <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
    <div class="panel" style="margin-bottom:18px;padding:0;border:1px solid var(--gold-300);background:rgba(212,175,55,0.04);border-radius:var(--r-sm);overflow:hidden;">
      <div style="padding:10px 16px;background:rgba(212,175,55,0.10);border-bottom:1px solid var(--gold-300);">
        <strong style="font-family:var(--font-display);color:var(--gold-300);font-size:14px;">📢 Pengumuman paket (<%= announcements.length %>)</strong>
      </div>
      <% announcements.forEach(function(a) { %>
        <div style="padding:12px 16px;border-bottom:1px solid var(--hairline-soft);">
          <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;">
            <strong style="font-family:var(--font-mono);font-size:12.5px;color:var(--cream-100);letter-spacing:0.04em;text-transform:uppercase;"><%= a.title %></strong>
            <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);"><%= fmt.dateLong(a.publishedAt) %></span>
          </div>
          <div style="margin-top:6px;font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);line-height:1.6;white-space:pre-wrap;"><%= a.body %></div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <%# Stage 277 — daily report submit + recent history (this crew's only). %>
  <% const todayYmd = new Date().toISOString().slice(0, 10);
     const latestReport = (typeof myReports !== 'undefined' && myReports.length > 0) ? myReports[0] : null;
     const submittedToday = latestReport && latestReport.reportDate.toISOString().slice(0, 10) === todayYmd;
     const okFlag = (typeof query !== 'undefined' && query?.ok) || null;
     const errFlag = (typeof query !== 'undefined' && query?.err) || null;
  %>
  <div class="panel" style="margin-bottom:18px;padding:0;border:1px solid var(--hairline);background:rgba(255,255,255,0.02);border-radius:var(--r-sm);overflow:hidden;">
    <div style="padding:10px 16px;background:rgba(255,255,255,0.03);border-bottom:1px solid var(--hairline);display:flex;justify-content:space-between;align-items:center;gap:14px;">
      <strong style="font-family:var(--font-display);color:var(--gold-300);font-size:14px;">📝 Laporan harian</strong>
      <% if (submittedToday) { %>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--emerald);letter-spacing:0.1em;">✓ HARI INI TERKIRIM</span>
      <% } else { %>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--amber);letter-spacing:0.1em;">⏱ HARI INI BELUM</span>
      <% } %>
    </div>
    <div style="padding:14px 16px;">
      <% if (okFlag === 'report') { %>
        <div style="margin-bottom:10px;padding:6px 10px;background:rgba(80,176,113,0.10);border:1px solid var(--emerald);color:var(--emerald);border-radius:3px;font-family:var(--font-mono);font-size:11px;">✓ Laporan tersimpan</div>
      <% } %>
      <% if (errFlag) { %>
        <div style="margin-bottom:10px;padding:6px 10px;background:rgba(212,89,89,0.10);border:1px solid var(--ruby);color:var(--ruby);border-radius:3px;font-family:var(--font-mono);font-size:11px;">✕ <%= errFlag %></div>
      <% } %>
      <form method="POST" action="/crew/paket/<%= paket.slug %>/report">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div style="display:flex;gap:10px;margin-bottom:10px;flex-wrap:wrap;align-items:center;">
          <label style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.1em;text-transform:uppercase;">Mood:</label>
          <label style="font-family:var(--font-mono);font-size:11px;cursor:pointer;"><input type="radio" name="mood" value="GREEN" checked> <span style="color:var(--emerald);">🟢 Lancar</span></label>
          <label style="font-family:var(--font-mono);font-size:11px;cursor:pointer;"><input type="radio" name="mood" value="AMBER"> <span style="color:var(--gold-300);">🟡 Ada gangguan</span></label>
          <label style="font-family:var(--font-mono);font-size:11px;cursor:pointer;"><input type="radio" name="mood" value="RED"> <span style="color:var(--ruby);">🔴 Bermasalah</span></label>
        </div>
        <textarea name="body" rows="4" minlength="5" maxlength="4000" required
                  placeholder="Ringkasan hari ini: kegiatan, kondisi jemaah, masalah, hand-over ke shift berikutnya..."
                  style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:8px 12px;border-radius:3px;font-family:var(--font-mono);font-size:12px;box-sizing:border-box;line-height:1.5;"></textarea>
        <div style="margin-top:8px;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);">
            <% if (submittedToday) { %>
              Re-submit akan menimpa laporan hari ini.
            <% } else { %>
              Satu laporan per hari per paket.
            <% } %>
          </span>
          <button type="submit" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:6px 16px;border-radius:3px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;">Kirim laporan</button>
        </div>
      </form>
      <% if (typeof myReports !== 'undefined' && myReports.length > 0) { %>
        <details style="margin-top:14px;">
          <summary style="cursor:pointer;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.1em;">RIWAYAT (<%= myReports.length %>)</summary>
          <div style="margin-top:8px;">
            <% myReports.forEach(function(r) {
                 const moodColor = r.mood === 'RED' ? 'var(--ruby)' : (r.mood === 'AMBER' ? 'var(--gold-300)' : 'var(--emerald)');
                 const moodIcon = r.mood === 'RED' ? '🔴' : (r.mood === 'AMBER' ? '🟡' : '🟢');
            %>
              <div style="padding:8px 10px;margin-bottom:6px;background:var(--ink-1000);border-left:2px solid <%= moodColor %>;border-radius:3px;font-family:var(--font-mono);font-size:11px;">
                <div style="display:flex;justify-content:space-between;gap:10px;margin-bottom:4px;">
                  <span style="color:var(--cream-100);font-weight:600;"><%= r.reportDate.toISOString().slice(0,10) %><% if (r.dayNumber) { %> · H<%= r.dayNumber %><% } %></span>
                  <span style="color:<%= moodColor %>;font-size:10px;"><%= moodIcon %> <%= r.mood %></span>
                </div>
                <div style="color:var(--cream-100);line-height:1.5;white-space:pre-wrap;"><%= r.body %></div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>
    </div>
  </div>

  <%# Stage 214 — dietary brief panel for hotel/kitchen handoff. Only
      renders when there's ≥1 non-REGULAR jemaah; quiet trips skip the
      panel entirely. Mirrors the S213 email layout so crew see the
      same brief in-portal. %>
  <%# Stage 228 — pickup pax rollup so crew knows the bus distribution.
      Only renders when paket has pickup points + at least one chosen. %>
  <% if (typeof paket.pickupSummary !== 'undefined' && paket.pickupSummary && paket.pickupSummary.length > 0
         && paket.pickupSummary.some(function(p) { return p.id !== null; })) { %>
    <div class="panel" style="margin-bottom:18px;padding:0;border:1px solid var(--hairline);background:rgba(255,255,255,0.02);border-radius:var(--r-sm);overflow:hidden;">
      <div style="padding:10px 16px;background:rgba(255,255,255,0.03);border-bottom:1px solid var(--hairline);">
        <strong style="font-family:var(--font-display);color:var(--gold-300);font-size:14px;">🚌 Distribusi pickup</strong>
      </div>
      <div style="padding:12px 16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px 14px;font-family:var(--font-mono);font-size:11.5px;">
        <% paket.pickupSummary.forEach(function(p) { %>
          <div style="padding:6px 10px;background:var(--ink-1000);border-radius:3px;border-left:3px solid <%= p.id === null ? 'var(--amber)' : 'var(--gold-300)' %>;">
            <div style="color:<%= p.id === null ? 'var(--amber)' : 'var(--gold-300)' %>;font-size:11px;letter-spacing:0.04em;text-transform:uppercase;"><%= p.label %></div>
            <div style="color:var(--cream-100);font-size:14px;margin-top:2px;"><%= p.paxCount %> pax<% if (p.count !== p.paxCount) { %> · <%= p.count %> booking<% } %></div>
            <% if (p.departTime) { %><div style="color:var(--ink-200);font-size:10px;margin-top:2px;">⏰ <%= p.departTime %></div><% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (typeof paket.dietarySummary !== 'undefined' && paket.dietarySummary && paket.dietarySummary.specials.length > 0) {
       const DIET_LABEL = {
         VEGETARIAN: 'Vegetarian',
         HALAL_STRICT: 'Halal ketat',
         SOFT_TEXTURE: 'Tekstur lembut',
         DIABETIC: 'Diabetes',
         OTHER: 'Lainnya',
       };
       const DIET_COLOR = {
         VEGETARIAN: 'var(--emerald)',
         HALAL_STRICT: 'var(--gold-300)',
         SOFT_TEXTURE: 'var(--amber)',
         DIABETIC: 'var(--ruby)',
         OTHER: 'var(--sapphire)',
       };
       const grouped = new Map();
       for (const s of paket.dietarySummary.specials) {
         const d = s.jemaah.dietary;
         if (!grouped.has(d)) grouped.set(d, []);
         grouped.get(d).push(s);
       }
  %>
    <div class="panel" style="margin-bottom:18px;padding:14px 16px;border:1px solid var(--gold-300);background:rgba(212,175,55,0.04);border-radius:var(--r-sm);">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
        <h3 style="margin:0;font-family:var(--font-display);color:var(--gold-300);">🍽 Brief diet khusus untuk hotel</h3>
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
          <%= paket.dietarySummary.specialPax %> / <%= paket.dietarySummary.totalPax %> pax · diet khusus
        </div>
      </div>
      <p class="sub" style="margin:0 0 12px;">Tunjukkan ke kitchen hotel saat check-in agar makanan disiapkan sesuai.</p>
      <% [...grouped.entries()].forEach(([code, rows]) => { %>
        <div style="margin-top:10px;padding:8px 10px;background:var(--ink-1000);border-left:3px solid <%= DIET_COLOR[code] || 'var(--gold-300)' %>;border-radius:0 var(--r-sm) var(--r-sm) 0;">
          <div style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.06em;text-transform:uppercase;color:<%= DIET_COLOR[code] || 'var(--gold-300)' %>;margin-bottom:6px;">
            <%= code %> — <%= DIET_LABEL[code] || code %> (<%= rows.length %> jemaah)
          </div>
          <ul style="margin:0;padding-left:20px;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);line-height:1.7;">
            <% rows.forEach((b) => { %>
              <li>
                <%= b.jemaah.fullName %><% if (b.room?.roomNo) { %> <span style="color:var(--ink-200);">· kamar <%= b.room.roomNo %></span><% } %>
                <% if (b.jemaah.dietaryNotes) { %>
                  — <em style="color:var(--gold-300);"><%= b.jemaah.dietaryNotes %></em>
                <% } %>
              </li>
            <% }) %>
          </ul>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (paket.bookings.length === 0) { %>
    <div class="empty">Belum ada booking aktif untuk paket ini.</div>
  <% } else { %>
    <table class="tbl">
      <thead>
        <tr>
          <th style="width:130px;">Booking</th>
          <th>Jemaah</th>
          <th style="width:90px;">Kelas</th>
          <th style="width:100px;">Kamar</th>
          <th style="width:120px;">Pickup</th>
          <th style="width:90px;">Status</th>
          <th>Dokumen</th>
        </tr>
      </thead>
      <tbody>
        <% const okFlash = (typeof query !== 'undefined' && query?.ok === 'note_saved'); %>
        <% paket.bookings.forEach(function(b) {
             const myNote = (typeof myNotesByJemaah !== 'undefined') ? myNotesByJemaah[b.jemaah.id] : null;
        %>
          <tr>
            <td>
              <div class="id"><%= b.bookingNo %></div>
              <div class="sx"><%= b.paxCount %> PAX</div>
            </td>
            <td>
              <div class="nm"><%= b.jemaah.fullName %></div>
              <%# Stage 231 — booking tag pills (S226). Surfaces VIP / LANSIA
                  / HONEYMOON tags so crew sees who needs special attention. %>
              <% if (Array.isArray(b.tags) && b.tags.length > 0) { %>
                <div style="margin-top:3px;display:flex;gap:3px;flex-wrap:wrap;">
                  <% b.tags.forEach(function(t) { %>
                    <span style="background:rgba(212,175,55,0.12);border:1px solid var(--gold-300);color:var(--gold-300);padding:1px 6px;border-radius:3px;font-family:var(--font-mono);font-size:9px;letter-spacing:0.04em;"><%= t %></span>
                  <% }) %>
                </div>
              <% } %>
              <div class="sx">📱 <%= b.jemaah.phone %></div>
              <% if (b.jemaah.emergencyContact) { %>
                <div class="sx">🆘 <%= b.jemaah.emergencyContact %></div>
              <% } %>
              <% if (b.jemaah.passportNo) { %>
                <div class="sx">PSP <%= b.jemaah.passportNo %><% if (b.jemaah.passportExpiry) { %> · exp <%= fmt.dateShort(b.jemaah.passportExpiry) %><% } %></div>
              <% } %>
            </td>
            <td><%= b.kelas %></td>
            <td>
              <% if (b.room) { %>
                <div class="nm"><%= b.room.roomNo %></div>
                <div class="sx">lt <%= b.room.floor %> · <%= b.room.wing || '' %></div>
              <% } else { %>
                <span class="sx" style="color:var(--amber);">— belum</span>
              <% } %>
            </td>
            <%# Stage 228 — pickup column. TBD rendered amber so crew sees
                who hasn't picked yet at a glance. %>
            <td>
              <% if (b.pickup) { %>
                <div class="nm" style="color:var(--gold-300);"><%= b.pickup.label %></div>
                <% if (b.pickup.departTime) { %>
                  <div class="sx">⏰ <%= b.pickup.departTime %></div>
                <% } %>
              <% } else { %>
                <span class="sx" style="color:var(--amber);">— TBD</span>
              <% } %>
            </td>
            <td><span class="status-tag <%= b.status.toLowerCase() %>"><%= b.status %></span></td>
            <td>
              <div class="doc-strip">
                <% (b.docPills || []).forEach(function(p) { %>
                  <span class="doc-pill state-<%= p.state %>" title="<%= p.type %> · <%= p.state %>"><%= p.label %></span>
                <% }) %>
              </div>
            </td>
          </tr>
          <%# Stage 187 — per-jemaah note row. Always visible (even when
              empty) so crew sees the textarea to start writing. %>
          <tr>
            <td colspan="7" style="padding-top:0;padding-bottom:14px;border-top:0;">
              <details<%= myNote ? ' open' : '' %> style="margin-left:14px;">
                <summary style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);letter-spacing:0.06em;cursor:pointer;text-transform:uppercase;">
                  📝 Catatan crew
                  <% if (myNote) { %><span style="color:var(--gold-300);">· tersimpan <%= fmt.dateShort(myNote.updatedAt) %></span><% } %>
                </summary>
                <form method="POST" action="/crew/paket/<%= paket.slug %>/note" style="margin-top:8px;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="jemaahId" value="<%= b.jemaah.id %>">
                  <textarea name="body" maxlength="2000" rows="2" placeholder="Tulis catatan tentang jemaah ini (kosongkan untuk hapus)…" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:8px 10px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11.5px;resize:vertical;"><%= myNote?.body || '' %></textarea>
                  <div style="display:flex;justify-content:flex-end;margin-top:6px;">
                    <button type="submit" style="background:var(--gold-300);border:0;color:var(--ink-1000);padding:5px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;font-weight:600;">Simpan catatan</button>
                  </div>
                </form>
              </details>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('partials/sos-fab', { paketSlug: paket.slug }) %>
<%- include('partials/crew-mobile-tabs') %>
</body>
</html>

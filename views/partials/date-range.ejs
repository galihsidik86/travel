<%
  // Inputs: from, to (YYYY-MM-DD strings), basePath (e.g. '/agen' or '/admin')
  // Renders a date-range filter bar with presets + custom date inputs.
%>
<style>
  .dr-bar {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 12px 16px;
    margin-bottom: 20px;
  }
  .dr-bar .dr-lbl {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase;
  }
  .dr-bar .dr-input { padding: 6px 10px; font-size: 12px; max-width: 150px; }
  .dr-bar .dr-preset {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-100); padding: 6px 12px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.1em; cursor: pointer;
    text-decoration: none; display: inline-block;
  }
  .dr-bar .dr-preset:hover { color: var(--gold-300); border-color: var(--gold-300); }
  .dr-bar .dr-preset.is-active {
    color: var(--gold-300); border-color: var(--gold-300);
    background: rgba(212,175,55,0.06);
  }
  .dr-bar .dr-sep { width: 1px; height: 22px; background: var(--ink-500); margin: 0 4px; }
</style>

<form method="GET" action="<%= basePath %>" class="dr-bar" id="dr-form-<%= basePath.replace(/\W/g,'') %>">
  <input type="hidden" name="tab" value="<%= typeof activeTab !== 'undefined' ? activeTab : 'analytics' %>">
  <span class="dr-lbl">Range</span>
  <input class="input dr-input" type="date" name="from" value="<%= from %>">
  <span class="dr-lbl">→</span>
  <input class="input dr-input" type="date" name="to" value="<%= to %>">
  <button type="submit" class="dr-preset" style="color:var(--gold-300);border-color:var(--gold-300);">APPLY</button>
  <span class="dr-sep"></span>
  <span class="dr-lbl">Preset</span>
  <button type="button" class="dr-preset" data-preset="7">7 HARI</button>
  <button type="button" class="dr-preset" data-preset="30">30 HARI</button>
  <button type="button" class="dr-preset" data-preset="90">90 HARI</button>
  <button type="button" class="dr-preset" data-preset="ytd">YTD</button>
  <a href="<%= basePath %><%= typeof activeTab !== 'undefined' ? '?tab=' + activeTab : '' %>" class="dr-preset" style="margin-left:auto;">RESET</a>
</form>

<script>
  (function () {
    const form = document.currentScript.previousElementSibling;
    const fromInput = form.querySelector('input[name="from"]');
    const toInput = form.querySelector('input[name="to"]');
    function ymd(d) { return d.toISOString().slice(0, 10); }
    form.querySelectorAll('[data-preset]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const preset = btn.dataset.preset;
        const to = new Date();
        let from;
        if (preset === 'ytd') {
          from = new Date(to.getFullYear(), 0, 1);
        } else {
          const days = parseInt(preset, 10);
          from = new Date(to);
          from.setDate(to.getDate() - (days - 1));
        }
        fromInput.value = ymd(from);
        toInput.value = ymd(to);
        form.submit();
      });
    });
  })();
</script>

<%# Floating SOS button + modal. Only renders for MUTHAWWIF on /crew/* pages. %>
<%# Caller may set `paketSlug` if the page knows which paket is in context. %>
<button class="sos-fab" type="button" aria-label="Kirim SOS"
        onclick="document.getElementById('sos-modal').showModal()">
  <span class="sos-fab__dot"></span>
  <span class="sos-fab__lbl">SOS</span>
</button>

<dialog id="sos-modal" class="sos-modal">
  <%# Stage 373 — multipart so optional photo evidence (e.g. injury, broken
      bus, food poisoning) can attach. The route handler tolerates a missing
      file part for offline-queued replays (S368 queue serialises text only). %>
  <form method="POST" action="/crew/sos" class="sos-form" id="sos-form" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% if (typeof paketSlug !== 'undefined' && paketSlug) { %>
      <input type="hidden" name="paketSlug" value="<%= paketSlug %>">
    <% } %>
    <div class="sos-modal__head">
      <div>
        <div class="sos-modal__eyebrow">Laporan darurat</div>
        <h2>Kirim sinyal <em>SOS</em></h2>
        <p class="sos-modal__sub">Admin Religio Pro akan menerima email + WA dalam hitungan detik. Hanya gunakan untuk hal genting.</p>
      </div>
      <button type="button" class="sos-modal__close"
              onclick="document.getElementById('sos-modal').close()">×</button>
    </div>

    <label class="sos-field">
      <span>Jenis insiden</span>
      <select name="type" required>
        <option value="SOS" selected>SOS — Darurat / nyawa</option>
        <option value="MEDICAL">Medis (luka, sakit)</option>
        <option value="LOST_JEMAAH">Jemaah hilang / terpisah</option>
        <option value="SECURITY">Keamanan (pencurian, kekerasan)</option>
        <option value="LOGISTICAL">Logistik (bus, hotel, makanan)</option>
        <option value="OTHER">Lain-lain</option>
      </select>
    </label>

    <label class="sos-field">
      <span>Lokasi saat ini (opsional)</span>
      <input type="text" name="locationLabel" maxlength="200" autocomplete="off"
             placeholder="mis. Masjid Nabawi gate 21, atau Hotel Andalus">
    </label>

    <label class="sos-field">
      <span>Apa yang terjadi? (singkat)</span>
      <textarea name="message" maxlength="2000" rows="4"
                placeholder="Mis. 'Bu Khadijah pingsan di pelataran Masjid Bilal, kondisi sadar tapi lemah, perlu ambulans.'"></textarea>
    </label>

    <%# Stage 373 — photo evidence. capture="environment" opens rear camera
        on phones, falls back to picker on desktop. accept restricts to
        images (matches incidentStorage allowlist). Optional — text-only
        SOS still goes through; the form post drops the empty file gracefully. %>
    <label class="sos-field">
      <span>Foto evidence (opsional)</span>
      <input type="file" name="photo" accept="image/jpeg,image/png,image/webp,image/heic,image/heif" capture="environment"
             style="background:var(--ink-1000); color:var(--cream-100); border:1px solid var(--hairline-soft); border-radius:var(--r-sm); padding:8px 10px; font-family:inherit; font-size:12.5px;">
      <small id="sos-photo-warn" style="display:none; color:var(--amber); font-family:var(--font-mono); font-size:10.5px; margin-top:2px;">
        ⚠ Offline — foto tidak ter-queue; teks SOS tetap terkirim, ulangi foto saat online.
      </small>
    </label>

    <div class="sos-modal__actions">
      <button type="button" class="sos-modal__cancel"
              onclick="document.getElementById('sos-modal').close()">Batal</button>
      <button type="submit" class="sos-modal__send">KIRIM SOS</button>
    </div>
  </form>
</dialog>

<style>
  .sos-fab {
    position: fixed; right: 18px; bottom: 84px; z-index: 60;
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--ruby); color: var(--cream-100);
    border: 2px solid rgba(255,255,255,0.18);
    box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 4px 12px rgba(0,0,0,0.4);
    cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
    animation: sos-pulse 2.6s ease-out infinite;
  }
  .sos-fab:hover { background: #C46259; }
  .sos-fab__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cream-100); margin-bottom: 4px; box-shadow: 0 0 8px rgba(255,255,255,0.7); }
  .sos-fab__lbl { letter-spacing: 0.2em; }
  @keyframes sos-pulse {
    0%   { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 0 rgba(181,86,74,0.6); }
    70%  { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 16px rgba(181,86,74,0); }
    100% { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 0 rgba(181,86,74,0); }
  }

  .sos-modal { width: min(440px, calc(100vw - 32px)); padding: 0; background: transparent; border: 0; }
  .sos-modal::backdrop { background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); }
  .sos-form {
    background: var(--ink-900); border: 1px solid var(--ruby); border-radius: var(--r-lg);
    padding: 22px 22px 18px;
    display: flex; flex-direction: column; gap: 14px;
    color: var(--cream-100);
  }
  .sos-modal__head { display: flex; justify-content: space-between; align-items: start; gap: 16px; }
  .sos-modal__eyebrow { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ruby); }
  .sos-modal__head h2 { font-family: var(--font-display); font-size: 24px; font-weight: 500; margin: 4px 0 6px; color: var(--cream-100); letter-spacing: -0.015em; }
  .sos-modal__head h2 em { font-style: italic; color: var(--ruby); }
  .sos-modal__sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-100); line-height: 1.55; margin: 0; }
  .sos-modal__close {
    background: transparent; border: 0; color: var(--ink-200);
    font-size: 24px; line-height: 1; cursor: pointer; padding: 0 4px; flex-shrink: 0;
  }
  .sos-modal__close:hover { color: var(--cream-100); }
  .sos-field { display: flex; flex-direction: column; gap: 6px; }
  .sos-field > span {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200);
  }
  .sos-field input, .sos-field select, .sos-field textarea {
    background: var(--ink-1000); color: var(--cream-100); border: var(--hairline-soft);
    border-radius: var(--r-sm); padding: 10px 12px; font-size: 13px; font-family: inherit;
  }
  .sos-field textarea { resize: vertical; min-height: 84px; }
  .sos-modal__actions { display: flex; gap: 10px; margin-top: 4px; }
  .sos-modal__cancel, .sos-modal__send {
    flex: 1; padding: 12px 16px; min-height: 46px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; cursor: pointer;
  }
  .sos-modal__cancel {
    background: transparent; border: var(--hairline-soft); color: var(--ink-100);
  }
  .sos-modal__cancel:hover { color: var(--cream-100); border-color: var(--ink-100); }
  .sos-modal__send {
    background: var(--ruby); color: var(--cream-100); border: 0;
  }
  .sos-modal__send:hover { background: #C46259; }
  /* Stage 368 — queued-incidents badge on the FAB. Mirrors the SOS-light
     "N queued" affordance from S355 so crew see pending replays. */
  .sos-fab__queued {
    position: absolute; top: -4px; right: -4px;
    min-width: 22px; height: 22px; padding: 0 6px;
    background: var(--amber); color: var(--ink-1000);
    border-radius: 11px; font-family: var(--font-mono); font-size: 11px;
    font-weight: 700; line-height: 22px; text-align: center;
    border: 2px solid var(--ink-1000);
  }
</style>

<%# Stage 368 — offline-aware crew incident queue. Captures /crew/sos
    POSTs when navigator.onLine === false OR fetch throws mid-send.
    Auto-flush replays on `online` event + 30s tick. Server-side rate
    limit (S137) makes replays naturally idempotent — 429 treated as
    success (already-handled). %>
<script src="/shared/crew-incident-queue.js" defer></script>
<script>
  (function () {
    const form = document.getElementById('sos-form');
    const fab = document.querySelector('.sos-fab');
    if (!form) return;
    // Append a "N queued" badge to the FAB so crew know about pending replays.
    let queuedBadge = null;
    function paintBadge(n) {
      if (!fab) return;
      if (n > 0) {
        if (!queuedBadge) {
          queuedBadge = document.createElement('span');
          queuedBadge.className = 'sos-fab__queued';
          fab.appendChild(queuedBadge);
        }
        queuedBadge.textContent = String(n);
      } else if (queuedBadge) {
        queuedBadge.remove();
        queuedBadge = null;
      }
    }
    async function queueOffline(payload) {
      if (!window.CrewIncidentQueue) throw new Error('queue unavailable');
      await window.CrewIncidentQueue.enqueue({
        url: '/crew/sos', payload, label: 'crew-sos',
      });
    }
    // Stage 373 — warn jemaah upfront when they attach a photo while offline.
    // We can't reliably queue Blobs in the S368 IDB store today; queued
    // replays will be text-only.
    const $photoInput = form.querySelector('input[name="photo"]');
    const $photoWarn = document.getElementById('sos-photo-warn');
    function updatePhotoWarn() {
      if (!$photoWarn || !$photoInput) return;
      const hasFile = $photoInput.files && $photoInput.files.length > 0;
      const offline = typeof navigator !== 'undefined' && navigator.onLine === false;
      $photoWarn.style.display = (hasFile && offline) ? 'block' : 'none';
    }
    if ($photoInput) $photoInput.addEventListener('change', updatePhotoWarn);
    window.addEventListener('online', updatePhotoWarn);
    window.addEventListener('offline', updatePhotoWarn);

    form.addEventListener('submit', async (ev) => {
      // Always intercept — we route through fetch so we can fall back to
      // the queue on network failure (which the regular form POST can't do).
      ev.preventDefault();
      // S373 — keep both: text payload (for offline queue / fallback) and
      // FormData (for online multipart with photo).
      const fd = new FormData(form);
      const payload = {};
      for (const [k, v] of fd.entries()) {
        if (typeof v === 'string') payload[k] = v;
        // File entries are dropped from `payload` — only the text fields
        // make it into the offline queue; the file goes via FormData online.
      }
      const sendBtn = form.querySelector('.sos-modal__send');
      const dialog = document.getElementById('sos-modal');
      if (sendBtn) sendBtn.disabled = true;
      // Offline → queue immediately. Photo (if any) is dropped — user was warned.
      if (typeof navigator !== 'undefined' && navigator.onLine === false) {
        try {
          await queueOffline(payload);
          alert('⏱ Queued (offline) — akan dikirim saat signal balik.');
          if (dialog) dialog.close();
          form.reset();
        } catch (qErr) {
          alert('✕ Gagal queue: ' + (qErr.message || 'storage error'));
        } finally {
          if (sendBtn) sendBtn.disabled = false;
        }
        return;
      }
      // Online → multipart POST (photo included if attached).
      try {
        const res = await fetch('/crew/sos', {
          method: 'POST',
          credentials: 'same-origin',
          redirect: 'follow',
          // No explicit Content-Type — browser sets multipart boundary automatically
          body: fd,
        });
        if (res.ok || res.redirected || res.status === 429) {
          if (dialog) dialog.close();
          form.reset();
          // Reload to surface admin redirect banner (?sos=sent) if any.
          window.location.href = '/crew?sos=sent';
        } else {
          throw new Error('HTTP ' + res.status);
        }
      } catch (err) {
        // Network blew up mid-send → queue text payload (no photo).
        try {
          await queueOffline(payload);
          alert('⏱ Gagal kirim langsung — queued (tanpa foto), akan retry otomatis.');
          if (dialog) dialog.close();
          form.reset();
        } catch (qErr) {
          alert('✕ ' + (err.message || 'Network error'));
        }
      } finally {
        if (sendBtn) sendBtn.disabled = false;
      }
    });
    // Auto-flush + badge paint
    if (window.CrewIncidentQueue) {
      window.CrewIncidentQueue.startAutoFlush({
        intervalMs: 30_000,
        onChange: async () => {
          const n = await window.CrewIncidentQueue.countPending();
          paintBadge(n);
        },
      });
    }
    // Stage 369 — PWA shortcut deep-link. Android long-press crew icon
    // → "SOS Crew" opens /crew?sos=1. Auto-open the SOS modal so crew
    // can submit in one tap. Strips ?sos=1 from URL so reload doesn't
    // keep re-opening. iOS ignores manifest shortcuts (no surface there).
    try {
      const params = new URLSearchParams(window.location.search);
      if (params.get('sos') === '1') {
        const dialog = document.getElementById('sos-modal');
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
          // Focus the type select so keyboard users can tab immediately.
          const typeSel = dialog.querySelector('select[name="type"]');
          if (typeSel) typeSel.focus();
        }
        const url = new URL(window.location.href);
        url.searchParams.delete('sos');
        window.history.replaceState({}, '', url.pathname + (url.search ? url.search : ''));
      }
    } catch (_err) { /* silent — auto-open is a convenience */ }
  })();
</script>

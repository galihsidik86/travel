<%# Stage 319 — Mobile bottom-nav for /crew. Mirrors the jemaah pattern
    (views/partials/mobile-tabs.ejs) using the same .m-tabs class so all
    styling + safe-area handling is inherited. 4 tabs: Home / Manifest
    (best-effort link to assigned paket from locals if present, else
    /crew root) / Kontak / Notif. SOS-fab stays as separate critical
    surface. %>
<nav class="m-tabs" aria-label="Navigasi crew">
  <a href="/crew" data-tab="/crew">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 11l9-8 9 8"/>
      <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"/>
    </svg>
    <span>Home</span>
  </a>
  <%
    // Manifest link: if a paket slug is in scope (current page is a
    // /crew/paket/:slug view) re-use it. Otherwise drop the user back
    // at /crew where they can pick an assignment.
    const manifestHref = (typeof paket !== 'undefined' && paket && paket.slug)
      ? `/crew/paket/${paket.slug}`
      : '/crew';
  %>
  <a href="<%= manifestHref %>" data-tab="/crew/paket">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
      <rect x="9" y="3" width="6" height="4" rx="1"/>
      <path d="M9 12h6M9 16h4"/>
    </svg>
    <span>Manifest</span>
  </a>
  <a href="/crew/contacts" data-tab="/crew/contacts">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span>Kontak</span>
  </a>
  <a href="/crew/notifications" data-tab="/crew/notifications">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span>Notif</span>
  </a>
</nav>
<script>
  // Highlight closest-matching tab (longest matching prefix wins).
  // /crew/paket/:slug/attendance/:dayId highlights Manifest because
  // /crew/paket is the longest prefix that matches.
  (function () {
    const path = location.pathname.replace(/\/$/, '') || '/';
    const links = document.querySelectorAll('.m-tabs a[data-tab]');
    let best = null;
    let bestLen = -1;
    for (const a of links) {
      const t = a.dataset.tab;
      // Special case for /crew root: any /crew/* path is considered
      // a match for the Home tab, but a more-specific tab wins via
      // length comparison.
      if (path === t || path.startsWith(t + '/') || (t === '/crew' && path.startsWith('/crew'))) {
        if (t.length > bestLen) { best = a; bestLen = t.length; }
      }
    }
    if (best) best.classList.add('is-active');
  })();
</script>

<script>
  // Highlight the closest-matching tab (longest matching prefix wins) so
  // /saya/bookings/:id activates Beranda, /saya/notifications activates Notif.
  (function () {
    const path = location.pathname.replace(/\/$/, '') || '/';
    const links = document.querySelectorAll('.m-tabs a[data-tab]');
    let best = null;
    let bestLen = -1;
    for (const a of links) {
      const t = a.dataset.tab;
      if (path === t || path.startsWith(t + '/') || (t === '/saya' && path.startsWith('/saya'))) {
        if (t.length > bestLen) { best = a; bestLen = t.length; }
      }
    }
    if (best) best.classList.add('is-active');
  })();
</script>

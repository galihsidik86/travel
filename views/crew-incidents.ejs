<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Insiden Anda</title>
<link rel="stylesheet" href="/shared/tokens.css">
<link rel="stylesheet" href="/shared/crew-readable.css">
<%- include('partials/pwa-head', { pwaRole: 'crew' }) %>
<script src="/shared/csrf.js"></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 960px; margin: 0 auto; padding: 24px 18px 100px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 18px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  h1 { font-family: var(--font-display); font-size: 26px; color: var(--cream-100); margin: 0 0 6px; letter-spacing: -0.01em; }
  .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.06em; margin-bottom: 20px; }
  .kpi-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 18px; }
  .kpi-card { background: var(--ink-900); border: 1px solid var(--hairline-soft); border-radius: var(--r-md); padding: 12px; text-align: center; }
  .kpi-card .lbl { font-family: var(--font-mono); font-size: 9px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; }
  .kpi-card .val { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); }
  .kpi-card.ruby .val { color: var(--ruby); }
  .kpi-card.amber .val { color: var(--amber); }
  .kpi-card.emerald .val { color: var(--emerald); }
  .filter-nav { display: flex; gap: 6px; font-family: var(--font-mono); font-size: 10.5px; margin-bottom: 16px; flex-wrap: wrap; }
  .filter-nav a { color: var(--ink-200); text-decoration: none; padding: 6px 10px; border: 1px solid var(--hairline-soft); border-radius: 4px; }
  .filter-nav a.active { color: var(--gold-300); border-color: var(--gold-300); }
  .row-card { background: var(--ink-900); border: 1px solid var(--hairline-soft); border-radius: var(--r-md); padding: 14px 16px; margin-bottom: 10px; }
  .row-card.open { border-left: 3px solid var(--ruby); }
  .row-card.acked { border-left: 3px solid var(--amber); }
  .row-card.resolved { border-left: 3px solid var(--emerald); opacity: 0.8; }
  .row-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; flex-wrap: wrap; }
  .pill { display: inline-block; padding: 2px 8px; border-radius: 4px; font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.06em; font-weight: 600; }
  .pill.OPEN { background: rgba(212,89,89,0.12); color: var(--ruby); }
  .pill.ACKED { background: rgba(212,175,107,0.12); color: var(--gold-300); }
  .pill.RESOLVED { background: rgba(80,176,113,0.12); color: var(--emerald); }
  .pill.AGE-old { background: rgba(212,89,89,0.10); color: var(--ruby); }
  .pill.AGE-warn { background: rgba(212,175,107,0.10); color: var(--gold-300); }
  .msg { margin-top: 8px; font-family: var(--font-body); font-size: 13.5px; color: var(--cream-100); line-height: 1.5; }
  .meta-line { margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--hairline-soft); font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.04em; }
  .empty { padding: 60px 20px; text-align: center; font-family: var(--font-mono); font-size: 12px; color: var(--ink-300); background: var(--ink-900); border-radius: var(--r-md); }
  @media (max-width: 720px) {
    .kpi-strip { grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .kpi-card { padding: 10px 6px; }
    .kpi-card .val { font-size: 18px; }
    .kpi-card .lbl { font-size: 8.5px; }
  }
</style>
</head>
<body class="has-m-tabs crew-app">
  <div class="wrap">
    <a class="btn-back" href="/crew">Dashboard</a>
    <h1>Insiden Anda</h1>
    <div class="sub">
      Riwayat insiden yang Anda kirim · <%= queue.days %> hari terakhir.
      OPEN belum ditangani admin · ACKED sudah dilihat · RESOLVED tuntas.
    </div>

    <div class="kpi-strip">
      <div class="kpi-card"><div class="lbl">Total</div><div class="val"><%= queue.counts.total %></div></div>
      <div class="kpi-card ruby"><div class="lbl">OPEN</div><div class="val"><%= queue.counts.OPEN || 0 %></div></div>
      <div class="kpi-card amber"><div class="lbl">ACKED</div><div class="val"><%= queue.counts.ACKED || 0 %></div></div>
      <div class="kpi-card emerald"><div class="lbl">RESOLVED</div><div class="val"><%= queue.counts.RESOLVED || 0 %></div></div>
    </div>

    <div class="filter-nav">
      <% [['ACTIVE', 'Aktif'], ['OPEN', 'OPEN'], ['ACKED', 'ACKED'], ['RESOLVED', 'RESOLVED'], ['ALL', 'Semua']].forEach(function(opt) { %>
        <a href="/crew/incidents?status=<%= opt[0] %>" class="<%= status === opt[0] ? 'active' : '' %>"><%= opt[1] %></a>
      <% }) %>
    </div>

    <% if (queue.rows.length === 0) { %>
      <div class="empty">Tidak ada insiden di filter <%= status %>.<br>Aktifkan SOS dari tombol merah di pojok kanan bawah kalau butuh.</div>
    <% } else {
         queue.rows.forEach(function(r) {
           const ageClass = r.ageHours > 48 ? 'AGE-old' : r.ageHours > 24 ? 'AGE-warn' : '';
           const cardClass = r.status.toLowerCase();
    %>
      <div class="row-card <%= cardClass %>">
        <div class="row-head">
          <div style="flex:1;min-width:240px;">
            <div style="font-family:var(--font-display);font-size:15px;color:var(--cream-100);line-height:1.3;">
              <%= r.type %>
              <% if (r.paket) { %>
                · <span style="color:var(--gold-300);font-size:13px;"><%= r.paket.title %></span>
              <% } %>
            </div>
            <div style="margin-top:4px;">
              <span class="pill <%= r.status %>"><%= r.status %></span>
              <% if (ageClass) { %><span class="pill <%= ageClass %>"><%= r.ageHours %>h ago</span><% } %>
              <% if (r.location) { %>
                <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-left:4px;">📍 <%= r.location %></span>
              <% } %>
            </div>
          </div>
        </div>
        <% if (r.message) { %>
          <div class="msg"><%= r.message %></div>
        <% } %>
        <% if (r.status !== 'OPEN') { %>
          <div class="meta-line">
            <% if (r.ackedAt) { %>
              ACK <%= fmt.dateLong(r.ackedAt) %>
              <% if (r.ackedBy) { %> · oleh <%= r.ackedBy.fullName %><% } %>
            <% } %>
            <% if (r.resolvedAt) { %>
              <% if (r.ackedAt) { %> · <% } %>RESOLVED <%= fmt.dateLong(r.resolvedAt) %>
              <% if (r.resolvedBy) { %> · oleh <%= r.resolvedBy.fullName %><% } %>
            <% } %>
            <% if (r.resolution) { %>
              <div style="margin-top:4px;color:var(--cream-100);font-style:italic;">Resolusi: <%= r.resolution %></div>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }); } %>
  </div>
  <%- include('partials/sos-fab') %>
  <%- include('partials/crew-mobile-tabs') %>
</body>
</html>

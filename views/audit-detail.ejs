<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Audit · <%= entry.action %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 20px;
  }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head { margin-bottom: 24px; }
  .head h1 {
    font-family: var(--font-display); font-size: 36px; font-weight: 500;
    color: var(--cream-100); margin: 0; letter-spacing: -0.015em;
  }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em; margin-top: 8px;
  }
  .panel {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 24px;
    margin-bottom: 18px;
  }
  .panel h3 {
    font-family: var(--font-display); font-size: 20px; font-weight: 500;
    color: var(--cream-100); margin: 0 0 18px;
  }
  .meta-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .meta-item .l {
    font-family: var(--font-mono); font-size: 9.5px;
    color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase;
  }
  .meta-item .v {
    font-family: var(--font-mono); font-size: 13px;
    color: var(--cream-100); margin-top: 4px; word-break: break-all;
  }
  .meta-item .v.gold { color: var(--gold-300); }
  .json-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .json-pane {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm); overflow: hidden;
  }
  .json-pane .ph {
    padding: 10px 14px; border-bottom: var(--hairline-soft);
    font-family: var(--font-mono); font-size: 10px;
    color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase;
    background: var(--ink-900);
  }
  .json-pane.before .ph { color: var(--ruby); }
  .json-pane.after .ph { color: var(--emerald); }
  .json-pane pre {
    margin: 0; padding: 16px;
    font-family: var(--font-mono); font-size: 12px;
    color: var(--cream-100); line-height: 1.6;
    overflow-x: auto;
    max-height: 480px;
    white-space: pre-wrap; word-break: break-word;
  }
  .json-pane .empty {
    padding: 32px 16px; text-align: center;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-300); letter-spacing: 0.08em;
  }
  .action-tag {
    padding: 4px 10px; font-family: var(--font-mono); font-size: 11px;
    background: var(--ink-1000); border: var(--hairline-soft);
    color: var(--ink-100); border-radius: 3px;
    letter-spacing: 0.12em;
  }
  .action-tag.create  { color: var(--emerald); border-color: rgba(74,143,109,0.4); }
  .action-tag.update  { color: var(--gold-300); border-color: rgba(212,175,55,0.4); }
  .action-tag.delete  { color: var(--ruby); border-color: rgba(181,86,74,0.4); }
  .action-tag.login   { color: var(--sapphire); border-color: rgba(74,111,143,0.4); }
  .action-tag.payment_received { color: var(--emerald); border-color: rgba(74,143,109,0.4); }
  .action-tag.status_change { color: var(--gold-300); border-color: rgba(212,175,55,0.4); }
  .action-tag.password_change { color: var(--amber); border-color: rgba(201,147,59,0.4); }
  .user-agent {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); margin-top: 8px;
    background: var(--ink-1000); border: var(--hairline-soft);
    padding: 10px 14px; border-radius: var(--r-sm);
    word-break: break-all;
  }
  @media (max-width: 900px) { .json-cols { grid-template-columns: 1fr; } .meta-grid { grid-template-columns: 1fr 1fr; } }
</style>
</head>
<body data-screen-label="02 Admin · Audit Detail">
<div class="wrap">

  <div class="crumb">
    <a href="/admin/audit">← KEMBALI KE AUDIT LOG</a>
  </div>

  <div class="head">
    <h1>
      <span class="action-tag <%= entry.action.toLowerCase() %>"><%= entry.action %></span>
      <span style="font-family:var(--font-mono);font-size:18px;color:var(--ink-100);margin-left:8px;letter-spacing:0.04em;"><%= entry.entity %></span>
      <% if (entry.entityId) { %>
        <span style="font-family:var(--font-mono);font-size:14px;color:var(--gold-300);margin-left:8px;letter-spacing:0.04em;"><%= entry.entityId %></span>
      <% } %>
    </h1>
    <div class="sub">
      <%= fmt.dateLong(entry.createdAt) %> · <%= new Date(entry.createdAt).toISOString().slice(11, 19) %>
    </div>
  </div>

  <!-- Metadata -->
  <div class="panel">
    <h3>Metadata</h3>
    <div class="meta-grid">
      <div class="meta-item">
        <div class="l">Actor</div>
        <div class="v gold"><%= entry.actorEmail || '— sistem / anonim —' %></div>
      </div>
      <div class="meta-item">
        <div class="l">Role saat itu</div>
        <div class="v"><%= entry.actorRole || '—' %></div>
      </div>
      <div class="meta-item">
        <div class="l">Actor User ID</div>
        <div class="v"><%= entry.actorUserId || '—' %></div>
      </div>
      <div class="meta-item">
        <div class="l">Entity</div>
        <div class="v"><%= entry.entity %></div>
      </div>
      <div class="meta-item">
        <div class="l">Entity ID</div>
        <div class="v"><%= entry.entityId || '—' %></div>
      </div>
      <div class="meta-item">
        <div class="l">IP</div>
        <div class="v"><%= entry.ip || '—' %></div>
      </div>
    </div>
    <% if (entry.userAgent) { %>
      <div style="margin-top:14px;">
        <div class="l" style="font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">USER AGENT</div>
        <div class="user-agent"><%= entry.userAgent %></div>
      </div>
    <% } %>
  </div>

  <!-- Before / After diff -->
  <div class="panel">
    <h3>Snapshot perubahan</h3>
    <div class="json-cols">
      <div class="json-pane before">
        <div class="ph">BEFORE</div>
        <% if (entry.before) { %>
          <pre><%= JSON.stringify(entry.before, null, 2) %></pre>
        <% } else { %>
          <div class="empty">— tidak ada snapshot sebelum —</div>
        <% } %>
      </div>
      <div class="json-pane after">
        <div class="ph">AFTER</div>
        <% if (entry.after) { %>
          <pre><%= JSON.stringify(entry.after, null, 2) %></pre>
        <% } else { %>
          <div class="empty">— tidak ada snapshot setelah —</div>
        <% } %>
      </div>
    </div>
  </div>

</div>
</body>
</html>

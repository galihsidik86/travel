<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Email click heatmap · <%= heatmap.type %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1100px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }

  h1 {
    font-family: var(--font-display); font-size: 32px; font-weight: 500;
    color: var(--cream-100); margin: 0 0 10px; letter-spacing: -0.015em;
  }
  h1 em { font-style: italic; color: var(--gold-300); }
  .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.08em; margin-bottom: 28px;
  }

  .panel {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 20px 24px; margin-bottom: 22px;
  }
  .totals {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 14px; margin-bottom: 16px;
  }
  .totals .cell {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm); padding: 12px 14px;
  }
  .totals .l {
    font-family: var(--font-mono); font-size: 9.5px;
    color: var(--ink-300); letter-spacing: 0.14em; text-transform: uppercase;
  }
  .totals .v {
    font-family: var(--font-display); font-size: 24px;
    color: var(--cream-100); margin-top: 4px;
  }

  table {
    width: 100%; border-collapse: collapse;
    font-family: var(--font-mono); font-size: 11.5px;
  }
  th, td {
    padding: 8px 10px; text-align: left;
    border-bottom: var(--hairline-soft);
    color: var(--cream-100);
  }
  th {
    color: var(--ink-300); font-weight: 400; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  td.num, th.num { text-align: right; }
  td.url { color: var(--gold-300); word-break: break-all; max-width: 540px; }
  .bar-wrap {
    background: var(--ink-1000); width: 80px; height: 6px;
    border-radius: 3px; overflow: hidden; display: inline-block; vertical-align: middle;
    margin-right: 8px;
  }
  .bar {
    background: var(--gold-300); height: 100%;
  }
  .empty {
    color: var(--ink-300); font-style: italic;
    text-align: center; padding: 40px 0;
  }
</style>
</head>
<body data-screen-label="79 Admin · Email CTR heatmap">
<div class="wrap">
  <div class="crumb"><a href="/admin">/ADMIN</a> / EMAIL CTR / <%= heatmap.type %></div>
  <h1>Email click <em>heatmap</em></h1>
  <div class="sub">
    Tipe notif: <strong style="color:var(--cream-100);"><%= heatmap.type %></strong>
    · jendela <%= heatmap.windowDays %> hari terakhir
    · <%= heatmap.totals.urls %> URL unik
    · <%= heatmap.totals.clicks %> total klik
  </div>

  <% if (heatmap.rows.length === 0) { %>
    <div class="panel">
      <div class="empty">
        Belum ada klik tercatat untuk tipe ini dalam <%= heatmap.windowDays %> hari terakhir.<br>
        <span style="font-size:10px;letter-spacing:0.1em;">Cek apakah email tipe ini memang mengandung link, dan apakah recipient membuka inbox.</span>
      </div>
    </div>
  <% } else { %>
    <div class="panel">
      <div class="totals">
        <div class="cell">
          <div class="l">Total clicks</div>
          <div class="v"><%= heatmap.totals.clicks %></div>
        </div>
        <div class="cell">
          <div class="l">URL unik</div>
          <div class="v"><%= heatmap.totals.urls %></div>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th>URL / path</th>
            <th class="num">Klik</th>
            <th class="num">Recipients</th>
            <th class="num">Share</th>
          </tr>
        </thead>
        <tbody>
          <% heatmap.rows.forEach(function(r) { %>
            <tr>
              <td class="url"><%= r.label %></td>
              <td class="num"><%= r.clicks %></td>
              <td class="num"><%= r.recipients %></td>
              <td class="num">
                <span class="bar-wrap"><span class="bar" style="width: <%= Math.min(100, r.sharePct || 0) %>%;"></span></span>
                <%= r.sharePct ?? '—' %>%
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
</body>
</html>

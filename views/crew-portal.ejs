<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Crew · <%= user.fullName %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 980px; margin: 0 auto; padding: 32px 40px 80px; }

  .topbar {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 18px; margin-bottom: 28px;
    border-bottom: var(--hairline-soft);
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
  }
  .topbar .who { color: var(--gold-300); }
  .topbar button {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-100); cursor: pointer;
    padding: 6px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .topbar button:hover { color: var(--gold-300); border-color: var(--gold-300); }

  .hero {
    background:
      radial-gradient(80% 60% at 80% 0%, rgba(212,175,55,0.10), transparent 60%),
      var(--ink-900);
    border: var(--hairline-gold);
    border-radius: var(--r-xl);
    padding: 36px 44px;
    margin-bottom: 28px;
  }
  .hero .eyebrow { color: var(--gold-300); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; }
  .hero h1 { font-family: var(--font-display); font-size: 34px; font-weight: 500; color: var(--cream-100); margin: 10px 0 0; letter-spacing: -0.015em; }
  .hero h1 em { font-style: italic; color: var(--gold-300); }
  .hero .sub { font-family: var(--font-mono); font-size: 12px; color: var(--ink-100); letter-spacing: 0.08em; margin-top: 8px; }

  .paket-list { display: flex; flex-direction: column; gap: 14px; }
  .paket-card {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 22px 24px;
    display: grid; grid-template-columns: 1fr auto auto; gap: 20px; align-items: center;
    text-decoration: none; color: inherit;
    transition: border-color 120ms ease;
  }
  .paket-card:hover { border-color: var(--gold-300); }
  .paket-card .title {
    font-family: var(--font-display); font-size: 19px; font-weight: 500;
    color: var(--cream-100);
  }
  .paket-card .meta {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.04em; margin-top: 4px;
  }
  .paket-card .meta .id { color: var(--gold-300); }
  .paket-card .pax {
    font-family: var(--font-display); font-size: 22px; color: var(--cream-100);
    font-weight: 500; text-align: right;
  }
  .paket-card .pax .sub {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); letter-spacing: 0.06em; margin-top: 2px; font-weight: normal;
  }
  .paket-card .cta {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
    color: var(--gold-300); text-transform: uppercase;
    border: 1px solid var(--gold-300); padding: 7px 14px; border-radius: 3px;
  }

  .status-tag {
    padding: 3px 8px; font-family: var(--font-mono); font-size: 9.5px;
    border-radius: 3px; letter-spacing: 0.1em; border: 1px solid; display: inline-block; margin-top: 6px;
  }
  .status-tag.active   { color: var(--emerald); border-color: var(--emerald); background: rgba(74,143,109,0.08); }
  .status-tag.draft    { color: var(--amber); border-color: var(--amber); }
  .status-tag.closed   { color: var(--ruby); border-color: var(--ruby); }

  .empty {
    border: 1px dashed var(--ink-500); border-radius: var(--r-md);
    padding: 40px; text-align: center;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); line-height: 1.7;
  }

  @media (max-width: 720px) {
    .paket-card {
      grid-template-columns: 1fr auto;
      grid-template-areas: "title pax" "cta cta";
      gap: 10px 14px; padding: 16px 18px;
    }
    .paket-card > div:first-child { grid-area: title; }
    .paket-card .pax { grid-area: pax; }
    .paket-card .cta {
      grid-area: cta; text-align: center; padding: 10px;
      min-height: 44px; display: flex; align-items: center; justify-content: center;
    }
  }
</style>
</head>
<body data-screen-label="05 Crew · Home">
<div class="wrap">

  <div class="topbar">
    <div>MUTHAWWIF · <span class="who"><%= user.email %></span></div>
    <div style="display:flex;gap:10px;align-items:center;">
      <%# Stage 245 — cross-paket ICE contact book %>
      <a href="/crew/contacts" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;color:var(--ink-100);font-family:var(--font-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;padding:6px 14px;border:var(--hairline-soft);border-radius:var(--r-sm);">
        <span>Kontak</span>
      </a>
      <%# Stage 148 — unread notif badge linking to /crew/notifications. %>
      <a href="/crew/notifications" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;color:var(--ink-100);font-family:var(--font-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;padding:6px 14px;border:var(--hairline-soft);border-radius:var(--r-sm);">
        <span>Notifikasi</span>
        <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
          <span style="background:var(--gold-300);color:var(--ink-1000);font-weight:600;padding:1px 7px;border-radius:9px;font-size:9.5px;letter-spacing:0;"><%= unreadCount %></span>
        <% } %>
      </a>
      <form method="POST" action="/logout"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit">Keluar</button></form>
    </div>
  </div>

  <div class="hero">
    <div class="eyebrow">Crew Portal · <%= paketList.length %> paket di-assign</div>
    <h1>Assalamu'alaikum,<br><em><%= user.fullName.split(' ')[0] %></em>.</h1>
    <div class="sub">Pilih paket untuk melihat manifest jemaah, kamar, dan kesiapan dokumen.</div>
  </div>

  <%# Stage 246 — "Hari ini" widget. Only renders when there's at least
      one signal worth showing (no empty panel waste). %>
  <%
    const hasToday = typeof today !== 'undefined' && today && (
      today.departingSoon.length > 0
      || today.attendanceDueToday.length > 0
      || today.openIncidents.length > 0
    );
  %>
  <% if (hasToday) { %>
    <div style="background:rgba(212,175,55,0.04);border:1px solid var(--gold-300);border-radius:var(--r-sm);padding:18px 20px;margin-bottom:24px;">
      <h3 style="margin:0 0 12px;font-family:var(--font-display);color:var(--gold-300);font-size:18px;">📍 Hari ini</h3>

      <% if (today.departingSoon.length > 0) { %>
        <div style="margin-bottom:12px;">
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">🛫 Paket berangkat ≤ 48 jam (<%= today.departingSoon.length %>)</div>
          <% today.departingSoon.forEach(function(p) { %>
            <a href="/crew/paket/<%= p.slug %>" style="display:block;padding:8px 12px;background:var(--ink-1000);border-left:3px solid var(--amber);border-radius:0 3px 3px 0;margin-bottom:6px;text-decoration:none;font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);">
              <strong style="color:var(--gold-300);"><%= p.title %></strong>
              · <%= fmt.dateLong(p.departureDate) %>
              · <span style="color:var(--ink-200);"><%= p.kursiTerisi %> / <%= p.kursiTotal %> kursi</span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (today.attendanceDueToday.length > 0) { %>
        <div style="margin-bottom:12px;">
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">✓ Absensi hari ini (<%= today.attendanceDueToday.length %>)</div>
          <% today.attendanceDueToday.forEach(function(a) { %>
            <a href="/crew/paket/<%= a.paket.slug %>/attendance/<%= a.day.id %>" style="display:block;padding:8px 12px;background:var(--ink-1000);border-left:3px solid var(--emerald);border-radius:0 3px 3px 0;margin-bottom:6px;text-decoration:none;font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);">
              <strong style="color:var(--emerald);">H<%= a.day.dayNumber %>: <%= a.day.title %></strong>
              · <span style="color:var(--ink-200);"><%= a.paket.title %></span>
              <span style="color:var(--gold-300);float:right;">Mark sekarang →</span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (today.openIncidents.length > 0) { %>
        <div>
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">⚠ Insiden Anda belum tuntas (<%= today.openIncidents.length %>)</div>
          <% today.openIncidents.forEach(function(inc) { %>
            <div style="padding:8px 12px;background:var(--ink-1000);border-left:3px solid <%= inc.status === 'OPEN' ? 'var(--ruby)' : 'var(--amber)' %>;border-radius:0 3px 3px 0;margin-bottom:6px;font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);">
              <strong style="color:<%= inc.status === 'OPEN' ? 'var(--ruby)' : 'var(--amber)' %>;"><%= inc.type %></strong>
              · <span style="color:var(--ink-100);"><%= inc.message ? (inc.message.length > 80 ? inc.message.slice(0, 80) + '…' : inc.message) : '—' %></span>
              <div style="color:var(--ink-200);font-size:10px;margin-top:3px;">
                <%= inc.status %> · <%= fmt.dateLong(inc.createdAt) %>
                <% if (inc.paket) { %>· <%= inc.paket.title %><% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (paketList.length === 0) { %>
    <div class="empty">
      Anda belum di-assign ke paket apa pun.<br>
      Hubungi admin untuk assignment.
    </div>
  <% } else { %>
    <div class="paket-list">
      <% paketList.forEach(function(p) { %>
        <a class="paket-card" href="/crew/paket/<%= p.slug %>">
          <div>
            <div class="title"><%= p.title %></div>
            <div class="meta">
              <span class="id"><%= p.slug %></span>
              · DEP <%= fmt.dateShort(p.departureDate) %>
              · <%= p.durationDays %> hari
              · <%= p._count.bookings %> booking
            </div>
            <span class="status-tag <%= p.status.toLowerCase() %>"><%= p.status %></span>
          </div>
          <div class="pax">
            <%= p.kursiTerisi %>/<%= p.kursiTotal %>
            <div class="sub">kursi terisi</div>
          </div>
          <div class="cta">Manifest →</div>
        </a>
      <% }) %>
    </div>
  <% } %>

  <%# Stage 207 — crew's own open tasks (S91). Read-only on this surface;
      admin still owns the create/complete/cancel flow. %>
  <% if (typeof myTasks !== 'undefined' && myTasks && myTasks.totals.open > 0) { %>
    <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 500; color: var(--cream-100); margin: 32px 0 10px; letter-spacing: -0.015em;">
      Tugas Anda
    </h3>
    <div style="font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.08em; margin-bottom: 14px;">
      <%= myTasks.totals.open %> tugas terbuka
      <% if (myTasks.totals.overdue > 0) { %>
        · <span style="color:var(--ruby);"><%= myTasks.totals.overdue %> overdue</span>
      <% } %>
      <% if (myTasks.totals.shown < myTasks.totals.open) { %>
        · menampilkan <%= myTasks.totals.shown %>
      <% } %>
    </div>
    <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:24px;">
      <% myTasks.rows.forEach(function(t) {
           const overdue = t.dueAt && new Date(t.dueAt).getTime() < Date.now();
      %>
        <div style="background:var(--ink-900); border:1px solid <%= overdue ? 'var(--ruby)' : 'var(--hairline-soft)' %>; border-radius:var(--r-sm); padding:12px 14px;">
          <div style="display:flex; justify-content:space-between; gap:10px; align-items:baseline;">
            <div style="font-family:var(--font-mono); font-size:11px; color:var(--gold-300); letter-spacing:0.06em; text-transform:uppercase;">
              <% if (t.booking) { %>
                <%= t.booking.bookingNo %><% if (t.booking.jemaah?.fullName) { %> · <%= t.booking.jemaah.fullName %><% } %>
              <% } else { %>
                Tugas
              <% } %>
            </div>
            <% if (t.dueAt) { %>
              <div style="font-family:var(--font-mono); font-size:10px; color:<%= overdue ? 'var(--ruby)' : 'var(--ink-200)' %>; letter-spacing:0.06em;">
                <% if (overdue) { %>⚠ OVERDUE <% } %>due <%= fmt.dateShort(t.dueAt) %>
              </div>
            <% } %>
          </div>
          <div style="color:var(--cream-100); font-size:13px; margin-top:6px; line-height:1.5;">
            <%= t.body %>
          </div>
          <% if (t.booking?.paket?.title) { %>
            <div style="font-family:var(--font-mono); font-size:10px; color:var(--ink-200); margin-top:6px;">
              📍 <%= t.booking.paket.title %>
            </div>
          <% } %>
          <% if (t.createdByEmail) { %>
            <div style="font-family:var(--font-mono); font-size:9.5px; color:var(--ink-300); margin-top:4px;">
              dari <%= t.createdByEmail %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (typeof myIncidents !== 'undefined' && myIncidents.length > 0) { %>
    <h3 style="font-family: var(--font-display); font-size: 20px; font-weight: 500; color: var(--cream-100); margin: 32px 0 10px; letter-spacing: -0.015em;">
      Riwayat alert Anda
    </h3>
    <div style="font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.08em; margin-bottom: 14px;">
      <%= myIncidents.length %> alert terakhir · status admin terlihat di sini setelah ditindaklanjuti
    </div>
    <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:24px;">
      <% myIncidents.forEach(function(it) { %>
        <div style="background:var(--ink-900); border:var(--hairline); border-radius:var(--r-sm); padding:12px 14px; display:grid; grid-template-columns:1fr auto; gap:10px; align-items:center;">
          <div>
            <div style="color:var(--cream-100); font-size:13px;"><%= it.type %><% if (it.paket) { %> · <span style="color:var(--gold-300);"><%= it.paket.title %></span><% } %></div>
            <div style="font-family:var(--font-mono); font-size:10.5px; color:var(--ink-200); margin-top:2px;">
              <%= fmt.date(it.createdAt) %>
              <% if (it.resolvedAt) { %>· resolved <%= fmt.date(it.resolvedAt) %><% } else if (it.ackedAt) { %>· acked <%= fmt.date(it.ackedAt) %><% } %>
            </div>
          </div>
          <% const cls = it.status === 'OPEN' ? 'ruby' : (it.status === 'ACKED' ? 'amber' : 'emerald'); %>
          <span style="padding:3px 8px; font-family:var(--font-mono); font-size:10px; border-radius:3px; letter-spacing:0.1em; border:1px solid var(--<%= cls %>); color:var(--<%= cls %>);"><%= it.status %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('partials/sos-fab') %>
</body>
</html>

<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Insiden</title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<script src="/shared/csrf.js"></script>
<script src="/shared/push-admin.js" defer></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 22px; gap: 18px; flex-wrap: wrap; }
  .head h1 { font-family: var(--font-display); font-size: 34px; font-weight: 500; color: var(--cream-100); margin: 0; letter-spacing: -0.015em; }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; margin-top: 8px; }

  .kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 22px; }
  .kpi { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 16px 18px; }
  .kpi .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
  .kpi .v { font-family: var(--font-display); font-size: 30px; color: var(--cream-100); margin-top: 6px; font-weight: 500; }
  .kpi.open .v { color: var(--ruby); }
  .kpi.acked .v { color: var(--amber); }
  .kpi.resolved .v { color: var(--emerald); }

  .filter-bar { display: flex; gap: 8px; align-items: end; margin-bottom: 18px; flex-wrap: wrap; }
  .filter-bar select.input { padding: 6px 10px; font-size: 12px; background-color: var(--ink-1000); color: var(--cream-100); }
  .filter-bar .lbl { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; display: block; margin-bottom: 4px; }

  .tbl { width: 100%; border-collapse: collapse; background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); overflow: hidden; }
  .tbl thead th { text-align: left; padding: 12px 14px; background: var(--ink-1000); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); font-weight: 500; border-bottom: var(--hairline); }
  .tbl tbody td { padding: 11px 14px; border-bottom: var(--hairline-soft); font-size: 12.5px; color: var(--cream-200); vertical-align: top; }
  .tbl tbody tr:hover td { background: var(--ink-850); cursor: pointer; }
  .tbl .id { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .tbl .sx { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; }
  .tbl tbody tr.open-row td { box-shadow: inset 3px 0 0 var(--ruby); }

  .status-tag { padding: 3px 8px; font-family: var(--font-mono); font-size: 10px; border-radius: 3px; letter-spacing: 0.12em; border: 1px solid; }
  .status-tag.open     { color: var(--ruby);    border-color: var(--ruby);    background: rgba(181,86,74,0.10); }
  .status-tag.acked    { color: var(--amber);   border-color: var(--amber);   background: rgba(201,147,59,0.08); }
  .status-tag.resolved { color: var(--emerald); border-color: var(--emerald); background: rgba(74,143,109,0.08); }

  .type-tag { padding: 3px 8px; font-family: var(--font-mono); font-size: 10px; border-radius: 3px; letter-spacing: 0.1em; border: 1px solid var(--ink-500); color: var(--ink-100); }
  .type-tag.sos { color: var(--ruby); border-color: var(--ruby); font-weight: 600; }

  .empty { padding: 48px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); }

  @media (max-width: 720px) {
    .kpi-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body data-screen-label="02 Admin · Insiden">
<div class="wrap">
  <div class="crumb"><a href="/admin">← KEMBALI KE DASHBOARD</a></div>
  <div class="head">
    <div>
      <h1>Insiden <em>lapangan</em></h1>
      <div class="sub"><%= total %> total · OPEN paling atas, sortir berikutnya pakai filter</div>
    </div>
    <div id="rp-push-bar"
         style="display:none; align-items:center; gap:10px; font-family:var(--font-mono); font-size:11px;">
      <span id="rp-push-status" style="color:var(--ink-200); letter-spacing:0.06em;">Push: memeriksa…</span>
      <button type="button" id="rp-push-enable"
              style="display:none; background:var(--gold-300); color:var(--ink-1000); border:0; padding:8px 14px; border-radius:var(--r-sm); font-family:var(--font-mono); font-size:10px; letter-spacing:0.14em; text-transform:uppercase; cursor:pointer; font-weight:600;">
        Aktifkan push
      </button>
      <button type="button" id="rp-push-disable"
              style="display:none; background:transparent; color:var(--ink-100); border:var(--hairline-soft); padding:8px 14px; border-radius:var(--r-sm); font-family:var(--font-mono); font-size:10px; letter-spacing:0.14em; text-transform:uppercase; cursor:pointer;">
        Matikan
      </button>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi open"><div class="l">OPEN</div><div class="v"><%= countsByStatus.OPEN %></div></div>
    <div class="kpi acked"><div class="l">ACKED</div><div class="v"><%= countsByStatus.ACKED %></div></div>
    <div class="kpi resolved"><div class="l">RESOLVED</div><div class="v"><%= countsByStatus.RESOLVED %></div></div>
  </div>

  <form method="GET" action="/admin/incidents" class="filter-bar">
    <div>
      <label class="lbl">Status</label>
      <select name="status" class="input" onchange="this.form.submit()">
        <option value="ALL" <%= filters.status === 'ALL' ? 'selected' : '' %>>Semua</option>
        <option value="OPEN" <%= filters.status === 'OPEN' ? 'selected' : '' %>>OPEN</option>
        <option value="ACKED" <%= filters.status === 'ACKED' ? 'selected' : '' %>>ACKED</option>
        <option value="RESOLVED" <%= filters.status === 'RESOLVED' ? 'selected' : '' %>>RESOLVED</option>
      </select>
    </div>
    <div>
      <label class="lbl">Type</label>
      <select name="type" class="input" onchange="this.form.submit()">
        <option value="ALL" <%= filters.type === 'ALL' ? 'selected' : '' %>>Semua</option>
        <% Object.entries(typeLabels).forEach(function([k, lbl]) { %>
          <option value="<%= k %>" <%= filters.type === k ? 'selected' : '' %>><%= lbl %></option>
        <% }) %>
      </select>
    </div>
  </form>

  <% if (rows.length === 0) { %>
    <div class="empty">Tidak ada insiden untuk filter ini.</div>
  <% } else { %>
    <table class="tbl">
      <thead>
        <tr>
          <th style="width:110px;">Status</th>
          <th style="width:140px;">Jenis</th>
          <th>Crew · Paket</th>
          <th>Pesan</th>
          <th style="width:140px;">Waktu</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(r) { %>
          <tr class="<%= r.status === 'OPEN' ? 'open-row' : '' %>"
              onclick="location.href='/admin/incidents/<%= r.id %>'">
            <td><span class="status-tag <%= r.status.toLowerCase() %>"><%= r.status %></span></td>
            <td><span class="type-tag <%= r.type === 'SOS' ? 'sos' : '' %>"><%= typeLabels[r.type] || r.type %></span></td>
            <td>
              <div style="color:var(--cream-100);font-weight:500;"><%= r.createdBy?.fullName || r.createdBy?.email || '—' %></div>
              <div class="sx"><%= r.createdBy?.email %></div>
              <% if (r.paket) { %>
                <div class="sx" style="color:var(--gold-300);"><%= r.paket.title %></div>
              <% } %>
            </td>
            <td>
              <div style="max-width:420px; white-space:pre-line; line-height:1.5;">
                <%= r.message ? (r.message.length > 140 ? r.message.slice(0, 140) + '…' : r.message) : '—' %>
              </div>
              <% if (r.locationLabel) { %><div class="sx">📍 <%= r.locationLabel %></div><% } %>
            </td>
            <td class="sx">
              <%= fmt.date(r.createdAt) %>
              <% if (r.ackedAt) { %><div>ack <%= fmt.date(r.ackedAt) %></div><% } %>
              <% if (r.resolvedAt) { %><div>resolved <%= fmt.date(r.resolvedAt) %></div><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div style="margin-top:18px; display:flex; gap:8px; align-items:center; font-family:var(--font-mono); font-size:11px; color:var(--ink-200);">
        Page <%= page %> / <%= totalPages %>
        <% if (page > 1) { %><a href="?status=<%= filters.status %>&type=<%= filters.type %>&page=<%= page-1 %>" style="color:var(--gold-300);text-decoration:none;">← prev</a><% } %>
        <% if (page < totalPages) { %><a href="?status=<%= filters.status %>&type=<%= filters.type %>&page=<%= page+1 %>" style="color:var(--gold-300);text-decoration:none;">next →</a><% } %>
      </div>
    <% } %>
  <% } %>
</div>
</body>
</html>

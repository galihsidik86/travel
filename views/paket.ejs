<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — <%= paket.title %><% if (paket.subtitle) { %> · <%= paket.subtitle %><% } %></title>
<%# Stage 194 — SEO + Open Graph + Twitter Card meta tags. `seo`
    object built server-side in the paket landing route. %>
<% if (typeof seo !== 'undefined' && seo) { %>
  <meta name="description" content="<%= seo.description %>">
  <link rel="canonical" href="<%= seo.url %>">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= seo.url %>">
  <meta property="og:title" content="<%= seo.title %>">
  <meta property="og:description" content="<%= seo.description %>">
  <meta property="og:image" content="<%= seo.image %>">
  <meta property="og:site_name" content="Religio Pro">
  <meta property="og:locale" content="<%= seo.locale %>">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= seo.title %>">
  <meta name="twitter:description" content="<%= seo.description %>">
  <meta name="twitter:image" content="<%= seo.image %>">
<% } %>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<script src="/shared/csrf.js"></script>
<%# Stage 383 — UU PDP cookie consent banner (public pages) %>
<script src="/shared/cookie-banner.js" defer></script>
<style>
  body { overflow-x: hidden; }

  /* RIBBON */
  .ribbon { background: linear-gradient(90deg, var(--ink-1000), var(--ink-900) 30%, var(--ink-900) 70%, var(--ink-1000)); border-bottom: var(--hairline-soft); padding: 10px 0; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); }
  .ribbon__inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; display: flex; justify-content: space-between; align-items: center; gap: 24px; }
  .ribbon__left { display: flex; align-items: center; gap: 14px; }
  .ribbon__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold-300); box-shadow: 0 0 12px var(--gold-300); animation: pulse 2.4s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  .ribbon__url { color: var(--cream-200); }
  .ribbon__url em { color: var(--gold-300); font-style: normal; }

  /* NAV */
  .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(20px); background: rgba(10,9,8,0.82); border-bottom: var(--hairline-soft); }
  .nav__inner { max-width: 1280px; margin: 0 auto; padding: 16px 32px; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 32px; }
  .nav__links { display: flex; gap: 32px; justify-content: center; font-size: 13px; color: var(--ink-100); }
  .nav__links a { color: inherit; text-decoration: none; transition: color var(--dur-fast); }
  .nav__links a:hover { color: var(--gold-300); }
  .nav__price { display: flex; align-items: center; gap: 16px; }
  .nav__price .amount { font-family: var(--font-display); font-size: 22px; color: var(--gold-300); font-weight: 500; line-height: 1; }
  .nav__price .amount .from { font-family: var(--font-mono); font-size: 10px; color: var(--ink-300); text-transform: uppercase; letter-spacing: 0.14em; display: block; margin-bottom: 2px; }

  /* HERO */
  .hero { position: relative; padding: 96px 32px 80px; max-width: 1280px; margin: 0 auto; overflow: hidden; }
  .hero__bg { position: absolute; inset: -100px -200px -100px 40%; background: radial-gradient(60% 60% at 60% 30%, rgba(212,175,55,0.10), transparent 70%), radial-gradient(40% 40% at 20% 80%, rgba(74,143,109,0.04), transparent 60%); pointer-events: none; }
  .hero__crest { position: absolute; right: 0; top: 64px; width: 540px; height: 540px; border: 1px solid rgba(212,175,55,0.18); border-radius: 50%; pointer-events: none; }
  .hero__crest::before { content: ""; position: absolute; inset: 80px; border: 1px solid rgba(212,175,55,0.10); border-radius: 50%; }
  .hero__crest::after { content: ""; position: absolute; inset: 180px; border: 1px solid rgba(212,175,55,0.06); border-radius: 50%; }
  .hero__grid { position: relative; display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: end; }
  .hero__eyebrow { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; }
  .hero__eyebrow .line { flex: 1; max-width: 80px; height: 1px; background: var(--ink-500); }
  .hero__title { font-family: var(--font-display); font-size: clamp(56px, 8vw, 104px); line-height: 0.94; letter-spacing: -0.025em; font-weight: 400; color: var(--cream-100); margin: 0; }
  .hero__title em { font-style: italic; color: var(--gold-300); font-weight: 400; }
  .hero__arabic { font-family: var(--font-arabic); font-size: 38px; color: var(--gold-200); direction: rtl; text-align: left; margin: 28px 0 8px; line-height: 1.5; letter-spacing: 0.02em; }
  .hero__translit { font-family: var(--font-display); font-style: italic; font-size: 16px; color: var(--ink-100); margin: 0 0 36px; }
  .hero__meta { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: var(--hairline-soft); margin-top: 40px; padding-top: 24px; }
  .hero__meta div { padding-right: 16px; }
  .hero__meta dt { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-300); margin-bottom: 6px; }
  .hero__meta dd { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); font-weight: 500; margin: 0; letter-spacing: -0.005em; line-height: 1.15; }
  .hero__meta dd .u { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); margin-left: 4px; }

  /* AGENT CARD */
  .agent-card { background: radial-gradient(120% 80% at 0% 0%, rgba(212,175,55,0.06), transparent 60%), var(--ink-900); border: 1px solid var(--ink-500); border-radius: var(--r-xl); padding: 32px; box-shadow: var(--shadow-lg), var(--inset-hairline); position: relative; }
  .agent-card__head { display: flex; justify-content: space-between; align-items: center; padding-bottom: 18px; border-bottom: var(--hairline-soft); margin-bottom: 22px; }
  .agent-card__head .l { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-300); }
  .agent-card__profile { display: flex; align-items: center; gap: 16px; }
  .agent-card__avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--ink-700), var(--ink-900)); border: 1px solid var(--gold-300); display: grid; place-items: center; font-family: var(--font-display); font-size: 22px; color: var(--gold-300); }
  .agent-card__name { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.01em; line-height: 1.1; }
  .agent-card__name em { font-style: italic; color: var(--gold-300); }
  .agent-card__role { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }
  .agent-card__contacts { display: flex; flex-direction: column; gap: 10px; margin: 22px 0; }
  .agent-card__contacts a { display: flex; align-items: center; gap: 12px; padding: 12px 14px; background: var(--ink-850); border: var(--hairline); border-radius: var(--r-md); color: var(--cream-200); font-size: 13px; text-decoration: none; transition: all var(--dur-fast); }
  .agent-card__contacts a:hover { border-color: var(--gold-300); background: var(--ink-800); }
  .agent-card__contacts svg { width: 16px; height: 16px; stroke: var(--gold-300); fill: none; stroke-width: 1.5; flex-shrink: 0; }
  .agent-card__price { margin-top: 24px; padding-top: 22px; border-top: var(--hairline-soft); display: flex; align-items: end; justify-content: space-between; }
  .agent-card__price .from { font-family: var(--font-mono); font-size: 10px; color: var(--ink-300); letter-spacing: 0.14em; text-transform: uppercase; }
  .agent-card__price .amount { font-family: var(--font-display); font-size: 44px; color: var(--gold-300); font-weight: 500; line-height: 1; margin-top: 4px; letter-spacing: -0.01em; }
  .agent-card__price .amount .ccy { font-family: var(--font-mono); font-size: 13px; color: var(--ink-200); margin-right: 6px; }
  .agent-card__cta { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; }
  .agent-card__cta .promo { font-family: var(--font-mono); font-size: 10px; color: var(--emerald); letter-spacing: 0.12em; text-transform: uppercase; }

  /* SECTIONS */
  .section { max-width: 1280px; margin: 0 auto; padding: 96px 32px; border-top: var(--hairline-soft); position: relative; }
  .section__head { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-bottom: 56px; }
  .section__head h2 { font-family: var(--font-display); font-size: clamp(36px, 5vw, 56px); line-height: 1; letter-spacing: -0.02em; color: var(--cream-100); margin: 12px 0 0; font-weight: 400; }
  .section__head h2 em { font-style: italic; color: var(--gold-300); }
  .section__head p { color: var(--ink-100); font-size: 15px; line-height: 1.65; margin: 0; align-self: end; max-width: 480px; }

  /* HIGHLIGHTS */
  .highlights { display: grid; grid-template-columns: repeat(4, 1fr); border: var(--hairline); border-radius: var(--r-lg); overflow: hidden; background: var(--ink-900); }
  .highlight { padding: 32px 28px; border-right: var(--hairline-soft); position: relative; }
  .highlight:last-child { border-right: 0; }
  .highlight__ico { width: 28px; height: 28px; margin-bottom: 22px; color: var(--gold-300); }
  .highlight__ico svg { width: 100%; height: 100%; stroke: currentColor; fill: none; stroke-width: 1.25; }
  .highlight__label { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-200); margin-bottom: 8px; }
  .highlight__value { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); font-weight: 500; line-height: 1.2; letter-spacing: -0.005em; }
  .highlight__sub { font-size: 12.5px; color: var(--ink-100); margin-top: 6px; }
  .stars { color: var(--gold-300); letter-spacing: 0.04em; font-size: 13px; }

  /* HOTELS */
  .hotels { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .hotel { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-lg); overflow: hidden; display: flex; flex-direction: column; }
  .hotel__visual { height: 320px; position: relative; overflow: hidden; border-bottom: var(--hairline); }
  .hotel--mekkah .hotel__visual { background: radial-gradient(ellipse at 50% 100%, rgba(212,175,55,0.4), transparent 50%), radial-gradient(ellipse at 50% 20%, rgba(184,148,86,0.15), transparent 70%), linear-gradient(180deg, var(--ink-1000), #15110a); }
  .hotel--madinah .hotel__visual { background: radial-gradient(ellipse at 50% 80%, rgba(74,143,109,0.35), transparent 55%), radial-gradient(circle at 50% 35%, rgba(237,230,211,0.08), transparent 50%), linear-gradient(180deg, var(--ink-1000), #0c1410); }
  .hotel__visual::before { content: ""; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 3px 3px; }
  .skyline { position: absolute; bottom: 0; left: 0; right: 0; height: 140px; pointer-events: none; }
  .skyline svg { width: 100%; height: 100%; display: block; }
  .skyline path { fill: rgba(5,4,3,0.7); }
  .hotel__visual .crescent { position: absolute; top: 32px; right: 32px; font-family: var(--font-arabic); font-size: 56px; color: var(--gold-200); direction: rtl; opacity: 0.4; }
  .hotel__meta { padding: 28px 32px 32px; display: flex; flex-direction: column; gap: 14px; }
  .hotel__row { display: flex; justify-content: space-between; align-items: baseline; }
  .hotel__name { font-family: var(--font-display); font-size: 30px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.01em; margin: 0; line-height: 1.1; }
  .hotel__city { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-300); }
  .hotel__desc { color: var(--ink-100); font-size: 14px; line-height: 1.6; margin: 0; }
  .hotel__specs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 8px; padding-top: 18px; border-top: var(--hairline-soft); }
  .hotel__specs > div { display: flex; flex-direction: column; gap: 4px; }
  .hotel__specs .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-300); letter-spacing: 0.14em; text-transform: uppercase; }
  .hotel__specs .v { font-size: 13.5px; color: var(--cream-200); }

  /* ITINERARY */
  .timeline { position: relative; padding-left: 64px; list-style: none; margin: 0; }
  .timeline::before { content: ""; position: absolute; left: 24px; top: 12px; bottom: 12px; width: 1px; background: linear-gradient(180deg, transparent, var(--gold-500) 5%, var(--ink-500) 50%, var(--ink-500) 95%, transparent); }
  .day { position: relative; padding: 24px 0; border-bottom: var(--hairline-soft); display: grid; grid-template-columns: 0.5fr 1fr 1fr; gap: 48px; align-items: start; }
  .day:last-child { border-bottom: 0; }
  .day::before { content: ""; position: absolute; left: -52px; top: 36px; width: 9px; height: 9px; border-radius: 50%; background: var(--ink-900); border: 2px solid var(--gold-300); box-shadow: 0 0 0 4px var(--ink-950); }
  .day--highlight::before { background: var(--gold-300); box-shadow: 0 0 0 4px var(--ink-950), var(--glow-gold); }
  .day__num { font-family: var(--font-mono); font-size: 10px; color: var(--ink-300); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 4px; }
  .day__date { font-family: var(--font-display); font-size: 30px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.01em; line-height: 1; }
  .day__date .month { display: block; font-size: 13px; font-family: var(--font-mono); color: var(--gold-300); letter-spacing: 0.16em; text-transform: uppercase; margin-top: 6px; font-weight: 400; }
  .day__title { font-family: var(--font-display); font-size: 24px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.005em; margin: 0 0 8px; line-height: 1.2; }
  .day__title em { font-style: italic; color: var(--gold-300); }
  .day__desc { font-size: 14px; color: var(--ink-100); line-height: 1.6; margin: 0; }
  .day__tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .day__pembi-title { font-family: var(--font-mono); font-size: 10px; color: var(--ink-300); letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 10px; }
  .tag { font-family: var(--font-mono); font-size: 10px; color: var(--ink-100); letter-spacing: 0.08em; padding: 4px 9px; border: 1px solid var(--ink-500); border-radius: var(--r-sm); background: var(--ink-850); }
  .tag--gold { color: var(--gold-200); border-color: rgba(212,175,55,0.4); background: rgba(212,175,55,0.06); }
  .tag--emerald { color: #8FCBAA; border-color: rgba(74,143,109,0.4); background: var(--emerald-soft); }

  /* PRICING */
  .pricing { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .price-card { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-lg); padding: 32px 28px; display: flex; flex-direction: column; position: relative; transition: all var(--dur-mid) var(--ease-out); }
  .price-card:hover { transform: translateY(-2px); border-color: var(--gold-300); box-shadow: var(--shadow-lg); }
  .price-card--feature { background: radial-gradient(120% 80% at 50% 0%, rgba(212,175,55,0.10), transparent 60%), var(--ink-900); border-color: var(--gold-300); box-shadow: var(--shadow-gold); }
  .price-card__crown { position: absolute; top: -12px; right: 28px; background: var(--gold-300); color: var(--ink-950); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; padding: 5px 11px; border-radius: var(--r-sm); font-weight: 600; }
  .price-card__class { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--gold-300); margin-bottom: 8px; }
  .price-card__name { font-family: var(--font-display); font-size: 36px; color: var(--cream-100); font-weight: 500; line-height: 1; letter-spacing: -0.01em; margin: 0 0 6px; }
  .price-card__per { font-size: 12.5px; color: var(--ink-200); margin-bottom: 24px; }
  .price-card__amount { display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px; }
  .price-card__amount .ccy { font-family: var(--font-mono); font-size: 12px; color: var(--ink-200); letter-spacing: 0.12em; }
  .price-card__amount .v { font-family: var(--font-display); font-size: 48px; color: var(--gold-300); font-weight: 500; line-height: 1; letter-spacing: -0.02em; }
  .price-card__amount .u { font-family: var(--font-mono); font-size: 12px; color: var(--gold-300); margin-left: 2px; }
  .price-card__cicilan { font-size: 12px; color: var(--ink-100); padding: 12px 0; border-top: var(--hairline-soft); border-bottom: var(--hairline-soft); margin: 16px 0 22px; }
  .price-card__cicilan strong { color: var(--cream-200); font-weight: 600; }
  .price-card ul { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 9px; flex: 1; }
  .price-card li { font-size: 12.5px; color: var(--ink-100); display: flex; align-items: start; gap: 10px; line-height: 1.45; }
  .price-card li::before { content: "→"; color: var(--gold-300); font-family: var(--font-mono); font-size: 12px; flex-shrink: 0; margin-top: 1px; }
  .price-card .btn { justify-content: center; width: 100%; }

  /* INCLUSIONS */
  .incl { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .incl-col { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-lg); padding: 36px 32px; }
  .incl-col--no { border-color: rgba(181,86,74,0.25); }
  .incl-col h3 { font-family: var(--font-display); font-size: 28px; color: var(--cream-100); margin: 0 0 22px; font-weight: 500; letter-spacing: -0.005em; padding-bottom: 16px; border-bottom: var(--hairline-soft); display: flex; align-items: center; gap: 12px; }
  .incl-col h3 .badge { font-size: 10px; }
  .incl-col ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px 24px; }
  .incl-col li { font-size: 13.5px; color: var(--cream-200); display: flex; gap: 12px; line-height: 1.5; padding-left: 0; }
  .incl-col li::before { content: ""; flex-shrink: 0; width: 16px; height: 16px; margin-top: 2px; background-image: var(--check); background-size: contain; background-repeat: no-repeat; }
  .incl-col--yes { --check: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><path d='M3 8.5l3 3 7-7' fill='none' stroke='%23D4AF37' stroke-width='1.6' stroke-linecap='round'/></svg>"); }
  .incl-col--no { --check: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><path d='M4 4l8 8M12 4l-8 8' fill='none' stroke='%23B5564A' stroke-width='1.6' stroke-linecap='round'/></svg>"); }

  /* PAYMENT */
  .scheme { display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: start; }
  .scheme__steps { list-style: none; padding: 0; margin: 0; counter-reset: step; position: relative; }
  .scheme__steps::before { content: ""; position: absolute; left: 19px; top: 24px; bottom: 24px; width: 1px; background: linear-gradient(180deg, var(--gold-300), var(--ink-500)); opacity: 0.4; }
  .scheme__steps li { counter-increment: step; display: grid; grid-template-columns: 56px 1fr; gap: 20px; padding: 18px 0; position: relative; }
  .scheme__steps li::before { content: counter(step, decimal-leading-zero); grid-column: 1; align-self: start; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; color: var(--gold-300); width: 40px; height: 40px; display: grid; place-items: center; background: var(--ink-900); border: 1px solid var(--gold-300); border-radius: 50%; z-index: 2; }
  .scheme__steps h4 { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin: 6px 0 6px; font-weight: 500; letter-spacing: -0.005em; }
  .scheme__steps p { color: var(--ink-100); font-size: 13.5px; line-height: 1.6; margin: 0; }
  .scheme__steps .due { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 8px; }
  .pay-methods { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-lg); padding: 32px; }
  .pay-methods h4 { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin: 0 0 4px; font-weight: 500; }
  .pay-methods .lede { font-size: 13.5px; color: var(--ink-100); margin: 0 0 24px; line-height: 1.55; }
  .pay-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .pay-tile { aspect-ratio: 1.6; background: var(--ink-850); border: var(--hairline-soft); border-radius: var(--r-md); display: flex; flex-direction: column; justify-content: space-between; padding: 14px 16px; transition: all var(--dur-fast); }
  .pay-tile:hover { border-color: var(--gold-300); }
  .pay-tile .l { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; color: var(--ink-300); text-transform: uppercase; }
  .pay-tile .v { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.005em; }
  .pay-tile .v em { font-style: italic; color: var(--gold-300); }

  /* BOOKING */
  .booking { background: radial-gradient(80% 60% at 100% 0%, rgba(212,175,55,0.06), transparent 60%), var(--ink-900); border: var(--hairline); border-radius: var(--r-xl); padding: 56px; display: grid; grid-template-columns: 1fr 1fr; gap: 56px; }
  .booking__left h2 { font-family: var(--font-display); font-size: 44px; color: var(--cream-100); margin: 12px 0 16px; font-weight: 400; line-height: 1; letter-spacing: -0.02em; }
  .booking__left h2 em { font-style: italic; color: var(--gold-300); }
  .booking__left p { color: var(--ink-100); font-size: 14.5px; line-height: 1.65; margin: 0; }
  .booking__assure { margin-top: 32px; padding-top: 24px; border-top: var(--hairline-soft); display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .booking__assure > div { display: flex; flex-direction: column; gap: 4px; }
  .booking__assure .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--gold-300); letter-spacing: 0.14em; text-transform: uppercase; }
  .booking__assure .v { font-size: 13.5px; color: var(--cream-200); line-height: 1.45; }
  .self-booking-banner {
    grid-column: span 2;
    background: rgba(74,143,109,0.08);
    border: 1px solid rgba(74,143,109,0.4);
    color: var(--cream-100);
    padding: 12px 16px;
    border-radius: var(--r-md);
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    line-height: 1.7;
  }
  .self-booking-banner strong { color: var(--emerald); }
  .self-booking-banner a {
    color: var(--gold-300);
    text-decoration: none;
    margin-left: 8px;
    border-bottom: 1px dotted var(--gold-300);
  }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-grid label { display: flex; flex-direction: column; gap: 6px; }
  .form-grid label.wide { grid-column: span 2; }
  .form-grid label span { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); }
  .form-grid select, .form-grid textarea, .form-grid .input { background: var(--ink-850); border: 1px solid var(--ink-500); border-radius: var(--r-md); padding: 13px 14px; color: var(--cream-200); font-family: var(--font-sans); font-size: 13.5px; outline: none; transition: border-color var(--dur-fast); }
  .form-grid select:focus, .form-grid textarea:focus, .form-grid .input:focus { border-color: var(--gold-300); box-shadow: 0 0 0 3px rgba(212,175,55,0.12); }
  .form-grid textarea { min-height: 78px; resize: vertical; font-family: var(--font-sans); }
  .form-grid .submit-row { grid-column: span 2; display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-top: 12px; }
  .form-grid .submit-row .agree { font-size: 11.5px; color: var(--ink-200); line-height: 1.55; flex: 1; }
  .form-grid .submit-row .agree a { color: var(--gold-300); }

  .lockin { margin-top: 16px; padding: 14px 16px; background: rgba(212,175,55,0.05); border: 1px solid rgba(212,175,55,0.25); border-radius: var(--r-md); display: flex; align-items: center; gap: 12px; font-size: 12px; color: var(--cream-200); line-height: 1.5; }
  .lockin svg { width: 18px; height: 18px; flex-shrink: 0; stroke: var(--gold-300); fill: none; stroke-width: 1.5; }
  .lockin strong { color: var(--gold-300); }

  /* Booking success state */
  .booking-success { background: radial-gradient(80% 80% at 50% 0%, rgba(74,143,109,0.10), transparent 70%), var(--ink-900); border: 1px solid var(--emerald); border-radius: var(--r-xl); padding: 64px 56px; text-align: center; }
  .booking-success__check { width: 64px; height: 64px; margin: 0 auto 24px; border-radius: 50%; border: 1.5px solid var(--emerald); display: grid; place-items: center; background: rgba(74,143,109,0.1); }
  .booking-success__check svg { width: 28px; height: 28px; stroke: var(--emerald); fill: none; stroke-width: 2; }
  .booking-success h2 { font-family: var(--font-display); font-size: 44px; color: var(--cream-100); margin: 0 0 16px; font-weight: 400; letter-spacing: -0.015em; line-height: 1.05; }
  .booking-success h2 em { font-style: italic; color: var(--gold-300); }
  .booking-success p { color: var(--ink-100); font-size: 15px; line-height: 1.65; margin: 0 auto 32px; max-width: 540px; }
  .booking-success__no { font-family: var(--font-mono); font-size: 13px; color: var(--gold-300); letter-spacing: 0.14em; padding: 14px 20px; border: 1px solid var(--gold-300); border-radius: var(--r-md); display: inline-block; margin: 16px 0 32px; }
  .booking-success__details { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: var(--hairline-soft); border-bottom: var(--hairline-soft); padding: 24px 0; margin: 32px 0; }
  .booking-success__details > div { border-right: var(--hairline-soft); padding: 0 16px; }
  .booking-success__details > div:last-child { border-right: 0; }
  .booking-success__details .l { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-300); margin-bottom: 6px; }
  .booking-success__details .v { font-family: var(--font-display); font-size: 20px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.005em; }
  .form-error { grid-column: span 2; padding: 12px 16px; background: var(--ruby-soft); border: 1px solid var(--ruby); border-radius: var(--r-md); color: #E69089; font-size: 13px; margin-top: 12px; }

  /* TRUST */
  .trust { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; border-top: var(--hairline-soft); border-bottom: var(--hairline-soft); padding: 28px 0; margin-top: 56px; }
  .trust > div { text-align: center; border-right: var(--hairline-soft); padding: 8px 16px; }
  .trust > div:last-child { border-right: 0; }
  .trust .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-300); letter-spacing: 0.16em; text-transform: uppercase; }
  .trust .v { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); font-weight: 500; margin-top: 6px; letter-spacing: -0.005em; }

  /* FAQ */
  .faq details { border-top: var(--hairline-soft); padding: 24px 0; }
  .faq details:last-child { border-bottom: var(--hairline-soft); }
  .faq summary { list-style: none; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-family: var(--font-display); font-size: 22px; color: var(--cream-100); font-weight: 500; letter-spacing: -0.005em; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; font-family: var(--font-display); color: var(--gold-300); font-size: 28px; line-height: 1; transition: transform var(--dur-mid); }
  .faq details[open] summary::after { content: "—"; }
  .faq details p { color: var(--ink-100); font-size: 14px; line-height: 1.65; margin: 16px 0 0; max-width: 720px; }

  /* FINAL */
  .final { text-align: center; padding: 128px 32px; border-top: var(--hairline-soft); position: relative; overflow: hidden; }
  .final::before { content: ""; position: absolute; inset: 0; background: radial-gradient(50% 70% at 50% 100%, rgba(212,175,55,0.10), transparent 70%); pointer-events: none; }
  .final__quote { font-family: var(--font-arabic); font-size: 52px; color: var(--gold-200); direction: rtl; line-height: 1.5; margin: 0; }
  .final h2 { font-family: var(--font-display); font-size: clamp(48px, 7vw, 96px); line-height: 0.95; font-weight: 400; color: var(--cream-100); margin: 32px 0 24px; letter-spacing: -0.02em; }
  .final h2 em { font-style: italic; color: var(--gold-300); }
  .final p { max-width: 560px; margin: 0 auto 48px; color: var(--ink-100); font-size: 16px; line-height: 1.6; }
  .final__ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* FOOTER */
  .foot { border-top: var(--hairline-soft); padding: 36px 32px; max-width: 1280px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.06em; }

  /* STICKY */
  .stick { position: fixed; bottom: 24px; left: 50%; transform: translate(-50%, 24px); z-index: 100; background: radial-gradient(120% 80% at 0% 0%, rgba(212,175,55,0.08), transparent 60%), rgba(17,16,14,0.95); backdrop-filter: blur(20px); border: 1px solid var(--gold-300); border-radius: var(--r-full); padding: 12px 14px 12px 26px; display: flex; align-items: center; gap: 24px; box-shadow: var(--shadow-lg), var(--glow-gold); opacity: 0; transition: all var(--dur-slow) var(--ease-out); pointer-events: none; }
  .stick.is-visible { opacity: 1; transform: translate(-50%, 0); pointer-events: auto; }
  .stick__price { display: flex; flex-direction: column; gap: 2px; }
  .stick__price .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-300); letter-spacing: 0.14em; text-transform: uppercase; }
  .stick__price .v { font-family: var(--font-display); font-size: 22px; color: var(--gold-300); line-height: 1; font-weight: 500; }
  .stick__divider { width: 1px; height: 30px; background: var(--ink-500); }
  .stick__agent { display: flex; align-items: center; gap: 10px; }
  .stick__avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--ink-700), var(--ink-900)); border: 1px solid var(--gold-300); display: grid; place-items: center; font-family: var(--font-display); font-size: 14px; color: var(--gold-300); }
  .stick__agent .who { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; }
  .stick__agent .name { font-size: 13px; color: var(--cream-200); }

  @media (max-width: 980px) {
    .hero__grid, .hotels, .scheme, .booking, .incl, .pricing, .day, .form-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero__crest { display: none; }
    .highlights, .trust, .booking-success__details { grid-template-columns: repeat(2, 1fr); }
    .highlight, .trust > div, .booking-success__details > div { border-right: 0; border-bottom: var(--hairline-soft); }
    .section__head { grid-template-columns: 1fr; gap: 20px; }
    .timeline { padding-left: 32px; }
    .day::before { left: -20px; }
    .pay-grid { grid-template-columns: repeat(2, 1fr); }
    .nav__links { display: none; }
    .nav__inner { grid-template-columns: auto auto; }
    .booking { padding: 32px; }
    .stick { left: 12px; right: 12px; transform: translateY(24px); width: auto; flex-wrap: wrap; justify-content: center; }
    .stick.is-visible { transform: translateY(0); }
  }
</style>
</head>
<%
  // Helpers in template scope
  const hotelMadinah = paket.hotels.find(h => h.city === 'MADINAH');
  const hotelMekkah  = paket.hotels.find(h => h.city === 'MEKKAH');
  const hotelPlus    = paket.hotels.filter(h => h.city !== 'MADINAH' && h.city !== 'MEKKAH' && h.city !== 'JEDDAH' && h.city !== 'JAKARTA');
  const minPrice = paket.prices.reduce((m, p) => (m == null || Number(p.priceIdr) < m ? Number(p.priceIdr) : m), null);
  const kursiSisa = paket.kursiTotal - paket.kursiTerisi;
  const KELAS_LABEL = { QUAD: 'Quad', TRIPLE: 'Triple', DOUBLE: 'Double', VVIP: 'VVIP Suite' };
  const stars = (n) => '★'.repeat(Math.max(0, Math.min(5, n)));
%>
<body data-screen-label="06 Paket Detail · Live">

<!-- RIBBON -->
<div class="ribbon">
  <div class="ribbon__inner">
    <div class="ribbon__left">
      <span class="ribbon__dot"></span>
      <% if (agent) { %>
        <span>Halaman ini dibuatkan untuk Anda oleh agen tersertifikasi RELIGIO PRO</span>
      <% } else { %>
        <span>Halaman resmi paket Religio Pro</span>
      <% } %>
    </div>
    <div class="ribbon__url">religio.pro/p/<%= paket.slug %><% if (agent) { %> <em>?a=<%= agent.slug %></em><% } %></div>
  </div>
</div>

<!-- NAV -->
<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="brand-mark">
      <span class="brand-mark__glyph">R</span>
      <span class="brand-mark__name">Religio <em>Pro</em></span>
    </a>
    <div class="nav__links">
      <a href="#hotel">Hotel</a>
      <a href="#itinerary">Rute</a>
      <a href="#harga">Harga</a>
      <a href="#termasuk">Termasuk</a>
      <a href="#bayar">Pembayaran</a>
      <a href="#daftar">Daftar</a>
    </div>
    <div class="nav__price">
      <div>
        <span class="amount"><span class="from">Mulai</span>Rp <%= fmt.rpShort(minPrice) %></span>
      </div>
      <%# Stage 356 — Web Share button. Hidden by default; JS feature-detect
          flips it visible when navigator.share is available. Preserves
          ?a=<agentSlug> attribution so referral credit follows the share. %>
      <button type="button" id="rp-paket-share-btn" data-paket-slug="<%= paket.slug %>" data-paket-title="<%= paket.title %>" data-agent-slug="<%= agent ? agent.slug : '' %>" style="display:none;background:transparent;color:var(--gold-300);border:1px solid var(--gold-300);padding:6px 12px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;margin-right:8px;">📤 Bagikan</button>
      <a class="btn btn--primary btn--sm" href="#daftar">Pesan</a>
    </div>
  </div>
</nav>
<script>
  // Stage 356 — Web Share API integration for paket landing. Feature-detected;
  // hidden when navigator.share is absent (most desktop browsers). Native
  // share sheet routes through WhatsApp / SMS / email / etc depending on OS.
  // URL preserves the agent slug so referral attribution stays intact.
  (function () {
    if (typeof navigator === 'undefined' || typeof navigator.share !== 'function') return;
    const btn = document.getElementById('rp-paket-share-btn');
    if (!btn) return;
    btn.style.display = 'inline-block';
    btn.addEventListener('click', async () => {
      const slug = btn.getAttribute('data-paket-slug');
      const title = btn.getAttribute('data-paket-title') || 'Paket Religio Pro';
      const agent = btn.getAttribute('data-agent-slug') || '';
      const origin = window.location.origin;
      const path = '/p/' + encodeURIComponent(slug) + (agent ? '?a=' + encodeURIComponent(agent) : '');
      const shareUrl = origin + path;
      try {
        await navigator.share({
          title: 'Religio Pro — ' + title,
          text: 'Lihat paket umroh ' + title + ' di Religio Pro.',
          url: shareUrl,
        });
      } catch (err) {
        // AbortError = user dismissed; silent. Other errors logged but harmless.
        if (err && err.name !== 'AbortError') console.warn('[paket-share]', err);
      }
    });
  })();
</script>

<!-- HERO -->
<section class="hero">

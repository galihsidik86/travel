  <div class="hotels">
    <% if (hotelMadinah) { %>
    <article class="hotel hotel--madinah">
      <div class="hotel__visual">
        <div class="crescent">ﷲ</div>
        <div class="skyline">
          <svg viewBox="0 0 800 140" preserveAspectRatio="none">
            <path d="M0,140 L0,90 L40,90 L40,72 L70,72 L70,90 L100,90 L100,60 L140,60 L140,46 L170,46 L170,60 L210,60 L210,82 L260,82 L260,42 L280,30 L300,42 L300,82 L350,82 L350,52 L380,52 L380,38 L420,38 L420,52 L460,52 L460,76 L520,76 L520,48 L560,48 L560,34 L600,34 L600,48 L640,48 L640,70 L700,70 L700,84 L760,84 L760,96 L800,96 L800,140 Z"/>
            <path d="M260,42 L280,18 L300,42" fill="rgba(74,143,109,0.4)"/>
          </svg>
        </div>
      </div>
      <div class="hotel__meta">
        <div class="hotel__row">
          <h3 class="hotel__name"><%= hotelMadinah.name %></h3>
          <span class="hotel__city">Madinah</span>
        </div>
        <% if (hotelMadinah.description) { %><p class="hotel__desc"><%= hotelMadinah.description %></p><% } %>
        <div class="hotel__specs">
          <div><span class="l">Bintang</span><span class="v stars"><%= stars(hotelMadinah.stars) %></span></div>
          <% if (hotelMadinah.distance) { %><div><span class="l">Jarak Nabawi</span><span class="v"><%= hotelMadinah.distance %></span></div><% } %>
          <div><span class="l">Lama menginap</span><span class="v"><%= hotelMadinah.nights %> malam</span></div>
        </div>
      </div>
    </article>
    <% } %>

    <% if (hotelMekkah) { %>
    <article class="hotel hotel--mekkah">
      <div class="hotel__visual">
        <div class="crescent">ﷺ</div>
        <div class="skyline">
          <svg viewBox="0 0 800 140" preserveAspectRatio="none">
            <path d="M0,140 L0,100 L60,100 L60,80 L100,80 L100,60 L140,60 L140,42 L180,42 L180,30 L200,12 L220,30 L220,42 L260,42 L260,68 L320,68 L320,28 L340,12 L360,28 L360,68 L420,68 L420,50 L460,50 L460,68 L520,68 L520,86 L580,86 L580,60 L640,60 L640,86 L720,86 L720,100 L800,100 L800,140 Z"/>
            <path d="M180,30 L200,8 L220,30" fill="rgba(212,175,55,0.4)"/>
            <path d="M320,28 L340,4 L360,28" fill="rgba(212,175,55,0.5)"/>
          </svg>
        </div>
      </div>
      <div class="hotel__meta">
        <div class="hotel__row">
          <h3 class="hotel__name"><%= hotelMekkah.name %></h3>
          <span class="hotel__city">Mekkah</span>
        </div>
        <% if (hotelMekkah.description) { %><p class="hotel__desc"><%= hotelMekkah.description %></p><% } %>
        <div class="hotel__specs">
          <div><span class="l">Bintang</span><span class="v stars"><%= stars(hotelMekkah.stars) %></span></div>
          <% if (hotelMekkah.distance) { %><div><span class="l">Jarak Haram</span><span class="v"><%= hotelMekkah.distance %></span></div><% } %>
          <div><span class="l">Lama menginap</span><span class="v"><%= hotelMekkah.nights %> malam</span></div>
        </div>
      </div>
    </article>
    <% } %>
  </div>
</section>

<!-- ITINERARY -->
<% if (paket.days.length) { %>
<section class="section" id="itinerary">
  <div class="section__head">
    <div>
      <p class="eyebrow">02 · Rute perjalanan</p>
      <h2><%= paket.durationDays %> hari,<br>satu <em>panggilan suci.</em></h2>
    </div>
    <p>Setiap hari dirancang dengan ritme yang seimbang — ibadah inti pada waktu utama, ziarah pada saat suhu paling teduh, dan istirahat yang cukup untuk para sepuh.</p>
  </div>

  <ol class="timeline">
    <% paket.days.forEach((day) => { %>
      <li class="day<%= day.highlight ? ' day--highlight' : '' %>">
        <div>
          <% if (day.dayRange) { %><div class="day__num"><%= day.dayRange %></div><% } %>
          <div class="day__date"><%= day.dateLabel || day.dayNumber %><% if (day.monthLabel) { %><span class="month"><%= day.monthLabel %></span><% } %></div>
        </div>
        <div>
          <h3 class="day__title"><%- day.title.replace(/(→|—|·)/g, '<em>$1</em>') %></h3>
          <p class="day__desc"><%= day.description %></p>
          <% if (Array.isArray(day.tags) && day.tags.length) { %>
            <div class="day__tags">
              <% day.tags.forEach((t, i) => { %>
                <span class="tag<%= i === 0 && day.highlight ? ' tag--gold' : '' %>"><%= t %></span>
              <% }) %>
            </div>
          <% } %>
        </div>
        <% if (day.pembimbingNote) { %>
        <div>
          <h4 class="day__pembi-title"><%= day.pembimbingTitle || 'Catatan Pembimbing' %></h4>
          <p class="day__desc"><%= day.pembimbingNote %></p>
        </div>
        <% } else { %>
        <div></div>
        <% } %>
      </li>
    <% }) %>
  </ol>
</section>
<% } %>

<!-- PRICING -->
<section class="section" id="harga">
  <div class="section__head">
    <div>
      <p class="eyebrow">03 · Harga &amp; Kelas Kamar</p>
      <h2>Empat kelas.<br>Satu <em>standar VVIP.</em></h2>
    </div>
    <p>Harga termasuk visa, tiket pesawat PP, hotel sesuai kelas, makan 3x/hari di Saudi, transportasi AC penuh, muthawwif tetap, dan perlengkapan lengkap.</p>
  </div>

  <div class="pricing">
    <% paket.prices.forEach((p) => { %>
      <div class="price-card<%= p.isFeatured ? ' price-card--feature' : '' %>">
        <% if (p.isFeatured) { %><span class="price-card__crown">Most Popular</span><% } %>
        <div class="price-card__class"><%= KELAS_LABEL[p.kelas] %></div>
        <h3 class="price-card__name"><%= p.label || KELAS_LABEL[p.kelas] %></h3>
        <% if (p.caption) { %><p class="price-card__per"><%= p.caption %></p><% } %>
        <div class="price-card__amount">
          <span class="ccy">IDR</span>
          <span class="v"><%= Math.round(Number(p.priceIdr) / 1_000_000) %></span>
          <span class="u">JT</span>
        </div>
        <% if (p.cicilanIdr && p.cicilanMonths) { %>
        <div class="price-card__cicilan"><strong>Rp <%= fmt.rpShort(p.cicilanIdr) %></strong> / <%= p.cicilanMonths %>× cicilan 0%</div>
        <% } %>
        <% if (Array.isArray(p.perks)) { %>
        <ul>
          <% p.perks.forEach((perk) => { %><li><%= perk %></li><% }) %>
        </ul>
        <% } %>
        <a class="btn <%= p.isFeatured ? 'btn--primary' : 'btn--ghost' %>" href="#daftar" data-prefill-kelas="<%= p.kelas %>">Pilih <%= KELAS_LABEL[p.kelas] %></a>
      </div>
    <% }) %>
  </div>
</section>

<!-- INCLUSIONS -->
<% if (Array.isArray(paket.inclusions) || Array.isArray(paket.exclusions)) { %>
<section class="section" id="termasuk">
  <div class="section__head">
    <div>
      <p class="eyebrow">04 · Transparansi penuh</p>
      <h2>Apa yang termasuk,<br>apa yang <em>tidak.</em></h2>
    </div>
    <p>Daftar lengkap, tanpa biaya tersembunyi. Semua yang Anda butuhkan untuk fokus pada ibadah sudah disiapkan; sisanya jelas di awal.</p>
  </div>

  <div class="incl">
    <% if (Array.isArray(paket.inclusions)) { %>
    <div class="incl-col incl-col--yes">
      <h3>Termasuk dalam harga <span class="badge badge--gold"><%= paket.inclusions.length %> item</span></h3>
      <ul>
        <% paket.inclusions.forEach((item) => { %><li><%= item %></li><% }) %>
      </ul>
    </div>
    <% } %>
    <% if (Array.isArray(paket.exclusions)) { %>
    <div class="incl-col incl-col--no">
      <h3>Tidak termasuk <span class="badge badge--ruby"><%= paket.exclusions.length %> item</span></h3>
      <ul>
        <% paket.exclusions.forEach((item) => { %><li><%= item %></li><% }) %>
      </ul>
    </div>
    <% } %>
  </div>
</section>
<% } %>

<!-- PAYMENT SCHEME -->
<section class="section" id="bayar">
  <div class="section__head">
    <div>
      <p class="eyebrow">05 · Skema pembayaran</p>
      <h2>DP, cicilan,<br>atau <em>pelunasan.</em></h2>
    </div>
    <p>Pilih ritme yang nyaman. Pembayaran terkonfirmasi otomatis di aplikasi — tanpa foto bukti transfer, tanpa drama.</p>
  </div>

  <div class="scheme">
    <ol class="scheme__steps">
      <li><div><h4>Booking fee</h4><p>Mengunci kursi Anda di manifes. Refundable 100% sampai 60 hari sebelum keberangkatan.</p><span class="due">IDR 5 Jt · saat daftar</span></div></li>
      <li><div><h4>DP minimum</h4><p>Setoran awal yang memastikan posisi Anda terjamin. Visa &amp; tiket mulai diproses.</p><span class="due">IDR 25 Jt · H-150</span></div></li>
      <li><div><h4>Cicilan bulanan</h4><p>Auto-debet via Payment Gateway resmi. Notifikasi WhatsApp 3 hari sebelum jatuh tempo.</p><span class="due">12× cicilan 0%</span></div></li>
      <li><div><h4>Pelunasan akhir</h4><p>Pelunasan paling lambat 30 hari sebelum keberangkatan. Status di app otomatis <strong style="color:var(--gold-300);">LUNAS</strong>.</p><span class="due">H-30 · sebelum berangkat</span></div></li>
    </ol>

    <div class="pay-methods">
      <h4>Metode pembayaran resmi</h4>
      <p class="lede">Terhubung Payment Gateway tersertifikasi OJK. Konfirmasi otomatis &amp; instan — tidak perlu kirim bukti transfer.</p>
      <div class="pay-grid">
        <div class="pay-tile"><span class="l">Virtual Account</span><span class="v">VA <em>Bank</em></span></div>
        <div class="pay-tile"><span class="l">QR Code Nasional</span><span class="v">QRIS</span></div>
        <div class="pay-tile"><span class="l">E-Wallet</span><span class="v">OVO · <em>GoPay</em></span></div>
        <div class="pay-tile"><span class="l">E-Wallet</span><span class="v">DANA · <em>ShopeePay</em></span></div>
        <div class="pay-tile"><span class="l">Credit Card</span><span class="v">Visa / <em>Master</em></span></div>
        <div class="pay-tile"><span class="l">Cicilan 0%</span><span class="v">12 / <em>24 bulan</em></span></div>
      </div>
    </div>
  </div>
</section>

<!-- BOOKING -->
<section class="section" id="daftar">
  <div id="booking-mount">
    <div class="booking">
      <div class="booking__left">
        <p class="eyebrow">06 · Daftar via halaman ini</p>
        <h2>Kunci kursi <em>Anda</em><br>dalam 90 detik.</h2>
        <% if (agent) { %>
          <p>Isi form di samping — tim CS akan mengkonfirmasi dalam 1 jam kerja. Anda akan terdaftar otomatis di bawah agen <strong style="color:var(--gold-300);"><%= agent.displayName %></strong>.</p>
          <div class="lockin">
            <svg viewBox="0 0 24 24"><rect x="5" y="10" width="14" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
            <div><strong>Auto-Agent Lock-in.</strong> Pendaftaran via halaman ini otomatis terhubung dengan agen Anda — komisi terlacak transparan di sistem.</div>
          </div>
        <% } else { %>
          <p>Isi form di samping — tim CS akan mengkonfirmasi dalam 1 jam kerja.</p>
        <% } %>

        <div class="booking__assure">
          <div><span class="l">Garansi refund</span><span class="v">Booking fee 100% kembali jika batal H-60</span></div>
          <div><span class="l">Data dienkripsi</span><span class="v">AES-256 · sesuai UU PDP Indonesia</span></div>
          <div><span class="l">Izin resmi</span><span class="v">SISKOPATUH · Kemenag · AMPHURI</span></div>
          <div><span class="l">Respon CS</span><span class="v">Konfirmasi maks 1 jam kerja (08–22)</span></div>
        </div>
      </div>

      <% if (currentUser && currentUser.role === 'JEMAAH' && prefillJemaah) { %>
        <div class="self-booking-banner" id="self-banner">
          <strong>Login sebagai <%= currentUser.email %></strong> — booking ini akan otomatis terhubung ke akun Anda.
          <a href="#" id="switch-other">Booking untuk orang lain?</a>
        </div>
      <% } %>

      <%# Stage 289 — inquiry success / error flash %>
      <% if (query?.inquiry === 'sent') { %>
        <div style="margin-bottom:14px;padding:12px 16px;background:rgba(80,176,113,0.10);border:1px solid var(--emerald);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:12px;color:var(--emerald);">
          ✓ Inquiry Anda terkirim — tim kami akan menghubungi via WA dalam 24 jam.
        </div>
      <% } else if (query?.inquiry === 'err') { %>
        <div style="margin-bottom:14px;padding:12px 16px;background:rgba(212,89,89,0.10);border:1px solid var(--ruby);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:12px;color:var(--ruby);">
          ✕ <%= query?.msg || 'Gagal kirim inquiry' %>
        </div>
      <% } %>

      <form id="booking-form" class="form-grid" novalidate>
        <input type="hidden" name="paketSlug" value="<%= paket.slug %>">
        <% if (agent) { %><input type="hidden" name="agentSlug" value="<%= agent.slug %>"><% } %>

        <label>
          <span>Nama lengkap (sesuai paspor)</span>
          <input class="input" name="fullName" required placeholder="Mis. Ahmad Fauzi" minlength="2" maxlength="190"
                 value="<%= prefillJemaah ? prefillJemaah.fullName : '' %>" />
        </label>
        <label>
          <span>WhatsApp aktif</span>
          <input class="input" name="phone" required placeholder="0812-XXXX-XXXX" minlength="8" maxlength="30" inputmode="tel"
                 value="<%= prefillJemaah ? prefillJemaah.phone : '' %>" />
        </label>
        <label>
          <span>Kelas kamar</span>
          <select name="kelas" required>
            <% paket.prices.forEach((p) => { %>
              <option value="<%= p.kelas %>"<%= p.isFeatured ? ' selected' : '' %>>
                <%= KELAS_LABEL[p.kelas] %> — Rp <%= fmt.rpShort(p.priceIdr) %><%= p.isFeatured ? ' (Paling populer)' : '' %>
              </option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Jumlah jemaah</span>
          <select name="paxCount">
            <option value="1">1 jemaah</option>
            <option value="2">2 jemaah (pasangan)</option>
            <option value="3">3-4 jemaah (keluarga)</option>
            <option value="5">5+ jemaah (rombongan)</option>
          </select>
        </label>
        <label class="wide">
          <span>Catatan khusus (opsional)</span>
          <textarea name="notes" maxlength="2000" placeholder="Mis: lansia perlu kursi roda, alergi makanan, request sekamar dengan saudara, dll."></textarea>
        </label>
        <div id="form-error-mount"></div>
        <% if (kursiSisa <= 0) { %>
          <div style="background:rgba(212,175,55,0.06); border:1px solid rgba(212,175,55,0.35); border-radius:var(--r-sm); padding:12px 14px; margin-bottom:12px; font-size:12.5px; color:var(--cream-100);">
            <strong style="color:var(--gold-300);">Paket ini sudah PENUH.</strong> Anda akan masuk ke <em>waitlist</em> — kami hubungi saat ada kursi kosong (umumnya dari cancel/refund).
          </div>
        <% } %>
        <div class="submit-row">
          <span class="agree">Dengan mendaftar, saya menyetujui <a href="#">Syarat &amp; Ketentuan</a> dan <a href="#">Kebijakan Privasi UU PDP</a>.</span>
          <%
            // Stage 52 — variant-aware CTA. `ctaText` is passed from the
            // route; defaults to "Kunci kursi saya →" preserved when no
            // variant is set, so existing paket without A/B copy don't
            // suddenly read "BOOK SEKARANG".
            const ctaDefault = kursiSisa <= 0 ? 'Daftar waitlist →' : 'Kunci kursi saya →';
            const ctaLabel = (typeof ctaText !== 'undefined' && ctaText && ctaText !== 'BOOK SEKARANG')
              ? (kursiSisa <= 0 ? 'Daftar waitlist →' : ctaText) // waitlist label always wins when full
              : ctaDefault;
          %>
          <button class="btn btn--primary btn--lg" type="submit" id="booking-submit"
                  data-full="<%= kursiSisa <= 0 ? '1' : '0' %>"
                  data-cta-default="<%= ctaDefault %>">
            <%= ctaLabel %>
          </button>
        </div>
      </form>

      <%# Stage 289 — low-friction inquiry form. For visitors not ready
          to book; gives admins/agents a lead path without commit. %>
      <details style="margin-top:20px;border-top:1px solid var(--hairline-soft);padding-top:18px;">
        <summary style="cursor:pointer;font-family:var(--font-mono);font-size:12px;color:var(--gold-300);letter-spacing:0.06em;text-align:center;">💬 Belum siap booking? Tanya dulu — admin akan WA Anda</summary>
        <form method="POST" action="/api/inquiry" style="margin-top:14px;display:flex;flex-direction:column;gap:10px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="paketSlug" value="<%= paket.slug %>">
          <% if (agent) { %><input type="hidden" name="agentSlug" value="<%= agent.slug %>"><% } %>
          <input class="input" name="fullName" required minlength="2" maxlength="190" placeholder="Nama Anda"
                 value="<%= prefillJemaah ? prefillJemaah.fullName : '' %>">
          <input class="input" name="phone" required minlength="8" maxlength="30" inputmode="tel" placeholder="WhatsApp (0812-XXXX-XXXX)"
                 value="<%= prefillJemaah ? prefillJemaah.phone : '' %>">
          <input class="input" name="email" type="email" maxlength="190" placeholder="Email (opsional)">
          <textarea class="input" name="message" rows="3" maxlength="2000" placeholder="Pertanyaan / kebutuhan khusus (opsional)"></textarea>
          <button type="submit" class="btn btn--outline-gold" style="margin-top:4px;">📩 Kirim inquiry</button>
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);text-align:center;">
            Admin akan menghubungi via WhatsApp dalam 24 jam. Tidak ada komitmen.
          </div>
        </form>
      </details>
    </div>
  </div>

  <!-- Trust strip -->
  <% if (Array.isArray(paket.trustBadges) && paket.trustBadges.length) { %>
  <div class="trust">
    <% paket.trustBadges.forEach((b) => { %>
      <div><div class="l"><%= b.label %></div><div class="v"><%= b.value %></div></div>
    <% }) %>
  </div>
  <% } %>

  <!-- Stage 71 — public crew profiles for assigned muthawif -->
  <% if (typeof publicCrew !== 'undefined' && publicCrew.length > 0) { %>
  <div class="crew-strip">
    <div class="crew-strip__title">Ditemani <em>tim berpengalaman</em></div>
    <div class="crew-strip__grid">
      <% publicCrew.forEach(function(c) { %>
        <a class="crew-card" href="/c/<%= c.crew.slug %>">
          <% if (c.crew.photoUrl) { %>
            <img class="crew-card__photo" src="<%= c.crew.photoUrl %>" alt="<%= c.fullName %>" loading="lazy">
          <% } else { %>
            <div class="crew-card__photo crew-card__placeholder">🧑‍🏫</div>
          <% } %>
          <div class="crew-card__name">
            <%= c.crew.titlePrefix ? c.crew.titlePrefix + ' ' : '' %><%= c.fullName %>
          </div>
          <div class="crew-card__arrow">Profil →</div>
        </a>
      <% }) %>
    </div>
  </div>
  <style>
    .crew-strip { margin: 36px auto 0; max-width: 1080px; padding: 0 24px; }
    .crew-strip__title { font-family: var(--font-display); font-size: 24px; font-weight: 500; color: var(--cream-100); margin: 0 0 18px; letter-spacing: -0.01em; }
    .crew-strip__title em { font-style: italic; color: var(--gold-300); }
    .crew-strip__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
    .crew-card { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 16px; text-align: center; text-decoration: none; color: var(--cream-100); transition: border-color 0.15s; }
    .crew-card:hover { border-color: var(--gold-300); }
    .crew-card__photo { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; }
    .crew-card__placeholder { display: flex; align-items: center; justify-content: center; background: var(--ink-1000); border: 1px dashed var(--ink-700); font-size: 28px; color: var(--ink-300); }
    .crew-card__name { font-family: var(--font-mono); font-size: 11.5px; color: var(--cream-100); letter-spacing: 0.04em; }
    .crew-card__arrow { font-family: var(--font-mono); font-size: 10px; color: var(--gold-300); margin-top: 6px; letter-spacing: 0.08em; }
  </style>
  <% } %>

  <!-- Stage 63 — testimonials (PUBLISHED only, paket-specific OR generic) -->
  <% if (typeof testimonials !== 'undefined' && testimonials.length > 0) { %>
  <div class="testimonials">
    <h3 class="testimonials__title">Apa kata jemaah <em>kami</em></h3>
    <div class="testimonials__grid">
      <% testimonials.forEach(function(t) { %>
        <div class="testi">
          <div class="testi__rating"><%= '★'.repeat(t.rating) %><span style="color:rgba(255,255,255,0.18);"><%= '☆'.repeat(5 - t.rating) %></span></div>
          <p class="testi__body">"<%= t.body %>"</p>
          <div class="testi__author">
            <% if (t.photoUrl) { %>
              <img class="testi__photo" src="<%= t.photoUrl %>" alt="<%= t.jemaahName %>" loading="lazy">
            <% } %>
            <div>
              <div class="testi__name"><%= t.jemaahName %></div>
              <% if (t.jemaahCity) { %><div class="testi__city"><%= t.jemaahCity %></div><% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</section>

<style>
  .testimonials { margin: 48px auto 0; max-width: 1080px; padding: 0 24px; }
  .testimonials__title { font-family: var(--font-display); font-size: 28px; font-weight: 500; color: var(--cream-100); margin: 0 0 24px; letter-spacing: -0.015em; }
  .testimonials__title em { font-style: italic; color: var(--gold-300); }

<!-- STICKY BAR -->
<div class="stick" id="stick">
  <div class="stick__price">
    <span class="l">Mulai dari</span>
    <span class="v">Rp <%= fmt.rpShort(minPrice) %></span>
  </div>
  <div class="stick__divider"></div>
  <div class="stick__agent">
    <div class="stick__avatar"><%= agent ? agent.displayName.charAt(0) : 'R' %></div>
    <div>
      <div class="who">Dilayani oleh</div>
      <div class="name"><%= agent ? agent.displayName : 'Religio Pro' %></div>
    </div>
  </div>
  <div class="stick__divider"></div>
  <a class="btn btn--primary" href="#daftar">Pesan kursi →</a>
</div>

<script>
  // Sticky bar reveal
  (function () {
    const stick = document.getElementById('stick');
    const hero = document.querySelector('.hero');
    if (!stick || !hero) return;
    const io = new IntersectionObserver(
      ([entry]) => stick.classList.toggle('is-visible', !entry.isIntersecting),
      { threshold: 0.1 }
    );
    io.observe(hero);
  })();

  // Smooth scroll for in-page anchors
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href');
      if (id === '#' || id.length < 2) return;
      const el = document.querySelector(id);
      if (!el) return;
      e.preventDefault();
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Prefill kelas when a pricing CTA is clicked
  document.querySelectorAll('[data-prefill-kelas]').forEach(a => {
    a.addEventListener('click', () => {
      const sel = document.querySelector('select[name="kelas"]');
      if (sel) sel.value = a.dataset.prefillKelas;
    });
  });

  // ── Self-booking: "Booking untuk orang lain?" toggle ────────
  (function () {
    const banner = document.getElementById('self-banner');
    const switchLink = document.getElementById('switch-other');
    if (!banner || !switchLink) return;
    switchLink.addEventListener('click', (e) => {
      e.preventDefault();
      banner.remove(); // remove banner → POST without session = anonymous booking
      const form = document.getElementById('booking-form');
      if (form) {
        form.elements.fullName.value = '';
        form.elements.phone.value = '';
        form.elements.fullName.focus();
      }
      // Note: we still send the cookie, but server-side decides based on form
      // values. To force anonymous, add a hidden flag:
      const flag = document.createElement('input');
      flag.type = 'hidden'; flag.name = 'forceAnonymous'; flag.value = '1';
      form.appendChild(flag);
    });
  })();

  // ── Booking form submission ──────────────────────────────
  (function () {
    const form = document.getElementById('booking-form');
    if (!form) return;
    const submit = document.getElementById('booking-submit');
    const mount = document.getElementById('booking-mount');
    const errMount = document.getElementById('form-error-mount');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errMount.innerHTML = '';
      submit.disabled = true;
      submit.textContent = 'Mengirim…';

      const fd = new FormData(form);
      const payload = {
        paketSlug: fd.get('paketSlug'),
        agentSlug: fd.get('agentSlug') || null,
        fullName: fd.get('fullName')?.toString().trim(),
        phone: fd.get('phone')?.toString().trim(),
        kelas: fd.get('kelas'),
        paxCount: fd.get('paxCount'),
        notes: fd.get('notes')?.toString().trim() || null,
      };

      const isFull = submit.dataset.full === '1';
      const endpoint = isFull ? '/api/waitlist' : '/api/booking';
      const sendPayload = isFull
        ? { paketSlug: payload.paketSlug, fullName: payload.fullName, phone: payload.phone, notes: payload.notes }
        : payload;
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(sendPayload),
        });
        const data = await res.json();
        if (!res.ok) throw data?.error || { message: 'Gagal mengirim. Coba lagi.' };

        // Replace form with success state
        mount.innerHTML = isFull ? renderWaitlistSuccess(data) : renderSuccess(data);
        mount.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        const msg = err?.message || 'Terjadi kesalahan. Coba lagi.';
        const details = err?.details
          ? '<ul style="margin:8px 0 0 18px;padding:0;">' +
            Object.entries(err.details).map(([k, v]) => `<li><strong>${k}:</strong> ${v.join(', ')}</li>`).join('') +
            '</ul>'
          : '';
        errMount.innerHTML = `<div class="form-error">${msg}${details}</div>`;
        submit.disabled = false;
        // Stage 52 — restore variant CTA from data attr instead of
        // hardcoding, so a B-bucketed visitor keeps seeing their variant.
        submit.textContent = isFull
          ? 'Daftar waitlist →'
          : (submit.getAttribute('data-cta-default') || 'Kunci kursi saya →');
      }
    });

    function renderWaitlistSuccess(data) {
      const w = data.waitlist || {};
      return `
        <div class="booking-success">
          <div class="booking-success__check" style="background:rgba(212,175,55,0.12); border-color:var(--gold-300);">
            <svg viewBox="0 0 24 24"><polyline points="4,12 10,18 20,7"/></svg>
          </div>
          <h2>Anda di <em>waitlist.</em></h2>
          <div class="booking-success__no">${w.id ? w.id.slice(-8).toUpperCase() : 'WL-'}</div>
          <p>Kami akan menghubungi Anda via WhatsApp begitu ada kursi yang tersedia (biasanya dari pembatalan).</p>
        </div>`;
    }

    function renderSuccess(data) {
      const b = data.booking;
      const a = data.agent;
      const totalFmt = new Intl.NumberFormat('id-ID', { maximumFractionDigits: 0 }).format(Math.round(Number(b.totalAmount)));
      const agentLine = a
        ? `Konfirmasi akan dikirim ke WhatsApp Anda. Agen <strong style="color:var(--gold-300);">${a.displayName}</strong> juga akan menghubungi Anda dalam 1 jam kerja.`
        : 'Konfirmasi akan dikirim ke WhatsApp Anda dalam 1 jam kerja.';
      return `
        <div class="booking-success">
          <div class="booking-success__check">
            <svg viewBox="0 0 24 24"><polyline points="4,12 10,18 20,7"/></svg>
          </div>
          <h2>Pendaftaran <em>tercatat.</em></h2>
          <div class="booking-success__no">${b.bookingNo}</div>
          <p>${agentLine}</p>
          <div class="booking-success__details">
            <div><div class="l">Kelas</div><div class="v">${b.kelas}</div></div>
            <div><div class="l">Jumlah</div><div class="v">${b.paxCount} pax</div></div>
            <div><div class="l">Total</div><div class="v">Rp ${totalFmt}</div></div>
            <div><div class="l">Status</div><div class="v">${b.status}</div></div>
          </div>
          <p style="font-family:var(--font-mono);font-size:11px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;">Booking fee Rp 5 Jt akan ditagih saat konfirmasi</p>
        </div>`;
    }
  })();
</script>

<!-- Stage 66 — soft conversion modal. Fires once per visitor (localStorage)
     after they scroll past hero AND idle for 30s. WA-first because most
     Indonesian conversions land in chat first, form second. -->
<%
  const agentWA = (typeof agent !== 'undefined' && agent && agent.whatsapp)
    ? agent.whatsapp.replace(/[^0-9]/g, '').replace(/^0/, '62')
    : '6285711234567'; // fallback office number
  const agentName = (typeof agent !== 'undefined' && agent) ? agent.displayName : 'tim Religio Pro';
  const waText = encodeURIComponent(`Halo ${agentName}, saya tertarik dengan paket ${paket.title}. Bisa konsultasi dulu?`);
%>
<div id="conv-modal" class="conv-modal" aria-hidden="true" role="dialog">
  <div class="conv-modal__card">
    <button class="conv-modal__close" type="button" aria-label="Tutup" id="conv-modal-close">×</button>
    <div class="conv-modal__title">Butuh konsultasi dulu?</div>
    <p class="conv-modal__body">
      <%= agentName %> standby di WhatsApp — bisa cek slot, kelas tersisa, atau tanya rincian sebelum daftar.
      Jawaban dalam 30 menit pada jam kerja.
    </p>
    <a class="conv-modal__cta" href="https://wa.me/<%= agentWA %>?text=<%= waText %>" target="_blank" rel="noopener" id="conv-modal-cta">
      💬 Chat WhatsApp sekarang
    </a>
    <div class="conv-modal__dismiss">
      <a href="#" id="conv-modal-later">Nanti saja</a>
    </div>
  </div>
</div>
<style>
  .conv-modal { position: fixed; left: 0; right: 0; bottom: 16px; z-index: 9999; display: none; padding: 0 16px; pointer-events: none; }
  .conv-modal.show { display: flex; justify-content: center; pointer-events: auto; animation: convSlide 0.32s ease-out; }
  @keyframes convSlide { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .conv-modal__card { background: var(--ink-900); border: 1px solid var(--gold-300); border-radius: var(--r-md); padding: 18px 22px; max-width: 380px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.5); position: relative; }
  .conv-modal__close { position: absolute; top: 6px; right: 10px; background: transparent; border: 0; color: var(--ink-200); font-size: 20px; cursor: pointer; line-height: 1; padding: 4px 8px; }
  .conv-modal__close:hover { color: var(--cream-100); }
  .conv-modal__title { font-family: var(--font-display); font-size: 18px; font-weight: 500; color: var(--cream-100); margin-bottom: 8px; }
  .conv-modal__body { font-family: var(--font-body); font-size: 13.5px; line-height: 1.5; color: var(--cream-200); margin: 0 0 16px; }
  .conv-modal__cta { display: block; text-align: center; background: #25D366; color: white; padding: 12px 18px; border-radius: 6px; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; text-decoration: none; transition: filter 0.15s; }
  .conv-modal__cta:hover { filter: brightness(1.1); }
  .conv-modal__dismiss { text-align: center; margin-top: 10px; }
  .conv-modal__dismiss a { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); text-decoration: underline; }
</style>
<script>
  (function() {
    // Stage 66 — guards before wiring:
    //  - 24h cooldown after dismiss (localStorage)
    //  - skip viewports too small (mobile bottom bar collisions)
    const KEY = 'rp_conv_modal_dismissed';
    const COOLDOWN_MS = 24 * 60 * 60 * 1000;
    try {
      const prev = parseInt(localStorage.getItem(KEY) || '0', 10);
      if (prev && Date.now() - prev < COOLDOWN_MS) return;
    } catch {}
    if (window.innerHeight < 500) return;

    const modal = document.getElementById('conv-modal');
    const closeBtn = document.getElementById('conv-modal-close');
    const laterBtn = document.getElementById('conv-modal-later');
    const cta = document.getElementById('conv-modal-cta');
    if (!modal || !closeBtn) return;

    let triggered = false;
    let scrolledPastHero = false;
    let idleTimer = null;

    function dismiss() {
      modal.classList.remove('show');
      modal.setAttribute('aria-hidden', 'true');
      try { localStorage.setItem(KEY, String(Date.now())); } catch {}
    }
    function show() {
      if (triggered) return;
      triggered = true;
      modal.classList.add('show');
      modal.setAttribute('aria-hidden', 'false');
    }
    closeBtn.addEventListener('click', dismiss);
    laterBtn.addEventListener('click', (e) => { e.preventDefault(); dismiss(); });
    cta.addEventListener('click', () => {
      // CTA click = success outcome; suppress next 24h
      try { localStorage.setItem(KEY, String(Date.now())); } catch {}
    });

    // Trigger: scroll past hero (1× viewport) AND idle 30s with no input
    function resetIdle() {
      if (idleTimer) clearTimeout(idleTimer);
      if (!scrolledPastHero) return;
      idleTimer = setTimeout(show, 30_000);
    }
    window.addEventListener('scroll', () => {
      if (window.scrollY > window.innerHeight * 0.8) {
        scrolledPastHero = true;
      }
      resetIdle();
    }, { passive: true });
    // Touch + mouse also count as activity so the modal doesn't fire mid-interaction
    window.addEventListener('touchstart', resetIdle, { passive: true });
    window.addEventListener('mousemove', resetIdle, { passive: true });
  })();
</script>

</body>

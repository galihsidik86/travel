              <span>Instagram · <strong style="color:var(--cream-100);">@<%= agent.igHandle %></strong></span>
            </a>
          <% } %>
        </div>
      <% } else { %>
        <div class="agent-card__contacts" style="margin-top:0;">
          <a href="https://wa.me/6285715690293" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M21 11.5C21 17 16.5 21.5 11 21.5C9.3 21.5 7.7 21 6.3 20.1L3 21L4 17.8C3.1 16.4 2.5 14.7 2.5 12.9C2.5 7.4 7 2.9 12.5 2.9C18 2.9 22.5 7.4 22.5 12.9"/></svg>
            <span>WhatsApp · <strong style="color:var(--cream-100);">0857-1569-0293</strong></span>
          </a>
        </div>
      <% } %>

      <div class="agent-card__price">
        <div>
          <div class="from">Harga mulai</div>
          <div class="amount"><span class="ccy">IDR</span><%= fmt.rpShort(minPrice) %></div>
        </div>
        <div class="agent-card__cta">
          <span class="promo">Cicilan 0% · 12 bulan</span>
          <a class="btn btn--primary btn--lg" href="#daftar">Pesan kursi</a>
        </div>
      </div>
    </aside>
  </div>
</section>

<!-- HIGHLIGHTS -->

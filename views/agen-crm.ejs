<!-- Lead create modal -->
<div class="modal-overlay" id="lead-modal" aria-hidden="true">
  <div class="modal">
    <h2>Tambah Lead Baru</h2>
    <div class="sub" id="lead-modal-sub">Cold</div>

    <div class="err" id="lead-modal-err"></div>

    <form id="lead-form">
      <input type="hidden" name="status" value="COLD">

      <div class="field">
        <label class="label" for="lf-name">Nama lengkap *</label>
        <input class="input" name="fullName" id="lf-name" required maxlength="190">
      </div>
      <div class="field-grid">
        <div class="field">
          <label class="label" for="lf-phone">Telepon / WA *</label>
          <input class="input" name="phone" id="lf-phone" required maxlength="30">

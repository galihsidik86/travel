        <div class="field">
          <label class="label" for="lf-paket">Paket diminati (slug)</label>
          <input class="input" name="interestedPaketSlug" id="lf-paket" placeholder="ramadhan-aqsa-2026">
        </div>
        <div class="field">
          <label class="label" for="lf-kelas">Kelas</label>
          <select class="input" name="interestedKelas" id="lf-kelas">
            <option value="">—</option>
            <option value="QUAD">Quad</option>
            <option value="TRIPLE">Triple</option>
            <option value="DOUBLE">Double</option>
            <option value="VVIP">VVIP</option>
          </select>
        </div>
      </div>
      <div class="field-grid">
        <div class="field">
          <label class="label" for="lf-pax">Est. PAX</label>
          <input class="input" type="number" min="1" max="20" name="estPaxCount" id="lf-pax">
        </div>
        <div class="field">
          <label class="label" for="lf-val">Est. nilai (Rp)</label>
          <input class="input" type="number" min="0" step="100000" name="estValueIdr" id="lf-val">
        </div>
      </div>
      <div class="field">
        <label class="label" for="lf-notes">Catatan</label>
        <input class="input" name="notes" id="lf-notes" maxlength="500" placeholder="Mis. tertarik VVIP keluarga 4 orang">
      </div>

      <div class="actions">
        <button type="button" class="btn btn--ghost" id="lead-cancel">Batal</button>
        <button type="submit" class="btn btn--primary">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Page switcher (with URL ?tab= support so reloads land on same tab)
  const items = document.querySelectorAll('.rail__item[data-page]');
  const pages = document.querySelectorAll('.page');
  const leaf = document.getElementById('crumb-leaf');
  const labels = { leads: 'Leads Pipeline', kit: 'Marketing Kit', wallet: 'Wallet & Komisi', analytics: 'Analitik' };

  function activate(target) {
    if (!labels[target]) return;
    items.forEach((b) => b.classList.toggle('is-active', b.dataset.page === target));
    pages.forEach((p) => p.classList.toggle('is-active', p.id === 'page-' + target));
    if (leaf) leaf.textContent = labels[target];
    const url = new URL(location.href);
    url.searchParams.set('tab', target);
    history.replaceState(null, '', url.toString());
  }

  // Activate from ?tab= on initial load (default: leads)
  (function () {
    const u = new URL(location.href);
    const initial = u.searchParams.get('tab');
    if (initial && labels[initial]) activate(initial);
  })();

  items.forEach((btn) => {
    btn.addEventListener('click', () => activate(btn.dataset.page));
  });

  // Copy buttons
  document.querySelectorAll('button[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const path = btn.dataset.copy;
      const full = location.origin + path;
      try {
        await navigator.clipboard.writeText(full);
        const old = btn.textContent;
        btn.textContent = 'TERSALIN';
        setTimeout(() => (btn.textContent = old), 1200);
      } catch {
        btn.textContent = 'GAGAL';
      }
    });
  });

  // ===== Lead modal =====
  const modal = document.getElementById('lead-modal');
  const modalSub = document.getElementById('lead-modal-sub');
  const modalErr = document.getElementById('lead-modal-err');
  const form = document.getElementById('lead-form');

  function openModal(initialStatus) {
    form.reset();
    form.elements.status.value = initialStatus || 'COLD';
    modalSub.textContent = initialStatus === 'WARM' ? 'Warm' : 'Cold';
    modalErr.classList.remove('is-visible');
    modal.classList.add('is-open');
    setTimeout(() => form.elements.fullName.focus(), 0);
  }
  function closeModal() { modal.classList.remove('is-open'); }

  document.querySelectorAll('[data-add-lead]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.dataset.addLead));
  });
  document.getElementById('lead-cancel').addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    modalErr.classList.remove('is-visible');
    const fd = new FormData(form);
    const body = {};
    for (const [k, v] of fd.entries()) {
      if (v !== '') body[k] = v;
    }
    try {
      const r = await fetch('/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        modalErr.textContent = j?.error?.message || 'Gagal menyimpan lead';
        modalErr.classList.add('is-visible');
        return;
      }
      location.reload();
    } catch {
      modalErr.textContent = 'Tidak dapat menghubungi server';
      modalErr.classList.add('is-visible');
    }
  });

  // ===== Convert modal =====
  const cModal = document.getElementById('convert-modal');
  const cName  = document.getElementById('convert-modal-name');
  const cErr   = document.getElementById('convert-modal-err');
  const cForm  = document.getElementById('convert-form');
  let convertingId = null;

  function openConvert(card) {
    convertingId = card.dataset.leadId;
    cName.textContent = card.dataset.leadName || '—';
    cForm.elements.paketSlug.value = card.dataset.leadPaket || '';
    cForm.elements.kelas.value     = card.dataset.leadKelas || 'QUAD';
    cForm.elements.paxCount.value  = card.dataset.leadPax || 1;
    cForm.elements.notes.value     = card.dataset.leadNotes || '';
    cErr.classList.remove('is-visible');
    cModal.classList.add('is-open');
  }
  function closeConvert() { cModal.classList.remove('is-open'); convertingId = null; }
  document.getElementById('convert-cancel').addEventListener('click', closeConvert);
  cModal.addEventListener('click', (e) => { if (e.target === cModal) closeConvert(); });

  cForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!convertingId) return;
    cErr.classList.remove('is-visible');
    const fd = new FormData(cForm);
    const body = {};
    for (const [k, v] of fd.entries()) {
      if (v !== '') body[k] = v;
    }
    try {
      const r = await fetch('/api/leads/' + convertingId + '/convert', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        cErr.textContent = j?.error?.message || 'Gagal membuat booking';
        cErr.classList.add('is-visible');
        return;
      }
      location.reload();
    } catch {
      cErr.textContent = 'Tidak dapat menghubungi server';
      cErr.classList.add('is-visible');
    }
  });

  // ===== Lead actions: move + delete + convert =====
  document.querySelectorAll('.lead[data-lead-id]').forEach((card) => {
    const id = card.dataset.leadId;
    card.querySelectorAll('[data-move]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        const r = await fetch('/api/leads/' + id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: btn.dataset.move }),
        });
        if (r.ok) location.reload();
        else btn.disabled = false;
      });
    });
    const del = card.querySelector('[data-delete-lead]');
    if (del) {
      del.addEventListener('click', async () => {
        if (!confirm('Hapus lead ini?')) return;
        del.disabled = true;
        const r = await fetch('/api/leads/' + id, { method: 'DELETE' });
        if (r.ok) location.reload();
        else del.disabled = false;
      });
    }
    const conv = card.querySelector('[data-convert-lead]');
    if (conv) {
      conv.addEventListener('click', () => openConvert(card));
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeModal(); closeConvert(); }
  });
</script>
</body>
</html>

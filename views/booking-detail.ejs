  </div>
</div>
<% } %>

<%# Stage 256 — clone modal. CANCEL_ROLES can clone. %>
<% if (canCancel) { %>
<div class="modal-overlay" id="clone-modal" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true">
    <header class="modal__head">
      <h3>Clone booking → jemaah baru</h3>
      <button type="button" class="modal__close" id="clone-close-x" aria-label="Tutup">×</button>
    </header>
    <form method="POST" action="/admin/bookings/<%= b.id %>/clone">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div style="padding:10px 14px;background:rgba(212,175,55,0.04);border:1px solid var(--gold-300);border-radius:var(--r-sm);margin-bottom:14px;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
        Akan kloning paket <strong style="color:var(--gold-300);"><%= b.paket.title %></strong>
        · kelas <strong><%= b.kelas %></strong>
        · agen <strong><%= b.agent?.displayName || 'Kantor Pusat' %></strong>
        <% if (b.groupKey) { %>
          · <strong style="color:var(--gold-300);">grup <%= b.groupKey %></strong>
        <% } else { %>
          · grup baru akan dibuat
        <% } %>
      </div>

      <div class="field">
        <label class="label" for="cf-jname">Nama jemaah baru *</label>
        <input class="input" id="cf-jname" name="newJemaahName" required minlength="2" maxlength="190" autocomplete="off">
      </div>
      <div class="field">
        <label class="label" for="cf-jphone">Telepon jemaah baru *</label>
        <input class="input" id="cf-jphone" name="newJemaahPhone" required maxlength="30" autocomplete="off">
      </div>
      <div class="field">
        <label class="label" for="cf-jemail">Email (opsional)</label>
        <input class="input" type="email" id="cf-jemail" name="newJemaahEmail" maxlength="190" autocomplete="off">
      </div>
      <div class="field">
        <label class="label" for="cf-jnik">NIK (opsional, 16 digit)</label>
        <input class="input" id="cf-jnik" name="newJemaahNik" maxlength="16" pattern="\d{16}" autocomplete="off">
      </div>
      <div class="field">
        <label class="label" for="cf-pax">PAX (default sama dengan source: <%= b.paxCount %>)</label>
        <input class="input" type="number" id="cf-pax" name="paxCount" min="1" max="20" value="<%= b.paxCount %>">
      </div>
      <div class="field">
        <label class="label" for="cf-prefix">Catatan tambahan (opsional)</label>
        <textarea class="input" id="cf-prefix" name="notesPrefix" rows="2" maxlength="500" placeholder="Mis. Istri dari Pak Ahmad"></textarea>
      </div>

      <div class="actions">
        <button type="button" class="btn btn--ghost" id="clone-close">Batal</button>
        <button type="submit" class="btn btn--primary">Buat clone</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script>
  // Stage 256 — clone modal wiring
  (function() {
    const modal = document.getElementById('clone-modal');
    const openBtn = document.getElementById('open-clone');
    const closeX = document.getElementById('clone-close-x');
    const closeB = document.getElementById('clone-close');
    if (!modal || !openBtn) return;
    openBtn.addEventListener('click', () => modal.classList.add('is-open'));
    if (closeX) closeX.addEventListener('click', () => modal.classList.remove('is-open'));
    if (closeB) closeB.addEventListener('click', () => modal.classList.remove('is-open'));
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.remove('is-open');
    });
  })();
</script>

<script>
  // Pay modal — for the booking detail page we redirect to manifest tab + open Pay there.
  // Simplest: open the existing Pay modal in the admin dashboard via querystring trick? For now, just navigate.
  const payBtn = document.getElementById('open-pay');
  if (payBtn) {
    payBtn.addEventListener('click', () => {
      // Trigger the admin manifest tab where Pay modal lives
      location.href = '/admin?tab=manifest&manifestPaket=<%= b.paket.slug %>#pay-<%= b.id %>';
    });
  }

  const cancelBtn = document.getElementById('open-cancel');
  const cancelModal = document.getElementById('cancel-modal');
  const cancelClose = document.getElementById('cancel-close');
  if (cancelBtn && cancelModal) {
    cancelBtn.addEventListener('click', () => {
      cancelModal.classList.add('is-open');
      setTimeout(() => document.getElementById('cf-reason').focus(), 0);
    });
    cancelClose.addEventListener('click', () => cancelModal.classList.remove('is-open'));
    cancelModal.addEventListener('click', (e) => {
      if (e.target === cancelModal) cancelModal.classList.remove('is-open');
    });
  }

  // Refund modal
  const refundBtn = document.getElementById('open-refund');
  const refundModal = document.getElementById('refund-modal');
  const refundClose = document.getElementById('refund-close');
  const refundForm = document.getElementById('refund-form');
  const refundErr = document.getElementById('refund-err');
  if (refundBtn && refundModal) {
    refundBtn.addEventListener('click', () => {
      refundErr.classList.remove('is-visible');
      refundModal.classList.add('is-open');
      setTimeout(() => document.getElementById('rf-reason').focus(), 0);
    });
    refundClose.addEventListener('click', () => refundModal.classList.remove('is-open'));
    refundModal.addEventListener('click', (e) => {
      if (e.target === refundModal) refundModal.classList.remove('is-open');
    });

    // Stage 183 — preset percentage buttons. Computes pct of paid total
    // and floors to integer (refund amount must be a whole Rupiah).
    document.querySelectorAll('.refund-preset').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const wrapper = btn.closest('[data-refund-paid]');
        const paid = Number(wrapper?.dataset?.refundPaid || 0);
        if (!paid) return;
        const pct = Number(btn.dataset.pct || 0);
        const amount = Math.floor(paid * (pct / 100));
        const input = document.getElementById('rf-amount');
        if (input) {
          input.value = amount;
          input.focus();
          input.select();
        }
      });
    });

    refundForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      refundErr.classList.remove('is-visible');
      const fd = new FormData(refundForm);
      const body = {};
      for (const [k, v] of fd.entries()) if (v !== '') body[k] = v;
      try {
        const r = await fetch('/api/refunds', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          refundErr.textContent = j?.error?.message || 'Gagal issue refund';
          refundErr.classList.add('is-visible');
          return;
        }
        location.reload();
      } catch {
        refundErr.textContent = 'Tidak dapat menghubungi server';
        refundErr.classList.add('is-visible');
      }
    });
  }

  // Transfer modal
  const transferBtn = document.getElementById('open-transfer');
  const transferModal = document.getElementById('transfer-modal');
  const transferClose = document.getElementById('transfer-close');
  if (transferBtn && transferModal) {
    transferBtn.addEventListener('click', () => {
      transferModal.classList.add('is-open');
      setTimeout(() => document.getElementById('tf-to').focus(), 0);
    });
    transferClose.addEventListener('click', () => transferModal.classList.remove('is-open'));
    transferModal.addEventListener('click', (e) => {
      if (e.target === transferModal) transferModal.classList.remove('is-open');
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (cancelModal) cancelModal.classList.remove('is-open');
      if (refundModal) refundModal.classList.remove('is-open');
      if (transferModal) transferModal.classList.remove('is-open');
    }
  });

  // ── S82 — @-mention autocomplete on the notes textarea ──────
  (function initMentionAutocomplete() {
    const ta = document.getElementById('notesTextarea');
    const dd = document.getElementById('mentionDropdown');
    if (!ta || !dd) return;

    let activeIdx = 0;
    let rows = [];
    let triggerStart = -1;   // index in textarea where the `@` lives
    let debounceTimer = null;
    let inflight = 0;        // monotonic; stale fetches ignored

    function hide() {
      dd.hidden = true;
      dd.innerHTML = '';
      rows = []; activeIdx = 0; triggerStart = -1;
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
      }[c]));
    }

    function commitPick(idx) {
      const pick = rows[idx];
      if (!pick || triggerStart < 0) return hide();
      const before = ta.value.slice(0, triggerStart);
      // Token spans from triggerStart (the trigger char) through the cursor.
      const after = ta.value.slice(ta.selectionStart);
      // S88 — :code picks insert `:code ` and rely on server-side expansion;
      // @email picks insert the full email. The visible difference helps
      // admins remember which form they used.
      const inserted = pick.code ? (':' + pick.code + ' ') : ('@' + pick.email + ' ');
      ta.value = before + inserted + after;
      const newPos = (before + inserted).length;
      ta.selectionStart = ta.selectionEnd = newPos;
      ta.focus();
      hide();
    }

    function currentTrigger() {
      // Walk back from cursor: capture chars until whitespace or BOF.
      // Returns { start, token, kind } where kind ∈ 'email' | 'code'.
      const pos = ta.selectionStart;
      let i = pos - 1;
      while (i >= 0 && !/\s/.test(ta.value[i])) i -= 1;
      const start = i + 1;
      const head = ta.value[start];
      if (head !== '@' && head !== ':') return null;
      const token = ta.value.slice(start + 1, pos);
      return { start, token, kind: head === '@' ? 'email' : 'code' };
    }

    function render() {
      dd.innerHTML = '';
      if (rows.length === 0) {
        dd.innerHTML = '<div class="mention-dd__empty">— tidak ada cocok —</div>';
        dd.hidden = false;
        return;
      }
      rows.forEach((r, i) => {
        const div = document.createElement('div');
        div.className = 'mention-dd__row' + (i === activeIdx ? ' is-active' : '');
        // S88 — code rows render differently from email rows
        if (r.code) {
          div.innerHTML = '<span><strong>:' + escapeHtml(r.code) + '</strong> · <span class="mention-dd__email">' + escapeHtml(r.user.email) + '</span></span>'
            + '<span class="mention-dd__role">' + escapeHtml(r.user.role) + '</span>';
        } else {
          div.innerHTML = '<span><strong>' + escapeHtml(r.fullName) + '</strong> · <span class="mention-dd__email">' + escapeHtml(r.email) + '</span></span>'
            + '<span class="mention-dd__role">' + escapeHtml(r.role) + '</span>';
        }
        div.addEventListener('mousedown', (ev) => {
          ev.preventDefault();
          commitPick(i);
        });
        dd.appendChild(div);
      });
      dd.hidden = false;
    }

    async function refresh() {
      const trig = currentTrigger();
      if (!trig) return hide();
      triggerStart = trig.start;
      const q = trig.token;
      // S88 — :code lookups can start matching after 1 char (codes are
      // short by design); @email lookups still need 2 to avoid noise.
      const minLen = trig.kind === 'code' ? 1 : 2;
      if (q.length < minLen) {
        rows = []; activeIdx = 0;
        const hint = trig.kind === 'code'
          ? 'ketik kode shortcut…'
          : 'ketik min 2 huruf untuk cari…';
        dd.innerHTML = '<div class="mention-dd__empty">' + hint + '</div>';
        dd.hidden = false;
        return;
      }
      const endpoint = trig.kind === 'code'
        ? '/admin/bookings/shortcode-search'
        : '/admin/bookings/mention-search';
      const reqId = ++inflight;
      try {
        const r = await fetch(endpoint + '?q=' + encodeURIComponent(q), {
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin',
        });
        if (reqId !== inflight) return;
        if (!r.ok) return hide();
        const data = await r.json();
        rows = data.rows || []; activeIdx = 0;
        render();
      } catch (_e) { /* network blip — keep current state */ }
    }

    ta.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(refresh, 120);
    });
    ta.addEventListener('keydown', (e) => {
      if (dd.hidden) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = (activeIdx + 1) % Math.max(rows.length, 1); render(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = (activeIdx - 1 + Math.max(rows.length, 1)) % Math.max(rows.length, 1); render(); }
      else if ((e.key === 'Enter' || e.key === 'Tab') && rows.length > 0) { e.preventDefault(); commitPick(activeIdx); }
      else if (e.key === 'Escape') { e.preventDefault(); hide(); }
    });
    ta.addEventListener('blur', () => setTimeout(hide, 150));  // delay so click on row registers
  })();
</script>
</body>
</html>

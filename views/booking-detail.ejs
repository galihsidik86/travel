    <div class="cancel-note" style="color:var(--ink-100);border-color:rgba(212,175,55,0.3);background:rgba(212,175,55,0.05);">
      <strong style="color:var(--gold-300);">CATATAN:</strong><br>
      • <code>agentSlugCap</code> (URL asal) <strong>tidak diubah</strong> — historical trail aman<br>
      • Komisi PENDING ikut agen baru (atau dihapus kalau ke Kantor Pusat)<br>
      • Komisi EARNED tetap di agen asal kecuali kamu centang opsi di bawah<br>
      • Komisi PAID/CANCELLED tidak disentuh
    </div>

    <form method="POST" action="/admin/bookings/<%= b.id %>/transfer-agent">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="field">
        <label class="label" for="tf-to">Pindahkan ke *</label>
        <select class="input" name="toAgentId" id="tf-to" required>
          <option value="">— Kantor Pusat (hapus agen) —</option>
          <% agents.forEach(function(a) { %>
            <option value="<%= a.id %>" <%= b.agentId === a.id ? 'disabled' : '' %>>
              <%= a.displayName %> (slug: <%= a.slug %>)<%= b.agentId === a.id ? ' — agen saat ini' : '' %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label class="label" for="tf-reason">Alasan transfer *</label>
        <textarea class="input" id="tf-reason" name="reason" required minlength="3" maxlength="2000" rows="3"
                  placeholder="Mis. agen asal resign, permintaan jemaah, dll."></textarea>
      </div>

      <div class="field" style="display:flex;align-items:center;gap:8px;">
        <input type="checkbox" name="includeEarnedKomisi" id="tf-earn" style="accent-color:var(--gold-300);">
        <label for="tf-earn" style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);letter-spacing:0.06em;cursor:pointer;">
          Transfer juga komisi EARNED yang belum dibayar (default: tetap di agen asal)
        </label>
      </div>

      <div class="actions">
        <button type="button" class="btn btn--ghost" id="transfer-close">Batal</button>
        <button type="submit" class="btn btn--primary">Konfirmasi Transfer</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- Refund modal -->
<% if (canRefund) { %>
<div class="modal-overlay" id="refund-modal" aria-hidden="true">
  <div class="modal">
    <h2>Issue Refund</h2>
    <div class="sub-m"><%= b.bookingNo %> · <%= b.jemaah.fullName %> · sisa paid <%= fmt.rpFull(paid) %></div>

    <div class="cancel-note">
      <strong>HEADS UP:</strong><br>
      • Membuat Payment baru dengan jumlah negatif (status REFUNDED)<br>
      • paidAmount booking berkurang sesuai jumlah refund<br>
      • Refund penuh (sisa = 0) → status booking jadi REFUNDED (terminal)<br>
      • Refund partial tetap CANCELLED — bisa di-refund berulang sampai paid = 0
    </div>

    <% if (b.noShowAt) { %>
      <div style="background:rgba(181,86,74,0.10);border:1px solid var(--ruby);border-radius:var(--r-sm);padding:11px 14px;margin-bottom:14px;font-family:var(--font-mono);font-size:11px;color:var(--ruby);line-height:1.5;">
        <strong>⚠ NO-SHOW (S145):</strong><br>
        Booking ini di-flag no-show pada <%= fmt.date(b.noShowAt) %>. Jemaah tidak hadir di Hari 1.<br>
        Mungkin saja jemaah terbang dengan operator lain — refund penuh bisa berarti uang hilang dua kali.<br>
        Untuk refund <strong>penuh</strong>, centang konfirmasi di bawah. Refund partial (goodwill) tidak butuh konfirmasi.
      </div>
    <% } %>

    <div class="err-m" id="refund-err"></div>

    <form id="refund-form">
      <input type="hidden" name="bookingId" value="<%= b.id %>">

      <div class="field">
        <label class="label" for="rf-amount">Jumlah refund (Rp) *</label>
        <input class="input" type="number" name="amount" id="rf-amount" required min="1" max="<%= paid %>" step="1" value="<%= paid %>">
        <%# Stage 183 — preset percentage buttons. data-pct stores the
            target percentage; click handler sets the amount input based
            on `paid`. "BALANCE" is 100% — visual emphasis that this is
            a full refund. %>
        <div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;" data-refund-paid="<%= paid %>">
          <button type="button" class="refund-preset" data-pct="25" style="background:transparent;border:1px solid var(--hairline-soft);color:var(--ink-100);padding:5px 10px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;">25%</button>
          <button type="button" class="refund-preset" data-pct="50" style="background:transparent;border:1px solid var(--hairline-soft);color:var(--ink-100);padding:5px 10px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;">50%</button>
          <button type="button" class="refund-preset" data-pct="75" style="background:transparent;border:1px solid var(--hairline-soft);color:var(--ink-100);padding:5px 10px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;">75%</button>
          <button type="button" class="refund-preset" data-pct="100" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:5px 10px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;">BALANCE (100%)</button>
        </div>
        <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);margin-top:6px;">
          Max <%= fmt.rpFull(paid) %>
        </div>
      </div>

      <div class="field">
        <label class="label" for="rf-method">Metode *</label>
        <select class="input" name="method" id="rf-method" required>
          <option value="TRANSFER">Transfer Bank</option>
          <option value="CASH">Cash</option>
          <option value="VA">Virtual Account</option>
          <option value="QRIS">QRIS</option>
          <option value="EWALLET">E-Wallet</option>
          <option value="CARD">Reverse Kartu Kredit</option>
        </select>
      </div>

      <%# Stage 235 — structured reason code dropdown. Optional but
          recommended; admin who picks "OTHER" gives the free-text below. %>
      <div class="field">
        <label class="label" for="rf-reason-code">Kategori alasan (untuk analitik)</label>
        <select class="input" id="rf-reason-code" name="reasonCode">
          <option value="">— pilih kategori (opsional) —</option>
          <option value="JEMAAH_REQUEST">Jemaah minta batal/refund</option>
          <option value="PAKET_CANCELLED">Paket dibatalkan oleh kami</option>
          <option value="VISA_REJECTED">Visa ditolak</option>
          <option value="JEMAAH_ILL">Jemaah sakit / meninggal</option>
          <option value="DOCUMENT_INCOMPLETE">Dokumen tidak lengkap</option>
          <option value="NO_SHOW_REFUND">No-show (admin acknowledge)</option>
          <option value="GOODWILL">Goodwill (diskresi admin)</option>
          <option value="DUPLICATE_PAYMENT">Pembayaran dobel</option>
          <option value="FRAUD_CHARGEBACK">Fraud / chargeback</option>
          <option value="OTHER">Lainnya</option>
        </select>
      </div>

      <div class="field">
        <label class="label" for="rf-reason">Alasan refund *</label>
        <textarea class="input" id="rf-reason" name="reason" required minlength="3" maxlength="2000" rows="3" placeholder="Mis. nasabah minta refund, biaya admin dipotong 10%, dll."></textarea>
      </div>

      <% if (b.noShowAt) { %>
        <div class="field">
          <label style="display:flex;gap:8px;align-items:flex-start;cursor:pointer;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
            <input type="checkbox" name="acknowledgeNoShow" value="true" style="margin-top:2px;">
            <span>Saya konfirmasi: jemaah <strong>tidak terbang dengan operator lain</strong> dan refund penuh memang yang dimaksud.</span>
          </label>
        </div>
      <% } %>

      <div class="actions">
        <button type="button" class="btn btn--ghost" id="refund-close">Batal</button>
        <button type="submit" class="btn btn--danger">Konfirmasi Refund</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- Cancel modal -->
<% if (canCancel) { %>
<div class="modal-overlay" id="cancel-modal" aria-hidden="true">
  <div class="modal">
    <h2>Cancel Booking</h2>

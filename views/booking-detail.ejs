          <option value="JEMAAH_REQUEST">Permintaan jemaah</option>
          <option value="PAKET_CANCELLED">Paket dibatalkan operator</option>
          <option value="PAYMENT_NOT_RECEIVED">Pembayaran tidak masuk</option>
          <option value="DOCUMENT_INCOMPLETE">Dokumen tidak lengkap</option>
          <option value="NO_SHOW">Tidak hadir keberangkatan</option>
          <option value="GOODWILL">Goodwill (kebijakan operator)</option>
          <option value="OTHER">Lainnya</option>
        </select>
      </div>
      <div class="field">
        <label class="label" for="cf-reason">Alasan pembatalan *</label>
        <textarea class="input" id="cf-reason" name="reason" required minlength="3" maxlength="2000" rows="3" placeholder="Mis. permintaan jemaah, masalah dokumen, dll."></textarea>
      </div>
      <div class="actions">
        <button type="button" class="btn btn--ghost" id="cancel-close">Batal</button>

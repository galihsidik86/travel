<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — <%= b.bookingNo %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<script src="/shared/csrf.js"></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 20px;
  }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head { margin-bottom: 28px; display: flex; justify-content: space-between; align-items: end; gap: 24px; }
  .head h1 {
    font-family: var(--font-display); font-size: 36px; font-weight: 500;
    color: var(--cream-100); margin: 0; letter-spacing: -0.015em;
  }
  .head h1 .id {
    font-family: var(--font-mono); font-size: 22px;
    color: var(--gold-300); letter-spacing: 0.04em;
    margin-right: 12px;
  }
  .head .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em; margin-top: 8px;
  }
  .head .status-tag {
    padding: 6px 14px; font-family: var(--font-mono); font-size: 12px;
    border-radius: 4px; letter-spacing: 0.14em; border: 1px solid;
  }
  .head .status-tag.pending   { color: var(--amber);   border-color: var(--amber); background: rgba(201,147,59,0.08); }
  .head .status-tag.booked    { color: var(--sapphire); border-color: var(--sapphire); }
  .head .status-tag.dp_paid   { color: var(--gold-300); border-color: var(--gold-300); }
  .head .status-tag.partial   { color: var(--gold-300); border-color: rgba(212,175,55,0.5); }
  .head .status-tag.lunas     { color: var(--emerald); border-color: var(--emerald); background: rgba(74,143,109,0.08); }
  .head .status-tag.cancelled { color: var(--ruby);    border-color: var(--ruby);     background: rgba(181,86,74,0.08); }
  .head .status-tag.refunded  { color: var(--ruby);    border-color: var(--ruby); }

  .ok-banner, .err-banner {
    padding: 12px 16px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 12px;
    margin-bottom: 20px;
  }
  .ok-banner { background: rgba(74,143,109,0.08); border: 1px solid rgba(74,143,109,0.4); color: var(--emerald); }
  .err-banner { background: rgba(176,68,68,0.08); border: 1px solid rgba(176,68,68,0.4); color: var(--ruby); }

  .grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 18px; }

  .panel {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 24px;
    margin-bottom: 18px;
  }
  .panel h3 {
    font-family: var(--font-display); font-size: 20px; font-weight: 500;
    color: var(--cream-100); margin: 0 0 16px;
    padding-bottom: 12px; border-bottom: var(--hairline-soft);
  }
  .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .info-item .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; }
  .info-item .v { font-family: var(--font-mono); font-size: 13px; color: var(--cream-100); margin-top: 4px; word-break: break-word; }
  .info-item .v.gold { color: var(--gold-300); }
  .info-item .v a { color: var(--gold-300); text-decoration: none; }
  .info-item .v a:hover { text-decoration: underline; }

  .money-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px;
    margin: 18px 0; padding: 18px;
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm);
  }
  .money-row .cell { text-align: center; }
  .money-row .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
  .money-row .v { font-family: var(--font-display); font-size: 24px; color: var(--cream-100); margin-top: 6px; font-weight: 500; }
  .money-row .v.gold { color: var(--gold-300); }
  .money-row .v.emerald { color: var(--emerald); }
  .money-row .v.ruby { color: var(--ruby); }

  .progress-bar {
    height: 8px; background: var(--ink-700); border-radius: 4px; overflow: hidden;
    margin-top: 12px;
  }
  .progress-bar > i { display: block; height: 100%; background: var(--gold-300); }
  .progress-bar > i.full { background: var(--emerald); }

  .tbl { width: 100%; border-collapse: collapse; }
  .tbl thead th {
    text-align: left; padding: 10px 12px;
    background: var(--ink-1000);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-200); font-weight: 500;
    border-bottom: var(--hairline);
  }
  .tbl tbody td {
    padding: 10px 12px; border-bottom: var(--hairline-soft);
    font-size: 13px; color: var(--cream-200);
  }
  .tbl tbody tr:last-child td { border-bottom: 0; }
  .tbl .num { text-align: right; font-family: var(--font-mono); }
  .tbl .amt.gold { color: var(--gold-300); }
  .tbl .id { font-family: var(--font-mono); color: var(--gold-300); font-size: 11px; }

  /* Timeline */
  .timeline { padding-left: 4px; }
  .timeline__row {
    padding: 10px 0;
    border-left: 1px dashed var(--ink-500);
    padding-left: 16px; margin-left: 8px;
    position: relative;
  }
  .timeline__row::before {
    content: '';
    position: absolute; left: -5px; top: 16px;
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--gold-300); border: 2px solid var(--ink-1000);
  }
  .timeline__row.action-create::before  { background: var(--emerald); }
  .timeline__row.action-update::before  { background: var(--gold-300); }
  .timeline__row.action-status_change::before { background: var(--amber); }
  .timeline__row.action-payment_received::before { background: var(--emerald); }
  .timeline__row.action-delete::before  { background: var(--ruby); }
  .timeline__row .t { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .timeline__row .a {
    margin-top: 4px; font-family: var(--font-mono); font-size: 11px;
    color: var(--cream-100); letter-spacing: 0.06em;
  }
  .timeline__row .who { color: var(--gold-300); }
  .timeline__row .snap { font-size: 11px; color: var(--ink-100); margin-top: 4px; word-break: break-word; }

  /* Actions panel */
  .actions-panel { display: flex; flex-direction: column; gap: 12px; }
  .actions-panel button, .actions-panel a {
    width: 100%; padding: 14px 18px;
    background: var(--ink-1000); border: var(--hairline-soft);
    color: var(--cream-100); cursor: pointer;
    border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; text-align: left; display: block;
  }
  .actions-panel button:hover, .actions-panel a:hover { border-color: var(--gold-300); color: var(--gold-300); }
  .actions-panel button.danger { color: var(--ruby); border-color: rgba(181,86,74,0.4); }
  .actions-panel button.danger:hover { color: var(--ruby); border-color: var(--ruby); background: rgba(181,86,74,0.08); }
  .actions-panel button.primary {
    background: var(--gold-300); color: var(--ink-1000);
    border-color: var(--gold-300); font-weight: 600;
  }
  .actions-panel button.primary:hover { background: var(--gold-200); }

  /* Modal (Pay + Cancel) */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(10,9,8,0.75); backdrop-filter: blur(6px);
    display: none; align-items: center; justify-content: center;
    padding: 24px;
  }
  .modal-overlay.is-open { display: flex; }
  .modal {
    background: var(--ink-900); border: var(--hairline-gold);
    border-radius: var(--r-md); padding: 32px;
    width: 100%; max-width: 480px;
  }
  .modal h2 {
    font-family: var(--font-display); font-size: 22px;
    color: var(--cream-100); margin: 0 0 6px; font-weight: 500;
  }
  .modal .sub-m {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em; margin-bottom: 18px;
  }
  .modal .field { margin-bottom: 14px; }
  .modal .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .modal .actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }
  .modal select.input { background-color: var(--ink-1000); color: var(--cream-100); }
  .modal .err-m {
    background: rgba(176,68,68,0.08);
    border: 1px solid rgba(176,68,68,0.4);
    color: var(--ruby);
    padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    margin-bottom: 14px; display: none;
  }
  .modal .err-m.is-visible { display: block; }

  /* Inline notes form */
  .notes-form { margin-top: 6px; }
  .notes-form textarea {
    width: 100%; min-height: 50px;
    font-family: inherit; font-size: 13px;
    color: var(--cream-100);
    background: var(--ink-1000);
    border: var(--hairline-soft); border-radius: var(--r-sm);
    padding: 8px 12px;
    resize: vertical;
  }
  .notes-form__actions {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 6px;
  }
  .notes-form__hint {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--ink-300); letter-spacing: 0.06em;
  }
  .notes-form__save {
    background: transparent; border: 1px solid var(--gold-300);
    color: var(--gold-300);
    padding: 5px 14px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.12em; cursor: pointer; text-transform: uppercase;
  }
  .notes-form__save:hover { background: rgba(212,175,55,0.08); }

  /* S82 — mention autocomplete dropdown */
  .mention-dd {
    position: absolute; z-index: 50;
    min-width: 240px; max-width: 360px; max-height: 200px;
    overflow-y: auto;
    background: var(--ink-900); border: 1px solid var(--gold-300);
    border-radius: var(--r-sm);
    box-shadow: 0 6px 20px rgba(0,0,0,0.6);
    font-family: var(--font-mono); font-size: 11.5px;
    padding: 4px 0;
  }
  .mention-dd__row {
    padding: 6px 12px; cursor: pointer;
    color: var(--cream-100);
    display: flex; justify-content: space-between; gap: 10px;
  }
  .mention-dd__row:hover, .mention-dd__row.is-active {
    background: rgba(212,175,55,0.12); color: var(--gold-300);
  }
  .mention-dd__email { color: inherit; }
  .mention-dd__role {
    color: var(--ink-200); font-size: 10px; letter-spacing: 0.1em;
    align-self: center;
  }
  .mention-dd__empty {
    padding: 8px 12px; color: var(--ink-300);
    font-style: italic; font-size: 11px;
  }

  .cancel-note {
    background: rgba(181,86,74,0.08); border: 1px solid rgba(181,86,74,0.3);
    color: var(--ruby);
    padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    margin-bottom: 14px; line-height: 1.6;
  }

  @media (max-width: 1000px) { .grid-2 { grid-template-columns: 1fr; } }
</style>
</head>
<body data-screen-label="02 Admin · Booking Detail">
<div class="wrap">

  <div class="crumb" style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
    <a href="/admin?tab=manifest&manifestPaket=<%= b.paket.slug %>">← KEMBALI KE MANIFEST</a>
    <span style="display:inline-flex;gap:6px;">
      <a href="/admin/bookings/<%= b.id %>/print" target="_blank" rel="noopener"
         style="color:var(--gold-300);text-decoration:none;border:1px solid var(--gold-300);padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;">
        🖨 CETAK
      </a>
      <span style="display:inline-flex;align-items:center;gap:0;">
        <a href="/admin/bookings/<%= b.id %>/voucher.pdf"
           <% if (b.voucherPrintCount > 0) { %>title="Last printed: <%= fmt.dateLong(b.lastVoucherPrintedAt) %> by <%= b.lastVoucherPrintedByEmail || '—' %> · total <%= b.voucherPrintCount %>×"<% } %>
           style="color:var(--gold-300);text-decoration:none;border:1px solid var(--gold-300);border-right:0;padding:6px 14px;border-radius:var(--r-sm) 0 0 var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;">
          ⇩ PDF<% if (b.voucherPrintCount > 0) { %><span style="margin-left:6px;color:var(--ink-200);font-size:9.5px;"><%= b.voucherPrintCount %>×</span><% } %>
        </a>
        <select onchange="if (this.value) window.location.href = '/admin/bookings/<%= b.id %>/voucher.pdf?lang=' + this.value;"
                style="background:var(--ink-1000);color:var(--gold-300);border:1px solid var(--gold-300);padding:6px 4px;border-radius:0 var(--r-sm) var(--r-sm) 0;font-family:var(--font-mono);font-size:10.5px;cursor:pointer;">
          <option value="">ID</option>
          <option value="en">EN</option>
          <option value="ar">AR</option>
        </select>
      </span>
      <a href="/admin/bookings/<%= b.id %>/bundle.zip"
         style="color:var(--gold-300);text-decoration:none;border:1px solid var(--gold-300);padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;">
        📦 BUNDLE
      </a>
    </span>
  </div>

  <script>
    (function () {
      const u = new URL(location.href);
      const ok = u.searchParams.get('ok');
      const err = u.searchParams.get('err');
      const banners = { cancelled: 'Booking dibatalkan.', notes: 'Catatan tersimpan.', transferred: 'Booking di-transfer ke agen baru.', created: 'Booking baru berhasil dibuat.', intent_cancelled: 'Payment intent di-cancel.' };
      if (ok && banners[ok]) {
        const el = document.createElement('div');
        el.className = 'ok-banner';
        el.textContent = banners[ok];
        document.querySelector('.head').after(el);
      }
      if (err) {
        const el = document.createElement('div');
        el.className = 'err-banner';
        el.textContent = decodeURIComponent(err);
        document.querySelector('.head').after(el);
      }
    })();
  </script>

  <div class="head">
    <div>
      <h1>
        <span class="id"><%= b.bookingNo %></span>
        <em style="color:var(--gold-300);font-style:italic;"><%= b.paket.title %></em>
      </h1>
      <div class="sub">
        DEP <%= fmt.dateLong(b.paket.departureDate) %> ·
        Dibuat <%= fmt.dateLong(b.createdAt) %>
      </div>
    </div>
    <div>
      <span class="status-tag <%= b.status.toLowerCase() %>"><%= b.status %></span>
      <% if (b.noShowAt) { %>
        <span style="display:inline-block;margin-left:8px;padding:4px 10px;border:1px solid var(--ruby);color:var(--ruby);background:rgba(181,86,74,0.08);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.08em;border-radius:3px;" title="Jemaah tidak mark hadir di Hari 1 — auto-flagged S144 detect-no-shows pada <%= fmt.date(b.noShowAt) %>">
          ⚠ NO-SHOW
        </span>
      <% } %>
    </div>
  </div>

  <%
    const total = Number(b.totalAmount?.toString?.() ?? b.totalAmount) || 0;
    const paid  = Number(b.paidAmount?.toString?.()  ?? b.paidAmount)  || 0;
    const sisa  = Math.max(0, total - paid);
    const pct   = total > 0 ? Math.round((paid / total) * 100) : 0;
  %>

  <div class="grid-2">
    <div>
      <%# Stage 206 — pinned notes banner. Shows at the top so urgent
          context (VIP, prior dispute, special instructions) isn't
          buried below cards. Toggle button to unpin available when
          admin can edit notes. %>
      <% if (b.notesPinned && b.notes) { %>
        <div style="background:rgba(212,175,55,0.10);border:2px solid var(--gold-300);color:var(--cream-100);padding:14px 18px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:12px;line-height:1.7;margin-bottom:18px;">
          <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;margin-bottom:6px;">
            <strong style="color:var(--gold-300);letter-spacing:0.06em;text-transform:uppercase;">📌 CATATAN PENTING (PINNED)</strong>
            <% if (canEditNotes) { %>
              <form method="POST" action="/admin/bookings/<%= b.id %>/notes/pin" style="display:inline;margin:0;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="pinned" value="false">
                <button type="submit" style="background:transparent;border:1px solid var(--ink-200);color:var(--ink-100);padding:3px 10px;border-radius:var(--r-xs);font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;">× Unpin</button>
              </form>
            <% } %>
          </div>
          <div style="white-space:pre-wrap;color:var(--cream-100);"><%= b.notes %></div>
        </div>
      <% } %>

      <% if (b.cancelRequested) { %>
        <div style="background:rgba(201,147,59,0.08);border:1px solid var(--amber);color:var(--cream-100);padding:14px 18px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:12px;line-height:1.7;margin-bottom:18px;">
          <strong style="color:var(--amber);">PERMINTAAN PEMBATALAN DARI JEMAAH</strong> · <%= fmt.dateLong(b.cancelRequestedAt) %><br>
          Alasan: <em style="color:var(--cream-200);"><%= b.cancelRequestReason %></em><br>
          <span style="color:var(--ink-200);">Konfirmasi dengan jemaah via WhatsApp, lalu klik "× CANCEL BOOKING" di kanan untuk memproses.</span>
          <%# Stage 224 — admin decline. Inline form with required reason. %>
          <% if (canCancel) { %>
            <details style="margin-top:10px;">
              <summary style="cursor:pointer;color:var(--gold-300);font-family:var(--font-mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase;">↳ Atau: Tolak permintaan ini</summary>
              <form method="POST" action="/admin/bookings/<%= b.id %>/cancel-request/decline" style="margin-top:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="text" name="reason" required minlength="3" maxlength="500"
                       placeholder="Alasan tolak (min 3 karakter)"
                       style="flex:1 1 300px;min-width:200px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:6px 10px;border-radius:3px;font-family:var(--font-mono);font-size:11px;">
                <button type="submit" style="background:transparent;border:1px solid var(--ruby);color:var(--ruby);padding:6px 16px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;">
                  ✕ Tolak request
                </button>
              </form>
              <div style="margin-top:6px;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);">Jemaah akan dapat email/WA dengan alasan ini. Booking tetap aktif.</div>
            </details>
          <% } %>
        </div>
      <% } %>

      <%# Stage 221 — admin pickup setter. Walk-in / phone bookings don't
          have a /saya account so the jemaah self-pick path (S202) can't
          help; admin assigns the pickup directly from here. Only shows
          when paket has curated pickup points. %>
      <% if (typeof canSetPickup !== 'undefined' && canSetPickup && paketPickups && paketPickups.length > 0) { %>
        <div class="panel" style="background:rgba(212,175,55,0.03);border:1px solid var(--gold-300);margin-bottom:18px;">
          <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px;">
            <strong style="font-family:var(--font-display);color:var(--gold-300);">🚌 Pickup point</strong>
            <% if (b.pickupId) { %>
              <span style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);">Pilihan saat ini: <strong style="color:var(--gold-300);"><%= (paketPickups.find((p) => p.id === b.pickupId)?.label) || '—' %></strong></span>
            <% } else { %>
              <span style="font-family:var(--font-mono);font-size:10.5px;color:var(--amber);">Belum dipilih (TBD)</span>
            <% } %>
          </div>
          <form method="POST" action="/admin/bookings/<%= b.id %>/pickup" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <select name="pickupId" class="input" style="flex:1 1 240px;min-width:200px;">
              <option value="">— TBD (kosongkan pilihan) —</option>
              <% paketPickups.forEach(function(p) { %>
                <% const selected = b.pickupId === p.id; %>
                <% const fullTag = p.isFull && !selected ? ' · PENUH' : ''; %>
                <% const capTag = p.maxCapacity != null ? ` (${p.occupiedPax}/${p.maxCapacity})` : ''; %>
                <option value="<%= p.id %>" <%= selected ? 'selected' : '' %> <%= p.isFull && !selected ? 'disabled' : '' %>>
                  <%= p.label %><%= capTag %><%= fullTag %><% if (p.departTime) { %> · <%= p.departTime %><% } %>
                </option>
              <% }) %>
            </select>
            <button type="submit" class="btn btn--primary" style="padding:6px 18px;">Set Pickup</button>
          </form>
          <div style="margin-top:6px;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);">Admin override — pilihan jemaah dari /saya akan ditimpa. Tidak bisa pilih bus yang sudah penuh.</div>
        </div>
      <% } %>

      <!-- Info -->
      <div class="panel">
        <h3>Info booking</h3>
        <div class="info-grid">
          <div class="info-item">
            <div class="l">Jemaah</div>
            <div class="v gold">
              <a href="/admin/jemaah/<%= b.jemaahId %>/edit"><%= b.jemaah.fullName %></a>
            </div>
          </div>
          <div class="info-item">
            <div class="l">Telepon</div>
            <div class="v"><%= b.jemaah.phone %></div>
          </div>
          <div class="info-item">
            <div class="l">Kelas</div>
            <div class="v"><%= b.kelas %> · <%= b.paxCount %> PAX</div>
          </div>
          <div class="info-item">
            <div class="l">Agen</div>
            <div class="v">
              <% if (b.agent) { %>
                <%= b.agent.displayName %> <span style="color:var(--ink-200);">(<%= b.agent.slug %>)</span>
              <% } else if (b.agentSlugCap) { %>
                — slug <%= b.agentSlugCap %> tidak resolve —
              <% } else { %>
                — Kantor Pusat —
              <% } %>
            </div>
          </div>
          <div class="info-item">
            <div class="l">Kamar</div>
            <div class="v">
              <% if (b.room) { %>
                <span class="gold"><%= b.room.roomNo %></span>
                · Lt <%= b.room.floor ?? '—' %><% if (b.room.wing) { %> · <%= b.room.wing %><% } %>
              <% } else { %>
                <span style="color:var(--ink-300);">— belum di-assign —</span>
              <% } %>
            </div>
          </div>
          <div class="info-item">
            <div class="l">Booking fee</div>
            <div class="v"><%= b.bookingFeeAt ? fmt.date(b.bookingFeeAt) : '—' %></div>
          </div>
          <% if (b.cancelledAt) { %>
            <div class="info-item" style="grid-column: 1/-1;">
              <div class="l">Dibatalkan</div>
              <div class="v" style="color:var(--ruby);">
                <%= fmt.dateLong(b.cancelledAt) %>
                <% if (b.cancelReason) { %> — <%= b.cancelReason %><% } %>
              </div>
            </div>
          <% } %>
          <%# Stage 257 — group siblings panel. Visible when groupKey is set
              even if no siblings exist (admin needs to see the key). %>
          <% if (b.groupKey) { %>
            <div class="info-item" style="grid-column: 1/-1;">
              <div class="l">Grup booking</div>
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--cream-100);margin-top:4px;">
                <a href="/admin?tab=manifest&manifestPaket=<%= b.paket.slug %>&manifestGroup=<%= encodeURIComponent(b.groupKey) %>" style="color:var(--gold-300);text-decoration:none;font-weight:600;">🔗 <%= b.groupKey %></a>
                <% if (typeof groupSiblings !== 'undefined' && groupSiblings.length > 0) { %>
                  · <%= groupSiblings.length %> booking lain di grup
                <% } %>
              </div>
              <% if (typeof groupSiblings !== 'undefined' && groupSiblings.length > 0) { %>
                <div style="margin-top:6px;display:flex;gap:6px;flex-wrap:wrap;">
                  <% groupSiblings.forEach(function(s) { %>
                    <a href="/admin/bookings/<%= s.id %>" style="padding:5px 10px;background:rgba(212,175,55,0.04);border:1px solid var(--hairline-soft);border-radius:3px;text-decoration:none;font-family:var(--font-mono);font-size:10.5px;color:var(--cream-100);">
                      <strong style="color:var(--gold-300);"><%= s.bookingNo %></strong>
                      · <%= s.jemaah?.fullName || '—' %>
                      · <%= s.kelas %>
                      <span style="color:var(--ink-200);">(<%= s.status %>)</span>
                    </a>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% } %>

          <%# Stage 226 — booking tags. Admin curates labels (VIP/LANSIA/etc.)
              for fast manifest filtering + visual identification. %>
          <div class="info-item" style="grid-column: 1/-1;">
            <div class="l">Tags</div>
            <%
              const curTags = Array.isArray(b.tags) ? b.tags : [];
              const presets = typeof bookingTagPresets !== 'undefined' ? bookingTagPresets : [];
              const canSetTags = canEditNotes && b.status !== 'CANCELLED' && b.status !== 'REFUNDED';
            %>
            <% if (curTags.length > 0) { %>
              <div style="margin-top:4px;display:flex;gap:6px;flex-wrap:wrap;">
                <% curTags.forEach(function(t) { %>
                  <span class="badge badge--gold" style="font-size:10px;letter-spacing:0.06em;"><%= t %></span>
                <% }) %>
              </div>
            <% } else { %>
              <div class="sx" style="margin-top:4px;">— belum ada tag —</div>
            <% } %>
            <% if (canSetTags) { %>
              <form method="POST" action="/admin/bookings/<%= b.id %>/tags" style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="text" name="tags" maxlength="200"
                       value="<%= curTags.join(', ') %>"
                       placeholder="VIP, LANSIA, ..."
                       style="flex:1 1 220px;min-width:200px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 9px;border-radius:3px;font-family:var(--font-mono);font-size:11px;text-transform:uppercase;">
                <button type="submit" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:5px 12px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;">Simpan tags</button>
              </form>
              <% if (presets.length > 0) { %>
                <div style="margin-top:6px;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);">
                  Saran:
                  <% presets.forEach(function(p) { %>
                    <button type="button" data-tag-preset="<%= p %>" style="background:transparent;border:1px dashed var(--ink-200);color:var(--ink-100);padding:2px 8px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.06em;cursor:pointer;margin-left:2px;">+ <%= p %></button>
                  <% }) %>
                </div>
                <script>
                  // Click preset → append to the input (deduped, comma-separated)
                  document.querySelectorAll('[data-tag-preset]').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                      const inp = btn.closest('form').querySelector('input[name="tags"]');
                      const cur = inp.value.split(',').map(function(s) { return s.trim().toUpperCase(); }).filter(Boolean);
                      const tag = btn.dataset.tagPreset;
                      if (!cur.includes(tag)) cur.push(tag);
                      inp.value = cur.join(', ');
                      inp.focus();
                    });
                  });
                </script>
              <% } %>
            <% } %>
          </div>

          <div class="info-item" style="grid-column: 1/-1;">
            <div class="l">Catatan</div>
            <% if (canEditNotes) { %>
              <form method="POST" action="/admin/bookings/<%= b.id %>/notes" class="notes-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <%# Stage 180 — quick-insert dropdown for common note phrases.
                    Hidden when admin hasn't created any templates yet. %>
                <% if (typeof noteTemplates !== 'undefined' && noteTemplates.length > 0) { %>
                  <div style="display:flex;gap:8px;align-items:center;margin-bottom:6px;">
                    <select id="note-template-picker" style="background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:4px 8px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;">
                      <option value="">📌 Sisipkan template…</option>
                      <% noteTemplates.forEach((t) => { %>
                        <option value="<%- JSON.stringify(t.body) %>"><%= t.name %></option>
                      <% }) %>
                    </select>
                    <a href="/admin/bookings/note-templates" style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);text-decoration:none;letter-spacing:0.08em;">kelola →</a>
                  </div>
                  <script>
                    (function(){
                      const sel = document.getElementById('note-template-picker');
                      const ta = document.getElementById('notesTextarea');
                      if (!sel || !ta) return;
                      sel.addEventListener('change', (e) => {
                        if (!e.target.value) return;
                        let body;
                        try { body = JSON.parse(e.target.value); } catch { return; }
                        const sep = ta.value && !ta.value.endsWith('\n') ? '\n' : '';
                        ta.value = ta.value + sep + body;
                        ta.focus();
                        ta.setSelectionRange(ta.value.length, ta.value.length);
                        sel.value = '';
                      });
                    })();
                  </script>
                <% } %>
                <div class="notes-form__wrap" style="position:relative;">
                  <textarea name="notes" id="notesTextarea" class="input" maxlength="2000" rows="2"
                            placeholder="Catatan internal — mis. preferensi makanan, kontak alternatif, dst. Tag @email@religio.pro untuk notif."><%= b.notes || '' %></textarea>
                  <div id="mentionDropdown" class="mention-dd" hidden></div>
                </div>
                <div class="notes-form__actions">
                  <span class="notes-form__hint">max 2000 karakter · @email / :code mention · TODO ... by YYYY-MM-DD untuk tugas</span>
                  <button type="submit" class="notes-form__save">SIMPAN</button>
                </div>
              </form>
              <%# Stage 206 — pin/unpin toggle. Only shown when notes are
                  non-empty (no point pinning empty content). %>
              <% if (b.notes && !b.notesPinned && canEditNotes) { %>
                <form method="POST" action="/admin/bookings/<%= b.id %>/notes/pin" style="display:inline-flex;margin-top:8px;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="pinned" value="true">
                  <button type="submit" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:5px 12px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;">📌 Pin catatan ini</button>
                </form>
              <% } %>
            <% } else { %>
              <div class="v"><%= b.notes || '— tidak ada —' %></div>
            <% } %>
          </div>
        </div>

        <!-- Stage 49/50/51 — attribution snapshot. Hidden when nothing was
             captured (e.g. admin walk-in booking, very old row pre-S48). -->
        <% if (b.firstViewAt || b.viewCount > 0 || b.heroVariant || b.utmSource) {
          const visitDays = b.firstViewAt
            ? Math.max(0, Math.floor((new Date(b.createdAt).getTime() - new Date(b.firstViewAt).getTime()) / 86_400_000))
            : null;
        %>
          <div style="margin-top:14px;padding:12px 14px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-100);letter-spacing:0.04em;">
            <span style="color:var(--ink-200);text-transform:uppercase;letter-spacing:0.14em;font-size:10px;">Attribution</span><br>
            <% if (b.viewCount > 0) { %>
              <span style="color:var(--cream-100);">visit <strong><%= b.viewCount %>×</strong> sebelum booking</span>
              <% if (visitDays !== null) { %> · pertama <%= visitDays %>h sebelum <% } %>
              ·
            <% } %>
            <% if (b.heroVariant) { %>
              <span style="color:var(--gold-300);">varian hero <%= b.heroVariant %></span> ·
            <% } %>
            <% if (b.utmCampaign || b.utmSource || b.utmMedium) { %>
              <span style="color:var(--cream-200);">
                via <%= b.utmSource || '—' %><% if (b.utmMedium) { %> / <%= b.utmMedium %><% } %><% if (b.utmCampaign) { %> · <%= b.utmCampaign %><% } %>
              </span>
            <% } else if (b.viewCount > 0) { %>
              <span style="color:var(--ink-200);">direct / no UTM</span>
            <% } %>
          </div>
        <% } %>

        <div class="money-row">
          <div class="cell">
            <div class="l">Total</div>
            <div class="v"><%= fmt.rpShort(total) %></div>
          </div>
          <div class="cell">
            <div class="l">Sudah dibayar</div>
            <div class="v <%= paid >= total && total > 0 ? 'emerald' : 'gold' %>"><%= fmt.rpShort(paid) %></div>
          </div>
          <div class="cell">
            <div class="l">Sisa</div>
            <div class="v <%= sisa === 0 ? 'emerald' : 'ruby' %>"><%= fmt.rpShort(sisa) %></div>
          </div>
        </div>
        <div class="progress-bar"><i class="<%= pct >= 100 ? 'full' : '' %>" style="width:<%= Math.min(100, pct) %>%;"></i></div>
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);margin-top:6px;text-align:right;letter-spacing:0.08em;">
          <%= pct %>% PAID
        </div>
      </div>

      <!-- Payments -->
      <div class="panel">
        <h3>Riwayat pembayaran (<%= b.payments.length %>)</h3>
        <% if (b.payments.length === 0) { %>
          <div style="text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:24px 0;">Belum ada pembayaran.</div>
        <% } else { %>
          <table class="tbl">
            <thead>
              <tr>
                <th>Waktu</th>
                <th>Metode</th>
                <th>Ref / VA</th>
                <th>Status</th>
                <th class="num">Jumlah</th>
              </tr>
            </thead>
            <tbody>
              <% b.payments.forEach(function(p) { %>
                <% const pAmt = Number(p.amount?.toString?.() ?? p.amount) || 0; const isRefund = pAmt < 0; %>
                <tr>
                  <td>
                    <div style="color:var(--cream-100);"><%= fmt.date(p.paidAt || p.createdAt) %></div>
                    <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);"><%= new Date(p.paidAt || p.createdAt).toISOString().slice(11,16) %></div>
                  </td>
                  <td><span class="badge"><%= p.method %></span></td>
                  <td style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);">
                    <%= p.gatewayRef || p.vaNumber || (isRefund && p.notes ? p.notes.slice(0, 40) : '—') %>
                  </td>
                  <td>
                    <% const cls = p.status === 'PAID' ? 'badge--emerald' : (p.status === 'FAILED' ? 'badge--ruby' : (p.status === 'REFUNDED' ? 'badge--ruby' : 'badge--amber')); %>
                    <span class="badge <%= cls %>"><%= p.status %></span>
                  </td>
                  <td class="num amt" style="<%= isRefund ? 'color:var(--ruby);' : 'color:var(--gold-300);' %>">
                    <% if (p.currency === 'IDR') { %><%= isRefund ? '−' : '' %><%= fmt.rpFull(Math.abs(pAmt)) %><% } else { %><%= isRefund ? '−' : '' %><%= Math.abs(pAmt).toLocaleString('en-US') %> <%= p.currency %><% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- 5qq: Payment intents (online gateway history) -->
      <% if (paymentIntents && paymentIntents.length > 0) { %>
        <div class="panel">
          <h3>Payment Intents (<%= paymentIntents.length %>)</h3>
          <p style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);margin:0 0 14px;letter-spacing:0.06em;">
            Online payment attempts via Midtrans. SETTLED rows link to the matching Payment.
          </p>
          <table class="tbl">
            <thead>
              <tr>
                <th>Waktu</th>
                <th>Order ID</th>
                <th>Status</th>
                <th>Gateway</th>
                <th class="num">Jumlah</th>
                <th style="text-align:right;">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% paymentIntents.forEach(function(it) { %>
                <%
                  const stCls = it.status === 'SETTLED' ? 'badge--emerald'
                              : it.status === 'PENDING' ? 'badge--amber'
                              : it.status === 'CREATED' ? 'badge--gold'
                              : 'badge--ruby';
                  const itAmt = Number(it.amount?.toString?.() ?? it.amount) || 0;
                %>
                <tr>
                  <td>
                    <div style="color:var(--cream-100);"><%= fmt.date(it.createdAt) %></div>
                    <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);"><%= new Date(it.createdAt).toISOString().slice(11,16) %></div>
                  </td>
                  <td style="font-family:var(--font-mono);font-size:10.5px;color:var(--gold-300);"><%= it.orderId %></td>
                  <td>
                    <span class="badge <%= stCls %>"><%= it.status %></span>
                    <% if (it.paymentId) { %>
                      <div style="font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);margin-top:4px;">→ payment <%= it.paymentId.slice(-8) %></div>
                    <% } %>
                  </td>
                  <td style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);">
                    <%= it.gatewayStatus || '—' %>
                  </td>
                  <td class="num amt gold"><%= fmt.rpFull(itAmt) %></td>
                  <td style="text-align:right;">
                    <% if (canCancelIntent && (it.status === 'CREATED' || it.status === 'PENDING')) { %>
                      <form method="POST" action="/admin/bookings/<%= b.id %>/intents/<%= it.id %>/cancel"
                            style="display:inline;margin:0;"
                            onsubmit="return confirm('Cancel intent ini? (Hanya gunakan kalau Snap session dead + Midtrans tidak kirim webhook)');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" style="background:transparent;border:1px solid rgba(181,86,74,0.5);color:var(--ruby);padding:4px 10px;border-radius:3px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;cursor:pointer;text-transform:uppercase;">CANCEL</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <!-- Komisi -->
      <% if (b.komisi.length > 0) { %>
        <div class="panel">
          <h3>Komisi (<%= b.komisi.length %>)</h3>
          <table class="tbl">
            <thead>
              <tr>
                <th>Waktu</th>
                <th>Status</th>
                <th>Earned</th>
                <th>Paid</th>
                <th class="num">Jumlah</th>
              </tr>
            </thead>
            <tbody>
              <% b.komisi.forEach(function(k) { %>
                <tr>
                  <td><%= fmt.date(k.createdAt) %></td>
                  <td>
                    <% const cls = k.status === 'EARNED' ? 'badge--gold' : (k.status === 'PAID' ? 'badge--emerald' : (k.status === 'CANCELLED' ? 'badge--ruby' : 'badge--amber')); %>
                    <span class="badge <%= cls %>"><%= k.status %></span>
                  </td>
                  <td style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);"><%= k.earnedAt ? fmt.date(k.earnedAt) : '—' %></td>
                  <td style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);"><%= k.paidAt ? fmt.date(k.paidAt) : '—' %></td>
                  <td class="num amt gold"><%= fmt.rpFull(k.amount) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div>
      <!-- Actions -->
      <div class="panel">
        <h3>Aksi</h3>
        <div class="actions-panel">
          <% if (sisa > 0 && b.status !== 'CANCELLED' && b.status !== 'REFUNDED') { %>
            <button type="button" class="primary" id="open-pay">+ CATAT PEMBAYARAN</button>
          <% } %>
          <% if (canTransfer) { %>
            <button type="button" id="open-transfer">↪ TRANSFER AGEN</button>
          <% } %>
          <% if (canCancel) { %>
            <button type="button" id="open-clone">⎘ CLONE</button>
          <% } %>
          <% if (canCancel) { %>
            <button type="button" class="danger" id="open-cancel">× CANCEL BOOKING</button>
          <% } %>
          <% if (canRefund) { %>
            <button type="button" class="danger" id="open-refund">↩ ISSUE REFUND</button>
          <% } %>
          <a href="/admin?tab=manifest&manifestPaket=<%= b.paket.slug %>">KE MANIFEST</a>
          <a href="/admin?tab=bunking&bunkingPaket=<%= b.paket.slug %>">KE BUNKING</a>
        </div>
      </div>

      <!-- Stage 62 — vertical timeline grouped by event category -->
      <%
        // Categorise each audit row so the timeline reads as a narrative:
        //   ● created  (booking created)
        //   $ money    (payment, refund, komisi)
        //   ✕ cancel   (cancelled, transfer)
        //   📝 notes   (notes edits + claim)
        //   • other    (everything else)
        function categorise(h) {
          const a = h.after || {};
          if (h.action === 'CREATE') return { key: 'created', icon: '●', cls: 'emerald' };
          if (a.method || a.paidAmount != null || h.entity === 'Payment' || h.entity === 'Komisi' || h.entity === 'KomisiPayout') {
            return { key: 'money', icon: '$', cls: 'gold' };
          }
          if (a.cancelReason || a.status === 'CANCELLED' || a.status === 'REFUNDED' || a.transfer) {
            return { key: 'cancel', icon: '✕', cls: 'ruby' };
          }
          if (h.action === 'NOTES_UPDATE' || a.notes !== undefined || a.merged || a.claim) {
            return { key: 'notes', icon: '📝', cls: 'sapphire' };
          }
          return { key: 'other', icon: '•', cls: 'ink-100' };
        }
      %>
      <!-- Stage 98 — unified booking activity feed (audit + payments + tasks
           + mentions + notifs + docs + attendance). Renders ABOVE the audit-
           only timeline below, which is kept as a fallback for now. -->
      <% if (typeof activityFeed !== 'undefined' && activityFeed && activityFeed.rows.length > 0) {
        const kindIcon = { audit: '●', payment: '$', komisi: '$', mention: '@', task: '✓', notif: '✉', doc: '📄', attendance: '◉' };
        const kindCls = { audit: 'ink-100', payment: 'gold-300', komisi: 'gold-300', mention: 'sapphire', task: 'amber', notif: 'ink-200', doc: 'cream-100', attendance: 'emerald' };
      %>
        <div class="panel">
          <div class="panel__head" style="display:flex;justify-content:space-between;align-items:baseline;">
            <h3>Aktivitas booking</h3>
            <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.1em;">
              <%= activityFeed.counts.shown %><% if (activityFeed.counts.total > activityFeed.counts.shown) { %> dari <%= activityFeed.counts.total %><% } %> · semua sumber
            </span>
          </div>
          <div style="display:grid;gap:6px;margin-top:8px;">
            <% activityFeed.rows.forEach(function(a) { %>
              <div style="display:grid;grid-template-columns:18px 80px 1fr auto;gap:8px;align-items:start;padding:6px 8px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:3px;">
                <span style="color:var(--<%= kindCls[a.kind] || 'ink-100' %>);font-family:var(--font-mono);font-size:13px;line-height:1.2;text-align:center;"><%= kindIcon[a.kind] || '•' %></span>
                <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.08em;"><%= fmt.date(a.when) %></span>
                <div>
                  <div style="color:var(--cream-100);font-size:12.5px;line-height:1.4;"><%= a.label %></div>
                  <% if (a.by && a.by !== '—') { %>
                    <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);margin-top:2px;letter-spacing:0.04em;"><%= a.by %></div>
                  <% } %>
                </div>
                <span style="font-family:var(--font-mono);font-size:9px;color:var(--<%= kindCls[a.kind] || 'ink-200' %>);letter-spacing:0.12em;padding:1px 6px;border:var(--hairline-soft);border-radius:2px;align-self:start;"><%= a.kind.toUpperCase() %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="panel">
        <h3>Timeline (<%= b.history.length %>)</h3>
        <% if (b.history.length === 0) { %>
          <div style="text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:18px 0;">Tidak ada riwayat audit.</div>
        <% } %>
        <div class="vt">
          <% b.history.forEach(function(h) {
            const cat = categorise(h);
            const after = h.after || {};
            const parts = [];
            if (after.status) parts.push('status=' + after.status);
            if (after.paidAmount != null) parts.push('paid=' + (after.paidAmount).toLocaleString('id-ID'));
            if (after.method) parts.push(after.method);
            if (after.roomNo) parts.push('kamar=' + after.roomNo);
            if (after.cancelReason) parts.push('reason=' + after.cancelReason);
            if (after.bookingNo) parts.push('no=' + after.bookingNo);
            if (after.fieldsCopied) parts.push('merged ' + after.fieldsCopied.length + ' fields');
            if (after.docsTransferred != null) parts.push(after.docsTransferred + ' docs');
            if (after.transfer) parts.push('transfer agen');
            if (after.kursiFreed) parts.push('kursi freed=' + after.kursiFreed);
          %>
            <div class="vt-row">
              <div class="vt-bullet" style="color:var(--<%= cat.cls %>);border-color:var(--<%= cat.cls %>);"><%= cat.icon %></div>
              <div class="vt-body">
                <div class="vt-head">
                  <span class="vt-action"><%= h.action.replace(/_/g, ' ') %></span>
                  <% if (h.entity && h.entity !== 'Booking') { %>
                    <span class="vt-entity"><%= h.entity %></span>
                  <% } %>
                  <span class="vt-time"><%= fmt.date(h.createdAt) %> · <%= new Date(h.createdAt).toISOString().slice(11,16) %></span>
                </div>
                <% if (h.actorEmail) { %>
                  <div class="vt-actor">oleh <%= h.actorEmail %><% if (h.actorRole) { %> · <%= h.actorRole %><% } %></div>
                <% } %>
                <% if (parts.length) { %>
                  <div class="vt-snap"><%= parts.join(' · ') %></div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <style>
        .vt { display: flex; flex-direction: column; gap: 4px; position: relative; padding-left: 4px; }
        .vt::before { content: ''; position: absolute; left: 13px; top: 14px; bottom: 14px; width: 1px; background: var(--hairline-color, var(--ink-700)); }
        .vt-row { display: grid; grid-template-columns: 28px 1fr; gap: 12px; padding: 8px 0; align-items: start; position: relative; }
        .vt-bullet { width: 22px; height: 22px; border: 1px solid; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; background: var(--ink-900); margin-top: 2px; z-index: 1; flex-shrink: 0; }
        .vt-body { min-width: 0; }
        .vt-head { display: flex; gap: 10px; align-items: baseline; flex-wrap: wrap; }
        .vt-action { font-family: var(--font-mono); font-size: 11px; font-weight: 600; color: var(--cream-100); letter-spacing: 0.06em; text-transform: uppercase; }
        .vt-entity { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); padding: 1px 5px; border: 1px solid var(--ink-700); border-radius: 3px; letter-spacing: 0.06em; }
        .vt-time { margin-left: auto; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); }
        .vt-actor { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 2px; }
        .vt-snap { font-family: var(--font-mono); font-size: 10.5px; color: var(--cream-200); margin-top: 4px; padding: 4px 8px; background: var(--ink-1000); border: 1px dashed var(--ink-700); border-radius: 3px; word-break: break-word; }
      </style>
    </div>
  </div>
</div>

<!-- Transfer agen modal -->
<% if (canTransfer) { %>
<div class="modal-overlay" id="transfer-modal" aria-hidden="true">
  <div class="modal">
    <h2>Transfer Agen</h2>
    <div class="sub-m">
      <%= b.bookingNo %> · saat ini:
      <% if (b.agent) { %><strong style="color:var(--gold-300);"><%= b.agent.displayName %></strong> (<%= b.agent.slug %>)<% } else { %>— Kantor Pusat —<% } %>

<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Leaderboard Agen</title>
<meta name="description" content="Agen mitra Religio Pro paling banyak melayani jemaah lunas.">
<link rel="stylesheet" href="/shared/tokens.css">
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 880px; margin: 0 auto; padding: 48px 24px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 28px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head { text-align: center; margin-bottom: 36px; }
  .eyebrow { font-family: var(--font-mono); font-size: 11px; color: var(--gold-300); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 8px; }
  h1 { font-family: var(--font-display); font-size: 38px; font-weight: 500; color: var(--cream-100); margin: 0; letter-spacing: -0.015em; }
  h1 em { font-style: italic; color: var(--gold-300); }
  .sub { font-family: var(--font-body); font-size: 14px; color: var(--ink-100); margin-top: 12px; max-width: 560px; margin-left: auto; margin-right: auto; line-height: 1.55; }
  .empty { padding: 56px; text-align: center; font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-200); background: var(--ink-900); border-radius: var(--r-md); }
  .list { display: flex; flex-direction: column; gap: 12px; }
  .row { display: grid; grid-template-columns: 60px 60px 1fr auto; gap: 16px; align-items: center; background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 16px 20px; text-decoration: none; color: var(--cream-100); transition: border-color 0.15s; }
  .row:hover { border-color: var(--gold-300); }
  .row.rank-1 { border-color: var(--gold-300); background: linear-gradient(180deg, rgba(212,175,107,0.05), var(--ink-900)); }
  .rank { font-family: var(--font-display); font-size: 32px; color: var(--gold-300); font-weight: 500; text-align: center; }
  .rank.rank-1 { color: var(--gold-300); }
  .rank.rank-2 { color: var(--cream-200); }
  .rank.rank-3 { color: var(--amber); }
  .rank.rank-other { color: var(--ink-200); font-size: 22px; }
  .photo img { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; display: block; }
  .photo .placeholder { width: 56px; height: 56px; border-radius: 50%; background: var(--ink-1000); border: 1px dashed var(--ink-700); display: flex; align-items: center; justify-content: center; font-size: 24px; color: var(--ink-300); }
  .info { min-width: 0; }
  .name { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); font-weight: 500; }
  .meta { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; letter-spacing: 0.04em; }
  .meta span { margin-right: 12px; }
  .lunas { text-align: right; }
  .lunas__v { font-family: var(--font-display); font-size: 28px; color: var(--gold-300); font-weight: 500; line-height: 1; }
  .lunas__l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 4px; }
  .footer { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 40px; text-align: center; letter-spacing: 0.1em; }
</style>
</head>
<body data-screen-label="01 Public · Agen leaderboard">
<div class="wrap">
  <div class="crumb"><a href="/">← RELIGIO PRO</a></div>

  <div class="head">
    <p class="eyebrow">Network agen mitra</p>
    <h1>Agen <em>terbaik</em> kami</h1>
    <p class="sub">
      Ranked by jumlah jemaah yang berhasil berangkat. Klik untuk lihat profil masing-masing.
    </p>
  </div>

  <% if (rows.length === 0) { %>
    <div class="empty">Belum ada agen terverifikasi dengan jemaah lunas.</div>
  <% } else { %>
    <div class="list">
      <% rows.forEach(function(a, idx) {
        const rank = idx + 1;
        const rankCls = rank <= 3 ? `rank-${rank}` : 'rank-other';
      %>
        <a class="row <%= rank === 1 ? 'rank-1' : '' %>" href="/a/<%= a.slug %>">
          <div class="rank <%= rankCls %>">
            <% if (rank === 1) { %>🥇<% } else if (rank === 2) { %>🥈<% } else if (rank === 3) { %>🥉<% } else { %>#<%= rank %><% } %>
          </div>
          <div class="photo">
            <% if (a.photoUrl) { %>
              <img src="<%= a.photoUrl %>" alt="<%= a.displayName %>" loading="lazy">
            <% } else { %>
              <div class="placeholder">👤</div>
            <% } %>
          </div>
          <div class="info">
            <div class="name"><%= a.displayName %></div>
            <div class="meta">
              <% if (a.tier) { %><span><%= a.tier %></span><% } %>
              <% if (a.yearsActive > 0) { %><span><%= a.yearsActive %>+ tahun</span><% } %>
            </div>
          </div>
          <div class="lunas">
            <div class="lunas__v"><%= a.lunasCount %></div>
            <div class="lunas__l">jemaah lunas</div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

  <div class="footer">
    RELIGIO PRO · NETWORK AGEN MITRA TERPERCAYA
  </div>
</div>
</body>
</html>

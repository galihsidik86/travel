<script>
  const archiveBtn = document.getElementById('archive-btn');
  if (archiveBtn) {
    archiveBtn.addEventListener('click', () => {
      if (confirm('Arsipkan paket ini? Booking yang sudah ada tetap aman, tapi paket tidak akan tampil di landing.')) {
        document.getElementById('archive-form').submit();
      }
    });
  }

  // Stage 18 — clone modal
  (function () {
    const cloneBtn = document.getElementById('clone-btn');
    const modal = document.getElementById('clone-modal');
    if (!cloneBtn || !modal) return;
    const form = document.getElementById('clone-form');
    const err = document.getElementById('clone-err');
    const cancel = document.getElementById('cl-cancel');
    const slug = <%- JSON.stringify(paket.slug) %>;

    function showErr(msg) { err.textContent = msg; err.style.display = 'block'; }
    function hideErr() { err.style.display = 'none'; err.textContent = ''; }
    function open() { hideErr(); modal.classList.add('is-open'); }
    function close() { modal.classList.remove('is-open'); }

    cloneBtn.addEventListener('click', open);
    cancel.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideErr();
      const fd = new FormData(form);
      const body = {
        newSlug: fd.get('newSlug')?.toString().trim(),
        newTitle: fd.get('newTitle')?.toString().trim(),
        newDepartureDate: fd.get('newDepartureDate'),
        newReturnDate: fd.get('newReturnDate') || undefined,
        includeAgentOverrides: fd.get('includeAgentOverrides') === 'on',
      };
      const submitBtn = form.querySelector('button[type=submit]');
      submitBtn.disabled = true;
      try {
        const r = await fetch('/api/paket/' + encodeURIComponent(slug) + '/clone', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          showErr(j?.error?.message || 'Clone gagal');
          submitBtn.disabled = false;
          return;
        }
        const j = await r.json();
        // Redirect to the new paket's edit page
        location.href = '/admin/paket/' + encodeURIComponent(j.paket.slug) + '/edit';
      } catch (err) {
        showErr('Tidak dapat menghubungi server');
        submitBtn.disabled = false;
      }
    });
  })();

  <% if (mode === 'edit') { %>
  const SLUG = <%- JSON.stringify(paket.slug) %>;

  // ─── Helpers ───
  function openModal(id) { document.getElementById(id).classList.add('is-open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('is-open'); }
  function fillForm(form, data) {
    for (const [k, v] of Object.entries(data)) {
      const el = form.elements[k];
      if (!el) continue;
      if (el.type === 'checkbox') el.checked = !!v;
      else el.value = v ?? '';
    }
  }
  function formToBody(form) {
    const fd = new FormData(form);
    const body = {};
    for (const [k, v] of fd.entries()) {
      if (v !== '') body[k] = v;
    }
    // checkbox unchecked = field missing from FormData → ensure false sent for clarity
    form.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
      if (!cb.checked && !(cb.name in body)) body[cb.name] = '';
    });
    return body;
  }
  async function callJson(method, url, body) {
    const r = await fetch(url, {
      method,
      headers: body ? { 'Content-Type': 'application/json' } : {},
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!r.ok) {
      const j = await r.json().catch(() => ({}));
      throw new Error(j?.error?.message || `HTTP ${r.status}`);
    }
    return r.json();
  }

  // ─── Hotel modal ───
  const hModal = document.getElementById('hotel-modal');
  const hForm  = document.getElementById('hotel-form');
  const hErr   = document.getElementById('hotel-err');
  const hSub   = document.getElementById('hotel-modal-sub');
  const hTitle = document.getElementById('hotel-modal-title');
  let editingHotelId = null;

  function openHotelModal(row) {
    editingHotelId = row?.dataset.hotelId || null;
    hErr.classList.remove('is-visible');
    if (row) {
      hTitle.textContent = 'Edit Hotel';
      hSub.textContent = row.dataset.name;
      fillForm(hForm, {
        city: row.dataset.city, name: row.dataset.name,
        stars: row.dataset.stars, distance: row.dataset.distance,
        description: row.dataset.description, nights: row.dataset.nights,
        order: row.dataset.order,
      });
    } else {
      hTitle.textContent = 'Tambah Hotel';
      hSub.textContent = 'Baris baru';
      hForm.reset();
      hForm.elements.stars.value = '5';
      hForm.elements.nights.value = '3';
      hForm.elements.order.value = '0';
    }
    openModal('hotel-modal');
    setTimeout(() => hForm.elements.name.focus(), 0);
  }

  document.querySelectorAll('[data-add-hotel]').forEach((b) =>
    b.addEventListener('click', () => openHotelModal(null)));
  document.querySelectorAll('[data-close-hotel]').forEach((b) =>
    b.addEventListener('click', () => closeModal('hotel-modal')));
  hModal.addEventListener('click', (e) => { if (e.target === hModal) closeModal('hotel-modal'); });

  document.querySelectorAll('.child-row[data-hotel-id]').forEach((row) => {
    row.querySelector('[data-edit-hotel]').addEventListener('click', () => openHotelModal(row));
    row.querySelector('[data-delete-hotel]').addEventListener('click', async () => {
      if (!confirm('Hapus hotel ini?')) return;
      try {
        await callJson('DELETE', `/api/paket/${encodeURIComponent(SLUG)}/hotels/${row.dataset.hotelId}`);
        location.reload();
      } catch (e) { alert(e.message); }
    });
  });

  hForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    hErr.classList.remove('is-visible');
    try {
      const body = formToBody(hForm);
      if (editingHotelId) {
        await callJson('PATCH', `/api/paket/${encodeURIComponent(SLUG)}/hotels/${editingHotelId}`, body);
      } else {
        await callJson('POST', `/api/paket/${encodeURIComponent(SLUG)}/hotels`, body);
      }
      location.reload();
    } catch (e) {
      hErr.textContent = e.message;
      hErr.classList.add('is-visible');
    }
  });

  // ─── Room modal ───
  const KELAS_CAP = { QUAD: 4, TRIPLE: 3, DOUBLE: 2, VVIP: 1 };
  const rModal = document.getElementById('room-modal');
  const rForm  = document.getElementById('room-form');
  const rErr   = document.getElementById('room-err');
  const rSub   = document.getElementById('room-modal-sub');
  const rTitle = document.getElementById('room-modal-title');
  const rKelas = document.getElementById('rm-kelas');
  const rCap   = document.getElementById('rm-cap');
  let editingRoomId = null;

  // When kelas changes, suggest default capacity (only if cap field is empty)
  rKelas.addEventListener('change', () => {
    if (!rCap.value || rCap.dataset.autofill === '1') {
      rCap.value = KELAS_CAP[rKelas.value] || '';
      rCap.dataset.autofill = '1';
    }
  });
  rCap.addEventListener('input', () => { rCap.dataset.autofill = ''; });

  function openRoomModal(row) {
    editingRoomId = row?.dataset.roomId || null;
    rErr.classList.remove('is-visible');
    if (row) {
      rTitle.textContent = 'Edit Kamar';
      rSub.textContent = row.dataset.roomNo;
      fillForm(rForm, {
        roomNo: row.dataset.roomNo, kelas: row.dataset.kelas,
        floor: row.dataset.floor, wing: row.dataset.wing,
        capacity: row.dataset.capacity, notes: row.dataset.notes,
      });
      rCap.dataset.autofill = '';
    } else {
      rTitle.textContent = 'Tambah Kamar';
      rSub.textContent = 'Baris baru';
      rForm.reset();
      rKelas.value = 'QUAD';
      rCap.value = KELAS_CAP.QUAD;
      rCap.dataset.autofill = '1';
    }
    openModal('room-modal');
    setTimeout(() => rForm.elements.roomNo.focus(), 0);
  }

  document.querySelectorAll('[data-add-room]').forEach((b) =>
    b.addEventListener('click', () => openRoomModal(null)));
  document.querySelectorAll('[data-close-room]').forEach((b) =>
    b.addEventListener('click', () => closeModal('room-modal')));
  rModal.addEventListener('click', (e) => { if (e.target === rModal) closeModal('room-modal'); });

  document.querySelectorAll('.child-row[data-room-id]').forEach((row) => {
    row.querySelector('[data-edit-room]').addEventListener('click', () => openRoomModal(row));
    row.querySelector('[data-delete-room]').addEventListener('click', async () => {
      if (!confirm(`Hapus kamar ${row.dataset.roomNo}?`)) return;
      try {
        await callJson('DELETE', `/api/paket/${encodeURIComponent(SLUG)}/rooms/${row.dataset.roomId}`);
        location.reload();
      } catch (e) { alert(e.message); }
    });
  });

  rForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    rErr.classList.remove('is-visible');
    try {
      const body = formToBody(rForm);
      if (editingRoomId) {
        await callJson('PATCH', `/api/paket/${encodeURIComponent(SLUG)}/rooms/${editingRoomId}`, body);
      } else {
        await callJson('POST', `/api/paket/${encodeURIComponent(SLUG)}/rooms`, body);
      }
      location.reload();
    } catch (e) {
      rErr.textContent = e.message;
      rErr.classList.add('is-visible');
    }
  });

  // ─── Day modal ───
  const dModal = document.getElementById('day-modal');
  const dForm  = document.getElementById('day-form');
  const dErr   = document.getElementById('day-err');
  const dSub   = document.getElementById('day-modal-sub');
  const dTitle = document.getElementById('day-modal-title');
  let editingDayId = null;

  function openDayModal(row) {
    editingDayId = row?.dataset.dayId || null;
    dErr.classList.remove('is-visible');
    if (row) {
      dTitle.textContent = 'Edit Hari';
      dSub.textContent = `Hari ${row.dataset.dayNumber} — ${row.dataset.title}`;
      fillForm(dForm, {
        dayNumber: row.dataset.dayNumber,
        dayRange: row.dataset.dayRange,
        dateLabel: row.dataset.dateLabel,
        monthLabel: row.dataset.monthLabel,
        title: row.dataset.title,
        description: row.dataset.description,
        tagsText: row.dataset.tags,
        highlight: row.dataset.highlight === '1',
        pembimbingTitle: row.dataset.pembimbingTitle,
        pembimbingNote: row.dataset.pembimbingNote,
      });
    } else {
      dTitle.textContent = 'Tambah Hari';
      dSub.textContent = 'Baris baru';
      dForm.reset();
      // Suggest next day number
      const used = Array.from(document.querySelectorAll('.child-row[data-day-id]'))
        .map((r) => Number(r.dataset.dayNumber)).sort((a, b) => a - b);
      dForm.elements.dayNumber.value = used.length ? (used[used.length - 1] + 1) : 1;
    }
    openModal('day-modal');
    setTimeout(() => dForm.elements.title.focus(), 0);
  }

  document.querySelectorAll('[data-add-day]').forEach((b) =>
    b.addEventListener('click', () => openDayModal(null)));
  document.querySelectorAll('[data-close-day]').forEach((b) =>
    b.addEventListener('click', () => closeModal('day-modal')));
  dModal.addEventListener('click', (e) => { if (e.target === dModal) closeModal('day-modal'); });

  document.querySelectorAll('.child-row[data-day-id]').forEach((row) => {
    row.querySelector('[data-edit-day]').addEventListener('click', () => openDayModal(row));
    row.querySelector('[data-delete-day]').addEventListener('click', async () => {
      if (!confirm('Hapus hari itinerary ini?')) return;
      try {
        await callJson('DELETE', `/api/paket/${encodeURIComponent(SLUG)}/days/${row.dataset.dayId}`);
        location.reload();
      } catch (e) { alert(e.message); }
    });
  });

  dForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    dErr.classList.remove('is-visible');
    try {
      const body = formToBody(dForm);
      if (editingDayId) {
        await callJson('PATCH', `/api/paket/${encodeURIComponent(SLUG)}/days/${editingDayId}`, body);
      } else {
        await callJson('POST', `/api/paket/${encodeURIComponent(SLUG)}/days`, body);
      }
      location.reload();
    } catch (e) {
      dErr.textContent = e.message;
      dErr.classList.add('is-visible');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeModal('hotel-modal');
      closeModal('day-modal');
      closeModal('room-modal');
    }
  });
  <% } %>
</script>

<%# 5oo: crew panel JS — assign + unassign via fetch then reload %>
<% if (mode === 'edit' && Array.isArray(availableCrew)) { %>
<script>
  (function () {
    const slug = <%- JSON.stringify(paket.slug) %>;
    const assignBtn = document.getElementById('crew-assign-btn');
    const sel = document.getElementById('crew-select');
    const err = document.getElementById('crew-err');
    function showErr(msg) { err.textContent = msg; err.style.display = 'block'; }
    function hideErr() { err.style.display = 'none'; }

    assignBtn.addEventListener('click', async () => {
      hideErr();
      const userId = sel.value;
      if (!userId) { showErr('Pilih muthawwif dulu'); return; }
      assignBtn.disabled = true;
      try {
        const r = await fetch('/api/paket/' + encodeURIComponent(slug) + '/crew', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          showErr(j?.error?.message || 'Assign gagal');
          assignBtn.disabled = false;
          return;
        }
        location.reload();
      } catch {
        showErr('Tidak dapat menghubungi server');
        assignBtn.disabled = false;
      }
    });

    document.querySelectorAll('.crew-unassign').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('[data-crew-id]');
        const userId = row?.dataset.crewId;
        if (!userId || !confirm('Hapus crew ini dari paket?')) return;
        btn.disabled = true;
        try {
          const r = await fetch('/api/paket/' + encodeURIComponent(slug) + '/crew/' + encodeURIComponent(userId), {
            method: 'DELETE',
          });
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            showErr(j?.error?.message || 'Unassign gagal');
            btn.disabled = false;
            return;
          }
          location.reload();
        } catch {
          showErr('Tidak dapat menghubungi server');
          btn.disabled = false;
        }
      });
    });
  })();
</script>
<% } %>

<%# stage 14: komisi-override panel JS %>
<% if (mode === 'edit' && Array.isArray(availableAgents)) { %>
<script>
  (function () {
    const slug = <%- JSON.stringify(paket.slug) %>;
    const addBtn = document.getElementById('kom-add-btn');
    const agentSel = document.getElementById('kom-agent');
    const rateInp = document.getElementById('kom-rate');
    const err = document.getElementById('kom-err');
    function showErr(msg) { err.textContent = msg; err.style.display = 'block'; }
    function hideErr() { err.style.display = 'none'; }

    addBtn.addEventListener('click', async () => {
      hideErr();
      const agentId = agentSel.value;
      const ratePct = parseFloat(rateInp.value);
      if (!agentId) { showErr('Pilih agen dulu'); return; }
      if (!Number.isFinite(ratePct) || ratePct < 0 || ratePct > 100) {
        showErr('Rate harus 0-100');
        return;
      }
      addBtn.disabled = true;
      try {
        const r = await fetch('/api/paket/' + encodeURIComponent(slug) + '/komisi-overrides', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ agentId, rate: ratePct / 100 }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          showErr(j?.error?.message || 'Gagal menyimpan override');
          addBtn.disabled = false;
          return;
        }
        location.reload();
      } catch {
        showErr('Tidak dapat menghubungi server');
        addBtn.disabled = false;
      }
    });

    document.querySelectorAll('.kom-remove').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('[data-agent-id]');
        const agentId = row?.dataset.agentId;
        if (!agentId || !confirm('Hapus override komisi ini? Komisi yang sudah EARNED tetap tidak berubah.')) return;
        btn.disabled = true;
        try {
          const r = await fetch('/api/paket/' + encodeURIComponent(slug) + '/komisi-overrides/' + encodeURIComponent(agentId), {
            method: 'DELETE',
          });
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            showErr(j?.error?.message || 'Gagal hapus');
            btn.disabled = false;
            return;
          }
          location.reload();
        } catch {
          showErr('Tidak dapat menghubungi server');
          btn.disabled = false;
        }
      });
    });
  })();
</script>
<% } %>
</body>
</html>

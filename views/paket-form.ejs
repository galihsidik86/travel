          <div class="label-row"><label class="label" for="cl-ret">Tanggal pulang (opsional)</label></div>
          <input class="input" id="cl-ret" name="newReturnDate" type="date">
          <div class="helper">Kosongkan = otomatis (berangkat + durationDays).</div>
        </div>
      </div>
      <div class="field" style="margin-bottom:8px;">
        <label class="check-row" style="margin:0;">
          <input type="checkbox" name="includeAgentOverrides" id="cl-agen"> Ikut salin override komisi per-agen
        </label>
        <div class="helper">Pakai kalau agen yang sama dapat rate khusus di musim baru. Skip kalau matrix akan di-ulang dari nol.</div>
      </div>

      <div class="modal-actions" style="display:flex;justify-content:flex-end;gap:10px;margin-top:18px;">
        <button type="button" class="btn btn--ghost" id="cl-cancel">Batal</button>
        <button type="submit" class="btn btn--primary">Clone sekarang</button>
      </div>
    </form>
  </div>

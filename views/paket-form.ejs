<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — <%= mode === 'new' ? 'Paket Baru' : 'Edit Paket' %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<script src="/shared/csrf.js"></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 32px 40px 80px; }

  .crumb {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 20px;
  }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .crumb .sep { color: var(--ink-400); margin: 0 8px; }

  .form-head { margin-bottom: 28px; }
  .form-head h1 {
    font-family: var(--font-display); font-size: 40px; font-weight: 500;
    color: var(--cream-100); margin: 0; letter-spacing: -0.015em;
  }
  .form-head h1 em { font-style: italic; color: var(--gold-300); }
  .form-head .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em; margin-top: 8px;
  }

  .ok-banner {
    background: rgba(74,143,109,0.08); border: 1px solid rgba(74,143,109,0.4);
    color: var(--emerald);
    padding: 12px 16px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 12px;
    margin-bottom: 20px;
  }
  .err-banner {
    background: rgba(176,68,68,0.08); border: 1px solid rgba(176,68,68,0.4);
    color: var(--ruby);
    padding: 12px 16px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 12px;
    margin-bottom: 20px;
  }

  .panel {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 28px;
    margin-bottom: 20px;
  }
  .panel h3 {
    font-family: var(--font-display); font-size: 22px; font-weight: 500;
    color: var(--cream-100); margin: 0 0 6px;
  }
  .panel .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.08em;
    margin: 0 0 22px;
  }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  .grid-4 { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 12px; align-items: end; }

  .field { margin-bottom: 14px; }
  .field .label-row {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 4px;
  }
  .field .field-err {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ruby); margin-top: 4px;
  }
  .field .helper {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); margin-top: 4px; letter-spacing: 0.04em;
  }
  textarea.input { resize: vertical; min-height: 84px; font-family: inherit; }
  select.input { background-color: var(--ink-1000); color: var(--cream-100); }

  .price-row {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm); padding: 14px;
    margin-bottom: 10px;
  }
  .price-row .kelas-tag {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--gold-300); letter-spacing: 0.14em;
    background: var(--ink-900); border: var(--hairline-soft);
    padding: 4px 10px; border-radius: 3px;
    display: inline-block; margin-bottom: 10px;
  }
  .price-row .check-row {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-100); margin-top: 8px;
  }
  .price-row input[type="checkbox"] { accent-color: var(--gold-300); }

  .readonly-list {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm); padding: 16px;
  }
  .readonly-list .empty {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); text-align: center; padding: 20px;
  }
  .readonly-list .row {
    padding: 10px 0; border-bottom: var(--hairline-soft);
    font-size: 13.5px; color: var(--cream-200);
  }
  .readonly-list .row:last-child { border: 0; }
  .readonly-list .row .sx {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); margin-top: 2px;
  }

  .form-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 24px; padding-top: 20px;
    border-top: var(--hairline-soft);
  }
  .form-footer .left, .form-footer .right { display: flex; gap: 10px; }

  .btn-danger {
    background: transparent; border: 1px solid rgba(181,86,74,0.5);
    color: var(--ruby);
    padding: 9px 16px; border-radius: var(--r-sm);
    font-size: 13px; cursor: pointer;
    font-family: var(--font-sans);
  }
  .btn-danger:hover { background: rgba(181,86,74,0.08); border-color: var(--ruby); }

  /* Editable child list (hotels/days) */
  .child-panel-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 10px;
  }
  .child-panel-head .lbl {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); letter-spacing: 0.12em;
  }
  .child-panel-head .lbl strong { color: var(--cream-100); }
  .add-child-btn {
    background: transparent; border: 1px dashed var(--gold-300);
    color: var(--gold-300);
    padding: 5px 12px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.1em; cursor: pointer;
  }
  .add-child-btn:hover { background: rgba(212,175,55,0.08); }

  .child-list {
    display: flex; flex-direction: column; gap: 8px;
  }
  .child-row {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-sm); padding: 12px 14px;
    display: grid; grid-template-columns: 1fr auto; gap: 8px;
    align-items: center;
  }
  .child-row .info { min-width: 0; }
  .child-row .info .nm {
    color: var(--cream-100); font-size: 14px;
    line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .child-row .info .sx {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); margin-top: 3px; letter-spacing: 0.04em;
  }
  .child-row .acts { display: flex; gap: 4px; }
  .child-row .acts button {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-200);
    padding: 5px 10px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.1em; cursor: pointer;
  }
  .child-row .acts button:hover { color: var(--gold-300); border-color: var(--gold-300); }
  .child-row .acts button.danger:hover { color: var(--ruby); border-color: var(--ruby); }

  .child-empty {
    border: 1px dashed var(--ink-500); border-radius: var(--r-sm);
    padding: 20px 16px; text-align: center;
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); letter-spacing: 0.06em;
  }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(10,9,8,0.75); backdrop-filter: blur(6px);
    display: none; align-items: center; justify-content: center;
    padding: 24px;
  }
  .modal-overlay.is-open { display: flex; }
  .modal {
    background: var(--ink-900); border: var(--hairline-gold);
    border-radius: var(--r-md); padding: 32px;
    width: 100%; max-width: 560px;
    max-height: 90vh; overflow-y: auto;
  }
  .modal h2 {
    font-family: var(--font-display); font-size: 24px;
    color: var(--cream-100); margin: 0 0 6px; font-weight: 500;
  }
  .modal .sub-m {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
    margin-bottom: 18px;
  }
  .modal .actions {
    display: flex; gap: 10px; justify-content: flex-end;
    margin-top: 22px;
  }
  .modal .err-m {
    background: rgba(176,68,68,0.08);
    border: 1px solid rgba(176,68,68,0.4);
    color: var(--ruby);
    padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    margin-bottom: 16px; display: none;
  }
  .modal .err-m.is-visible { display: block; }
  .modal .check-row {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-100); margin-top: 8px;
  }
  .modal .check-row input[type="checkbox"] { accent-color: var(--gold-300); }
</style>
</head>
<body data-screen-label="02 Admin · Paket Form">
<div class="wrap">

  <div class="crumb">
    <a href="/admin?tab=packages">← KEMBALI KE PAKET</a>
    <% if (mode === 'edit') { %>
      <span class="sep">·</span>
      <a href="/admin/paket/<%= paket.slug %>/attendance">ABSENSI</a>
      <span class="sep">·</span>
      <a href="/admin?tab=manifest&manifestPaket=<%= paket.slug %>">MANIFEST</a>
    <% } %>
  </div>

  <div class="form-head">
    <h1>
      <% if (mode === 'new') { %>
        Paket <em>baru</em>
      <% } else { %>
        Edit <em><%= paket.title || paket.slug %></em>
      <% } %>
    </h1>
    <div class="sub">
      <% if (mode === 'new') { %>
        Status default DRAFT — ubah ke ACTIVE setelah harga + hotel + itinerary lengkap.
      <% } else { %>
        Slug saat ini: <code><%= paket.slug %></code>
      <% } %>
    </div>
  </div>

  <% if (typeof formError !== 'undefined' && formError) { %>
    <div class="err-banner"><%= formError %></div>
  <% } %>
  <% if (typeof query !== 'undefined' && false) { } %>
  <%
    const okMsg = ({ created: 'Paket berhasil dibuat.', updated: 'Perubahan disimpan.' })[locals?.ok || (typeof query !== 'undefined' ? query.ok : null)] ;
    // Simpler: rely on req.query passed implicitly — via res.locals? Use the URL directly.
  %>
  <script>
    (function () {
      const u = new URL(location.href);
      const ok = u.searchParams.get('ok');
      const err = u.searchParams.get('err');
      const banners = { created: 'Paket berhasil dibuat.', updated: 'Perubahan disimpan.' };
      if (ok && banners[ok]) {
        const el = document.createElement('div');
        el.className = 'ok-banner';
        el.textContent = banners[ok];
        document.querySelector('.form-head').after(el);
      }
      if (err) {
        const el = document.createElement('div');
        el.className = 'err-banner';
        el.textContent = decodeURIComponent(err);
        document.querySelector('.form-head').after(el);
      }
    })();
  </script>

  <form method="POST" action="<%= mode === 'new' ? '/admin/paket' : '/admin/paket/' + (paket.originalSlug || paket.slug) %>" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- ====== Identitas ====== -->
    <div class="panel">
      <h3>Identitas paket</h3>
      <p class="sub">Slug muncul di URL landing: <code>/p/&lt;slug&gt;</code></p>

      <div class="grid-2">
        <div class="field">
          <div class="label-row"><label class="label" for="f-slug">Slug *</label></div>
          <input class="input" id="f-slug" name="slug" required maxlength="190"
                 value="<%= paket.slug %>" placeholder="paket-ramadhan-2027">
          <% if (errors.slug) { %><div class="field-err"><%= errors.slug %></div><% } %>
          <div class="helper">huruf kecil, angka, strip</div>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-status">Status</label></div>
          <select class="input" id="f-status" name="status">
            <% ['DRAFT','ACTIVE','CLOSED','ARCHIVED'].forEach(function(s) { %>
              <option value="<%= s %>" <%= paket.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="field">
        <div class="label-row"><label class="label" for="f-title">Judul *</label></div>
        <input class="input" id="f-title" name="title" required maxlength="190" value="<%= paket.title %>">
        <% if (errors.title) { %><div class="field-err"><%= errors.title %></div><% } %>
      </div>

      <div class="field">
        <div class="label-row"><label class="label" for="f-subtitle">Subtitle</label></div>
        <input class="input" id="f-subtitle" name="subtitle" maxlength="190" value="<%= paket.subtitle || '' %>">
        <div class="helper">Mis. "14 Hari · 13 Malam · Lailatul Qadr di Mekkah"</div>
      </div>

      <div class="grid-2">
        <div class="field">
          <div class="label-row"><label class="label" for="f-arabic">Tagline Arab</label></div>
          <input class="input" id="f-arabic" name="arabicTagline" value="<%= paket.arabicTagline || '' %>">
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-translit">Translit Tagline</label></div>
          <input class="input" id="f-translit" name="translitTagline" value="<%= paket.translitTagline || '' %>">
        </div>
      </div>

      <!-- Stage 60 — 30-day visit sparkline. Anchored above hero title
           so admin sees traffic trend before tweaking copy that drives
           it. Hidden when viewTrend absent (e.g. on /new) OR when zero
           visits across the full window (no signal worth showing). -->
      <% if (typeof viewTrend !== 'undefined' && viewTrend && viewTrend.total > 0) {
        const points = viewTrend.points;
        const W = 320, H = 36, padX = 1, padY = 2;
        const maxV = Math.max(...points.map((p) => p.count));
        const step = (W - padX * 2) / (points.length - 1);
        const path = points.map((p, i) => {
          const x = padX + i * step;
          const y = maxV === 0 ? H - padY : H - padY - (p.count / maxV) * (H - padY * 2);
          return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
        }).join(' ');
        const lastWeek = points.slice(-7).reduce((s, p) => s + p.count, 0);
        const prevWeek = points.slice(-14, -7).reduce((s, p) => s + p.count, 0);
        const trendUp = lastWeek > prevWeek;
        const trendFlat = lastWeek === prevWeek;
      %>
        <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:10px 14px;margin-bottom:12px;display:flex;align-items:center;gap:14px;">
          <div style="flex:1;min-width:0;">
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">
              Visit landing · <%= viewTrend.days %> hari
            </div>
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--cream-100);margin-top:2px;">
              total <strong style="color:var(--gold-300);"><%= viewTrend.total %></strong>
              · 7h <strong><%= lastWeek %></strong>
              <span style="color:var(--<%= trendUp ? 'emerald' : trendFlat ? 'ink-200' : 'ruby' %>);">
                (<%= trendUp ? '▲' : trendFlat ? '=' : '▼' %> vs minggu sebelumnya <%= prevWeek %>)
              </span>
            </div>
          </div>
          <svg width="<%= W %>" height="<%= H %>" viewBox="0 0 <%= W %> <%= H %>" style="display:block;flex-shrink:0;">
            <path d="<%= path %>" fill="none" stroke="var(--gold-300)" stroke-width="1.5"/>
          </svg>
        </div>
      <% } %>

      <div class="field">
        <div class="label-row"><label class="label" for="f-hero">Hero Title HTML <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-left:6px;">VARIAN A</span></label></div>
        <textarea class="input" id="f-hero" name="heroTitleHtml" rows="3"><%= paket.heroTitleHtml || '' %></textarea>
        <div class="helper">HTML dipercaya — boleh &lt;em&gt; dan &lt;br&gt;</div>
      </div>

      <!-- Stage 50 — optional variant B for hero A/B test -->
      <div class="field">
        <div class="label-row">
          <label class="label" for="f-hero-b">Hero Title HTML <span style="font-family:var(--font-mono);font-size:10px;color:var(--gold-300);margin-left:6px;">VARIAN B (opsional)</span></label>
        </div>
        <textarea class="input" id="f-hero-b" name="heroTitleHtmlVariantB" rows="3" placeholder="Kosongkan kalau tidak ada A/B test"><%= paket.heroTitleHtmlVariantB || '' %></textarea>
        <div class="helper">Kalau diisi, landing /p/<%= paket.slug || '<slug>' %> serve A atau B 50/50 (deterministik per visitor cookie). Konversi per varian tampil di bawah ketika sudah ada data.</div>
      </div>

      <!-- Stage 52 — CTA button text per variant. Reuses hero bucketing. -->
      <div class="grid-2">
        <div class="field">
          <div class="label-row">
            <label class="label" for="f-cta-a">CTA tombol <span style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-left:6px;">VARIAN A</span></label>
          </div>
          <input class="input" id="f-cta-a" name="ctaTextVariantA" maxlength="60" placeholder="default: Kunci kursi saya →" value="<%= paket.ctaTextVariantA || '' %>">
          <div class="helper">Kosongkan untuk pakai default sistem.</div>
        </div>
        <div class="field">
          <div class="label-row">
            <label class="label" for="f-cta-b">CTA tombol <span style="font-family:var(--font-mono);font-size:10px;color:var(--gold-300);margin-left:6px;">VARIAN B (opsional)</span></label>
          </div>
          <input class="input" id="f-cta-b" name="ctaTextVariantB" maxlength="60" placeholder="mis. Daftar untuk Ramadhan 2027 →" value="<%= paket.ctaTextVariantB || '' %>">
          <div class="helper">Bucketing visitor sama dengan hero A/B. Saat full → label "Daftar waitlist →" tetap dipakai.</div>
        </div>
      </div>

      <%
        // Stage 50 — surface A/B breakdown when variantB is configured AND
        // we have at least some traffic. Computed in the route handler.
        const ab = typeof abBreakdown !== 'undefined' ? abBreakdown : null;
      %>
      <% if (paket.heroTitleHtmlVariantB && ab && (ab.A.visits > 0 || ab.B.visits > 0)) { %>
        <div class="panel" style="background:var(--ink-1000);margin-top:8px;padding:14px 16px;">
          <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:10px;">
            A/B konversi · <%= ab.window.days %> hari
            <% if (ab.winner) { %>
              <span style="float:right;color:var(--<%= ab.winner === 'tie' ? 'ink-200' : 'emerald' %>);">
                Pemenang: <%= ab.winner === 'tie' ? 'Seri' : ('Varian ' + ab.winner) %>
              </span>
            <% } else { %>
              <span style="float:right;color:var(--amber);">Belum cukup data (&lt;30 visit)</span>
            <% } %>
          </div>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
            <% ['A','B'].forEach(function(v) {
              const r = ab[v];
              const cls = r.conversionPct == null ? 'ink-200'
                : r.conversionPct >= 5 ? 'emerald'
                : r.conversionPct >= 2 ? 'gold-300'
                : r.conversionPct >= 1 ? 'amber' : 'ruby';
              const isWin = ab.winner === v;
            %>
              <div style="background:var(--ink-900);border:1px solid <%= isWin ? 'var(--emerald)' : 'var(--ink-700)' %>;border-radius:var(--r-sm);padding:10px 14px;">
                <div style="font-family:var(--font-mono);font-size:11px;color:var(--<%= isWin ? 'emerald' : 'ink-100' %>);letter-spacing:0.12em;">
                  VARIAN <%= v %><% if (isWin) { %> ★<% } %>
                </div>
                <div style="font-family:var(--font-display);font-size:22px;color:var(--<%= cls %>);margin-top:4px;font-weight:500;">
                  <%= r.conversionPct ?? '—' %>%
                </div>
                <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);margin-top:4px;">
                  <%= r.visits %> visit · <%= r.bookings %> booking
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="field">
        <div class="label-row"><label class="label" for="f-herodesc">Deskripsi hero</label></div>
        <textarea class="input" id="f-herodesc" name="heroDescription" rows="3"><%= paket.heroDescription || '' %></textarea>
      </div>
    </div>

    <!-- ====== Jadwal + kuota ====== -->
    <div class="panel">
      <h3>Jadwal &amp; kuota</h3>
      <p class="sub">Tanggal pulang harus ≥ tanggal berangkat.</p>

      <div class="grid-3">
        <div class="field">
          <div class="label-row"><label class="label" for="f-dep">Berangkat *</label></div>
          <input class="input" type="date" id="f-dep" name="departureDate" required value="<%= paket.departureDate || '' %>">
          <% if (errors.departureDate) { %><div class="field-err"><%= errors.departureDate %></div><% } %>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-ret">Pulang *</label></div>
          <input class="input" type="date" id="f-ret" name="returnDate" required value="<%= paket.returnDate || '' %>">
          <% if (errors.returnDate) { %><div class="field-err"><%= errors.returnDate %></div><% } %>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-dur">Durasi (hari) *</label></div>
          <input class="input" type="number" id="f-dur" name="durationDays" required min="1" max="60" value="<%= paket.durationDays %>">
          <% if (errors.durationDays) { %><div class="field-err"><%= errors.durationDays %></div><% } %>
        </div>
      </div>

      <div class="grid-3">
        <div class="field">
          <div class="label-row"><label class="label" for="f-kursi">Kuota kursi *</label></div>
          <input class="input" type="number" id="f-kursi" name="kursiTotal" required min="1" max="500" value="<%= paket.kursiTotal %>">
          <% if (errors.kursiTotal) { %><div class="field-err"><%= errors.kursiTotal %></div><% } %>
        </div>
        <div class="field">
          <div class="label-row"><label class="label">Terisi</label></div>
          <input class="input" type="number" disabled value="<%= paket.kursiTerisi || 0 %>">
          <div class="helper">otomatis dari booking</div>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-close">Manifes tutup</label></div>
          <input class="input" type="datetime-local" id="f-close" name="manifestClosesAt" value="<%= paket.manifestClosesAt || '' %>">
          <div class="helper">opsional</div>
        </div>
      </div>

      <div class="grid-3">
        <div class="field">
          <div class="label-row"><label class="label" for="f-komisi">Komisi agen (%)</label></div>
          <input class="input" type="number" id="f-komisi" name="komisiRatePct"
                 min="0" max="50" step="0.01"
                 value="<%= paket.komisiRatePct || '6' %>">
          <% if (errors.komisiRatePct) { %><div class="field-err"><%= errors.komisiRatePct %></div><% } %>
          <div class="helper">0-50%. Hanya dipakai saat LUNAS — komisi yang sudah EARNED tidak ikut berubah.</div>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-cost">Biaya per pax (Rp)</label></div>
          <input class="input" type="number" id="f-cost" name="costPerPaxIdr"
                 min="0" step="1"
                 placeholder="mis. 22000000"
                 value="<%= paket.costPerPaxIdr || '' %>">
          <% if (errors.costPerPaxIdr) { %><div class="field-err"><%= errors.costPerPaxIdr %></div><% } %>
          <div class="helper">Vendor cost (hotel + tiket + visa + ops). Kosongkan kalau belum dilacak — leaderboard akan skip kolom margin untuk paket ini.</div>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-cost-notes">Rincian biaya (opsional)</label></div>
          <textarea class="input" id="f-cost-notes" name="costNotes" rows="2"
                    placeholder="mis. Hotel 5*: 12 jt · Tiket: 8 jt · Visa: 2 jt"
                    style="resize:vertical;"><%= paket.costNotes || '' %></textarea>
          <div class="helper">Catatan internal. Tidak ditampilkan ke jemaah.</div>
        </div>
      </div>

      <!-- Stage 95 — benchmark flags per category vs network median -->
      <% if (mode === 'edit' && typeof costBenchmarks !== 'undefined' && costBenchmarks.some((b) => b.flag)) { %>
        <div style="margin-top:14px;padding:12px 14px;background:rgba(212,175,55,0.06);border:1px solid var(--gold-300);border-radius:var(--r-sm);">
          <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--gold-300);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:8px;">
            ⚠ Benchmark vs jaringan paket lain
          </div>
          <% costBenchmarks.filter((b) => b.flag).forEach(function(b) {
            const cls = b.flag === 'high' ? 'ruby' : 'amber';
            const symbol = b.flag === 'high' ? '▲' : '▼';
            const verb = b.flag === 'high' ? 'lebih tinggi' : 'lebih rendah';
          %>
            <div style="font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);margin:4px 0;">
              <strong style="color:var(--<%= cls %>);"><%= symbol %> <%= b.label %></strong>:
              <%= fmt.rpShort(b.amount) %>
              <span style="color:var(--ink-200);">vs median jaringan <%= fmt.rpShort(b.networkMedian) %></span>
              <span style="color:var(--<%= cls %>);">(<%= b.deltaPct > 0 ? '+' : '' %><%= b.deltaPct %>% <%= verb %>, n=<%= b.networkSample %>)</span>
            </div>
          <% }) %>
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);margin-top:6px;letter-spacing:0.04em;">
            Cek apakah angka ini benar — bisa typo, vendor overcharge, atau memang paket tier lain.
          </div>
        </div>
      <% } %>

      <!-- Stage 92 — cost lines breakdown (overrides costPerPaxIdr when present) -->
      <% if (mode === 'edit' && typeof costLines !== 'undefined') {
        const totalLines = costLines.reduce((s, l) => s + Number(l.amountIdr.toString()), 0);
      %>
        <div style="margin-top:18px;padding:16px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);">
          <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);letter-spacing:0.1em;text-transform:uppercase;">
              Rincian per vendor (otomatis sum ke biaya per pax)
            </div>
            <% if (costLines.length > 0) { %>
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
                Total: <strong><%= fmt.rpShort(totalLines) %></strong>
              </div>
            <% } %>
          </div>
          <div id="cost-lines-list" style="display:flex;flex-direction:column;gap:6px;">
            <% costLines.forEach(function(line) { %>
              <div data-line-id="<%= line.id %>" style="display:grid;grid-template-columns:140px 1fr 140px auto;gap:8px;align-items:center;padding:6px;background:var(--ink-900);border:var(--hairline-soft);border-radius:3px;">
                <span style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);"><%= costCategoryLabel(line.category) %></span>
                <span style="font-size:12px;color:var(--cream-200);"><%= line.vendorNote || '—' %></span>
                <span style="font-family:var(--font-mono);font-size:12px;color:var(--cream-100);text-align:right;"><%= fmt.rpShort(line.amountIdr) %></span>
                <button type="button" data-action="del-cost-line" data-id="<%= line.id %>"
                  style="background:transparent;border:1px solid var(--ruby);color:var(--ruby);padding:2px 8px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.08em;cursor:pointer;border-radius:3px;">×</button>
              </div>
            <% }) %>
          </div>
          <% if (costLines.length === 0) { %>
            <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-300);font-style:italic;padding:6px 0;">
              — belum ada vendor line. Tambah di bawah untuk breakdown otomatis. Tanpa line, gunakan "Biaya per pax (Rp)" di atas sebagai estimasi manual.
            </div>
          <% } %>

          <div style="margin-top:10px;padding-top:10px;border-top:1px dashed var(--ink-700);">
            <div style="display:grid;grid-template-columns:140px 1fr 140px auto;gap:8px;align-items:center;">
              <select id="ncl-cat" class="input" style="padding:6px 8px;font-size:11px;">
                <% costCategories.forEach(function(c) { %>
                  <option value="<%= c %>"><%= costCategoryLabel(c) %></option>
                <% }) %>
              </select>
              <input id="ncl-note" class="input" type="text" placeholder="vendor / note" maxlength="200" style="padding:6px 8px;font-size:11px;">
              <input id="ncl-amount" class="input" type="number" placeholder="0" min="0" step="1" style="padding:6px 8px;font-size:11px;text-align:right;">
              <button type="button" id="ncl-add"
                style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:4px 14px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;cursor:pointer;border-radius:3px;">+ TAMBAH</button>
            </div>
            <div id="cost-line-err" style="display:none;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ruby);"></div>
          </div>
        </div>
        <script>
        (function() {
          const slug = '<%= paket.slug %>';
          const addBtn = document.getElementById('ncl-add');
          const errBox = document.getElementById('cost-line-err');
          function showErr(msg) { errBox.textContent = msg; errBox.style.display = 'block'; }
          function hideErr() { errBox.style.display = 'none'; }

          if (addBtn) {
            addBtn.addEventListener('click', async () => {
              hideErr();
              const body = {
                category: document.getElementById('ncl-cat').value,
                amountIdr: document.getElementById('ncl-amount').value,
                vendorNote: document.getElementById('ncl-note').value,
              };
              if (!body.amountIdr) { showErr('Amount wajib diisi'); return; }
              try {
                const r = await fetch('/api/paket/' + slug + '/cost-lines', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  credentials: 'same-origin',
                  body: JSON.stringify(body),
                });
                if (!r.ok) {
                  const d = await r.json().catch(() => ({}));
                  showErr(d?.error?.message || 'Gagal simpan');
                  return;
                }
                location.reload();
              } catch (e) { showErr('Gagal simpan: ' + e.message); }
            });
          }

          document.querySelectorAll('[data-action="del-cost-line"]').forEach((btn) => {
            btn.addEventListener('click', async () => {
              if (!confirm('Hapus line ini?')) return;
              const id = btn.dataset.id;
              try {
                const r = await fetch('/api/paket/' + slug + '/cost-lines/' + id, {
                  method: 'DELETE',
                  credentials: 'same-origin',
                });
                if (!r.ok) { showErr('Gagal hapus'); return; }
                location.reload();
              } catch (e) { showErr('Gagal hapus: ' + e.message); }
            });
          });
        })();
        </script>
      <% } %>

      <%# Stage 190 — FAQ CRUD panel. Edit-mode only; renders accordion
          on /p/:slug below the hero. JSON CRUD via /api/paket/:slug/faqs. %>
      <% if (mode === 'edit' && typeof faqs !== 'undefined') { %>
        <div class="panel" style="margin-top:18px;">
          <h3>FAQ (<%= faqs.length %>)</h3>
          <p class="sub">Frequently asked questions yang muncul di /p/<%= paket.slug %> sebagai accordion. Urutan kecil-ke-besar.</p>
          <table style="width:100%;border-collapse:collapse;font-family:var(--font-mono);font-size:11px;">
            <thead>
              <tr style="border-bottom:1px solid var(--hairline);">
                <th style="text-align:left;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:200px;">Pertanyaan</th>
                <th style="text-align:left;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;">Jawaban</th>
                <th style="text-align:right;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:60px;">Sort</th>
                <th style="padding:6px 8px;width:80px;"></th>
              </tr>
            </thead>
            <tbody id="faq-tbody">
              <% faqs.forEach((f) => { %>
                <tr data-faq-id="<%= f.id %>">
                  <td style="padding:5px 8px;"><input type="text" class="faq-q" maxlength="200" value="<%= f.question %>" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;"><textarea class="faq-a" maxlength="5000" rows="2" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;resize:vertical;"><%= f.answer %></textarea></td>
                  <td style="padding:5px 8px;"><input type="number" class="faq-sort" min="0" max="9999" value="<%= f.sortOrder %>" style="width:50px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;text-align:right;">
                    <button type="button" class="faq-save" style="background:var(--gold-300);border:0;color:var(--ink-1000);padding:4px 10px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;font-weight:600;">Save</button>
                    <button type="button" class="faq-del" style="background:transparent;border:1px solid var(--ruby);color:var(--ruby);padding:4px 8px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;margin-left:4px;">×</button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr style="border-top:1px solid var(--hairline);">
                <td style="padding:8px;"><input type="text" id="nfaq-q" maxlength="200" placeholder="Pertanyaan baru…" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;"><textarea id="nfaq-a" maxlength="5000" rows="2" placeholder="Jawaban…" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;resize:vertical;"></textarea></td>
                <td style="padding:8px;"><input type="number" id="nfaq-sort" min="0" max="9999" value="0" style="width:50px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;text-align:right;"><button type="button" id="nfaq-add" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:4px 14px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;cursor:pointer;">+ TAMBAH</button></td>
              </tr>
            </tfoot>
          </table>
          <div id="faq-err" style="display:none;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ruby);"></div>
        </div>
        <script>
        (function() {
          const slug = '<%= paket.slug %>';
          const errBox = document.getElementById('faq-err');
          function showErr(m) { errBox.textContent = m; errBox.style.display = 'block'; }
          function hideErr() { errBox.style.display = 'none'; }
          document.getElementById('nfaq-add')?.addEventListener('click', async () => {
            hideErr();
            const body = {
              question: document.getElementById('nfaq-q').value.trim(),
              answer: document.getElementById('nfaq-a').value.trim(),
              sortOrder: Number(document.getElementById('nfaq-sort').value) || 0,
            };
            if (!body.question || !body.answer) { showErr('Q dan A wajib diisi'); return; }
            const r = await fetch('/api/paket/' + slug + '/faqs', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (r.ok) location.reload();
            else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
          });
          document.querySelectorAll('#faq-tbody tr').forEach((tr) => {
            const id = tr.dataset.faqId;
            tr.querySelector('.faq-save')?.addEventListener('click', async () => {
              hideErr();
              const body = {
                question: tr.querySelector('.faq-q').value.trim(),
                answer: tr.querySelector('.faq-a').value.trim(),
                sortOrder: Number(tr.querySelector('.faq-sort').value) || 0,
              };
              const r = await fetch('/api/paket/' + slug + '/faqs/' + id, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
              });
              if (r.ok) location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
            tr.querySelector('.faq-del')?.addEventListener('click', async () => {
              if (!confirm('Hapus FAQ ini?')) return;
              const r = await fetch('/api/paket/' + slug + '/faqs/' + id, { method: 'DELETE' });
              if (r.ok) location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
          });
        })();
        </script>
      <% } %>

      <%# Stage 196 — Pickup points CRUD panel. Edit-mode only.
          Renders pickup options on /saya/bookings/:id for jemaah. %>
      <% if (mode === 'edit' && typeof pickups !== 'undefined') { %>
        <div class="panel" style="margin-top:18px;">
          <h3>Pickup points (<%= pickups.length %>)</h3>
          <p class="sub">Titik penjemputan bus untuk paket ini. Tampil di /saya/bookings/&lt;id&gt; (panel jadwal).</p>
          <table style="width:100%;border-collapse:collapse;font-family:var(--font-mono);font-size:11px;">
            <thead>
              <tr style="border-bottom:1px solid var(--hairline);">
                <th style="text-align:left;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:140px;">Label</th>
                <th style="text-align:left;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;">Alamat</th>
                <th style="text-align:left;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:70px;">Jam</th>
                <th style="text-align:right;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:60px;">Sort</th>
                <th style="text-align:right;padding:6px 8px;color:var(--ink-200);font-weight:500;text-transform:uppercase;font-size:9.5px;letter-spacing:0.1em;width:70px;" title="Max pax/bus (kosong = no cap)">Cap</th>
                <th style="padding:6px 8px;width:80px;"></th>
              </tr>
            </thead>
            <tbody id="pickup-tbody">
              <% pickups.forEach((p) => { %>
                <tr data-pickup-id="<%= p.id %>">
                  <td style="padding:5px 8px;"><input type="text" class="pk-label" maxlength="80" value="<%= p.label %>" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;"><input type="text" class="pk-addr" maxlength="500" value="<%= p.address %>" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;"><input type="text" class="pk-time" maxlength="5" placeholder="05:00" value="<%= p.departTime || '' %>" style="width:60px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;"><input type="number" class="pk-sort" min="0" max="9999" value="<%= p.sortOrder %>" style="width:50px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;"><input type="number" class="pk-cap" min="1" max="200" placeholder="—" value="<%= p.maxCapacity ?? '' %>" style="width:55px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                  <td style="padding:5px 8px;text-align:right;">
                    <button type="button" class="pk-save" style="background:var(--gold-300);border:0;color:var(--ink-1000);padding:4px 10px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;font-weight:600;">Save</button>
                    <button type="button" class="pk-del" style="background:transparent;border:1px solid var(--ruby);color:var(--ruby);padding:4px 8px;border-radius:3px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;margin-left:4px;">×</button>
                  </td>
                </tr>
                <%# Stage 220 — driver sub-row. Shares data-pickup-id so the
                    main row's Save button reads the driver inputs too. %>
                <tr data-pickup-driver-row="<%= p.id %>" style="background:rgba(0,0,0,0.15);">
                  <td colspan="6" style="padding:4px 8px 8px 14px;">
                    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);">
                      <span style="text-transform:uppercase;letter-spacing:0.06em;">↳ Driver:</span>
                      <input type="text" class="pk-driver-name" data-driver-name="<%= p.id %>" maxlength="120" placeholder="Nama driver" value="<%= p.driverName || '' %>" style="flex:1 1 140px;min-width:120px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:4px 7px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;">
                      <input type="text" class="pk-driver-phone" data-driver-phone="<%= p.id %>" maxlength="30" placeholder="WA driver" value="<%= p.driverPhone || '' %>" style="flex:1 1 120px;min-width:100px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:4px 7px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;">
                      <input type="text" class="pk-plate" data-plate="<%= p.id %>" maxlength="20" placeholder="Plat (B 1234 CDE)" value="<%= p.plateNumber || '' %>" style="flex:1 1 100px;min-width:80px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:4px 7px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;text-transform:uppercase;">
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr style="border-top:1px solid var(--hairline);">
                <td style="padding:8px;"><input type="text" id="npk-label" maxlength="80" placeholder="Bekasi" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;"><input type="text" id="npk-addr" maxlength="500" placeholder="Jl. Ahmad Yani No.1, Bekasi" style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;"><input type="text" id="npk-time" maxlength="5" placeholder="05:00" style="width:60px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;"><input type="number" id="npk-sort" min="0" max="9999" value="0" style="width:50px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;"><input type="number" id="npk-cap" min="1" max="200" placeholder="—" style="width:55px;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:5px 7px;border-radius:3px;font-family:var(--font-mono);font-size:11px;"></td>
                <td style="padding:8px;text-align:right;"><button type="button" id="npk-add" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:4px 14px;border-radius:3px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;cursor:pointer;">+ TAMBAH</button></td>
              </tr>
            </tfoot>
          </table>
          <div id="pk-err" style="display:none;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ruby);"></div>
        </div>
        <script>
        (function() {
          const slug = '<%= paket.slug %>';
          const errBox = document.getElementById('pk-err');
          function showErr(m) { errBox.textContent = m; errBox.style.display = 'block'; }
          function hideErr() { errBox.style.display = 'none'; }
          document.getElementById('npk-add')?.addEventListener('click', async () => {
            hideErr();
            const capRaw = document.getElementById('npk-cap').value.trim();
            const body = {
              label: document.getElementById('npk-label').value.trim(),
              address: document.getElementById('npk-addr').value.trim(),
              departTime: document.getElementById('npk-time').value.trim(),
              sortOrder: Number(document.getElementById('npk-sort').value) || 0,
              maxCapacity: capRaw === '' ? null : Number(capRaw),
            };
            if (!body.label || !body.address) { showErr('Label dan alamat wajib'); return; }
            const r = await fetch('/api/paket/' + slug + '/pickups', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (r.ok) location.reload();
            else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
          });
          document.querySelectorAll('#pickup-tbody tr').forEach((tr) => {
            const id = tr.dataset.pickupId;
            tr.querySelector('.pk-save')?.addEventListener('click', async () => {
              hideErr();
              const capRaw = tr.querySelector('.pk-cap').value.trim();
              // Stage 220 — driver fields live in a sibling sub-row, not in
              // the main row; look them up by data-driver-* attribute keyed on the same pickup id.
              const driverName = document.querySelector(`[data-driver-name="${id}"]`)?.value.trim() ?? '';
              const driverPhone = document.querySelector(`[data-driver-phone="${id}"]`)?.value.trim() ?? '';
              const plate = document.querySelector(`[data-plate="${id}"]`)?.value.trim() ?? '';
              const body = {
                label: tr.querySelector('.pk-label').value.trim(),
                address: tr.querySelector('.pk-addr').value.trim(),
                departTime: tr.querySelector('.pk-time').value.trim(),
                sortOrder: Number(tr.querySelector('.pk-sort').value) || 0,
                maxCapacity: capRaw === '' ? null : Number(capRaw),
                driverName: driverName || null,
                driverPhone: driverPhone || null,
                plateNumber: plate || null,
              };
              const r = await fetch('/api/paket/' + slug + '/pickups/' + id, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
              });
              if (r.ok) location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
            tr.querySelector('.pk-del')?.addEventListener('click', async () => {
              if (!confirm('Hapus pickup ini?')) return;
              const r = await fetch('/api/paket/' + slug + '/pickups/' + id, { method: 'DELETE' });
              if (r.ok) location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
          });
        })();
        </script>
      <% } %>

      <%# Stage 374 — Vendor / hotel / emergency contact CRUD panel. Edit-mode only.
          JSON-driven (POST /api/paket/:slug/vendor-contacts etc) so admin can
          add hotel front desk, bus charter, ambulance, KBRI, clinic, etc.
          per-paket. Crew sees these on /crew/paket/:slug as tel:/wa.me links. %>
      <% if (mode === 'edit' && typeof vendorContacts !== 'undefined') { %>
        <div class="panel" style="margin-top:24px;">
          <h3>📒 Kontak vendor &amp; darurat (<%= vendorContacts.length %>)</h3>
          <div class="helper" style="margin-bottom:12px;">
            Crew tap untuk telepon langsung saat di lapangan — hotel, bus,
            ambulans, KBRI. Setidaknya isi Telepon ATAU WhatsApp; alamat opsional.
          </div>
          <div id="vc-list">
            <% if (vendorContacts.length === 0) { %>
              <p class="helper" style="color:var(--ink-200); font-style:italic;">Belum ada kontak. Tambah di bawah.</p>
            <% } else { %>
              <table style="width:100%; border-collapse:collapse; margin-bottom:14px;">
                <thead>
                  <tr style="border-bottom:var(--hairline);">
                    <th style="text-align:left; padding:6px; font-family:var(--font-mono); font-size:10px; color:var(--ink-200); letter-spacing:0.1em; text-transform:uppercase;">Kategori</th>
                    <th style="text-align:left; padding:6px; font-family:var(--font-mono); font-size:10px; color:var(--ink-200); letter-spacing:0.1em; text-transform:uppercase;">Label</th>
                    <th style="text-align:left; padding:6px; font-family:var(--font-mono); font-size:10px; color:var(--ink-200); letter-spacing:0.1em; text-transform:uppercase;">Telepon</th>
                    <th style="text-align:left; padding:6px; font-family:var(--font-mono); font-size:10px; color:var(--ink-200); letter-spacing:0.1em; text-transform:uppercase;">WhatsApp</th>
                    <th style="text-align:left; padding:6px; font-family:var(--font-mono); font-size:10px; color:var(--ink-200); letter-spacing:0.1em; text-transform:uppercase;">Sort</th>
                    <th style="text-align:right; padding:6px;"></th>
                  </tr>
                </thead>
                <tbody>
                  <% vendorContacts.forEach((c) => { %>
                    <tr data-vc-id="<%= c.id %>" style="border-bottom: 1px dashed rgba(255,255,255,0.04);">
                      <td style="padding:6px;">
                        <select data-field="category" class="input" style="padding:4px 6px; font-size:11px;">
                          <% vendorCategories.forEach((cat) => { %>
                            <option value="<%= cat %>" <%= c.category === cat ? 'selected' : '' %>><%= vendorCategoryLabels[cat] %></option>
                          <% }) %>
                        </select>
                      </td>
                      <td style="padding:6px;"><input data-field="label" class="input" style="padding:4px 6px; font-size:11px;" value="<%= c.label %>"></td>
                      <td style="padding:6px;"><input data-field="phone" class="input" style="padding:4px 6px; font-size:11px;" value="<%= c.phone || '' %>" placeholder="+62 / +966"></td>
                      <td style="padding:6px;"><input data-field="whatsapp" class="input" style="padding:4px 6px; font-size:11px;" value="<%= c.whatsapp || '' %>" placeholder="+62 / +966"></td>
                      <td style="padding:6px; width:60px;"><input data-field="sortOrder" class="input" type="number" style="padding:4px 6px; font-size:11px;" value="<%= c.sortOrder %>" min="0" max="9999"></td>
                      <td style="padding:6px; text-align:right; white-space:nowrap;">
                        <button type="button" class="btn" data-action="save" style="background:var(--gold-300); color:var(--ink-1000); padding:5px 10px; font-size:10px; border:0; border-radius:3px; cursor:pointer; font-family:var(--font-mono); letter-spacing:0.08em;">Simpan</button>
                        <button type="button" class="btn" data-action="delete" style="background:transparent; color:var(--ruby); padding:5px 8px; font-size:10px; border:1px solid var(--ruby); border-radius:3px; cursor:pointer; font-family:var(--font-mono); letter-spacing:0.08em;">×</button>
                      </td>
                    </tr>
                    <tr data-vc-extra="<%= c.id %>">
                      <td colspan="6" style="padding:0 6px 6px;">
                        <input data-field="address" class="input" style="width:100%; padding:4px 6px; font-size:11px; margin-bottom:4px;" value="<%= c.address || '' %>" placeholder="Alamat (opsional)">
                        <textarea data-field="notes" class="input" rows="1" style="width:100%; padding:4px 6px; font-size:11px;" placeholder="Catatan (opsional)"><%= c.notes || '' %></textarea>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
          <details>
            <summary style="cursor:pointer; font-family:var(--font-mono); font-size:11px; color:var(--gold-300); letter-spacing:0.08em;">+ Tambah kontak baru</summary>
            <div style="margin-top:10px; display:grid; grid-template-columns: 1fr 2fr; gap:8px; align-items:start;">
              <select id="vc-new-category" class="input" style="font-size:11px;">
                <% vendorCategories.forEach((cat) => { %>
                  <option value="<%= cat %>"><%= vendorCategoryLabels[cat] %></option>
                <% }) %>
              </select>
              <input id="vc-new-label" class="input" style="font-size:11px;" placeholder="Label (mis. 'Hotel Andalus Madinah · Front Desk')">
              <input id="vc-new-phone" class="input" style="font-size:11px;" placeholder="Telepon (mis. +966 9 …)">
              <input id="vc-new-whatsapp" class="input" style="font-size:11px;" placeholder="WhatsApp">
              <input id="vc-new-address" class="input" style="grid-column:1/-1; font-size:11px;" placeholder="Alamat (opsional)">
              <textarea id="vc-new-notes" class="input" rows="1" style="grid-column:1/-1; font-size:11px;" placeholder="Catatan (opsional)"></textarea>
            </div>
            <button type="button" id="vc-add-btn" class="btn" style="margin-top:8px; background:var(--gold-300); color:var(--ink-1000); padding:7px 14px; font-size:11px; border:0; border-radius:3px; cursor:pointer; font-family:var(--font-mono); letter-spacing:0.08em;">+ Tambah</button>
            <span id="vc-err" style="color:var(--ruby); font-family:var(--font-mono); font-size:11px; margin-left:10px;"></span>
          </details>
        </div>
        <script>
        (function () {
          const slug = '<%= paket.slug %>';
          function showErr(msg) {
            const el = document.getElementById('vc-err');
            if (el) { el.textContent = msg; setTimeout(() => { el.textContent = ''; }, 4000); }
          }
          // Add
          document.getElementById('vc-add-btn')?.addEventListener('click', async () => {
            const body = {
              category: document.getElementById('vc-new-category').value,
              label: document.getElementById('vc-new-label').value.trim(),
              phone: document.getElementById('vc-new-phone').value.trim(),
              whatsapp: document.getElementById('vc-new-whatsapp').value.trim(),
              address: document.getElementById('vc-new-address').value.trim(),
              notes: document.getElementById('vc-new-notes').value.trim(),
            };
            const r = await fetch('/api/paket/' + slug + '/vendor-contacts', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (r.ok) window.location.reload();
            else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
          });
          // Save / delete per row
          document.querySelectorAll('tr[data-vc-id]').forEach((tr) => {
            const id = tr.getAttribute('data-vc-id');
            const extra = document.querySelector('tr[data-vc-extra="' + id + '"]');
            tr.querySelector('[data-action="save"]')?.addEventListener('click', async () => {
              const fieldOf = (sel) => {
                const el = tr.querySelector('[data-field="' + sel + '"]')
                  || (extra && extra.querySelector('[data-field="' + sel + '"]'));
                return el ? el.value.trim() : '';
              };
              const body = {
                category: fieldOf('category'),
                label: fieldOf('label'),
                phone: fieldOf('phone'),
                whatsapp: fieldOf('whatsapp'),
                address: fieldOf('address'),
                notes: fieldOf('notes'),
                sortOrder: fieldOf('sortOrder'),
              };
              const r = await fetch('/api/paket/' + slug + '/vendor-contacts/' + id, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
              });
              if (r.ok) window.location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
            tr.querySelector('[data-action="delete"]')?.addEventListener('click', async () => {
              if (!confirm('Hapus kontak ini?')) return;
              const r = await fetch('/api/paket/' + slug + '/vendor-contacts/' + id, { method: 'DELETE' });
              if (r.ok) window.location.reload();
              else { const j = await r.json().catch(() => ({})); showErr(j?.error?.message || 'Gagal'); }
            });
          });
        })();
        </script>
      <% } %>

      <!-- Stage 61 — ads spend (ROI input) -->
      <div class="grid-2">
        <div class="field">
          <div class="label-row"><label class="label" for="f-ads-spend">Ads spend (Rp)</label></div>
          <input class="input" type="number" id="f-ads-spend" name="adsSpendIdr"
                 min="0" step="1"
                 placeholder="mis. 5000000"
                 value="<%= paket.adsSpendIdr || '' %>">
          <% if (errors.adsSpendIdr) { %><div class="field-err"><%= errors.adsSpendIdr %></div><% } %>
          <div class="helper">Total budget iklan untuk paket ini (Meta + Google + TikTok + dst). Kosongkan untuk paket organic — leaderboard akan render "—" ROI, bukan 0×.</div>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-ads-notes">Catatan kampanye (opsional)</label></div>
          <textarea class="input" id="f-ads-notes" name="adsNotes" rows="2"
                    placeholder="mis. Meta: 3 jt · Google: 1,5 jt · TT: 500 rb"
                    style="resize:vertical;"><%= paket.adsNotes || '' %></textarea>
          <div class="helper">Tidak ditampilkan ke jemaah.</div>
        </div>
      </div>

      <!-- Stage 222 — WhatsApp group invite for trip coordination -->
      <div class="field">
        <div class="label-row"><label class="label" for="f-wa-group">Link grup WhatsApp koordinasi (opsional)</label></div>
        <input class="input" type="url" id="f-wa-group" name="waGroupUrl"
               maxlength="500"
               placeholder="https://chat.whatsapp.com/XXXXXXX"
               value="<%= paket.waGroupUrl || '' %>">
        <% if (errors.waGroupUrl) { %><div class="field-err"><%= errors.waGroupUrl %></div><% } %>
        <div class="helper">Jemaah LUNAS + crew assigned dapat tombol "Gabung grup WA" di portal mereka. Kosongkan jika belum ada / tidak pakai grup.</div>
      </div>

      <!-- Stage 223 — per-paket required documents for readiness checklist -->
      <div class="field">
        <div class="label-row"><label class="label">Dokumen wajib untuk paket ini</label></div>
        <%
          const REQ_DOC_OPTS = [
            ['VISA_UMROH', 'Visa Umroh', 'Saudi paket — wajib hampir selalu.'],
            ['VACCINE_MENINGITIS', 'Vaksin Meningitis', 'Saudi wajib; Turki/Aqsa tidak.'],
            ['HEALTH_CERT', 'Surat sehat (medical)', 'Wajib untuk lansia & paket panjang.'],
            ['MANASIK_CERT', 'Sertifikat manasik', 'Pre-departure rite for umroh paket.'],
            ['MARRIAGE_CERT', 'Buku nikah', 'Untuk mahram/pasangan jemaah.'],
            ['FAMILY_CARD', 'Kartu Keluarga', 'Untuk klaim keluarga.'],
            ['OTHER', 'Lainnya', 'Untuk persyaratan khusus paket.'],
          ];
          // null in DB → fallback default; treat that as "default selected" for display
          const curReq = Array.isArray(paket.requiredDocs) ? paket.requiredDocs : null;
          const isDefault = curReq === null;
          const DEFAULT_SELECTED = ['VISA_UMROH', 'VACCINE_MENINGITIS', 'HEALTH_CERT', 'MANASIK_CERT'];
          function isChecked(code) {
            if (isDefault) return DEFAULT_SELECTED.includes(code);
            return curReq.includes(code);
          }
        %>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:6px 14px;font-family:var(--font-mono);font-size:11.5px;">
          <% REQ_DOC_OPTS.forEach(function(o) { %>
            <label style="display:flex;align-items:flex-start;gap:8px;cursor:pointer;padding:6px 8px;background:rgba(255,255,255,0.02);border-radius:3px;">
              <input type="checkbox" name="requiredDocs" value="<%= o[0] %>" <%= isChecked(o[0]) ? 'checked' : '' %> style="accent-color:var(--gold-300);margin-top:2px;">
              <div>
                <div style="color:var(--cream-100);"><%= o[1] %></div>
                <div style="font-size:10px;color:var(--ink-200);"><%= o[2] %></div>
              </div>
            </label>
          <% }) %>
        </div>
        <% if (errors.requiredDocs) { %><div class="field-err"><%= errors.requiredDocs %></div><% } %>
        <div class="helper">Centang yang relevan. Mempengaruhi <strong>checklist kesiapan</strong> (S23) — dropping satu = skor jemaah tidak otomatis dipenalti. Kosong = pakai default (Visa Umroh + Vaksin + Sertifikat sehat + Manasik).</div>
      </div>

      <!-- Stage 39 — lifetime profitability gauge. Edit-mode only; same math as
           the leaderboard so adjusting "Biaya per pax" above changes the pill
           below on next save. -->
      <% if (typeof profitability !== 'undefined' && profitability && profitability.lunasCount > 0) {
        const marginCls = profitability.marginPct == null ? 'ink-200' :
                          profitability.marginPct >= 20 ? 'emerald' :
                          profitability.marginPct >= 5  ? 'gold-300' :
                          profitability.marginPct >= 0  ? 'amber' : 'ruby';
        const netCls = profitability.netMarginIdr == null ? 'ink-200' :
                       profitability.netMarginIdr >= 0 ? 'emerald' : 'ruby';
      %>
        <div class="prof-panel">
          <div class="prof-head">Profitabilitas paket (lifetime · semua LUNAS)</div>
          <div class="prof-grid">
            <div class="prof-cell">
              <div class="l">Revenue LUNAS</div>
              <div class="v"><%= fmt.rpShort(profitability.lunasRevenueIdr) %></div>
              <div class="s"><%= profitability.lunasCount %> booking · <%= profitability.lunasPaxCount %> pax</div>
            </div>
            <div class="prof-cell">
              <div class="l">Total biaya vendor</div>
              <% if (profitability.totalCostIdr != null) { %>
                <div class="v"><%= fmt.rpShort(profitability.totalCostIdr) %></div>
                <div class="s"><%= fmt.rpShort(profitability.costPerPaxIdr) %>/pax × <%= profitability.lunasPaxCount %> pax</div>
              <% } else { %>
                <div class="v muted">—</div>
                <div class="s">isi "Biaya per pax" untuk hitung</div>
              <% } %>
            </div>
            <div class="prof-cell">
              <div class="l">Komisi terikat</div>
              <div class="v"><%= fmt.rpShort(profitability.komisiLiabilityIdr) %></div>
              <div class="s">EARNED + PAID</div>
            </div>
            <div class="prof-cell">
              <div class="l">Net margin</div>
              <% if (profitability.netMarginIdr != null) { %>
                <div class="v" style="color:var(--<%= netCls %>);">
                  <%= profitability.netMarginIdr < 0 ? '−' : '' %><%= fmt.rpShort(Math.abs(profitability.netMarginIdr)) %>
                </div>
                <div class="s" style="color:var(--<%= marginCls %>);font-weight:600;">
                  <%= profitability.marginPct %>% margin
                </div>
              <% } else { %>
                <div class="v muted">—</div>
                <div class="s">butuh biaya per pax</div>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>

      <%# Stage 176 — break-even projector. Compact panel below the
          profitability gauge: "N LUNAS bookings until cost covered".
          Same cost/komisi math; uses lunas averages, or featured-price
          fallback when zero LUNAS yet. %>
      <% if (typeof breakEven !== 'undefined' && breakEven && breakEven.hasCost) { %>
        <% const be = breakEven; %>
        <div class="be-panel">
          <div class="be-head">Break-even tracker
            <% if (be.usingFallback) { %>
              <span style="font-size:9px;color:var(--ink-300);text-transform:none;letter-spacing:0;">(estimasi dari featured price — belum ada LUNAS)</span>
            <% } %>
          </div>
          <div class="be-grid">
            <div class="be-cell">
              <div class="l">Status saat ini</div>
              <% if (be.alreadyBreakEven) { %>
                <div class="v" style="color:var(--emerald);">✓ Sudah BEP</div>
                <div class="s">Net +<%= fmt.rpShort(be.netSoFarIdr) %></div>
              <% } else { %>
                <div class="v" style="color:var(--ruby);">Net −<%= fmt.rpShort(Math.abs(be.netSoFarIdr)) %></div>
                <div class="s">belum tutup biaya</div>
              <% } %>
            </div>
            <div class="be-cell">
              <div class="l">Margin per pax</div>
              <% if (be.marginPerPax != null) { %>
                <div class="v" style="color:var(--<%= be.marginPerPax >= 0 ? 'emerald' : 'ruby' %>);">
                  <%= be.marginPerPax < 0 ? '−' : '' %><%= fmt.rpShort(Math.abs(be.marginPerPax)) %>
                </div>
                <div class="s">revenue − cost − komisi</div>
              <% } else { %>
                <div class="v muted">—</div>
                <div class="s">butuh harga + cost</div>
              <% } %>
            </div>
            <div class="be-cell">
              <div class="l">Booking tersisa untuk BEP</div>
              <% if (be.alreadyBreakEven) { %>
                <div class="v" style="color:var(--emerald);">0</div>
                <div class="s">target tercapai</div>
              <% } else if (be.booksNeeded == null) { %>
                <div class="v" style="color:var(--ruby);">⚠ tidak mungkin</div>
                <div class="s">margin per pax ≤ 0 — naikkan harga / turunkan biaya</div>
              <% } else { %>
                <div class="v" style="color:var(--<%= be.feasible ? 'gold-300' : 'ruby' %>);"><%= be.booksNeeded %></div>
                <div class="s">
                  <% if (be.feasible) { %>
                    sisa <%= be.seatsLeft %> kursi
                  <% } else { %>
                    butuh <%= be.booksNeeded %>, hanya tersisa <%= be.seatsLeft %> kursi
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
        <style>
          .be-panel { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-md); padding: 14px 16px; margin-bottom: 14px; }
          .be-head { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 10px; }
          .be-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
          .be-cell { background: var(--ink-900); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 10px 12px; }
          .be-cell .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; }
          .be-cell .v { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); margin-top: 4px; font-weight: 500; line-height: 1.1; }
          .be-cell .v.muted { color: var(--ink-300); }
          .be-cell .s { font-family: var(--font-mono); font-size: 10px; color: var(--ink-100); margin-top: 4px; }
          @media (max-width: 900px) { .be-grid { grid-template-columns: 1fr; } }
        </style>
      <% } %>

      <style>
        .prof-panel { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-md); padding: 14px 16px; margin-bottom: 14px; }
        .prof-head { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 10px; }
        .prof-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        .prof-cell { background: var(--ink-900); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 10px 12px; }
        .prof-cell .l { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; }
        .prof-cell .v { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); margin-top: 4px; font-weight: 500; line-height: 1.1; }
        .prof-cell .v.muted { color: var(--ink-300); }
        .prof-cell .s { font-family: var(--font-mono); font-size: 10px; color: var(--ink-100); margin-top: 4px; }
        @media (max-width: 900px) { .prof-grid { grid-template-columns: repeat(2, 1fr); } }
      </style>

      <div class="grid-4">
        <div class="field">
          <div class="label-row"><label class="label" for="f-air">Maskapai</label></div>
          <input class="input" id="f-air" name="airline" value="<%= paket.airline || '' %>">
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-aircd">Kode penerbangan</label></div>
          <input class="input" id="f-aircd" name="airlineCode" value="<%= paket.airlineCode || '' %>">
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-from">Dari (IATA)</label></div>
          <input class="input" id="f-from" name="routeFrom" maxlength="6" value="<%= paket.routeFrom || '' %>">
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-to">Ke (IATA)</label></div>
          <input class="input" id="f-to" name="routeTo" maxlength="6" value="<%= paket.routeTo || '' %>">
        </div>
      </div>
    </div>

    <!-- ====== Harga ====== -->
    <div class="panel">
      <h3>Harga per kelas</h3>
      <p class="sub">Kosongkan baris yang tidak dijual. Centang "Featured" untuk highlight gold di landing.</p>

      <% paket.prices.forEach(function(p) { %>
        <div class="price-row">
          <span class="kelas-tag"><%= p.kelas %></span>
          <div class="grid-4">
            <div class="field">
              <div class="label-row"><label class="label" for="pr-<%= p.kelas %>-price">Harga (Rp) *</label></div>
              <input class="input" type="number" id="pr-<%= p.kelas %>-price"
                     name="prices[<%= p.kelas %>][priceIdr]"
                     min="0" step="1"
                     value="<%= p.priceIdr != null && p.priceIdr !== '' ? Number(p.priceIdr.toString ? p.priceIdr.toString() : p.priceIdr) : '' %>">
            </div>
            <div class="field">
              <div class="label-row"><label class="label">Cicilan (Rp)</label></div>
              <input class="input" type="number"
                     name="prices[<%= p.kelas %>][cicilanIdr]"
                     min="0" step="1"
                     value="<%= p.cicilanIdr != null && p.cicilanIdr !== '' ? Number(p.cicilanIdr.toString ? p.cicilanIdr.toString() : p.cicilanIdr) : '' %>">
            </div>
            <div class="field">
              <div class="label-row"><label class="label">Bulan cicilan</label></div>
              <input class="input" type="number"
                     name="prices[<%= p.kelas %>][cicilanMonths]"
                     min="1" max="36"
                     value="<%= p.cicilanMonths || '' %>">
            </div>
            <div class="field">
              <div class="label-row"><label class="label">Label kamar</label></div>
              <input class="input"
                     name="prices[<%= p.kelas %>][label]"
                     value="<%= p.label || '' %>">
            </div>
          </div>
          <div class="field" style="margin-bottom:0;">
            <input class="input"
                   name="prices[<%= p.kelas %>][caption]"
                   placeholder="Caption (mis. 'Sharing 4 jemaah · bunking diatur via app')"
                   value="<%= p.caption || '' %>">
          </div>
          <label class="check-row">
            <input type="checkbox" name="prices[<%= p.kelas %>][isFeatured]" <%= p.isFeatured ? 'checked' : '' %>>
            FEATURED — highlight gold di landing
          </label>
        </div>
      <% }) %>
    </div>

    <!-- ====== Inclusions / Exclusions ====== -->
    <div class="panel">
      <h3>Inclusions &amp; exclusions</h3>
      <p class="sub">Satu item per baris.</p>
      <div class="grid-2">
        <div class="field">
          <div class="label-row"><label class="label" for="f-inc">Termasuk</label></div>
          <textarea class="input" id="f-inc" name="inclusionsText" rows="8"
                    placeholder="Visa Umroh resmi&#10;Tiket pesawat PP&#10;Hotel ★★★★★ 4 malam"><%= (paket.inclusions || []).join('\n') %></textarea>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="f-exc">Tidak termasuk</label></div>
          <textarea class="input" id="f-exc" name="exclusionsText" rows="8"
                    placeholder="Suntik meningitis&#10;Paspor baru"><%= (paket.exclusions || []).join('\n') %></textarea>
        </div>
      </div>
    </div>

    <!-- ====== Hotels + Days (interactive) ====== -->
    <% if (mode === 'edit') { %>
      <div class="panel">
        <h3>Hotel &amp; Itinerary</h3>
        <p class="sub">Klik baris untuk edit. Tambah / hapus berlaku langsung (tidak menunggu Simpan paket).</p>
        <div class="grid-2">
          <div>
            <div class="child-panel-head">
              <div class="lbl">HOTEL · <strong><%= paket.hotels.length %></strong></div>
              <button type="button" class="add-child-btn" data-add-hotel>+ TAMBAH HOTEL</button>
            </div>
            <div class="child-list" id="hotel-list">
              <% if (paket.hotels.length === 0) { %>
                <div class="child-empty">Belum ada hotel.</div>
              <% } %>
              <% paket.hotels.forEach(function(h) { %>
                <div class="child-row"
                     data-hotel-id="<%= h.id %>"
                     data-city="<%= h.city %>"
                     data-name="<%= h.name %>"
                     data-stars="<%= h.stars %>"
                     data-distance="<%= h.distance || '' %>"
                     data-description="<%= h.description || '' %>"
                     data-nights="<%= h.nights %>"
                     data-order="<%= h.order %>">
                  <div class="info">
                    <div class="nm"><%= h.name %></div>
                    <div class="sx"><%= h.city %> · <%= h.stars %>★ · <%= h.nights %> malam<% if (h.distance) { %> · <%= h.distance %><% } %></div>
                  </div>
                  <div class="acts">
                    <button type="button" data-edit-hotel>EDIT</button>
                    <button type="button" class="danger" data-delete-hotel>HAPUS</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <div>
            <div class="child-panel-head">
              <div class="lbl">ITINERARY · <strong><%= paket.days.length %></strong> HARI</div>
              <button type="button" class="add-child-btn" data-add-day>+ TAMBAH HARI</button>
            </div>
            <div class="child-list" id="day-list">
              <% if (paket.days.length === 0) { %>
                <div class="child-empty">Belum ada itinerary.</div>
              <% } %>
              <% paket.days.sort(function(a,b){return a.dayNumber-b.dayNumber;}).forEach(function(d) { %>
                <div class="child-row"
                     data-day-id="<%= d.id %>"
                     data-day-number="<%= d.dayNumber %>"
                     data-day-range="<%= d.dayRange || '' %>"
                     data-date-label="<%= d.dateLabel || '' %>"
                     data-month-label="<%= d.monthLabel || '' %>"
                     data-title="<%= d.title %>"
                     data-description="<%= d.description %>"
                     data-tags="<%= (d.tags || []).join(', ') %>"
                     data-highlight="<%= d.highlight ? '1' : '' %>"
                     data-pembimbing-title="<%= d.pembimbingTitle || '' %>"
                     data-pembimbing-note="<%= d.pembimbingNote || '' %>">
                  <div class="info">
                    <div class="nm"><strong>Hari <%= d.dayNumber %></strong> — <%= d.title %></div>
                    <div class="sx"><%= d.dayRange || '' %><% if (d.dateLabel) { %> · <%= d.dateLabel %><% } %><% if (d.monthLabel) { %> <%= d.monthLabel %><% } %></div>
                  </div>
                  <div class="acts">
                    <button type="button" data-edit-day>EDIT</button>
                    <button type="button" class="danger" data-delete-day>HAPUS</button>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <!-- ====== Rooms (Bunking) ====== -->
      <div class="panel">
        <h3>Kamar (Bunking)</h3>
        <p class="sub">Daftar kamar hotel — di-assign ke booking via tab Bunking. Hapus kamar memerlukan booking tidak ter-assign dulu.</p>

        <div class="child-panel-head">
          <div class="lbl">KAMAR · <strong><%= paket.rooms.length %></strong></div>
          <button type="button" class="add-child-btn" data-add-room>+ TAMBAH KAMAR</button>
        </div>
        <div class="child-list" id="room-list">
          <% if (paket.rooms.length === 0) { %>
            <div class="child-empty">Belum ada kamar.</div>
          <% } %>
          <% paket.rooms.forEach(function(r) {
            const occupied = (r.bookings || []).reduce(function(acc, b) { return acc + b.paxCount; }, 0);
            const state = occupied === 0 ? 'empty' : (occupied >= r.capacity ? 'full' : 'partial');
            const stateColor = state === 'full' ? 'var(--emerald)' : (state === 'partial' ? 'var(--gold-300)' : 'var(--ink-300)');
          %>
            <div class="child-row"
                 data-room-id="<%= r.id %>"
                 data-room-no="<%= r.roomNo %>"
                 data-floor="<%= r.floor ?? '' %>"
                 data-wing="<%= r.wing || '' %>"
                 data-kelas="<%= r.kelas %>"
                 data-capacity="<%= r.capacity %>"
                 data-notes="<%= r.notes || '' %>">
              <div class="info">
                <div class="nm">
                  <%= r.roomNo %>
                  <span style="color:<%= stateColor %>;font-family:var(--font-mono);font-size:10.5px;margin-left:8px;letter-spacing:0.06em;">
                    <%= occupied %>/<%= r.capacity %> slot
                  </span>
                </div>
                <div class="sx">
                  <%= r.kelas %> · Lt <%= r.floor ?? '—' %><% if (r.wing) { %> · <%= r.wing %><% } %>
                </div>
              </div>
              <div class="acts">
                <button type="button" data-edit-room>EDIT</button>
                <button type="button" class="danger" data-delete-room>HAPUS</button>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- ====== Crew (5oo) ====== -->
    <% if (mode === 'edit' && Array.isArray(availableCrew)) { %>
      <div class="panel">
        <h3>Crew (muthawwif)</h3>
        <p class="sub">Assign satu atau lebih muthawwif sebagai crew untuk paket ini. Mereka akan lihat manifest di <code>/crew/paket/<%= paket.slug %></code>.</p>

        <div id="crew-assigned-list" style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
          <% if (assignedCrew.length === 0) { %>
            <div style="padding:16px;border:1px dashed var(--ink-500);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
              Belum ada crew di-assign.
            </div>
          <% } else { %>
            <% assignedCrew.forEach(function(c) { %>
              <div class="child-row" data-crew-id="<%= c.id %>" style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);">
                <div style="flex:1;">
                  <div style="color:var(--cream-100);font-size:13px;"><%= c.fullName %></div>
                  <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);"><%= c.email %> · assigned <%= fmt.dateShort(c.assignedAt) %></div>
                </div>
                <button type="button" class="acts danger crew-unassign" style="background:transparent;border:1px solid rgba(181,86,74,0.5);color:var(--ruby);padding:5px 12px;border-radius:3px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;cursor:pointer;text-transform:uppercase;">HAPUS</button>
              </div>
            <% }) %>
          <% } %>
        </div>

        <div style="display:flex;gap:10px;align-items:end;">
          <select id="crew-select" class="input" style="flex:1;background-color:var(--ink-900);color:var(--cream-100);">
            <option value="">— Pilih muthawwif untuk di-assign —</option>
            <%
              const assignedIds = new Set(assignedCrew.map((c) => c.id));
              availableCrew.filter((u) => !assignedIds.has(u.id)).forEach(function(u) {
            %>
              <option value="<%= u.id %>"><%= u.fullName %> · <%= u.email %></option>
            <% }) %>
          </select>
          <button type="button" id="crew-assign-btn" class="btn btn--primary">Assign</button>
        </div>
        <div id="crew-err" style="display:none;margin-top:10px;color:var(--ruby);font-family:var(--font-mono);font-size:11px;"></div>
      </div>
    <% } %>

    <!-- ====== Crew daily reports (stage 278) — read-only panel ====== -->
    <% if (mode === 'edit' && typeof crewReports !== 'undefined' && Array.isArray(crewReports)) { %>
      <div class="panel">
        <h3>Laporan harian crew</h3>
        <p class="sub">Crew submit dari <code>/crew/paket/<%= paket.slug %></code>. Mood 🔴 = perlu perhatian segera.</p>
        <% if (crewReports.length === 0) { %>
          <div style="padding:14px;border:1px dashed var(--ink-500);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
            Belum ada laporan harian dari crew.
          </div>
        <% } else { %>
          <div style="display:flex;flex-direction:column;gap:8px;max-height:480px;overflow-y:auto;">
            <% crewReports.forEach(function(r) {
                 const moodColor = r.mood === 'RED' ? 'var(--ruby)' : (r.mood === 'AMBER' ? 'var(--gold-300)' : 'var(--emerald)');
                 const moodIcon = r.mood === 'RED' ? '🔴' : (r.mood === 'AMBER' ? '🟡' : '🟢');
            %>
              <div style="padding:10px 14px;background:var(--ink-1000);border-left:3px solid <%= moodColor %>;border-radius:3px;font-family:var(--font-mono);font-size:11.5px;">
                <div style="display:flex;justify-content:space-between;gap:14px;margin-bottom:6px;">
                  <span style="color:var(--cream-100);">
                    <strong><%= r.reportDate.toISOString().slice(0,10) %></strong>
                    <% if (r.dayNumber) { %> · H<%= r.dayNumber %><% } %>
                    · <span style="color:var(--ink-200);"><%= r.crewUser.fullName %></span>
                  </span>
                  <span style="color:<%= moodColor %>;font-size:10px;letter-spacing:0.08em;"><%= moodIcon %> <%= r.mood %></span>
                </div>
                <div style="color:var(--cream-100);line-height:1.55;white-space:pre-wrap;"><%= r.body %></div>
                <% if (r.updatedAt > r.createdAt) { %>
                  <div style="margin-top:4px;font-size:9.5px;color:var(--ink-300);">diedit <%= fmt.dateLong(r.updatedAt) %></div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- ====== Per-agent komisi override (stage 14) ====== -->
    <% if (mode === 'edit' && Array.isArray(availableAgents)) { %>
      <div class="panel">
        <h3>Komisi override per agen</h3>
        <p class="sub">
          Default komisi paket ini = <strong><%= paket.komisiRatePct || '6' %>%</strong>.
          Tambahkan baris di sini jika seorang agen punya rate berbeda untuk paket ini saja
          (rate per-paket × per-agen menang atas <em>komisiRateOverride</em> agen dan
          <em>komisiRate</em> paket). Komisi yang sudah EARNED tidak ikut berubah.
        </p>

        <div id="kom-list" style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
          <% if (paketOverrides.length === 0) { %>
            <div id="kom-empty" style="padding:16px;border:1px dashed var(--ink-500);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
              Belum ada override per-agen.
            </div>
          <% } else { %>
            <% paketOverrides.forEach(function(o) { %>
              <div class="kom-row" data-agent-id="<%= o.agent.id %>"
                   style="display:grid;grid-template-columns:1fr 110px 80px;gap:12px;align-items:center;padding:10px 14px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);">
                <div>
                  <div style="color:var(--cream-100);font-size:13px;"><%= o.agent.displayName %></div>
                  <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--gold-300);"><%= o.agent.slug %></div>
                </div>
                <div style="font-family:var(--font-mono);font-size:13px;color:var(--cream-100);text-align:right;">
                  <span class="kom-rate-display"><%= (Number(o.rate.toString()) * 100).toFixed(2).replace(/\.?0+$/, '') %></span>%
                </div>
                <button type="button" class="kom-remove" style="background:transparent;border:1px solid rgba(181,86,74,0.5);color:var(--ruby);padding:6px 8px;border-radius:3px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;cursor:pointer;text-transform:uppercase;">HAPUS</button>
              </div>
            <% }) %>
          <% } %>
        </div>

        <div style="display:grid;grid-template-columns:1fr 110px auto;gap:10px;align-items:end;">
          <div>
            <label class="label" for="kom-agent" style="display:block;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">Agen</label>
            <select id="kom-agent" class="input" style="width:100%;background-color:var(--ink-900);color:var(--cream-100);">
              <option value="">— pilih agen —</option>
              <% availableAgents.forEach(function(a) { %>
                <option value="<%= a.id %>"><%= a.displayName %> · <%= a.slug %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="label" for="kom-rate" style="display:block;font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">Rate (%)</label>
            <input id="kom-rate" class="input" type="number" min="0" max="100" step="0.01" placeholder="mis. 15">
          </div>
          <button type="button" id="kom-add-btn" class="btn btn--primary">Set</button>
        </div>
        <div id="kom-err" style="display:none;margin-top:10px;color:var(--ruby);font-family:var(--font-mono);font-size:11px;"></div>
      </div>
    <% } %>

    <!-- ====== Footer ====== -->
    <div class="form-footer">
      <div class="left">
        <% if (mode === 'edit') { %>
          <button type="button" class="btn-danger" id="archive-btn">Arsipkan</button>
          <button type="button" class="btn btn--outline-gold" id="clone-btn">Clone untuk musim berikutnya</button>
        <% } %>
      </div>
      <div class="right">
        <a href="/admin?tab=packages" class="btn btn--ghost">Batal</a>
        <button type="submit" class="btn btn--primary">
          <%= mode === 'new' ? 'Buat Paket' : 'Simpan' %>
        </button>
      </div>
    </div>
  </form>

  <%# Stage 347 — bulk reschedule panel. Outside the main paket form so
      a confirm-typo doesn't trigger Save+Reschedule together. Only
      renders when there's at least one active booking to move. %>
  <% if (mode === 'edit' && typeof bulkReschedule !== 'undefined' && bulkReschedule && bulkReschedule.activeCount > 0) {
       const okFlash = typeof flash !== 'undefined' && flash?.ok ? flash.ok : null;
       const errFlash = typeof flash !== 'undefined' && flash?.err ? flash.err : null;
       const bulkMatch = okFlash && okFlash.startsWith('bulk_moved_') ? okFlash.match(/bulk_moved_(\d+)_failed_(\d+)/) : null;
  %>
    <div style="margin-top:30px;padding:24px;border:1px solid var(--ruby);border-radius:var(--r-md);background:rgba(212,89,89,0.04);">
      <h2 style="font-family:var(--font-display);font-size:20px;color:var(--ruby);margin:0 0 4px;letter-spacing:-0.01em;">⚠ Bulk reschedule</h2>
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);letter-spacing:0.04em;line-height:1.7;margin-bottom:16px;">
        Pindahkan SEMUA <strong style="color:var(--ruby);"><%= bulkReschedule.activeCount %></strong> booking aktif dari paket ini ke paket lain dalam satu operasi.
        Skenario tipikal: vendor gagal, visa batch ditolak, atau perubahan jadwal mendadak.
        <br><br>
        <strong style="color:var(--ruby);">PERILAKU:</strong>
        Setiap booking di-reschedule individually (lineage tetap tercatat per row).
        Komisi PENDING di-repoint, EARNED stays di booking lama, PAID tidak disentuh.
        Kursi paket asal otomatis bebas, kursi target dipakai.
        <strong>Pengangkutan paid amount utuh — tidak ada gerakan uang.</strong>
        Jemaah dapat notif individual (EMAIL+WA); agen dapat ONE ringkasan email per agen (bukan N notif).
      </div>

      <% if (bulkMatch) { %>
        <div style="padding:10px 14px;background:rgba(80,176,113,0.10);border:1px solid var(--emerald);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11.5px;color:var(--emerald);margin-bottom:14px;">
          ✓ Bulk reschedule selesai · Moved: <%= bulkMatch[1] %> · Failed: <%= bulkMatch[2] %>
        </div>
      <% } %>
      <% if (errFlash) { %>
        <div style="padding:10px 14px;background:rgba(212,89,89,0.08);border:1px solid var(--ruby);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11.5px;color:var(--ruby);margin-bottom:14px;">
          ✕ <%= errFlash %>
        </div>
      <% } %>

      <% if (bulkReschedule.choices.length === 0) { %>
        <div style="padding:14px;background:var(--ink-1000);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11.5px;color:var(--ink-200);">
          Tidak ada paket aktif/draft lain yang bisa dijadikan target. Buat paket baru dulu di <a href="/admin/paket/new" style="color:var(--gold-300);">/admin/paket/new</a>.
        </div>
      <% } else { %>
        <%
          // Build per-paket kelas map for inline kelas-dropdown population
          const bulkPaketKelasMap = {};
          bulkReschedule.choices.forEach(function(p) {
            bulkPaketKelasMap[p.id] = p.prices.map(function(pr) { return { kelas: pr.kelas, priceIdr: pr.priceIdr }; });
          });
        %>
        <form method="POST" action="/admin/paket/<%= paket.slug %>/bulk-reschedule" id="bulk-reschedule-form" onsubmit="return confirm('Yakin pindahkan ' + <%= bulkReschedule.activeCount %> + ' booking ke paket baru? Tidak bisa di-undo.');">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:12px;">
            <div>
              <label class="label" for="bulk-target">Paket target</label>
              <select class="input" name="targetPaketId" id="bulk-target" required>
                <option value="">— pilih paket —</option>
                <% bulkReschedule.choices.forEach(function(p) { const sl = p.kursiTotal - p.kursiTerisi; %>
                  <option value="<%= p.id %>"><%= p.title %> · <%= fmt.dateShort(p.departureDate) %> · sisa <%= sl %>/<%= p.kursiTotal %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="label" for="bulk-kelas">Kelas semua</label>
              <select class="input" name="targetKelas" id="bulk-kelas" required disabled>
                <option value="">— pilih paket dulu —</option>
              </select>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);margin-top:4px;">Semua booking dipindah ke kelas ini di paket target.</div>
            </div>
          </div>

          <div style="margin-bottom:12px;">
            <label class="label" for="bulk-reason-code">Kategori alasan</label>
            <select class="input" name="reasonCode" id="bulk-reason-code">
              <option value="">— pilih kategori —</option>
              <option value="PAKET_FULL">Paket asal penuh</option>
              <option value="OPERATOR_INITIATED" selected>Inisiatif operator (vendor gagal, dll.)</option>
              <option value="DOCUMENT_DELAY">Dokumen telat (visa batch reject)</option>
              <option value="SCHEDULE_CONFLICT">Bentrok jadwal</option>
              <option value="OTHER">Lainnya</option>
            </select>
          </div>

          <div style="margin-bottom:12px;">
            <label class="label" for="bulk-reason">Alasan singkat (akan dilampirkan ke setiap booking)</label>
            <textarea class="input" name="reason" id="bulk-reason" rows="2" maxlength="500" placeholder="Mis. vendor catering bangkrut, semua dipindah ke paket berikutnya."></textarea>
          </div>

          <div style="margin-bottom:14px;padding:12px 14px;background:var(--ink-1000);border-left:3px solid var(--ruby);border-radius:var(--r-sm);">
            <label style="display:block;font-family:var(--font-mono);font-size:10px;color:var(--ruby);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">Konfirmasi (ketik <code style="color:var(--gold-300);background:var(--ink-900);padding:1px 6px;border-radius:3px;"><%= paket.slug %></code>)</label>
            <input type="text" class="input" name="confirmSlug" required pattern="<%= paket.slug %>" placeholder="Ketik slug paket persis" autocomplete="off"
                   style="font-family:var(--font-mono);font-size:13px;color:var(--ruby);">
          </div>

          <button type="submit" class="btn btn--danger" style="padding:12px 22px;">
            ⚠ Bulk reschedule <%= bulkReschedule.activeCount %> booking
          </button>
        </form>

        <script>
          (function () {
            const PAKET_KELAS = <%- JSON.stringify(bulkPaketKelasMap) %>;
            const sel = document.getElementById('bulk-target');
            const kelas = document.getElementById('bulk-kelas');
            sel.addEventListener('change', function () {
              const choices = PAKET_KELAS[sel.value] || [];
              kelas.innerHTML = '<option value="">— pilih kelas —</option>';
              choices.forEach(function (c) {
                const opt = document.createElement('option');
                opt.value = c.kelas;
                opt.textContent = c.kelas + ' · Rp ' + Math.round(Number(c.priceIdr)).toLocaleString('id-ID');
                kelas.appendChild(opt);
              });
              kelas.disabled = choices.length === 0;
            });
          })();
        </script>
      <% } %>
    </div>
  <% } %>

  <% if (mode === 'edit') { %>
    <form id="archive-form" method="POST" action="/admin/paket/<%= paket.slug %>/delete" style="display:none;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"></form>
  <% } %>
</div>

<% if (mode === 'edit') { %>
<!-- Hotel modal -->

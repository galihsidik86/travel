<!-- Clone modal (stage 18) -->
<div class="modal-overlay" id="clone-modal" aria-hidden="true">
  <div class="modal">
    <h2>Clone paket untuk musim berikutnya</h2>
    <div class="sub-m">
      Hotels + Days + Prices akan disalin. Booking, kursi terisi, dan kamar TIDAK ikut. Paket baru landing di status <strong>DRAFT</strong>.
    </div>
    <div class="err-m" id="clone-err"></div>

    <form id="clone-form">
      <div class="field">
        <div class="label-row"><label class="label" for="cl-slug">Slug baru *</label></div>
        <input class="input" id="cl-slug" name="newSlug" required
               value="<%= paket.slug %>-2027" placeholder="paket-ramadhan-2027">
        <div class="helper">huruf kecil + strip. Harus unik.</div>
      </div>
      <div class="field">
        <div class="label-row"><label class="label" for="cl-title">Judul baru *</label></div>
        <input class="input" id="cl-title" name="newTitle" required
               value="<%= paket.title %>" placeholder="mis. Ramadhan Aqsa 2027">
      </div>
      <div class="grid-2">
        <div class="field">
          <div class="label-row"><label class="label" for="cl-dep">Tanggal berangkat baru *</label></div>
          <input class="input" id="cl-dep" name="newDepartureDate" type="date" required>
        </div>
        <div class="field">
          <div class="label-row"><label class="label" for="cl-ret">Tanggal pulang (opsional)</label></div>
          <input class="input" id="cl-ret" name="newReturnDate" type="date">
          <div class="helper">Kosongkan = otomatis (berangkat + durationDays).</div>
        </div>
      </div>
      <div class="field" style="margin-bottom:8px;">
        <label class="check-row" style="margin:0;">
          <input type="checkbox" name="includeAgentOverrides" id="cl-agen"> Ikut salin override komisi per-agen
        </label>
        <div class="helper">Pakai kalau agen yang sama dapat rate khusus di musim baru. Skip kalau matrix akan di-ulang dari nol.</div>
      </div>

      <div class="modal-actions" style="display:flex;justify-content:flex-end;gap:10px;margin-top:18px;">
        <button type="button" class="btn btn--ghost" id="cl-cancel">Batal</button>
        <button type="submit" class="btn btn--primary">Clone sekarang</button>
      </div>

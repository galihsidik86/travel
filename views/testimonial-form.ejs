<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Testimonial <%= mode === 'new' ? 'Baru' : 'Edit' %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 880px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  h1 { font-family: var(--font-display); font-size: 32px; font-weight: 500; color: var(--cream-100); margin: 0 0 20px; }
  .panel { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 24px; margin-bottom: 18px; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .field { margin-bottom: 14px; }
  .label { display: block; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
  .input { width: 100%; padding: 10px 12px; background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); color: var(--cream-100); font-size: 13px; box-sizing: border-box; }
  .input:focus { outline: 1px solid var(--gold-300); }
  textarea.input { resize: vertical; font-family: var(--font-body); }
  select.input { background-color: var(--ink-1000); color: var(--cream-100); }
  .helper { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 4px; }
  .field-err { font-family: var(--font-mono); font-size: 10.5px; color: var(--ruby); margin-top: 4px; }
  .form-error { padding: 10px 14px; border-radius: var(--r-sm); font-family: var(--font-mono); font-size: 11.5px; margin-bottom: 14px; background: rgba(181,86,74,0.08); border: 1px solid rgba(181,86,74,0.4); color: var(--ruby); }
  .ok-banner { padding: 10px 14px; border-radius: var(--r-sm); font-family: var(--font-mono); font-size: 11.5px; margin-bottom: 14px; background: rgba(74,143,109,0.08); border: 1px solid rgba(74,143,109,0.4); color: var(--emerald); }
  .actions { display: flex; gap: 10px; justify-content: flex-end; }
  .btn { padding: 10px 18px; border: 0; border-radius: 3px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
  .btn--primary { background: var(--gold-300); color: var(--ink-1000); }
  .btn--danger { background: transparent; border: 1px solid var(--ruby); color: var(--ruby); }
</style>
</head>
<body data-screen-label="02 Admin · Testimonial form">
<div class="wrap">
  <div class="crumb"><a href="/admin/testimonials">← KEMBALI</a></div>
  <h1><%= mode === 'new' ? 'Tambah testimonial' : 'Edit testimonial' %></h1>
  <%
    const okFromQuery = mode === 'edit' && (t.id) ? null : null;
  %>
  <% if (formError) { %><div class="form-error"><%= formError %></div><% } %>

  <form method="POST" action="<%= mode === 'new' ? '/admin/testimonials' : '/admin/testimonials/' + t.id %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="panel">
      <div class="grid-2">
        <div class="field">
          <label class="label" for="f-name">Nama jemaah *</label>
          <input class="input" id="f-name" name="jemaahName" maxlength="120" required value="<%= t.jemaahName || '' %>">
          <% if (errors.jemaahName) { %><div class="field-err"><%= errors.jemaahName %></div><% } %>
        </div>
        <div class="field">
          <label class="label" for="f-city">Kota (opsional)</label>
          <input class="input" id="f-city" name="jemaahCity" maxlength="120" value="<%= t.jemaahCity || '' %>" placeholder="mis. Jakarta">
        </div>
      </div>
      <div class="field">
        <label class="label" for="f-body">Isi testimonial * (10–2000 karakter)</label>
        <textarea class="input" id="f-body" name="body" rows="6" maxlength="2000" required><%= t.body || '' %></textarea>
        <% if (errors.body) { %><div class="field-err"><%= errors.body %></div><% } %>
      </div>
      <div class="grid-2">
        <div class="field">
          <label class="label" for="f-rating">Rating (1-5) *</label>
          <select class="input" id="f-rating" name="rating">
            <% [5, 4, 3, 2, 1].forEach(function(r) { %>
              <option value="<%= r %>" <%= Number(t.rating) === r ? 'selected' : '' %>><%= '★'.repeat(r) %> (<%= r %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="field">
          <label class="label" for="f-photo">Photo URL (opsional)</label>
          <input class="input" id="f-photo" name="photoUrl" maxlength="255" value="<%= t.photoUrl || '' %>" placeholder="/uploads/testimonials/jemaah.jpg">
          <div class="helper">Path relatif. Letakkan file di /uploads/testimonials/.</div>
        </div>
      </div>
      <div class="grid-2">
        <div class="field">
          <label class="label" for="f-paket">Paket (opsional)</label>
          <select class="input" id="f-paket" name="paketId">
            <option value="" <%= !t.paketId ? 'selected' : '' %>>— semua paket —</option>
            <% paketOptions.forEach(function(p) { %>
              <option value="<%= p.id %>" <%= t.paketId === p.id ? 'selected' : '' %>><%= p.title %></option>
            <% }) %>
          </select>
          <div class="helper">Pilih paket spesifik atau biarkan kosong untuk tampil di semua landing.</div>
        </div>
        <div class="field">
          <label class="label" for="f-status">Status</label>
          <select class="input" id="f-status" name="status">
            <option value="DRAFT" <%= t.status === 'DRAFT' ? 'selected' : '' %>>DRAFT (tidak publik)</option>
            <option value="PUBLISHED" <%= t.status === 'PUBLISHED' ? 'selected' : '' %>>PUBLISHED (tampil di /p/:slug)</option>
          </select>
        </div>
      </div>
      <div class="field">
        <label class="label" for="f-sort">Urutan tampil (sortOrder)</label>
        <input class="input" type="number" id="f-sort" name="sortOrder" value="<%= t.sortOrder ?? 0 %>" min="-1000" max="1000">
        <div class="helper">Angka kecil tampil duluan. Default 0.</div>
      </div>
    </div>
    <div class="actions">
      <% if (mode === 'edit' && t.id) { %>
        <button type="button" class="btn btn--danger"
                onclick="if(confirm('Hapus testimonial ini permanen?')) document.getElementById('del-form').submit();">
          HAPUS
        </button>
      <% } %>
      <button type="submit" class="btn btn--primary">SIMPAN</button>
    </div>
  </form>

  <% if (mode === 'edit' && t.id) { %>
    <form id="del-form" method="POST" action="/admin/testimonials/<%= t.id %>/delete" style="display:none;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    </form>
  <% } %>
</div>
</body>
</html>

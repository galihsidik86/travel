<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Audit Log</title>
<link rel="stylesheet" href="/shared/tokens.css">
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1400px; margin: 0 auto; padding: 32px 40px 80px; }

  .crumb {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 20px;
  }
  .crumb a { color: var(--gold-300); text-decoration: none; }

  .head { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: end; }
  .head h1 {
    font-family: var(--font-display); font-size: 40px; font-weight: 500;
    color: var(--cream-100); margin: 0; letter-spacing: -0.015em;
  }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em; margin-top: 8px;
  }
  .head .pager {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-100); letter-spacing: 0.08em;
  }

  .filter-bar {
    display: grid; grid-template-columns: repeat(6, 1fr) auto auto; gap: 8px;
    margin-bottom: 18px; align-items: end;
  }
  .filter-bar .field-mini { display: flex; flex-direction: column; gap: 4px; }
  .filter-bar .lbl {
    font-family: var(--font-mono); font-size: 9.5px;
    color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase;
  }
  .filter-bar .input { padding: 7px 10px; font-size: 12px; }
  .filter-bar select.input { background-color: var(--ink-1000); color: var(--cream-100); }
  .filter-bar .btn { padding: 7px 14px; font-size: 12px; }

  .tbl {
    width: 100%; border-collapse: collapse;
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); overflow: hidden;
  }
  .tbl thead th {
    text-align: left; padding: 12px 14px;
    background: var(--ink-1000);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-200); font-weight: 500;
    border-bottom: var(--hairline);
  }
  .tbl tbody td {
    padding: 11px 14px; border-bottom: var(--hairline-soft);
    font-size: 12.5px; color: var(--cream-200); vertical-align: middle;
  }
  .tbl tbody tr:hover td { background: var(--ink-850); }
  .tbl tbody tr:last-child td { border-bottom: 0; }
  .tbl .id { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .tbl .sx { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; letter-spacing: 0.04em; }
  .tbl .time { font-family: var(--font-mono); font-size: 11px; color: var(--cream-100); white-space: nowrap; }
  .tbl .action-tag {
    padding: 2px 7px; font-family: var(--font-mono); font-size: 9.5px;
    background: var(--ink-1000); border: var(--hairline-soft);
    color: var(--ink-100); border-radius: 3px;
    letter-spacing: 0.1em;
  }
  .tbl .action-tag.create  { color: var(--emerald); border-color: rgba(74,143,109,0.3); }
  .tbl .action-tag.update  { color: var(--gold-300); border-color: rgba(212,175,55,0.3); }
  .tbl .action-tag.delete  { color: var(--ruby); border-color: rgba(181,86,74,0.3); }
  .tbl .action-tag.login   { color: var(--sapphire); border-color: rgba(74,111,143,0.3); }
  .tbl .action-tag.logout  { color: var(--ink-200); }
  .tbl .action-tag.password_change { color: var(--amber); border-color: rgba(201,147,59,0.3); }
  .tbl .action-tag.payment_received { color: var(--emerald); border-color: rgba(74,143,109,0.4); }
  .tbl .action-tag.status_change   { color: var(--gold-300); border-color: rgba(212,175,55,0.3); }
  .tbl .entity-tag {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--cream-100); letter-spacing: 0.05em;
  }
  .tbl a.view-btn {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-100); padding: 4px 12px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
  }
  .tbl a.view-btn:hover { color: var(--gold-300); border-color: var(--gold-300); }

  .empty {
    padding: 40px; text-align: center;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200);
  }

  .pagination {
    margin-top: 20px; display: flex; justify-content: center;
    align-items: center; gap: 12px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-100); letter-spacing: 0.08em;
  }
  .pagination a, .pagination span {
    padding: 6px 12px;
    border-radius: 3px;
    background: var(--ink-900); border: var(--hairline-soft);
    color: var(--ink-100); text-decoration: none;
    font-size: 11px; letter-spacing: 0.1em;
  }
  .pagination a:hover { color: var(--gold-300); border-color: var(--gold-300); }
  .pagination span.current { color: var(--gold-300); border-color: var(--gold-300); }
  .pagination span.disabled { opacity: 0.4; cursor: not-allowed; }
</style>
</head>
<body data-screen-label="02 Admin · Audit">
<div class="wrap">

  <div class="crumb">
    <a href="/admin">← KEMBALI KE DASHBOARD</a>
  </div>

  <div class="head">
    <div>
      <h1>Audit <em>log</em></h1>
      <div class="sub"><%= total %> entri · append-only</div>
    </div>
    <div class="pager">
      Halaman <strong style="color:var(--gold-300);"><%= page %></strong> / <%= totalPages %>
    </div>
  </div>

  <!-- Activity sparkline + per-action breakdown -->
  <%
    const act = activity;
    const maxCount = Math.max(1, ...act.daily.map(function(d) { return d.count; }));
    const SW = 1320, SH = 80, SP = 6;
    const stepX = (SW - SP * 2) / Math.max(1, act.daily.length - 1);
    const linePoints = act.daily.map(function(d, i) {
      const y = SH - SP - (d.count / maxCount) * (SH - SP * 2);
      return (SP + i * stepX).toFixed(1) + ',' + y.toFixed(1);
    }).join(' ');
    const areaPoints = SP + ',' + (SH - SP) + ' '
      + linePoints + ' '
      + (SP + (act.daily.length - 1) * stepX).toFixed(1) + ',' + (SP + (SH - SP * 2)).toFixed(1);
    // Per-action totals — display top 6
    const actEntries = Object.entries(act.actionTotals)
      .sort(function(a, b) { return b[1] - a[1]; })
      .slice(0, 8);
    function colorForAction(a) {
      const map = {
        CREATE: 'var(--emerald)',
        UPDATE: 'var(--gold-300)',
        DELETE: 'var(--ruby)',
        LOGIN: 'var(--sapphire)',
        LOGOUT: 'var(--ink-300)',
        PASSWORD_CHANGE: 'var(--amber)',
        PAYMENT_RECEIVED: 'var(--emerald)',
        STATUS_CHANGE: 'var(--gold-200)',
      };
      return map[a] || 'var(--ink-200)';
    }
  %>
  <div style="background:var(--ink-900);border:var(--hairline);border-radius:var(--r-md);padding:18px 22px;margin-bottom:18px;">
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;">
      <div>
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Aktivitas · <%= act.rangeDays %> hari</div>
        <div style="font-family:var(--font-display);font-size:22px;color:var(--cream-100);margin-top:4px;font-weight:500;">
          <span style="color:var(--gold-300);"><%= act.totalCount %></span> entri
        </div>
      </div>
      <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.06em;">
        <%= fmt.dateShort(act.rangeFrom) %> → <%= fmt.dateShort(act.rangeTo) %>
      </div>
    </div>
    <% if (act.totalCount === 0) { %>
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:16px 0;">
        Tidak ada aktivitas di rentang ini.
      </div>
    <% } else { %>
      <svg viewBox="0 0 <%= SW %> <%= SH %>" preserveAspectRatio="none" style="width:100%;height:<%= SH %>px;display:block;">
        <polygon points="<%= areaPoints %>" fill="rgba(212,175,55,0.10)"/>
        <polyline points="<%= linePoints %>" fill="none" stroke="var(--gold-300)" stroke-width="1.5"/>
        <% act.daily.forEach(function(d, i) {
          if (d.count === 0) return;
          const y = SH - SP - (d.count / maxCount) * (SH - SP * 2);
          const x = SP + i * stepX;
        %>
          <circle cx="<%= x.toFixed(1) %>" cy="<%= y.toFixed(1) %>" r="2.2" fill="var(--gold-300)">
            <title><%= d.date %>: <%= d.count %> entri</title>
          </circle>
        <% }) %>
      </svg>
      <% if (actEntries.length > 0) { %>
        <div style="display:flex;flex-wrap:wrap;gap:8px 14px;margin-top:12px;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);letter-spacing:0.04em;">
          <% actEntries.forEach(function(e) { %>
            <span style="display:inline-flex;align-items:center;gap:6px;">
              <span style="width:8px;height:8px;border-radius:2px;background:<%= colorForAction(e[0]) %>;"></span>
              <%= e[0] %>
              <span style="color:var(--cream-100);font-weight:600;"><%= e[1] %></span>
            </span>
          <% }) %>
        </div>
      <% } %>
    <% } %>
  </div>

  <form method="GET" action="/admin/audit" class="filter-bar">
    <div class="field-mini">
      <span class="lbl">Entity</span>
      <select class="input" name="entity">
        <option value="ALL">All</option>
        <% ENTITIES.forEach(function(e) { %>
          <option value="<%= e %>" <%= filters.entity === e ? 'selected' : '' %>><%= e %></option>
        <% }) %>
      </select>
    </div>
    <div class="field-mini">
      <span class="lbl">Action</span>
      <select class="input" name="action">
        <option value="ALL">All</option>
        <% ACTIONS.forEach(function(a) { %>
          <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a %></option>
        <% }) %>
      </select>
    </div>
    <div class="field-mini">
      <span class="lbl">Actor email</span>
      <input class="input" name="actorEmail" value="<%= filters.actorEmail %>" placeholder="cari email…">
    </div>
    <div class="field-mini">
      <span class="lbl">Dari</span>
      <input class="input" type="date" name="from" value="<%= filters.from %>">
    </div>
    <div class="field-mini">
      <span class="lbl">Sampai</span>
      <input class="input" type="date" name="to" value="<%= filters.to %>">
    </div>
    <div></div>
    <button type="submit" class="btn btn--primary">Filter</button>
    <a href="/admin/audit" class="btn btn--ghost">Reset</a>
    <%
      // S138 — CSV export preserves current filter scope. Server caps at
      // 90d / 50k rows; admin pre-narrows via existing filters.
      const exportQs = new URLSearchParams();
      if (filters.entity !== 'ALL') exportQs.set('entity', filters.entity);
      if (filters.action !== 'ALL') exportQs.set('action', filters.action);
      if (filters.actorEmail) exportQs.set('actorEmail', filters.actorEmail);
      if (filters.from) exportQs.set('from', filters.from);
      if (filters.to) exportQs.set('to', filters.to);
      const exportHref = '/admin/audit/export.csv' + (exportQs.toString() ? '?' + exportQs.toString() : '');
    %>
    <a href="<%= exportHref %>" class="btn btn--ghost" title="Download CSV — 7 hari terakhir secara default, cap 90 hari / 50k baris.">⇩ CSV</a>
  </form>

  <table class="tbl">
    <thead>
      <tr>
        <th style="width:140px;">Waktu</th>
        <th style="width:130px;">Aksi</th>
        <th>Entity</th>
        <th>Actor</th>
        <th>IP</th>
        <th style="text-align:right;width:80px;">Detail</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="6" class="empty">Tidak ada entri yang cocok dengan filter.</td></tr>
      <% } %>
      <% rows.forEach(function(r) { %>
        <tr>
          <td>
            <div class="time"><%= fmt.date(r.createdAt) %></div>
            <div class="sx"><%= new Date(r.createdAt).toISOString().slice(11, 19) %></div>
          </td>
          <td><span class="action-tag <%= r.action.toLowerCase() %>"><%= r.action %></span></td>
          <td>
            <div class="entity-tag"><%= r.entity %></div>
            <% if (r.entityId) { %>
              <div class="sx">id <%= r.entityId.slice(-10) %></div>
            <% } %>
          </td>
          <td>
            <% if (r.actorEmail) { %>
              <div style="color:var(--cream-100);font-size:12.5px;"><%= r.actorEmail %></div>
              <div class="sx"><%= r.actorRole || '—' %></div>
            <% } else { %>
              <span class="sx">sistem / anonim</span>
            <% } %>
          </td>
          <td><span class="sx" style="color:var(--cream-200);"><%= r.ip || '—' %></span></td>
          <td style="text-align:right;">
            <a class="view-btn" href="/admin/audit/<%= r.id %>">VIEW</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <%
    // Build pagination URL preserving filters
    const qs = new URLSearchParams();
    if (filters.entity !== 'ALL') qs.set('entity', filters.entity);
    if (filters.action !== 'ALL') qs.set('action', filters.action);
    if (filters.actorEmail) qs.set('actorEmail', filters.actorEmail);
    if (filters.from) qs.set('from', filters.from);
    if (filters.to) qs.set('to', filters.to);
    function pageUrl(p) { const q = new URLSearchParams(qs); q.set('page', p); return '/admin/audit?' + q.toString(); }
  %>
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="<%= pageUrl(1) %>">« First</a>
        <a href="<%= pageUrl(page - 1) %>">‹ Prev</a>
      <% } else { %>
        <span class="disabled">« First</span>
        <span class="disabled">‹ Prev</span>
      <% } %>
      <span class="current">Hal <%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="<%= pageUrl(page + 1) %>">Next ›</a>
        <a href="<%= pageUrl(totalPages) %>">Last »</a>
      <% } else { %>
        <span class="disabled">Next ›</span>
        <span class="disabled">Last »</span>
      <% } %>
    </div>
  <% } %>
</div>
</body>
</html>

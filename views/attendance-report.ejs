<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Absensi · <%= paket.title %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head h1 { font-family: var(--font-display); font-size: 30px; font-weight: 500; color: var(--cream-100); margin: 0; letter-spacing: -0.015em; }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.08em; margin-top: 8px; }
  .head { margin-bottom: 24px; }

  .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 26px; }
  .kpi { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); padding: 16px 18px; }
  .kpi .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
  .kpi .v { font-family: var(--font-display); font-size: 26px; color: var(--cream-100); margin-top: 6px; font-weight: 500; }
  .kpi .v.gold { color: var(--gold-300); }

  .panel { background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); margin-bottom: 24px; overflow: hidden; }
  .panel .ph { padding: 18px 22px; border-bottom: var(--hairline); }
  .panel .ph h3 { font-family: var(--font-display); font-size: 19px; font-weight: 500; color: var(--cream-100); margin: 0 0 4px; }
  .panel .ph .pn { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.06em; margin: 0; }

  .tbl { width: 100%; border-collapse: collapse; }
  .tbl thead th { text-align: left; padding: 10px 14px; background: var(--ink-1000); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); font-weight: 500; border-bottom: var(--hairline); }
  .tbl tbody td { padding: 11px 14px; border-bottom: var(--hairline-soft); font-size: 12.5px; color: var(--cream-200); vertical-align: middle; }
  .tbl tbody tr:hover td { background: var(--ink-850); }
  .tbl tbody tr:last-child td { border-bottom: 0; }
  .tbl .id { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .tbl .nm { color: var(--cream-100); font-weight: 500; }
  .tbl .sx { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; }
  .tbl .num { font-family: var(--font-mono); text-align: right; }

  .meter {
    display: inline-block; vertical-align: middle;
    width: 100px; height: 6px; background: var(--ink-1000);
    border: 1px solid var(--ink-700); border-radius: 3px; overflow: hidden;
    margin-right: 8px;
  }
  .meter > i {
    display: block; height: 100%;
    background: linear-gradient(90deg, var(--ruby) 0%, var(--amber) 50%, var(--emerald) 100%);
  }
  .rate { font-family: var(--font-mono); font-size: 11.5px; min-width: 40px; display: inline-block; }
  .rate.ok   { color: var(--emerald); }
  .rate.warn { color: var(--amber); }
  .rate.bad  { color: var(--ruby); }
  .rate.none { color: var(--ink-300); }

  .empty { padding: 40px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); }
</style>
</head>
<body data-screen-label="02 Admin · Attendance Report">
<div class="wrap">
  <div class="crumb"><a href="/admin/paket/<%= paket.slug %>/edit">← KEMBALI KE EDIT PAKET</a></div>

  <div class="head">
    <h1>Absensi <em>jemaah</em></h1>
    <div class="sub">
      <%= paket.title %> · DEP <%= fmt.dateLong(paket.departureDate) %> · <%= paket.durationDays %> hari
    </div>
  </div>

  <%
    // Cross-paket totals for the KPI strip
    const totalMarks = bookings.reduce((s, b) => s + b.daysMarked, 0);
    const totalPresent = bookings.reduce((s, b) => s + b.daysPresent, 0);
    const overallPct = totalDays * totalActive === 0 ? 0
      : Math.round((totalPresent / (totalDays * totalActive)) * 100);
    function rateClass(pct, marked) {
      if (marked === 0) return 'none';
      if (pct >= 80) return 'ok';
      if (pct >= 50) return 'warn';
      return 'bad';
    }
  %>

  <div class="kpi-row">
    <div class="kpi"><div class="l">Jemaah aktif</div><div class="v gold"><%= totalActive %></div></div>
    <div class="kpi"><div class="l">Itinerary days</div><div class="v"><%= totalDays %></div></div>
    <div class="kpi"><div class="l">Total ditandai</div><div class="v"><%= totalMarks %> / <%= totalActive * totalDays %></div></div>
    <div class="kpi"><div class="l">Rate keseluruhan</div><div class="v <%= overallPct >= 80 ? 'gold' : '' %>"><%= overallPct %>%</div></div>
  </div>

  <!-- Per-day summary -->
  <div class="panel">
    <div class="ph">
      <h3>Per hari</h3>
      <p class="pn">Crew yang sudah menandai vs hadir, per itinerary day.</p>
    </div>
    <% if (days.length === 0) { %>
      <div class="empty">Paket ini belum punya itinerary day.</div>
    <% } else { %>
      <table class="tbl">
        <thead>
          <tr>
            <th style="width:70px;">Hari</th>
            <th>Judul</th>
            <th style="width:130px;">Tanggal</th>
            <th class="num" style="width:110px;">Ditandai</th>
            <th class="num" style="width:110px;">Hadir</th>
            <th style="width:220px;">Rate hadir</th>
          </tr>
        </thead>
        <tbody>
          <% days.forEach(function(d) {
            const pct = d.totalActive === 0 ? 0 : Math.round((d.presentCount / d.totalActive) * 100);
            const cls = rateClass(pct, d.markedCount);
          %>
            <tr>
              <td class="nm">#<%= d.dayNumber %></td>
              <td>
                <div class="nm"><%= d.title %></div>
              </td>
              <td class="sx"><%= d.dateLabel || '—' %><% if (d.monthLabel) { %> <%= d.monthLabel %><% } %></td>
              <td class="num"><%= d.markedCount %> / <%= d.totalActive %></td>
              <td class="num"><%= d.presentCount %></td>
              <td>
                <span class="meter"><i style="width:<%= pct %>%;"></i></span>
                <span class="rate <%= cls %>"><%= pct %>%</span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- Per-jemaah summary -->
  <div class="panel">
    <div class="ph">
      <h3>Per jemaah</h3>
      <p class="pn">Rate kehadiran tiap jemaah dari total <%= totalDays %> hari itinerary. Hari belum-ditandai dihitung sebagai tidak hadir.</p>
    </div>
    <% if (bookings.length === 0) { %>
      <div class="empty">Tidak ada booking aktif untuk paket ini.</div>
    <% } else { %>
      <table class="tbl">
        <thead>
          <tr>
            <th>Jemaah</th>
            <th style="width:90px;">Kelas</th>
            <th class="num" style="width:110px;">Hadir</th>
            <th class="num" style="width:110px;">Ditandai</th>
            <th style="width:220px;">Rate hadir</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(function(b) {
            const cls = rateClass(b.attendanceRatePct, b.daysMarked);
          %>
            <tr>
              <td>
                <div class="nm"><%= b.jemaah.fullName %></div>
                <div class="sx"><a href="/admin/bookings/<%= b.id %>" style="color:var(--gold-300);text-decoration:none;"><%= b.bookingNo %></a> · <%= b.jemaah.phone %></div>
              </td>
              <td><%= b.kelas %></td>
              <td class="num"><%= b.daysPresent %> / <%= b.daysTotal %></td>
              <td class="num"><%= b.daysMarked %></td>
              <td>
                <span class="meter"><i style="width:<%= b.attendanceRatePct %>%;"></i></span>
                <span class="rate <%= cls %>"><%= b.attendanceRatePct %>%</span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
</body>
</html>

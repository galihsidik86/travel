<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>RELIGIO PRO — Ibadah</title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head') %>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 640px; margin: 0 auto; padding: 24px 18px 100px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 18px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  h1 { font-family: var(--font-display); font-size: 28px; color: var(--cream-100); margin: 0 0 6px; letter-spacing: -0.01em; }
  h1 em { font-style: italic; color: var(--gold-300); }
  .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.06em; margin-bottom: 24px; line-height: 1.6; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .card {
    display: block; text-decoration: none;
    background: var(--ink-900); border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md); padding: 22px 18px;
    transition: transform 80ms ease, border-color 120ms ease, background 120ms ease;
  }
  .card:active { transform: scale(0.98); }
  .card:hover { border-color: var(--gold-300); background: rgba(212,175,107,0.04); }
  .card .lbl { font-family: var(--font-mono); font-size: 10px; color: var(--gold-300); letter-spacing: 0.14em; text-transform: uppercase; }
  .card .title { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin: 6px 0 8px; letter-spacing: -0.01em; }
  .card .desc { font-family: var(--font-body); font-size: 12.5px; color: var(--ink-100); line-height: 1.5; min-height: 38px; }
  .card .state { margin-top: 12px; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.06em; }
  .card .state.complete { color: var(--emerald); }
  .card .progress-bar { height: 4px; background: var(--ink-700); border-radius: 2px; overflow: hidden; margin-top: 6px; }
  .card .progress-bar > div { height: 100%; background: var(--gold-300); transition: width 200ms ease; }
  .info {
    margin-top: 22px; padding: 14px 16px;
    background: rgba(120,135,225,0.06); border: 1px solid var(--sapphire);
    border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px; color: var(--cream-100);
    line-height: 1.6;
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
    .card .desc { min-height: 0; }
  }
</style>
</head>
<body class="has-m-tabs">
  <div class="wrap">
    <a class="btn-back" href="/saya">Dashboard</a>
    <h1>Penghitung <em>ibadah</em></h1>
    <div class="sub">
      Hitung Thawaf, Sa'i, Tasbih, Jumrah, dan Wukuf — semua tanpa kehilangan
      count. Bekerja offline · data tersimpan di perangkat Anda.
    </div>

    <div class="grid">
      <a href="/saya/ibadah/thawaf" class="card" id="thawaf-card">
        <div class="lbl">7 putaran</div>
        <div class="title">Thawaf</div>
        <div class="desc">Mengelilingi Ka'bah 7 kali, dimulai &amp; berakhir di Hajar Aswad.</div>
        <div class="state" id="thawaf-state">— belum ada data —</div>
        <div class="progress-bar"><div id="thawaf-bar" style="width:0%"></div></div>
      </a>
      <a href="/saya/ibadah/sai" class="card" id="sai-card">
        <div class="lbl">7 trip</div>
        <div class="title">Sa'i</div>
        <div class="desc">Berjalan antara Safa &amp; Marwah sebanyak 7 trip.</div>
        <div class="state" id="sai-state">— belum ada data —</div>
        <div class="progress-bar"><div id="sai-bar" style="width:0%"></div></div>
      </a>
      <%# Stage 370 — Wukuf timer card. State derived from localStorage. %>
      <a href="/saya/ibadah/wukuf" class="card" id="wukuf-card">
        <div class="lbl">9 Dzulhijjah</div>
        <div class="title">Wukuf</div>
        <div class="desc">Countdown ke wukuf di Arafah — rukun haji paling penting.</div>
        <div class="state" id="wukuf-state">— belum diatur —</div>
      </a>
      <%# Stage 371 — Tasbih counter card. Standard 33+33+33 + Bebas mode. %>
      <a href="/saya/ibadah/tasbih" class="card" id="tasbih-card">
        <div class="lbl">33+33+33</div>
        <div class="title">Tasbih</div>
        <div class="desc">SubhanAllah · Alhamdulillah · Allahu Akbar pasca-shalat.</div>
        <div class="state" id="tasbih-state">— belum mulai —</div>
        <div class="progress-bar"><div id="tasbih-bar" style="width:0%"></div></div>
      </a>
      <%# Stage 372 — Jumrah counter card. 4 hari × per-jamarat × 7 batu. %>
      <a href="/saya/ibadah/jumrah" class="card" id="jumrah-card">
        <div class="lbl">7 × 7 batu</div>
        <div class="title">Jumrah</div>
        <div class="desc">Pelontaran 10–13 Dzulhijjah · 70 batu total dalam 4 hari.</div>
        <div class="state" id="jumrah-state">— belum mulai —</div>
        <div class="progress-bar"><div id="jumrah-bar" style="width:0%"></div></div>
      </a>
      <%# Stage 376 — Qibla compass card. State derived live from device. %>
      <a href="/saya/ibadah/qibla" class="card">
        <div class="lbl">Arah ka'bah</div>
        <div class="title">Qibla</div>
        <div class="desc">Kompas penunjuk arah kiblat — geolokasi + sensor orientasi ponsel.</div>
        <div class="state">— buka untuk aktifkan —</div>
      </a>
      <%# Stage 377 — Prayer time schedule card. State painted with next-prayer
          on page load via inline script below. %>
      <a href="/saya/ibadah/jadwal-shalat" class="card" id="jadwal-card">
        <div class="lbl">5 waktu</div>
        <div class="title">Jadwal Shalat</div>
        <div class="desc">Perkiraan jadwal 5 shalat berdasar lokasi GPS Anda.</div>
        <div class="state" id="jadwal-state">— buka untuk hitung —</div>
      </a>
    </div>

    <%# Stage 333 — daily doa widget. Pure client-side; cycled by
        day-of-year so the same jemaah sees a different doa each day.
        Stage 388 — audio playback via Web Speech TTS (3 lang buttons:
        Arabic, Latin pronunciation, Indonesian translation). %>
    <div class="doa-card" style="margin-top:22px;">
      <div class="doa-eyebrow">✨ Doa hari ini</div>
      <div id="doa-title" class="doa-title">—</div>
      <div id="doa-arabic" class="doa-arabic">—</div>
      <div id="doa-latin" class="doa-latin">—</div>
      <div id="doa-id" class="doa-id"></div>

      <%# Audio bar — gold play buttons per language. Hidden when
          SpeechSynthesis unsupported (older browsers). %>
      <div id="doa-audio" class="doa-audio-bar" style="display:none;">
        <span class="doa-audio-lbl">Dengarkan:</span>
        <button type="button" class="doa-play" data-lang="ar-SA" data-source="arabic" aria-label="Putar Arabic">
          <span class="ic">▶</span><span class="lbl">Arab</span>
        </button>
        <button type="button" class="doa-play" data-lang="id-ID" data-source="latin" aria-label="Putar latin">
          <span class="ic">▶</span><span class="lbl">Latin</span>
        </button>
        <button type="button" class="doa-play" data-lang="id-ID" data-source="translation" aria-label="Putar terjemahan">
          <span class="ic">▶</span><span class="lbl">Arti</span>
        </button>
      </div>
      <div id="doa-audio-hint" style="display:none;margin-top:8px;font-family:var(--font-mono);font-size:10px;color:var(--amber);letter-spacing:0.04em;"></div>

      <div style="margin-top:12px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.06em;">
        Doa berganti setiap hari · ada 11 doa dalam rotasi.
      </div>
    </div>

    <style>
      .doa-card {
        background:
          radial-gradient(60% 60% at 80% 0%, rgba(212,175,107,0.10), transparent 60%),
          linear-gradient(180deg, var(--ink-900), var(--ink-1000));
        border: 1px solid var(--gold-300);
        border-radius: var(--r-md);
        padding: 20px;
        position: relative;
        overflow: hidden;
      }
      .doa-card::after {
        content: ""; position: absolute;
        top: -40px; right: -40px;
        width: 120px; height: 120px;
        border: 1px solid var(--gold-300);
        border-radius: 50%;
        opacity: 0.15;
      }
      .doa-eyebrow {
        font-family: var(--font-mono); font-size: 10px;
        color: var(--gold-300); letter-spacing: 0.16em;
        text-transform: uppercase; margin-bottom: 8px;
        position: relative; z-index: 1;
      }
      .doa-title { font-family: var(--font-display); font-size: 17px; color: var(--cream-100); margin-bottom: 10px; line-height: 1.3; position: relative; z-index: 1; }
      .doa-arabic { font-family: 'Amiri', serif; font-size: 22px; color: var(--cream-100); text-align: right; direction: rtl; line-height: 2; margin-bottom: 10px; position: relative; z-index: 1; }
      .doa-latin { font-family: var(--font-body); font-style: italic; font-size: 13px; color: var(--ink-100); line-height: 1.6; margin-bottom: 8px; position: relative; z-index: 1; }
      .doa-id { font-family: var(--font-body); font-size: 13.5px; color: var(--cream-100); line-height: 1.6; position: relative; z-index: 1; }

      .doa-audio-bar {
        display: flex; align-items: center; gap: 10px;
        margin-top: 16px; padding-top: 14px;
        border-top: 1px solid rgba(212,175,107,0.2);
        position: relative; z-index: 2;
        flex-wrap: wrap;
      }
      .doa-audio-lbl {
        font-family: var(--font-mono); font-size: 10px;
        color: var(--ink-200); letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .doa-play {
        display: inline-flex; align-items: center; gap: 6px;
        background: transparent; border: 1px solid var(--gold-300);
        color: var(--gold-300); padding: 8px 14px;
        border-radius: var(--r-sm); cursor: pointer;
        font-family: var(--font-mono); font-size: 10.5px;
        letter-spacing: 0.1em; text-transform: uppercase;
        font-weight: 600; min-height: 38px;
        transition: background 180ms ease, color 180ms ease, box-shadow 180ms ease;
      }
      .doa-play .ic { font-size: 11px; line-height: 1; }
      .doa-play:hover, .doa-play:focus-visible {
        background: var(--gold-300); color: var(--ink-1000);
        box-shadow: 0 4px 12px rgba(212,175,107,0.25);
        outline: none;
      }
      .doa-play.is-playing {
        background: var(--gold-300); color: var(--ink-1000);
        animation: doa-pulse 1.4s ease-in-out infinite;
      }
      .doa-play.is-playing .ic::before { content: "■"; }
      .doa-play.is-playing .ic { font-size: 9px; }
      @keyframes doa-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(212,175,107,0.5); }
        50%      { box-shadow: 0 0 0 6px rgba(212,175,107,0); }
      }
      .doa-play:disabled { opacity: 0.4; cursor: not-allowed; }
      .doa-play:disabled:hover { background: transparent; color: var(--gold-300); box-shadow: none; }
    </style>

    <div class="info">
      <strong style="color:var(--sapphire);">Catatan:</strong> Penghitung ini adalah alat bantu — bukan pengganti niat &amp; doa yang dilantunkan
      langsung. Pastikan Anda tetap fokus pada zikir &amp; bacaan selama ibadah berlangsung.
    </div>
  </div>

  <script src="/shared/doa-harian.js"></script>
  <script src="/shared/doa-audio.js"></script>
  <script>
    (function () {
      let currentDoa = null;
      try {
        currentDoa = window.DoaHarian.getTodayDoa();
        if (!currentDoa) return;
        document.getElementById('doa-title').innerHTML = currentDoa.title;
        document.getElementById('doa-arabic').textContent = currentDoa.arabic;
        document.getElementById('doa-latin').textContent = '"' + currentDoa.latin + '"';
        document.getElementById('doa-id').textContent = currentDoa.translation;
      } catch (err) { console.warn('[doa-harian]', err); return; }

      // Stage 388 — TTS audio playback (Web Speech API). Reveal audio
      // bar only when supported; hide gracefully on older browsers.
      if (!window.DoaAudio || !window.DoaAudio.supported) return;
      const bar = document.getElementById('doa-audio');
      const hint = document.getElementById('doa-audio-hint');
      bar.style.display = 'flex';

      const buttons = bar.querySelectorAll('.doa-play');
      let playingBtn = null;

      function resetButton(btn) {
        if (!btn) return;
        btn.classList.remove('is-playing');
        const ic = btn.querySelector('.ic');
        if (ic) ic.textContent = '▶';
      }
      function markPlaying(btn) {
        if (playingBtn && playingBtn !== btn) resetButton(playingBtn);
        playingBtn = btn;
        btn.classList.add('is-playing');
      }

      // Voice availability check — Arabic TTS not always installed.
      function checkArabicAvailability() {
        const arBtn = bar.querySelector('.doa-play[data-source="arabic"]');
        if (!arBtn) return;
        if (!window.DoaAudio.hasArabic()) {
          arBtn.disabled = true;
          arBtn.title = 'Voice Arabic belum tersedia di device ini';
          hint.style.display = 'block';
          hint.textContent = '⚠ Voice Arabic belum terpasang di device ini — pakai Latin/Arti dulu, atau install bahasa Arab via OS Settings.';
        }
      }
      // Voices load async on some browsers — re-check after a delay.
      checkArabicAvailability();
      setTimeout(checkArabicAvailability, 800);

      buttons.forEach((btn) => {
        btn.addEventListener('click', async () => {
          // If this button is currently playing → stop (toggle).
          if (btn.classList.contains('is-playing')) {
            window.DoaAudio.stop();
            resetButton(btn);
            playingBtn = null;
            return;
          }
          const source = btn.dataset.source;
          const lang = btn.dataset.lang;
          const text = source === 'arabic' ? currentDoa.arabic
            : source === 'latin' ? currentDoa.latin
            : currentDoa.translation;
          markPlaying(btn);
          const result = await window.DoaAudio.play(text, {
            lang,
            // Latin transliteration not real Indonesian — slow it down so
            // the synthesised pronunciation is followable.
            rate: source === 'latin' ? 0.78 : 0.9,
            onEnd: () => resetButton(btn),
            onError: (reason) => {
              resetButton(btn);
              if (reason !== 'interrupted' && reason !== 'canceled') {
                hint.style.display = 'block';
                hint.textContent = '⚠ Gagal putar audio: ' + reason;
              }
            },
          });
          // Defensive: result may resolve before onEnd in some browsers.
          if (!result.ok && result.error && result.error !== 'interrupted' && result.error !== 'canceled') {
            resetButton(btn);
          }
        });
      });

      // Stop playback when user navigates away (otherwise voice keeps
      // speaking after page change in PWA).
      window.addEventListener('pagehide', () => window.DoaAudio.stop());
    })();
  </script>
  <script src="/shared/ibadah-counter.js"></script>
  <script>
    (async function () {
      async function paint(id, $state, $bar, max, labels) {
        try {
          const s = await IbadahCounter.getCounter(id);
          const complete = s.putaran >= max;
          const pct = Math.min(100, Math.round((s.putaran / max) * 100));
          $bar.style.width = pct + '%';
          if (complete) {
            $state.textContent = '✓ ' + labels.complete;
            $state.classList.add('complete');
          } else if (s.putaran === 0) {
            $state.textContent = '— belum mulai —';
          } else {
            $state.textContent = `Berjalan · ${s.putaran}/${max} ${labels.unit}`;
          }
        } catch (err) { console.warn(err); }
      }
      paint('thawaf', document.getElementById('thawaf-state'), document.getElementById('thawaf-bar'), 7, { unit: 'putaran', complete: '7 putaran tuntas' });
      paint('sai', document.getElementById('sai-state'), document.getElementById('sai-bar'), 7, { unit: 'trip', complete: '7 trip tuntas' });

      // S370 — Wukuf state from localStorage
      try {
        const $w = document.getElementById('wukuf-state');
        const s = localStorage.getItem('rp_wukuf_start');
        const e = localStorage.getItem('rp_wukuf_end');
        if (s && e) {
          const start = new Date(s); const end = new Date(e); const now = new Date();
          if (now < start) {
            const ms = start - now;
            const days = Math.floor(ms / 86_400_000);
            const hrs = Math.floor((ms % 86_400_000) / 3_600_000);
            $w.textContent = '⏳ ' + (days > 0 ? days + 'h ' + hrs + 'j' : hrs + 'j') + ' lagi';
          } else if (now < end) {
            $w.textContent = '✓ Sedang berlangsung';
            $w.classList.add('complete');
          } else {
            $w.textContent = '✓ Selesai · barakallahu fiikum';
            $w.classList.add('complete');
          }
        }
      } catch (_e) { /* localStorage may be private-mode */ }

      // S371 — Tasbih state (standard 33+33+33 totals)
      try {
        const $t = document.getElementById('tasbih-state');
        const $tb = document.getElementById('tasbih-bar');
        const states = await Promise.all([
          IbadahCounter.getCounter('tasbih_std_0'),
          IbadahCounter.getCounter('tasbih_std_1'),
          IbadahCounter.getCounter('tasbih_std_2'),
        ]);
        const total = states.reduce((sum, x) => sum + x.putaran, 0);
        const TARGET = 99;
        const pct = Math.min(100, Math.round((total / TARGET) * 100));
        $tb.style.width = pct + '%';
        if (total >= TARGET) {
          $t.textContent = '✓ 99 dzikir tuntas';
          $t.classList.add('complete');
        } else if (total === 0) {
          $t.textContent = '— belum mulai —';
        } else {
          $t.textContent = 'Berjalan · ' + total + '/' + TARGET + ' dzikir';
        }
      } catch (err) { console.warn(err); }

      // S372 — Jumrah state (total across 4 days)
      try {
        const $j = document.getElementById('jumrah-state');
        const $jb = document.getElementById('jumrah-bar');
        const ids = [
          'jumrah_10_aqaba',
          'jumrah_11_sughra', 'jumrah_11_wustha', 'jumrah_11_aqaba',
          'jumrah_12_sughra', 'jumrah_12_wustha', 'jumrah_12_aqaba',
          'jumrah_13_sughra', 'jumrah_13_wustha', 'jumrah_13_aqaba',
        ];
        const states = await Promise.all(ids.map((id) => IbadahCounter.getCounter(id)));
        const total = states.reduce((sum, x) => sum + x.putaran, 0);
        const TARGET = 70;
        const pct = Math.min(100, Math.round((total / TARGET) * 100));
        $jb.style.width = pct + '%';
        if (total >= TARGET) {
          $j.textContent = '✓ 70 batu tuntas (4 hari)';
          $j.classList.add('complete');
        } else if (total === 0) {
          $j.textContent = '— belum mulai —';
        } else {
          $j.textContent = 'Berjalan · ' + total + '/' + TARGET + ' batu';
        }
      } catch (err) { console.warn(err); }
    })();
  </script>
  <%- include('partials/mobile-tabs') %>
</body>
</html>

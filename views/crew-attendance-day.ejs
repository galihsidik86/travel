<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Absensi Hari <%= day.dayNumber %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<%- include('partials/pwa-head', { pwaRole: 'crew' }) %>
<script src="/shared/attendance-queue.js" defer></script>
<!-- Stage 367 — persistent storage opt-in (IDB durability) -->
<script src="/shared/persist-storage.js" defer></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 980px; margin: 0 auto; padding: 32px 40px 80px; }
  .crumb { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .crumb a { color: var(--gold-300); text-decoration: none; }
  .head h1 { font-family: var(--font-display); font-size: 28px; font-weight: 500; color: var(--cream-100); margin: 0; letter-spacing: -0.015em; }
  .head h1 em { font-style: italic; color: var(--gold-300); }
  .head .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.08em; margin-top: 8px; }
  .head { margin-bottom: 22px; }

  .ok-banner { display: none; background: rgba(74,143,109,0.08); border: 1px solid rgba(74,143,109,0.4); color: var(--emerald); padding: 10px 14px; border-radius: var(--r-sm); font-family: var(--font-mono); font-size: 11.5px; margin-bottom: 16px; }
  .ok-banner.is-visible { display: block; }

  .tbl { width: 100%; border-collapse: collapse; background: var(--ink-900); border: var(--hairline); border-radius: var(--r-md); overflow: hidden; }
  .tbl thead th { text-align: left; padding: 12px 14px; background: var(--ink-1000); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); font-weight: 500; border-bottom: var(--hairline); }
  .tbl tbody td { padding: 11px 14px; border-bottom: var(--hairline-soft); font-size: 12.5px; color: var(--cream-200); vertical-align: middle; }
  .tbl tbody tr:hover td { background: var(--ink-850); }
  .tbl .nm { color: var(--cream-100); font-weight: 500; }
  .tbl .id { font-family: var(--font-mono); font-size: 10.5px; color: var(--gold-300); letter-spacing: 0.06em; }
  .tbl .sx { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; }

  .row-form { display: flex; gap: 10px; align-items: center; margin: 0; }
  .row-form .toggle-wrap {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em;
    cursor: pointer;
  }
  .row-form input[type=checkbox] {
    appearance: none; width: 22px; height: 22px;
    border: 2px solid var(--ink-500); border-radius: 4px;
    cursor: pointer; background: var(--ink-1000); transition: all 120ms ease;
    position: relative;
  }
  .row-form input[type=checkbox]:checked {
    border-color: var(--emerald); background: var(--emerald);
  }
  .row-form input[type=checkbox]:checked::after {
    content: '✓'; position: absolute; top: -1px; left: 3px;
    color: var(--ink-1000); font-weight: 700; font-size: 16px;
  }
  .row-form .notes {
    flex: 1; min-width: 140px;
    background: var(--ink-1000); border: var(--hairline-soft);
    color: var(--cream-100); padding: 6px 10px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 11px;
  }
  .row-form button {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-100); cursor: pointer;
    padding: 7px 14px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  }
  .row-form button:hover { color: var(--gold-300); border-color: var(--gold-300); }

  .mark-meta { font-family: var(--font-mono); font-size: 9.5px; color: var(--ink-300); letter-spacing: 0.04em; margin-top: 4px; }
  .empty { padding: 40px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); }

  /* Connection + queue indicators */
  .net-banner {
    display: none; padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11.5px; margin-bottom: 14px;
    letter-spacing: 0.04em; line-height: 1.5;
  }
  .net-banner.offline {
    display: block;
    background: rgba(201,147,59,0.10); border: 1px solid rgba(201,147,59,0.45);
    color: var(--amber);
  }
  .net-banner.syncing {
    display: block;
    background: rgba(74,111,143,0.08); border: 1px solid rgba(74,111,143,0.4);
    color: var(--sapphire);
  }
  .net-banner b { color: inherit; font-weight: 600; }

  /* Per-row sync pill — sits inside .row-form, shows state of the most
     recent submission. */
  .sync-pill {
    display: none; align-self: center;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em;
    padding: 4px 8px; border-radius: 3px; border: 1px solid; text-transform: uppercase;
    white-space: nowrap;
  }
  .sync-pill.show { display: inline-block; }
  .sync-pill.queued  { color: var(--amber);   border-color: rgba(201,147,59,0.5);  background: rgba(201,147,59,0.08); }
  .sync-pill.syncing { color: var(--sapphire); border-color: rgba(74,111,143,0.45); background: rgba(74,111,143,0.06); }
  .sync-pill.ok      { color: var(--emerald); border-color: rgba(74,143,109,0.5);  background: rgba(74,143,109,0.08); }
  .sync-pill.error   { color: var(--ruby);    border-color: rgba(181,86,74,0.5);   background: rgba(181,86,74,0.08); }

  /* Whole-row queued accent */
  .tbl tbody tr.has-queued td:first-child { box-shadow: inset 3px 0 0 var(--amber); }

  @media (max-width: 720px) {
    /* Card-per-row layout: each jemaah becomes a vertical block, the
       hidden <thead> labels collapse, and the form widens for thumbs. */
    .tbl thead { display: none; }
    .tbl tbody td { display: block; padding: 6px 14px; border-bottom: 0; }
    .tbl tbody tr { display: block; padding: 14px 0; border-bottom: var(--hairline-soft); }
    .tbl tbody tr:hover td { background: transparent; }
    /* Jemaah identity gets a stronger separator from kelas/kamar */
    .tbl tbody td:first-child { padding-bottom: 10px; border-bottom: var(--hairline-soft); margin-bottom: 6px; }
    /* Kelas + Kamar share a row instead of stacking — both ~5 chars */
    .tbl tbody td:nth-child(2),
    .tbl tbody td:nth-child(3) {
      display: inline-block; padding: 4px 14px; font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.08em; color: var(--ink-200);
    }
    .tbl tbody td:nth-child(2)::before { content: 'KELAS · '; opacity: 0.6; }
    .tbl tbody td:nth-child(3)::before { content: 'KAMAR · '; opacity: 0.6; }

    /* Row form: stack checkbox + notes + button; bigger tap targets. */
    .row-form { flex-direction: column; align-items: stretch; gap: 10px; padding-top: 6px; }
    .row-form .toggle-wrap {
      padding: 10px 12px; border: var(--hairline-soft); border-radius: var(--r-sm);
      background: var(--ink-1000); font-size: 12.5px; gap: 10px;
      min-height: 48px;
    }
    .row-form input[type=checkbox] { width: 26px; height: 26px; }
    .row-form input[type=checkbox]:checked::after { top: -1px; left: 4px; font-size: 20px; }
    .row-form .notes { width: 100%; min-width: 0; min-height: 44px; font-size: 13px; padding: 10px 12px; }
    .row-form button {
      width: 100%; min-height: 48px; font-size: 11.5px;
      background: var(--gold-300); color: var(--ink-1000); border: 0; font-weight: 600;
    }
    .row-form button:hover { background: var(--gold-200); }
  }
</style>
<script src="/shared/csrf.js"></script>
</head>
<body data-screen-label="05 Crew · Attendance Day"
      class="has-m-tabs"
      data-user-name="<%= user.fullName || user.email %>"
      data-paket-slug="<%= paket.slug %>"
      data-day-id="<%= day.id %>">
<div class="wrap">
  <div class="crumb">
    <a class="btn-back" href="/crew/paket/<%= paket.slug %>/attendance">Overview Absensi</a>
  </div>

  <div class="head">
    <h1>Hari <%= day.dayNumber %> · <em><%= day.title %></em></h1>
    <div class="sub">
      <% if (day.dateLabel) { %><%= day.dateLabel %><% if (day.monthLabel) { %> <%= day.monthLabel %><% } %> · <% } %>
      <%= paket.title %>
    </div>
  </div>

  <% if (day.description) { %>
    <div style="background:var(--ink-900);border:var(--hairline);border-radius:var(--r-md);padding:14px 18px;margin-bottom:18px;font-family:var(--font-body);font-size:13px;color:var(--ink-100);line-height:1.55;">
      <%= day.description %>
    </div>
  <% } %>

  <div id="net-banner" class="net-banner" role="status"></div>
  <div id="ok-banner" class="ok-banner">Tersimpan.</div>

  <% if (bookings.length === 0) { %>
    <div class="tbl"><div class="empty">Tidak ada jemaah aktif untuk paket ini.</div></div>
  <% } else { %>
    <table class="tbl">
      <thead>
        <tr>
          <th>Jemaah</th>
          <th style="width:90px;">Kelas</th>
          <th style="width:90px;">Kamar</th>
          <th style="width:50%;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(function(b) { %>
          <tr>
            <td>
              <div class="nm"><%= b.jemaah.fullName %></div>
              <div class="sx"><span class="id"><%= b.bookingNo %></span> · 📱 <%= b.jemaah.phone %></div>
            </td>
            <td><%= b.kelas %></td>
            <td><%= b.room?.roomNo || '—' %></td>
            <td>
              <form class="row-form" method="POST"
                    action="/crew/paket/<%= paket.slug %>/attendance/<%= day.id %>/<%= b.id %>"
                    data-booking-id="<%= b.id %>"
                    data-booking-no="<%= b.bookingNo %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label class="toggle-wrap">
                  <input type="checkbox" name="present" value="on" <%= b.mark?.present ? 'checked' : '' %>>
                  <span class="toggle-label"><%= b.mark?.present ? 'Hadir' : (b.mark ? 'Tidak hadir' : 'Belum ditandai') %></span>
                </label>
                <input class="notes" type="text" name="notes" maxlength="500"
                       inputmode="text" autocomplete="off"
                       placeholder="Catatan (opsional, mis. alasan absen)"
                       value="<%= b.mark?.notes || '' %>">
                <button type="submit">Simpan</button>
                <span class="sync-pill" aria-live="polite"></span>
              </form>
              <div class="mark-meta">
                <% if (b.mark) { %>
                  terakhir: <%= fmt.date(b.mark.markedAt) %> oleh <%= b.mark.markedBy?.fullName || '—' %>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
  (function () {
    const u = new URL(location.href);
    if (u.searchParams.get('ok') === 'saved') {
      document.getElementById('ok-banner').classList.add('is-visible');
      history.replaceState(null, '', location.pathname);
      setTimeout(() => document.getElementById('ok-banner').classList.remove('is-visible'), 2500);
    }
  })();

  // ── Offline-friendly attendance submit ────────────────────────────
  // No-JS fallback: standard form POST → server 302 → ?ok=saved (above).
  // With JS: intercept submit, optimistic fetch, queue on failure.
  (function () {
    if (!('fetch' in window) || !window.AttendanceQueue) return;
    const Q = window.AttendanceQueue;
    const banner = document.getElementById('net-banner');
    const userName = document.body.dataset.userName || 'Anda';

    function setPill(form, state, label) {
      const pill = form.querySelector('.sync-pill');
      if (!pill) return;
      pill.className = 'sync-pill show ' + state;
      pill.textContent = label;
    }
    function clearPill(form) {
      const pill = form.querySelector('.sync-pill');
      if (pill) pill.className = 'sync-pill';
    }
    function setRowQueued(form, on) {
      const tr = form.closest('tr');
      if (tr) tr.classList.toggle('has-queued', !!on);
    }
    function updateRowFromSubmit(form, present, notes, when) {
      const label = form.querySelector('.toggle-label');
      if (label) label.textContent = present ? 'Hadir' : 'Tidak hadir';
      const meta = form.parentElement?.querySelector('.mark-meta');
      if (meta) {
        const t = when || new Date();
        const ts = t.toLocaleString('id-ID', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: 'short' });
        meta.textContent = 'terakhir: ' + ts + ' oleh ' + userName;
      }
    }

    function readForm(form) {
      const fd = new FormData(form);
      const csrf = fd.get('_csrf') || '';
      const present = !!form.querySelector('input[name=present]')?.checked;
      const notes = fd.get('notes') || '';
      return { csrf, present, notes };
    }

    function payloadFor({ csrf, present, notes }) {
      const p = { _csrf: csrf, notes: String(notes) };
      if (present) p.present = 'on';
      return p;
    }

    async function submitOnline(form, { csrf, present, notes }) {
      const body = new URLSearchParams();
      for (const [k, v] of Object.entries(payloadFor({ csrf, present, notes }))) {
        body.append(k, v);
      }
      const res = await fetch(form.action, {
        method: 'POST',
        credentials: 'same-origin',
        redirect: 'follow',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
    }

    function renderBanner(pendingCount, online) {
      if (!online) {
        banner.className = 'net-banner offline';
        banner.innerHTML = '<b>Mode offline.</b> Tandai jemaah seperti biasa — perubahan disimpan di perangkat dan otomatis terkirim saat koneksi kembali.';
        return;
      }
      if (pendingCount > 0) {
        banner.className = 'net-banner syncing';
        banner.innerHTML = '<b>Menyinkronkan…</b> ' + pendingCount + ' perubahan menunggu kirim.';
        return;
      }
      banner.className = 'net-banner'; // hidden by default
      banner.textContent = '';
    }

    async function refreshBanner() {
      const n = await Q.countPending();
      renderBanner(n, navigator.onLine);
    }

    // Map queue items back onto their .row-form so each row shows its state.
    async function paintFormStatesFromQueue() {
      const items = await Q.list();
      // Clear any previously-queued markers; we'll re-mark from the truth.
      document.querySelectorAll('form.row-form .sync-pill.queued, form.row-form .sync-pill.syncing, form.row-form .sync-pill.error')
        .forEach((p) => (p.className = 'sync-pill'));
      document.querySelectorAll('tr.has-queued').forEach((tr) => tr.classList.remove('has-queued'));

      const bySlug = document.body.dataset.paketSlug;
      const byDay = document.body.dataset.dayId;
      for (const it of items) {
        if (!it.url) continue;
        // url pattern: /crew/paket/<slug>/attendance/<dayId>/<bookingId>
        const segs = it.url.split('/').filter(Boolean);
        const idx = segs.indexOf('attendance');
        if (idx < 0 || segs.length < idx + 3) continue;
        const slug = segs[idx - 1];
        const dayId = segs[idx + 1];
        const bookingId = segs[idx + 2];
        if (slug !== bySlug || dayId !== byDay) continue;
        const form = document.querySelector('form.row-form[data-booking-id="' + bookingId + '"]');
        if (!form) continue;
        const state = it.status === 'failed' ? 'error' : (it.status === 'syncing' ? 'syncing' : 'queued');
        const label = state === 'error' ? 'Gagal sinkron' : (state === 'syncing' ? 'Mengirim…' : 'Menunggu sinkron');
        setPill(form, state, label);
        setRowQueued(form, state !== 'error');
      }
    }

    // Form intercept
    document.querySelectorAll('form.row-form').forEach((form) => {
      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const { csrf, present, notes } = readForm(form);

        // Optimistic UI: flip label immediately
        updateRowFromSubmit(form, present, notes);

        // S367 — ask for durability protection on first attendance mark.
        // Crew may rely on the queue to survive a multi-hour signal outage
        // on a mountain pass; eviction mid-trip would silently drop marks.
        if (window.PersistStorage) {
          window.PersistStorage.request({ reason: 'attendance' }).catch(() => {});
        }

        if (!navigator.onLine) {
          // Queue right away — no point trying fetch when navigator says offline.
          await Q.enqueue({
            url: form.action,
            payload: payloadFor({ csrf, present, notes }),
            label: form.dataset.bookingNo || form.dataset.bookingId,
          });
          setPill(form, 'queued', 'Menunggu sinkron');
          setRowQueued(form, true);
          refreshBanner();
          return;
        }

        // Online: try once, queue on network/server error.
        setPill(form, 'syncing', 'Mengirim…');
        try {
          await submitOnline(form, { csrf, present, notes });
          setPill(form, 'ok', 'Tersimpan');
          setRowQueued(form, false);
          setTimeout(() => clearPill(form), 1800);
        } catch (err) {
          await Q.enqueue({
            url: form.action,
            payload: payloadFor({ csrf, present, notes }),
            label: form.dataset.bookingNo || form.dataset.bookingId,
          });
          setPill(form, 'queued', 'Menunggu sinkron');
          setRowQueued(form, true);
          refreshBanner();
        }
      });
    });

    // Online/offline events
    window.addEventListener('offline', refreshBanner);
    window.addEventListener('online', refreshBanner);

    // Queue change → repaint banner + form states
    Q.onChange(() => { refreshBanner(); paintFormStatesFromQueue(); });

    // Boot
    refreshBanner();
    paintFormStatesFromQueue();
    Q.startAutoFlush({ intervalMs: 20_000 });
  })();
</script>
<%- include('partials/sos-fab', { paketSlug: paket.slug }) %>
<%- include('partials/crew-mobile-tabs') %>
</body>
</html>

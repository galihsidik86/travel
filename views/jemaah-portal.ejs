<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>RELIGIO PRO — Portal Jemaah · <%= user.fullName %></title>
<link rel="stylesheet" href="/shared/tokens.css">
<link rel="stylesheet" href="/shared/jemaah-readable.css">
<%- include('partials/pwa-head') %>
<script src="/shared/csrf.js"></script>
<style>
  body { background: var(--ink-1000); min-height: 100vh; }
  .wrap { max-width: 980px; margin: 0 auto; padding: 32px 40px 80px; }

  .topbar {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 18px; margin-bottom: 28px;
    border-bottom: var(--hairline-soft);
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.1em;
  }
  .topbar .who { color: var(--gold-300); }
  .topbar form { display: inline; }
  .topbar button {
    background: transparent; border: var(--hairline-soft);
    color: var(--ink-100); cursor: pointer;
    padding: 6px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .topbar button:hover { color: var(--gold-300); border-color: var(--gold-300); }

  .hero {
    background:
      radial-gradient(80% 60% at 80% 0%, rgba(212,175,55,0.10), transparent 60%),
      var(--ink-900);
    border: var(--hairline-gold);
    border-radius: var(--r-xl);
    padding: 40px 48px;
    margin-bottom: 32px;
  }
  .hero .eyebrow {
    color: var(--gold-300);
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .hero h1 {
    font-family: var(--font-display); font-size: 40px; font-weight: 500;
    color: var(--cream-100); margin: 12px 0 0; letter-spacing: -0.015em;
  }
  .hero h1 em { font-style: italic; color: var(--gold-300); }
  .hero .sub {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-100); letter-spacing: 0.08em; margin-top: 10px;
  }

  .panel {
    background: var(--ink-900); border: var(--hairline);
    border-radius: var(--r-md); padding: 28px;
    margin-bottom: 20px;
  }
  .panel h3 {
    font-family: var(--font-display); font-size: 22px; font-weight: 500;
    color: var(--cream-100); margin: 0 0 8px;
  }
  .panel .sub {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.08em; margin: 0 0 20px;
  }

  .claim-form {
    display: grid; grid-template-columns: 1fr 1fr auto; gap: 10px; align-items: end;
  }
  .claim-form .field { margin: 0; }
  .claim-form .label { display: block; font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 4px; }
  .claim-form button {
    background: var(--gold-300); color: var(--ink-1000);
    border: 0; padding: 10px 18px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.14em; cursor: pointer; font-weight: 600;
    text-transform: uppercase;
  }
  .claim-form button:hover { background: var(--gold-200); }

  .claim-err {
    margin-top: 12px;
    background: rgba(176,68,68,0.08); border: 1px solid rgba(176,68,68,0.4);
    color: var(--ruby);
    padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    display: none;
  }
  .claim-err.is-visible { display: block; }
  .claim-ok {
    margin-top: 12px;
    background: rgba(74,143,109,0.08); border: 1px solid rgba(74,143,109,0.4);
    color: var(--emerald);
    padding: 10px 14px; border-radius: var(--r-sm);
    font-family: var(--font-mono); font-size: 11px;
    display: none;
  }
  .claim-ok.is-visible { display: block; }

  .booking-list { display: flex; flex-direction: column; gap: 12px; }
  .booking-row {
    background: var(--ink-1000); border: var(--hairline-soft);
    border-radius: var(--r-md); padding: 18px 22px;
    display: grid; grid-template-columns: 1fr auto auto; gap: 18px;
    align-items: center;
  }
  .booking-row a.title-link {
    color: var(--cream-100); text-decoration: none;
    font-family: var(--font-display); font-size: 18px;
    font-weight: 500;
  }
  .booking-row a.title-link:hover { color: var(--gold-300); }
  .booking-row .meta {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); letter-spacing: 0.04em; margin-top: 4px;
  }
  .booking-row .id { color: var(--gold-300); }
  .booking-row .price {
    font-family: var(--font-display); font-size: 20px; color: var(--cream-100);
    font-weight: 500; text-align: right;
  }
  .booking-row .price .sub {
    font-family: var(--font-mono); font-size: 10.5px;
    color: var(--ink-200); letter-spacing: 0.06em;
    margin-top: 2px; font-weight: normal;
  }
  .status-tag {
    padding: 4px 10px; font-family: var(--font-mono); font-size: 10px;
    border-radius: 3px; letter-spacing: 0.12em; border: 1px solid;
  }
  .status-tag.pending   { color: var(--amber); border-color: var(--amber); }
  .status-tag.booked    { color: var(--sapphire); border-color: var(--sapphire); }
  .status-tag.dp_paid   { color: var(--gold-300); border-color: var(--gold-300); }
  .status-tag.partial   { color: var(--gold-300); border-color: rgba(212,175,55,0.5); }
  .status-tag.lunas     { color: var(--emerald); border-color: var(--emerald); background: rgba(74,143,109,0.08); }
  .status-tag.cancelled { color: var(--ruby); border-color: var(--ruby); }
  .status-tag.refunded  { color: var(--ruby); border-color: var(--ruby); background: rgba(181,86,74,0.08); }

  .empty {
    border: 1px dashed var(--ink-500); border-radius: var(--r-md);
    padding: 32px; text-align: center;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-200); line-height: 1.7;
  }
  .empty code { color: var(--gold-300); }

  @media (max-width: 720px) {
    .hero { padding: 28px 22px; }
    .hero h1 { font-size: 28px; }
    .claim-form { grid-template-columns: 1fr; }
    .claim-form button { width: 100%; min-height: 44px; }
    /* booking row stacks on phone: title-block, status, price each take a row */
    .booking-row { grid-template-columns: 1fr; gap: 10px; padding: 14px 16px; }
    .booking-row .price { text-align: left; }
    /* Hide redundant top-bar nav links — bottom-nav (.m-tabs) covers them */
    .topnav-link { display: none !important; }
    .topbar button { min-height: 40px; }
  }
</style>
</head>
<body data-screen-label="04 Portal Jemaah" class="has-m-tabs jemaah-app">
<div class="wrap">

  <div class="topbar">
    <div>JEMAAH · <span class="who"><%= user.email %></span></div>
    <div style="display:flex;gap:10px;align-items:center;">
      <a href="/saya/paket" class="topnav-link" style="background:transparent;border:var(--hairline-soft);color:var(--ink-100);text-decoration:none;padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;">Lihat paket</a>
      <a href="/saya/notifications" class="topnav-link" style="background:transparent;border:var(--hairline-soft);color:var(--ink-100);text-decoration:none;padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;position:relative;display:inline-flex;align-items:center;gap:8px;">
        Notifikasi
        <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
          <span title="<%= unreadCount %> notifikasi baru"
                style="background:var(--gold-300);color:var(--ink-1000);font-family:var(--font-mono);font-size:9.5px;line-height:1;padding:3px 6px;border-radius:8px;font-weight:700;letter-spacing:0.02em;">
            <%= unreadCount > 99 ? '99+' : unreadCount %>
          </span>
        <% } %>
      </a>
      <a href="/saya/profile" class="topnav-link" style="background:transparent;border:var(--hairline-soft);color:var(--ink-100);text-decoration:none;padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;">Profil &amp; dokumen</a>
      <form method="POST" action="/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">Keluar</button>
      </form>
    </div>
  </div>

  <script>
    (function () {
      const u = new URL(location.href);
      if (u.searchParams.get('welcome')) {
        const el = document.createElement('div');
        el.style.cssText = 'background:rgba(74,143,109,0.08);border:1px solid rgba(74,143,109,0.4);color:var(--emerald);padding:14px 18px;border-radius:6px;font-family:var(--font-mono);font-size:12px;margin-bottom:24px;';
        el.textContent = 'Selamat datang di portal jemaah Religio Pro! Klaim booking Anda untuk mulai memantau dokumen + pembayaran.';
        document.querySelector('.topbar').after(el);
      }
    })();
  </script>

  <%# Adaptive hero — cascade prioritas hero berdasarkan state:
       1. inTrip → Hari Ini hero (sudah di-render di Stage 320 block di bawah)
       2. Pre-trip dengan booking aktif → countdown hero H-N
       3. No active booking → welcome hero + CTA klaim
       Ini menggantikan generic hero yang selalu render. %>
  <%
    let nearestBooking = null;
    let daysUntilDep = null;
    if (typeof inTrip === 'undefined' || !inTrip) {
      const futureActive = (bookings || []).filter((b) => {
        if (['CANCELLED', 'REFUNDED', 'RESCHEDULED'].includes(b.status)) return false;
        const dep = new Date(b.paket?.departureDate);
        return !Number.isNaN(dep.getTime()) && dep.getTime() > Date.now();
      }).sort((a, b) => new Date(a.paket.departureDate) - new Date(b.paket.departureDate));
      nearestBooking = futureActive[0] || null;
      if (nearestBooking) {
        const dep = new Date(nearestBooking.paket.departureDate);
        const today = new Date(); today.setHours(0, 0, 0, 0);
        daysUntilDep = Math.ceil((dep.getTime() - today.getTime()) / 86_400_000);
      }
    }
  %>
  <% if (nearestBooking) { %>
    <%# Countdown hero — H-N hingga keberangkatan paket terdekat %>
    <% const tier = daysUntilDep <= 7 ? 'urgent' : (daysUntilDep <= 30 ? 'imminent' : 'planning'); %>
    <% const tierColor = tier === 'urgent' ? 'var(--ruby)' : (tier === 'imminent' ? 'var(--amber)' : 'var(--gold-300)'); %>
    <% const tierLabel = tier === 'urgent' ? '⏰ Sebentar lagi berangkat!' : (tier === 'imminent' ? '✈️ Mendekati keberangkatan' : '🕋 Persiapan keberangkatan'); %>
    <a href="/saya/bookings/<%= nearestBooking.id %>" style="display:block;text-decoration:none;color:inherit;margin-bottom:24px;">
      <div style="padding:28px 32px;background:linear-gradient(135deg,rgba(212,175,107,0.10),rgba(212,175,107,0.02));border:1px solid <%= tierColor %>;border-radius:var(--r-lg);position:relative;overflow:hidden;">
        <div style="font-family:var(--font-mono);font-size:10.5px;color:<%= tierColor %>;letter-spacing:0.16em;text-transform:uppercase;font-weight:600;">
          <%= tierLabel %>
        </div>
        <div style="display:flex;align-items:baseline;gap:14px;margin-top:8px;flex-wrap:wrap;">
          <div style="font-family:var(--font-display);font-size:48px;color:<%= tierColor %>;font-weight:500;line-height:1;letter-spacing:-0.02em;">
            H–<%= daysUntilDep %>
          </div>
          <div style="font-family:var(--font-display);font-size:22px;color:var(--cream-100);font-weight:500;font-style:italic;line-height:1.2;flex:1;min-width:200px;">
            <%= nearestBooking.paket.title %>
          </div>
        </div>
        <div style="font-family:var(--font-mono);font-size:11.5px;color:var(--ink-100);margin-top:10px;letter-spacing:0.04em;">
          <span style="color:var(--gold-300);"><%= nearestBooking.bookingNo %></span>
          · <%= nearestBooking.kelas %>
          · DEP <%= fmt.dateShort(nearestBooking.paket.departureDate) %>
          · <%= nearestBooking.status %>
          <span style="margin-left:8px;color:var(--gold-300);">Buka detail →</span>
        </div>
      </div>
    </a>
  <% } else if (typeof inTrip === 'undefined' || !inTrip) { %>
    <%# Welcome hero — 0 booking aktif, panggil klaim atau lihat paket %>
    <div class="hero">
      <div class="eyebrow">Assalamu'alaikum</div>
      <h1><em><%= user.fullName.split(' ')[0] %></em></h1>
      <div class="sub">
        <% if ((bookings || []).length === 0) { %>
          Anda belum punya booking ter-klaim. Klaim booking yang sudah ada via nomor + telepon, atau jelajahi paket baru.
        <% } else { %>
          Semua booking Anda sudah selesai atau di luar masa aktif. Lihat riwayat di bawah, atau pesan paket baru.
        <% } %>
      </div>
      <div style="margin-top:18px;display:flex;gap:10px;flex-wrap:wrap;">
        <a href="/saya/paket" style="background:var(--gold-300);color:var(--ink-1000);border:0;padding:10px 18px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;cursor:pointer;font-weight:600;text-transform:uppercase;text-decoration:none;">🕋 Jelajahi paket</a>
        <a href="#claim-section" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:10px 18px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;cursor:pointer;font-weight:600;text-transform:uppercase;text-decoration:none;">+ Klaim booking</a>
      </div>
    </div>
  <% } %>

  <%# Stage 379 — Onboarding welcome checklist. Renders only when jemaah
      has at least one incomplete item AND hasn't dismissed the card.
      Item 4 (PWA install) is checked client-side via display-mode:standalone
      + Notification.permission so the server-side score under-counts.
      The card auto-hides via JS when score=4/4 OR jemaah taps "Sembunyikan".
      Stale (>30d account) cards still render; dismiss is durable. %>
  <% if (typeof welcome !== 'undefined' && welcome) { %>
    <div id="rp-welcome-card" style="display:none;margin-bottom:18px;padding:18px 20px;background:linear-gradient(180deg,rgba(80,176,113,0.06),rgba(80,176,113,0.01));border:1px solid var(--emerald);border-radius:var(--r-md);">
      <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap;">
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--emerald);letter-spacing:0.14em;text-transform:uppercase;font-weight:600;">
          🌟 Mulai siapkan keberangkatan Anda
        </div>
        <button type="button" id="rp-welcome-dismiss" style="background:transparent;border:0;color:var(--ink-200);cursor:pointer;font-family:var(--font-mono);font-size:10px;letter-spacing:0.06em;">✕ Sembunyikan</button>
      </div>
      <div style="font-family:var(--font-display);font-size:18px;color:var(--cream-100);margin:4px 0 10px;line-height:1.3;">
        <em id="rp-welcome-score" style="color:var(--emerald);font-style:italic;">…</em> dari 4 langkah selesai
      </div>
      <div style="height:6px;background:var(--ink-1000);border-radius:3px;overflow:hidden;margin-bottom:12px;">
        <div id="rp-welcome-bar" style="height:100%;width:0%;background:var(--emerald);transition:width 240ms ease;"></div>
      </div>
      <ul id="rp-welcome-items" style="margin:0;padding:0;list-style:none;font-family:var(--font-mono);font-size:12px;color:var(--cream-100);line-height:1.6;">
        <% welcome.items.forEach(function(item) { %>
          <li data-key="<%= item.key %>" data-done="<%= item.done === true ? '1' : (item.done === false ? '0' : '') %>"
              style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:6px 0;border-bottom:1px dashed rgba(255,255,255,0.04);">
            <span><span class="rp-welcome-icon" style="margin-right:6px;"><%= item.done === true ? '✓' : '○' %></span><%= item.label %></span>
            <% if (item.link) { %>
              <a href="<%= item.link %>" style="color:var(--gold-300);text-decoration:none;font-size:10.5px;letter-spacing:0.06em;">Buka →</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </div>
    <script>
      // S379 — paint PWA installation client-side (display-mode:standalone
      // or iOS standalone), then compute overall score and hide card when
      // 4/4 done OR jemaah previously dismissed.
      (function () {
        const KEY = 'rp_welcome_dismissed';
        const card = document.getElementById('rp-welcome-card');
        if (!card) return;
        let dismissed = false;
        try { dismissed = localStorage.getItem(KEY) === '1'; } catch (_e) {}
        if (dismissed) return; // card stays display:none

        // Detect PWA install
        const isStandalone =
          (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches)
          || window.navigator.standalone === true;
        const pwaItem = card.querySelector('li[data-key="pwa"]');
        if (pwaItem) {
          pwaItem.setAttribute('data-done', isStandalone ? '1' : '0');
          const icon = pwaItem.querySelector('.rp-welcome-icon');
          if (icon) icon.textContent = isStandalone ? '✓' : '○';
        }

        // Compute score from all items
        const items = card.querySelectorAll('li[data-key]');
        let done = 0;
        items.forEach((li) => {
          if (li.getAttribute('data-done') === '1') {
            done += 1;
            // Visual: dim completed rows so jemaah focuses on remaining
            li.style.opacity = '0.55';
          }
        });
        const total = items.length;
        document.getElementById('rp-welcome-score').textContent = done;
        document.getElementById('rp-welcome-bar').style.width = Math.round(done / total * 100) + '%';

        // 100% done? auto-stay-hidden (card already display:none); else reveal.
        if (done < total) card.style.display = 'block';

        document.getElementById('rp-welcome-dismiss').addEventListener('click', () => {
          try { localStorage.setItem(KEY, '1'); } catch (_e) {}
          card.style.display = 'none';
        });
      })();
    </script>
  <% } %>

  <%# Stage 320 — Hari Ini hero. Renders only when jemaah's LUNAS booking
      is currently in-trip (today between departureDate + returnDate). %>
  <% if (typeof inTrip !== 'undefined' && inTrip) { %>
    <div style="padding:24px;margin-bottom:20px;background:linear-gradient(135deg,rgba(212,175,107,0.08),rgba(212,175,107,0.02));border:1px solid var(--gold-300);border-radius:var(--r-md);">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;">
        <div style="flex:1;min-width:200px;">
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--gold-300);letter-spacing:0.14em;text-transform:uppercase;">Hari ini · in-trip</div>
          <div style="font-family:var(--font-display);font-size:28px;color:var(--cream-100);margin-top:4px;line-height:1.1;">
            <em style="color:var(--gold-300);font-style:italic;">Hari ke-<%= inTrip.dayN %></em>
            <span style="font-family:var(--font-mono);font-size:14px;color:var(--ink-200);"> dari <%= inTrip.total %></span>
          </div>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-100);margin-top:6px;letter-spacing:0.04em;">
            <%= inTrip.paket.title %> · pulang <%= fmt.dateShort(inTrip.paket.returnDate) %>
          </div>
        </div>
        <a href="/saya/bookings/<%= inTrip.booking.id %>" style="text-decoration:none;background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:8px 14px;border-radius:3px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;white-space:nowrap;">
          Detail booking
        </a>
      </div>

      <% if (inTrip.todayItinerary) { %>
        <div style="margin-top:16px;padding:14px 16px;background:var(--ink-1000);border-radius:var(--r-sm);border-left:3px solid var(--gold-300);">
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Agenda hari ini</div>
          <div style="font-family:var(--font-display);font-size:16px;color:var(--cream-100);margin-top:4px;line-height:1.3;"><%= inTrip.todayItinerary.title %></div>
          <% if (inTrip.todayItinerary.description) { %>
            <div style="font-family:var(--font-body);font-size:13px;color:var(--ink-100);margin-top:6px;line-height:1.5;"><%= inTrip.todayItinerary.description %></div>
          <% } %>
        </div>
      <% } else { %>
        <div style="margin-top:16px;padding:10px 14px;background:var(--ink-1000);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-300);font-style:italic;">
          Tidak ada agenda terjadwal untuk hari ini.
        </div>
      <% } %>

      <% if (inTrip.nextItinerary) { %>
        <div style="margin-top:10px;padding:10px 14px;background:rgba(0,0,0,0.2);border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11px;color:var(--ink-100);letter-spacing:0.04em;">
          <span style="color:var(--ink-300);">Besok →</span> <%= inTrip.nextItinerary.title %>
        </div>
      <% } %>

      <%# Stage 330 — Ibadah counter shortcut (Thawaf + Sa'i). Only shown
          when in-trip; client-side counters work offline. %>
      <a href="/saya/ibadah" style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:14px;padding:12px 14px;background:rgba(212,175,107,0.04);border:1px solid var(--gold-300);border-radius:var(--r-sm);text-decoration:none;color:var(--cream-100);">
        <div>
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--gold-300);letter-spacing:0.14em;text-transform:uppercase;">Alat bantu ibadah</div>
          <div style="font-family:var(--font-display);font-size:15px;color:var(--cream-100);margin-top:2px;">Penghitung Thawaf &amp; Sa'i</div>
        </div>
        <span style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);letter-spacing:0.08em;text-transform:uppercase;">Buka →</span>
      </a>

      <%# Stage 335 — push subscribe CTA. Rendered only when in-trip AND
          push isn't already subscribed (Notification.permission !== 'granted').
          Hidden by default; the inline JS below checks support + permission
          state on load. Clicking triggers the existing S94 push-jemaah.js
          enable() flow via the hidden #rp-push-enable button. %>
      <div id="rp-push-cta-hero" style="display:none;margin-top:12px;padding:12px 14px;background:linear-gradient(135deg,rgba(80,176,113,0.10),rgba(80,176,113,0.02));border:1px solid var(--emerald);border-radius:var(--r-sm);align-items:center;justify-content:space-between;gap:12px;">
        <div style="flex:1;min-width:0;">
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--emerald);letter-spacing:0.14em;text-transform:uppercase;">🔔 Push notif</div>
          <div style="font-family:var(--font-display);font-size:14px;color:var(--cream-100);margin-top:2px;line-height:1.3;">Aktifkan notif tim</div>
          <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-100);margin-top:3px;letter-spacing:0.04em;">Dapatkan ACK SOS + announce paket realtime di lock-screen.</div>
        </div>
        <button type="button" id="rp-push-cta-hero-btn" style="background:var(--emerald);color:var(--ink-1000);border:0;padding:10px 14px;border-radius:3px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;font-weight:600;flex-shrink:0;">Aktifkan</button>
      </div>
      <script>
        (function () {
          // Show CTA only if browser supports push + permission isn't granted.
          // Hide entirely if Notification API missing or permission denied
          // (re-prompting after denial just fails silently — annoying).
          if (typeof Notification === 'undefined') return;
          if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
          const perm = Notification.permission;
          if (perm === 'granted' || perm === 'denied') return;
          const cta = document.getElementById('rp-push-cta-hero');
          if (!cta) return;
          cta.style.display = 'flex';
          const btn = document.getElementById('rp-push-cta-hero-btn');
          btn.addEventListener('click', () => {
            // Defer to S94 push-jemaah.js: it owns the VAPID + subscribe
            // logic. We just trigger its enable button.
            const target = document.getElementById('rp-push-enable');
            if (target && typeof target.click === 'function') {
              target.click();
              // Hide the CTA optimistically — the canonical bar will
              // repaint based on real subscribe outcome.
              cta.style.display = 'none';
            } else {
              cta.style.opacity = '0.5';
              setTimeout(() => location.reload(), 200);
            }
          });
        })();
      </script>

      <%# SOS-light moved out of hero card into a floating FAB (crew-style) —
          always visible at bottom-right when in-trip, no more scroll to find.
          See <dialog id="rp-help-modal"> + <button.sos-fab-jemaah> below. %>
    </div>

    <%# Stage 321 — SOS-light FAB + modal. Mirrors crew sos-fab.ejs visually
        but POSTs JSON to /api/saya/help-request (text-only, no photo). Same
        in-trip gate as before; position:fixed escapes the hero panel so the
        button floats over content regardless of scroll position. %>
    <button class="sos-fab-jemaah" type="button" aria-label="Kirim SOS bantuan"
            onclick="document.getElementById('rp-help-modal').showModal()">
      <span class="sos-fab-jemaah__dot"></span>
      <span class="sos-fab-jemaah__lbl">SOS</span>
    </button>

    <dialog id="rp-help-modal" class="sos-modal-jemaah">
      <div class="sos-form-jemaah">
        <div class="sos-modal-jemaah__head">
          <div>
            <div class="sos-modal-jemaah__eyebrow">Permintaan bantuan</div>
            <h2>Kirim sinyal <em>SOS</em></h2>
            <p class="sos-modal-jemaah__sub">Tim admin + crew yang dampingi akan menerima notif dalam hitungan detik. Lokasi GPS otomatis disertakan (kalau diizinkan).</p>
          </div>
          <button type="button" class="sos-modal-jemaah__close"
                  onclick="document.getElementById('rp-help-modal').close()">×</button>
        </div>
        <label class="sos-field-jemaah">
          <span>Apa yang terjadi? (singkat)</span>
          <textarea id="rp-help-msg" rows="4" maxlength="1000"
                    placeholder="Mis. 'Kepala pusing, butuh bantuan. Sekarang di gate 21 Masjid Nabawi.'"></textarea>
        </label>
        <div id="rp-help-status" class="sos-modal-jemaah__status"></div>
        <div class="sos-modal-jemaah__actions">
          <button type="button" id="rp-help-cancel" class="sos-modal-jemaah__cancel"
                  onclick="document.getElementById('rp-help-modal').close()">Batal</button>
          <button type="button" id="rp-help-submit" class="sos-modal-jemaah__send">KIRIM SOS</button>
        </div>
      </div>
    </dialog>

    <style>
      .sos-fab-jemaah {
        position: fixed; right: 18px; bottom: 84px; z-index: 60;
        width: 64px; height: 64px; border-radius: 50%;
        background: var(--ruby); color: var(--cream-100);
        border: 2px solid rgba(255,255,255,0.18);
        box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 4px 12px rgba(0,0,0,0.4);
        cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center;
        font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
        animation: sos-pulse-jemaah 2.6s ease-out infinite;
      }
      .sos-fab-jemaah:hover { background: #C46259; }
      .sos-fab-jemaah__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cream-100); margin-bottom: 4px; box-shadow: 0 0 8px rgba(255,255,255,0.7); }
      .sos-fab-jemaah__lbl { letter-spacing: 0.2em; }
      @keyframes sos-pulse-jemaah {
        0%   { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 0 rgba(181,86,74,0.6); }
        70%  { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 16px rgba(181,86,74,0); }
        100% { box-shadow: 0 14px 36px rgba(181,86,74,0.45), 0 0 0 0 rgba(181,86,74,0); }
      }
      .sos-fab-jemaah__queued {
        position: absolute; top: -4px; right: -4px;
        min-width: 22px; height: 22px; padding: 0 6px;
        background: var(--amber); color: var(--ink-1000);
        border-radius: 11px; font-family: var(--font-mono); font-size: 11px;
        font-weight: 700; line-height: 22px; text-align: center;
        border: 2px solid var(--ink-1000);
      }
      .sos-modal-jemaah { width: min(440px, calc(100vw - 32px)); padding: 0; background: transparent; border: 0; }
      .sos-modal-jemaah::backdrop { background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); }
      .sos-form-jemaah {
        background: var(--ink-900); border: 1px solid var(--ruby); border-radius: var(--r-lg);
        padding: 22px 22px 18px; display: flex; flex-direction: column; gap: 14px; color: var(--cream-100);
      }
      .sos-modal-jemaah__head { display: flex; justify-content: space-between; align-items: start; gap: 16px; }
      .sos-modal-jemaah__eyebrow { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ruby); }
      .sos-modal-jemaah__head h2 { font-family: var(--font-display); font-size: 24px; font-weight: 500; margin: 4px 0 6px; color: var(--cream-100); letter-spacing: -0.015em; }
      .sos-modal-jemaah__head h2 em { font-style: italic; color: var(--ruby); }
      .sos-modal-jemaah__sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-100); line-height: 1.55; margin: 0; }
      .sos-modal-jemaah__close { background: transparent; border: 0; color: var(--ink-200); font-size: 24px; line-height: 1; cursor: pointer; padding: 0 4px; flex-shrink: 0; }
      .sos-modal-jemaah__close:hover { color: var(--cream-100); }
      .sos-field-jemaah { display: flex; flex-direction: column; gap: 6px; }
      .sos-field-jemaah > span { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-200); }
      .sos-field-jemaah textarea { background: var(--ink-1000); color: var(--cream-100); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 10px 12px; font-size: 13px; font-family: inherit; resize: vertical; min-height: 84px; line-height: 1.5; }
      .sos-modal-jemaah__status { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); min-height: 14px; letter-spacing: 0.04em; }
      .sos-modal-jemaah__actions { display: flex; gap: 10px; margin-top: 4px; }
      .sos-modal-jemaah__cancel, .sos-modal-jemaah__send {
        flex: 1; padding: 12px 16px; min-height: 46px; border-radius: var(--r-sm);
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; cursor: pointer;
      }
      .sos-modal-jemaah__cancel { background: transparent; border: var(--hairline-soft); color: var(--ink-100); }
      .sos-modal-jemaah__cancel:hover { color: var(--cream-100); border-color: var(--ink-100); }
      .sos-modal-jemaah__send { background: var(--ruby); color: var(--cream-100); border: 0; }
      .sos-modal-jemaah__send:hover { background: #C46259; }
    </style>

    <script>
      (function () {
        const fab = document.querySelector('.sos-fab-jemaah');
        const modal = document.getElementById('rp-help-modal');
        const submit = document.getElementById('rp-help-submit');
        const msg = document.getElementById('rp-help-msg');
        const status = document.getElementById('rp-help-status');
        if (!fab || !modal || !submit) return;
        // FAB tap opens modal (onclick attr handles it); auto-focus textarea
        // when dialog is shown so jemaah can type one-handed in panic.
        modal.addEventListener('close', () => { status.textContent = ''; });
        function openModal() {
          if (modal.open) return;
          modal.showModal();
          setTimeout(() => msg?.focus(), 100);
        }
        // Expose for deep-link (S363) auto-open below.
        window.__rpJemaahSosOpen = openModal;
        // S358 — best-effort geolocation. Wait at most GEO_TIMEOUT_MS for
        // GPS lock; if the user denied permission OR the browser timed out,
        // resolve to null so the SOS still fires without blocking. We DON'T
        // ask permission until the SOS button is tapped — pre-asking would
        // train users to deny by default, defeating the purpose.
        const GEO_TIMEOUT_MS = 5000;
        function getGeolocation() {
          return new Promise((resolve) => {
            if (typeof navigator === 'undefined' || !navigator.geolocation) {
              resolve(null); return;
            }
            let settled = false;
            const timer = setTimeout(() => {
              if (settled) return;
              settled = true; resolve(null);
            }, GEO_TIMEOUT_MS);
            navigator.geolocation.getCurrentPosition(
              (pos) => {
                if (settled) return;
                settled = true; clearTimeout(timer);
                resolve({
                  latitude: pos.coords.latitude,
                  longitude: pos.coords.longitude,
                  accuracy: pos.coords.accuracy,
                });
              },
              () => {
                if (settled) return;
                settled = true; clearTimeout(timer);
                resolve(null);
              },
              { enableHighAccuracy: true, timeout: GEO_TIMEOUT_MS, maximumAge: 30_000 },
            );
          });
        }
        // S355 — offline-aware SOS submit. If navigator.onLine is false OR
        // the fetch throws, queue locally via SosLightQueue + show "queued"
        // banner. Auto-flush replays on `online` event + interval tick.
        async function tryDirectSend(text, location) {
          const r = await fetch('/api/saya/help-request', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text, location }),
          });
          const body = await r.json();
          return { ok: r.ok && body.ok, body };
        }
        async function queueOffline(text, location) {
          if (!window.SosLightQueue) throw new Error('queue unavailable');
          await window.SosLightQueue.enqueue({
            url: '/api/saya/help-request',
            payload: { message: text, location }, // S358 — location survives the queue
            label: 'sos-light',
          });
        }
        submit.addEventListener('click', async () => {
          const text = (msg.value || '').trim();
          if (text.length < 5) { status.textContent = 'Pesan minimal 5 karakter.'; status.style.color = 'var(--ruby)'; return; }
          submit.disabled = true;
          // S367 — durability ask on first SOS submit. If the SOS gets
          // queued (offline path), losing the IDB store would silently
          // drop a life-safety message. Best-effort; failure ignored.
          if (window.PersistStorage) {
            window.PersistStorage.request({ reason: 'sos' }).catch(() => {});
          }
          // S358 — capture GPS first (5s max, never blocks SOS). Tell jemaah
          // the SOS is being prepared so 5s wait isn't a confusing silence.
          status.textContent = 'Mengambil lokasi…'; status.style.color = 'var(--ink-200)';
          const location = await getGeolocation();
          status.textContent = 'Mengirim…';
          // S355: skip the network if browser already knows we're offline.
          if (typeof navigator !== 'undefined' && navigator.onLine === false) {
            try {
              await queueOffline(text, location);
              status.textContent = '⏱ Queued (offline) — akan dikirim saat signal balik.'
                + (location ? ' (📍 lokasi disertakan)' : '');
              status.style.color = 'var(--gold-300)';
              msg.value = '';
              setTimeout(() => { modal.close(); }, 5000);
            } catch (qErr) {
              status.textContent = '✕ Gagal queue: ' + (qErr.message || 'storage error');
              status.style.color = 'var(--ruby)';
            } finally {
              submit.disabled = false;
            }
            return;
          }
          try {
            const { ok, body } = await tryDirectSend(text, location);
            if (ok) {
              status.textContent = '✓ SOS terkirim ke ' + body.recipients + ' penerima. Tim akan menghubungi.'
                + (location ? ' (📍 lokasi disertakan)' : '');
              status.style.color = 'var(--emerald)';
              msg.value = '';
              setTimeout(() => { modal.close(); }, 4000);
            } else {
              status.textContent = '✕ ' + (body.message || 'Gagal');
              status.style.color = 'var(--ruby)';
            }
          } catch (err) {
            // Network blew up mid-send → queue + tell jemaah.
            try {
              await queueOffline(text, location);
              status.textContent = '⏱ Gagal kirim langsung — queued, akan retry otomatis.';
              status.style.color = 'var(--gold-300)';
              msg.value = '';
              setTimeout(() => { modal.close(); }, 5000);
            } catch (qErr) {
              status.textContent = '✕ ' + (err.message || 'Network error');
              status.style.color = 'var(--ruby)';
            }
          } finally {
            submit.disabled = false;
          }
        });
        // S355 — auto-flush: replay queued SOS on `online` + every 30s tick.
        // Pending count surfaces as an amber badge on the FAB (mirrors crew
        // sos-fab S368 queued-incidents badge convention).
        let queuedBadge = null;
        function paintFabBadge(n) {
          if (!fab) return;
          if (n > 0) {
            if (!queuedBadge) {
              queuedBadge = document.createElement('span');
              queuedBadge.className = 'sos-fab-jemaah__queued';
              fab.appendChild(queuedBadge);
            }
            queuedBadge.textContent = String(n);
          } else if (queuedBadge) {
            queuedBadge.remove();
            queuedBadge = null;
          }
        }
        if (window.SosLightQueue) {
          window.SosLightQueue.startAutoFlush({
            intervalMs: 30_000,
            onChange: async () => {
              const n = await window.SosLightQueue.countPending();
              paintFabBadge(n);
            },
          });
        }
        // Stage 363 — PWA shortcut deep-link: when jemaah long-presses the
        // home icon and taps "🆘 SOS Cepat", browser opens /saya?sos=1.
        // Auto-open the SOS modal + focus textarea so jemaah can type one-
        // handed in panic. Best-effort — pre-trip jemaah (no inTrip block
        // rendered) just gets a no-op since the FAB doesn't exist on page.
        try {
          const sosParam = new URLSearchParams(window.location.search).get('sos');
          if (sosParam === '1' && modal) {
            openModal();
            // Strip ?sos=1 from URL so a reload doesn't keep re-opening.
            const url = new URL(window.location.href);
            url.searchParams.delete('sos');
            window.history.replaceState({}, '', url.pathname + (url.search ? url.search : ''));
          }
        } catch (_err) { /* silent — auto-open is a convenience, not load-bearing */ }
      })();
    </script>
  <% } %>

  <%# Booking list — naik ke atas (primary content). Sebelumnya di paling
      bawah; sekarang jadi panel pertama setelah hero karena ini yang user
      cari dulu saat buka /saya. %>
  <% if (bookings.length > 0) { %>
    <div class="panel">
      <h3 style="margin:0 0 4px;">Booking saya</h3>
      <p class="sub" style="margin:0 0 18px;"><%= bookings.length %> booking ter-klaim di akun ini.</p>
      <div class="booking-list">
        <% bookings.forEach(function(b) { %>
          <%
            const total = Number(b.totalAmount?.toString?.() ?? b.totalAmount) || 0;
            const paid  = Number(b.paidAmount?.toString?.() ?? b.paidAmount) || 0;
            const sisa  = Math.max(0, total - paid);
          %>
          <div class="booking-row">
            <div>
              <a href="/saya/bookings/<%= b.id %>" class="title-link"><%= b.paket.title %></a>
              <div class="meta">
                <span class="id"><%= b.bookingNo %></span>
                · <%= b.kelas %>
                · <%= b.paxCount %> PAX
                · DEP <%= fmt.dateShort(b.paket.departureDate) %>
                <% if (b.agent) { %> · via <%= b.agent.displayName %><% } %>
              </div>
            </div>
            <div>
              <span class="status-tag <%= b.status.toLowerCase() %>"><%= b.status %></span>
            </div>
            <div class="price">
              <%= fmt.rpShort(total) %>
              <div class="sub">
                <% if (paid >= total && total > 0) { %>
                  <span style="color:var(--emerald);">LUNAS</span>
                <% } else { %>
                  sisa <%= fmt.rpShort(sisa) %>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <%# Claim form — collapsible kalau jemaah sudah punya booking (visual noise
      reduction). Open default kalau 0 booking (panggilan utama untuk new user). %>
  <div id="claim-section" class="panel" style="<%= bookings.length === 0 ? '' : 'padding:0;border-color:var(--hairline-soft);' %>">
    <% if (bookings.length === 0) { %>
      <%# Empty state — full panel + emoji untuk visual warmth %>
      <div style="text-align:center;padding:8px 0 16px;">
        <div style="font-size:42px;line-height:1;margin-bottom:8px;">🕋</div>
        <h3 style="margin:0 0 6px;">Klaim booking pertama Anda</h3>
        <p class="sub" style="margin:0 0 16px;">Masukkan nomor booking (mis. <code>RP-2026-00001</code>) + nomor telepon yang Anda pakai saat booking.</p>
      </div>
      <form id="claim-form" class="claim-form">
        <div class="field">
          <label class="label" for="cl-no">Nomor Booking *</label>
          <input class="input" type="text" name="bookingNo" id="cl-no" required maxlength="50" placeholder="RP-2026-XXXXX">
        </div>
        <div class="field">
          <label class="label" for="cl-phone">Telepon saat booking *</label>
          <input class="input" type="text" name="phone" id="cl-phone" required maxlength="30" placeholder="0812-xxxx-xxxx">
        </div>
        <button type="submit">KLAIM</button>
      </form>
      <div class="claim-err" id="claim-err"></div>
      <div class="claim-ok" id="claim-ok"></div>
    <% } else { %>
      <details style="padding:14px 22px;">
        <summary style="cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:12px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-100);">
          <span>+ Klaim booking lain</span>
          <span style="color:var(--ink-300);font-size:10px;">tap untuk buka</span>
        </summary>
        <p class="sub" style="margin:14px 0 12px;">Nomor booking + telepon yang Anda pakai saat booking.</p>
        <form id="claim-form" class="claim-form">
          <div class="field">
            <label class="label" for="cl-no">Nomor Booking *</label>
            <input class="input" type="text" name="bookingNo" id="cl-no" required maxlength="50" placeholder="RP-2026-XXXXX">
          </div>
          <div class="field">
            <label class="label" for="cl-phone">Telepon saat booking *</label>
            <input class="input" type="text" name="phone" id="cl-phone" required maxlength="30" placeholder="0812-xxxx-xxxx">
          </div>
          <button type="submit">KLAIM</button>
        </form>
        <div class="claim-err" id="claim-err"></div>
        <div class="claim-ok" id="claim-ok"></div>
      </details>
    <% } %>
  </div>

  <%# Compact push toggle — dim strip di bawah, bukan panel full lagi. DOM
      contract (#rp-push-bar, #rp-push-enable, #rp-push-disable) preserved
      supaya push-jemaah.js logic tidak berubah. %>
  <div id="rp-push-strip" style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;padding:10px 16px;margin-top:14px;background:rgba(255,255,255,0.015);border:1px solid var(--hairline-soft);border-radius:var(--r-sm);">
    <div id="rp-push-bar" style="display:none;align-items:center;gap:10px;flex:1;min-width:200px;">
      <span style="font-size:16px;opacity:0.6;">🔔</span>
      <span id="rp-push-status" style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);letter-spacing:0.04em;">…</span>
    </div>
    <div style="display:flex;gap:6px;">
      <button type="button" id="rp-push-enable" style="display:none;background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:6px 14px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;border-radius:3px;font-weight:600;">Aktifkan</button>
      <button type="button" id="rp-push-disable" style="display:none;background:transparent;border:1px solid var(--ink-500);color:var(--ink-200);padding:6px 14px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;border-radius:3px;">Matikan</button>
    </div>
  </div>
</div>

<script>
  const cf = document.getElementById('claim-form');
  const ce = document.getElementById('claim-err');
  const co = document.getElementById('claim-ok');

  cf.addEventListener('submit', async (e) => {
    e.preventDefault();
    ce.classList.remove('is-visible');
    co.classList.remove('is-visible');
    const fd = new FormData(cf);
    try {
      const r = await fetch('/api/saya/claim', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookingNo: fd.get('bookingNo'), phone: fd.get('phone') }),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        ce.textContent = j?.error?.message || 'Klaim gagal';
        ce.classList.add('is-visible');
        return;
      }
      const j = await r.json();
      co.textContent = j.alreadyClaimed
        ? 'Booking ini memang sudah ter-klaim oleh akun Anda.'
        : 'Booking berhasil di-klaim. Memuat ulang…';
      co.classList.add('is-visible');
      setTimeout(() => location.reload(), 1000);
    } catch {
      ce.textContent = 'Tidak dapat menghubungi server';
      ce.classList.add('is-visible');
    }
  });
</script>
<%- include('partials/mobile-tabs') %>
<!-- Stage 94 — jemaah push subscribe (loads after the SW is registered) -->
<script src="/shared/push-jemaah.js" defer></script>
<!-- Stage 355 — offline-aware SOS-light queue (IndexedDB-backed) -->
<script src="/shared/sos-light-queue.js" defer></script>
<!-- Stage 367 — persistent storage opt-in (durability protection for IDB) -->
<script src="/shared/persist-storage.js" defer></script>
<%# Stage 366 — App Badging API. Paints the unread notif count on the
    installed PWA's home screen icon (Chromium-based browsers + some
    Android launchers; Safari ignores silently). Reads unreadCount that
    /saya already loads for the topbar badge so no extra round-trip. %>
<script>
  (function () {
    if (typeof navigator === 'undefined' || typeof navigator.setAppBadge !== 'function') return;
    const n = Number('<%= typeof unreadCount !== "undefined" ? unreadCount : 0 %>') || 0;
    try {
      if (n > 0) navigator.setAppBadge(n).catch(() => {});
      else navigator.clearAppBadge().catch(() => {});
    } catch (_err) { /* silent — badge is best-effort */ }
  })();
</script>
</body>
</html>

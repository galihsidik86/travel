            <div class="recap-cell">
              <div class="l">Booking baru</div>
              <div class="v"><%= paketRecap.counts.newBookings.toLocaleString('id-ID') %></div>
              <div class="s">cancel · <%= paketRecap.counts.cancelledBookings.toLocaleString('id-ID') %></div>
            </div>
            <div class="recap-cell">
              <div class="l">Lunas minggu ini</div>
              <div class="v"><%= paketRecap.counts.lunasBookings.toLocaleString('id-ID') %></div>
              <div class="s">dari semua status</div>
            </div>
            <div class="recap-cell">
              <div class="l">Pembayaran masuk</div>
              <div class="v money"><%= fmt.rpShort(paketRecap.money.paymentsInIdr) %><span class="u">IDR</span></div>
              <div class="s">refund · <%= fmt.rpShort(paketRecap.money.refundsOutIdr) %></div>
            </div>
            <div class="recap-cell">
              <div class="l">Net revenue</div>
              <div class="v money"><%= fmt.rpShort(paketRecap.money.netRevenueIdr) %><span class="u">IDR</span></div>
              <div class="s">PAID − REFUNDED</div>
            </div>
            <div class="recap-cell">
              <div class="l">Dokumen verified</div>
              <div class="v"><%= paketRecap.counts.docsVerified.toLocaleString('id-ID') %></div>
              <div class="s">7 hari</div>
            </div>
            <div class="recap-cell">
              <div class="l">Kursi</div>
              <div class="v"><%= paketRecap.paket.kursiTerisi %><span class="u">/<%= paketRecap.paket.kursiTotal %></span></div>
              <div class="s">status · <%= paketRecap.paket.status %></div>
            </div>
          </div>
          <% if (paketRecap.recentNewBookings.length > 0) { %>
            <div class="recap-list">
              <div class="recap-list-h">Booking baru terkini</div>
              <% paketRecap.recentNewBookings.forEach(function(b) { %>
                <a class="recap-list-row" href="/admin/bookings/<%= b.id %>">
                  <span class="bk-when"><%= fmt.date(b.createdAt) %></span>
                  <span class="bk-no"><%= b.bookingNo %></span>
                  <span class="bk-jem"><%= b.jemaah?.fullName || '—' %></span>
                  <span class="bk-st status-<%= b.status.toLowerCase() %>"><%= b.status %></span>
                  <span class="bk-amt"><%= fmt.rpShort(b.totalAmount) %></span>
                </a>
              <% }) %>
            </div>
          <% } %>
          <div class="recap-foot">
            <a href="/admin/paket/<%= paketRecap.paket.slug %>/edit">Edit paket →</a>
            ·
            <a href="/admin?tab=manifest&manifestPaket=<%= paketRecap.paket.slug %>">Manifest →</a>
          </div>
        </div>
        <style>
          .recap-select { background: var(--ink-1000); border: var(--hairline-soft); color: var(--cream-100); padding: 4px 8px; font-family: var(--font-mono); font-size: 11px; border-radius: 3px; min-width: 220px; }
          .recap-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
          .recap-cell { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 12px 14px; }
          .recap-cell .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
          .recap-cell .v { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin-top: 4px; font-weight: 500; line-height: 1.1; }
          .recap-cell .v.money { font-size: 18px; color: var(--gold-300); }
          .recap-cell .v .u { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); margin-left: 3px; font-weight: 400; letter-spacing: 0.08em; }
          .recap-cell .s { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; }
          .recap-list { margin-top: 14px; padding-top: 12px; border-top: var(--hairline-soft); }
          .recap-list-h { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 6px; }
          .recap-list-row { display: grid; grid-template-columns: 90px 160px 1fr 90px 100px; gap: 12px; padding: 6px 0; text-decoration: none; color: var(--cream-200); border-bottom: var(--hairline-soft); font-size: 12.5px; align-items: center; }
          .recap-list-row:last-child { border-bottom: 0; }
          .recap-list-row:hover { background: rgba(255,255,255,0.02); }
          .recap-list-row .bk-when { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); }
          .recap-list-row .bk-no   { font-family: var(--font-mono); font-size: 11px; color: var(--gold-300); }
          .recap-list-row .bk-jem  { color: var(--cream-100); }
          .recap-list-row .bk-st   { font-family: var(--font-mono); font-size: 9.5px; padding: 2px 6px; border-radius: 3px; border: 1px solid var(--ink-100); color: var(--ink-100); text-align: center; }
          .recap-list-row .bk-amt  { font-family: var(--font-mono); font-size: 11px; color: var(--cream-100); text-align: right; }
          .recap-foot { margin-top: 12px; padding-top: 10px; border-top: var(--hairline-soft); font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); }
          .recap-foot a { color: var(--gold-300); text-decoration: none; }
          @media (max-width: 1100px) { .recap-grid { grid-template-columns: repeat(3, 1fr); } .recap-list-row { grid-template-columns: 1fr 1fr; } }
          @media (max-width: 720px)  { .recap-grid { grid-template-columns: repeat(2, 1fr); } }
        </style>
      <% } %>

      <!-- Status breakdown — proportional stacked bar + legend -->
      <div class="panel" style="margin-bottom:16px;">
        <div class="panel__head">
          <h3>Distribusi status booking</h3>
          <span class="meta">TOTAL <%= kpis.bookingCount %></span>
        </div>
        <%
          const SB_STATUSES = [
            { key: 'PENDING',   cls: 's-pending'   },
            { key: 'BOOKED',    cls: 's-booked'    },
            { key: 'DP_PAID',   cls: 's-dp'        },
            { key: 'PARTIAL',   cls: 's-partial'   },
            { key: 'LUNAS',     cls: 's-lunas'     },
            { key: 'CANCELLED', cls: 's-cancelled' },
            { key: 'REFUNDED',  cls: 's-refunded'  },
          ];
          const SB_TOTAL = SB_STATUSES.reduce((acc, s) => acc + (statusBreakdown[s.key] || 0), 0);
          const SB_ROWS = SB_STATUSES
            .map((s) => ({ ...s, count: statusBreakdown[s.key] || 0 }))
            .filter((r) => r.count > 0);
        %>
        <% if (SB_TOTAL === 0) { %>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:16px 0;">
            Belum ada booking ter-record.
          </div>
        <% } else { %>
          <div class="chart-stack" role="img" aria-label="Distribusi status booking">
            <% SB_ROWS.forEach(function(r) {
              const pct = Math.max(0.5, (r.count / SB_TOTAL) * 100);
            %>
              <div class="seg <%= r.cls %>"
                   style="width:<%= pct %>%;"
                   title="<%= r.key.replace('_',' ') %>: <%= r.count %> (<%= Math.round((r.count / SB_TOTAL) * 100) %>%)"></div>
            <% }) %>
          </div>
          <div class="chart-legend">
            <% SB_ROWS.forEach(function(r) {
              const pct = Math.round((r.count / SB_TOTAL) * 100);
            %>
              <span class="item">
                <span class="swatch" style="background: var(--<%=
                  r.cls === 's-pending'   ? 'amber'    :
                  r.cls === 's-booked'    ? 'sapphire' :
                  r.cls === 's-dp'        ? 'gold-300' :
                  r.cls === 's-partial'   ? 'gold-200' :
                  r.cls === 's-lunas'     ? 'emerald'  :
                  'ruby' %>);"></span>
                <%= r.key.replace('_', ' ') %>
                <span class="count"><%= r.count %></span>
                <span class="pct"><%= pct %>%</span>
              </span>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Komisi pipeline — money distribution by status (proportional stack) -->
      <div class="panel" style="margin-bottom:16px;">
        <div class="panel__head">
          <h3>Pipeline komisi</h3>
          <span class="meta">NILAI IDR · SEMUA AGEN</span>
        </div>
        <%
          const KOM_PIPELINE = [
            { key: 'PENDING',   label: 'Pending',   cls: 's-partial',   swatch: 'gold-200' },
            { key: 'EARNED',    label: 'Earned',    cls: 's-pending',   swatch: 'amber'    },
            { key: 'PAID',      label: 'Paid',      cls: 's-lunas',     swatch: 'emerald'  },
            { key: 'CANCELLED', label: 'Cancelled', cls: 's-cancelled', swatch: 'ruby'     },
          ];
          const KP_TOTAL = KOM_PIPELINE.reduce((acc, s) => acc + (kpis.komisi[s.key] || 0), 0);
          const KP_ROWS = KOM_PIPELINE
            .map((s) => ({ ...s, amount: kpis.komisi[s.key] || 0 }))
            .filter((r) => r.amount > 0);
        %>
        <% if (KP_TOTAL === 0) { %>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:16px 0;">
            Belum ada komisi ter-record.
          </div>
        <% } else { %>
          <div class="chart-stack" role="img" aria-label="Pipeline komisi">
            <% KP_ROWS.forEach(function(r) {
              const pct = Math.max(0.5, (r.amount / KP_TOTAL) * 100);
            %>
              <div class="seg <%= r.cls %>"
                   style="width:<%= pct %>%;"
                   title="<%= r.label %>: <%= fmt.rpFull(r.amount) %> (<%= Math.round((r.amount / KP_TOTAL) * 100) %>%)"></div>
            <% }) %>
          </div>
          <div class="chart-legend">
            <% KP_ROWS.forEach(function(r) {
              const pct = Math.round((r.amount / KP_TOTAL) * 100);
            %>
              <span class="item">
                <span class="swatch" style="background: var(--<%= r.swatch %>);"></span>
                <%= r.label %>
                <span class="count"><%= fmt.rpShort(r.amount) %></span>
                <span class="pct"><%= pct %>%</span>
              </span>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="grid-2">
        <!-- Top paket -->
        <div class="panel">
          <div class="panel__head">
            <h3>Paket aktif · isi terbesar</h3>
            <span class="meta"><%= topPaket.length %> PAKET</span>
          </div>
          <% if (topPaket.length === 0) { %>
            <div style="padding:40px 0;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">Belum ada paket aktif.</div>
          <% } %>
          <% topPaket.forEach(function(p) { %>
            <div class="topp-row">
              <div>
                <div class="nm"><%= p.title %></div>
                <div class="sx">DEP <%= fmt.date(p.departureDate).toUpperCase() %> · <%= p.durationDays %> HARI</div>
                <div class="progress-bar"><i style="width:<%= p.fillPct %>%;"></i></div>
              </div>
              <div class="ku"><%= p.kursiTerisi %>/<%= p.kursiTotal %></div>
              <div class="pct"><%= p.fillPct %>%</div>
            </div>
          <% }) %>
        </div>

        <!-- Activity -->
        <div class="panel">
          <div class="panel__head">
            <h3>Aktivitas terkini</h3>
            <span class="meta"><%= recentActivity.length %> ENTRI</span>
          </div>
          <div class="activity">
            <% recentActivity.forEach(function(a) { %>
              <div class="activity__row">
                <div class="t"><%= relTime(a.createdAt) %></div>
                <div class="e">
                  <span class="who"><%= a.actorEmail || 'sistem' %></span>
                  <%= fmtAction(a.action) %>
                  <span class="ent"><%= a.entity %><% if (a.entityId) { %> <%= a.entityId.slice(-6) %><% } %></span>
                </div>
              </div>
            <% }) %>
            <% if (recentActivity.length === 0) { %>
              <div style="padding:24px 0;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">Belum ada aktivitas.</div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Per-paket revenue trend (5ee) -->
      <div class="panel">
        <div class="panel__head">
          <h3>Tren revenue per paket</h3>
          <span class="meta">LUNAS · <%= revenueTrendRange.days %> HARI</span>
        </div>
        <% if (!paketRevenueTrend || paketRevenueTrend.length === 0) { %>
          <div style="padding:24px 0;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
            Belum ada LUNAS booking di range yang dipilih.
          </div>
        <% } else { %>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <% paketRevenueTrend.forEach(function(p) {
              const maxRev = Math.max(1, ...p.daily.map(function(d) { return d.revenue; }));
              const W = 360, H = 36;
              const stepX = (W - 4) / Math.max(1, p.daily.length - 1);
              const points = p.daily.map(function(d, i) {
                const y = H - 2 - (d.revenue / maxRev) * (H - 6);
                return (2 + i * stepX).toFixed(1) + ',' + y.toFixed(1);
              }).join(' ');
              const areaPoints = '2,' + (H-2) + ' ' + points + ' ' + (2 + (p.daily.length - 1) * stepX).toFixed(1) + ',' + (H-2);
            %>
              <div style="display:grid;grid-template-columns:1fr <%= W %>px 130px;gap:16px;align-items:center;padding-bottom:14px;border-bottom:var(--hairline-soft);">
                <div>
                  <a href="/admin/paket/<%= p.slug %>/edit" style="color:var(--cream-100);text-decoration:none;font-weight:500;font-size:14px;line-height:1.3;display:block;">
                    <%= p.title %>
                  </a>
                  <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-top:2px;">
                    slug <%= p.slug %>
                  </div>
                </div>
                <svg viewBox="0 0 <%= W %> <%= H %>" preserveAspectRatio="none" style="width:100%;height:<%= H %>px;display:block;">
                  <polygon points="<%= areaPoints %>" fill="rgba(212,175,55,0.12)"/>
                  <polyline points="<%= points %>" fill="none" stroke="var(--gold-300)" stroke-width="1.5"/>
                </svg>
                <div style="text-align:right;">
                  <div style="font-family:var(--font-display);font-size:18px;color:var(--gold-300);font-weight:500;"><%= fmt.rpShort(p.total) %></div>
                  <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);">IDR · <%= p.daily.filter(function(d){return d.revenue>0;}).length %> hari aktif</div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Top agents revenue — horizontal bars (visual scan) -->
      <% const topAgentsForChart = topAgents.filter((a) => a.revenue > 0).slice(0, 6);
         const maxAgentRev = Math.max(1, ...topAgentsForChart.map((a) => a.revenue));
      %>
      <% if (topAgentsForChart.length > 0) { %>
        <div class="panel">
          <div class="panel__head">
            <h3>Revenue per agen</h3>
            <span class="meta">TOP <%= topAgentsForChart.length %> · LUNAS</span>
          </div>
          <div class="chart-bars-h">
            <% topAgentsForChart.forEach(function(a) {
              const pct = Math.max(1, (a.revenue / maxAgentRev) * 100);
            %>
              <div class="row">
                <div class="lbl">
                  <%= a.displayName %>
                  <span class="sx"><%= a.tier || 'Mitra' %> · <%= a.lunasCount %> lunas</span>
                </div>
                <div class="track" title="<%= fmt.rpFull(a.revenue) %> IDR">
                  <div class="fill" style="width:<%= pct %>%;"></div>
                </div>
                <div class="val">
                  <%= fmt.rpShort(a.revenue) %><span class="u">IDR</span>
                  <% if (a.komisiEarned > 0) { %>
                    <span class="sx">komisi <%= fmt.rpShort(a.komisiEarned) %></span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Per-paket leaderboard + cross-agent komisi monthly trend (stage 16 admin parity) -->
      <div class="panel">
        <div class="panel__head">
          <h3>Leaderboard paket</h3>
          <span class="meta">CROSS-AGEN · TOP <%= analytics.perPaketLeaderboard.length %></span>
        </div>
        <% if (analytics.perPaketLeaderboard.length === 0) { %>
          <div style="padding:24px 0;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
            Belum ada booking di range yang dipilih.
          </div>
        <% } else { %>
          <%
            const lbMaxRev = Math.max(1, ...analytics.perPaketLeaderboard.map((p) => p.lunasRevenue));
          %>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <% analytics.perPaketLeaderboard.forEach(function(p) {
              const pctOfMax = Math.round((p.lunasRevenue / lbMaxRev) * 100);
              const convCls = p.conversionPct == null ? 'ink-200' :
                              p.conversionPct >= 50 ? 'emerald' :
                              p.conversionPct >= 25 ? 'gold-300' : 'ink-200';
            %>
              <%
                // Stage 22 — net margin per paket. Null when admin hasn't
                // entered costPerPaxIdr yet (don't pretend to compute).
                const marginCls = p.marginPct == null ? 'ink-200' :
                                  p.marginPct >= 20 ? 'emerald' :
                                  p.marginPct >= 5  ? 'gold-300' :
                                  p.marginPct >= 0  ? 'amber' : 'ruby';
                const netCls = p.netMarginIdr == null ? 'ink-200' :
                               p.netMarginIdr >= 0 ? 'emerald' : 'ruby';
              %>
              <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:12px 16px;">
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;">
                  <a href="/admin/paket/<%= p.slug %>/edit"
                     style="color:var(--cream-100);text-decoration:none;font-size:14px;font-weight:500;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    <%= p.title %>
                  </a>
                  <% if (p.speedTier && p.speedTier !== 'unknown') {
                    const tierCls = p.speedTier === 'fast' ? 'emerald'
                                  : p.speedTier === 'acceptable' ? 'amber' : 'ruby';
                    const tierLabel = p.speedTier === 'fast' ? 'FAST'
                                    : p.speedTier === 'acceptable' ? 'OK' : 'SLOW';
                  %>
                    <span title="p95 <%= p.speedP95 %>ms · <%= p.speedSample %> sample (7d)"
                          style="font-family:var(--font-mono);font-size:9px;font-weight:600;padding:2px 6px;border:1px solid var(--<%= tierCls %>);border-radius:3px;color:var(--<%= tierCls %>);letter-spacing:0.1em;">
                      <%= tierLabel %> <%= p.speedP95 %>ms
                    </span>
                  <% } %>
                  <span style="font-family:var(--font-mono);font-size:12px;color:var(--gold-300);white-space:nowrap;">
                    <%= fmt.rpShort(p.lunasRevenue) %>
                  </span>
                </div>
                <div style="height:5px;background:var(--ink-700);border-radius:2px;margin-top:8px;overflow:hidden;">
                  <i style="display:block;height:100%;width:<%= pctOfMax %>%;background:var(--gold-300);"></i>
                </div>
                <div style="display:flex;gap:16px;margin-top:8px;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);flex-wrap:wrap;">
                  <span><%= p.totalBookings %> booking</span>
                  <span style="color:var(--gold-300);"><%= p.lunasCount %> LUNAS</span>
                  <% if (p.hotCount > 0) { %><span><%= p.hotCount %> hot</span><% } %>
                  <% if (p.cancelledCount > 0) { %><span style="color:var(--ruby);"><%= p.cancelledCount %> cncl</span><% } %>
                  <span><%= p.agentCount %> agen<% if (p.directCount > 0) { %> + <%= p.directCount %> kantor pusat<% } %></span>
                  <span style="margin-left:auto;color:var(--<%= convCls %>);">
                    <%= p.conversionPct ?? '—' %>% conv
                  </span>
                </div>
                <div style="display:flex;gap:14px;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-300);flex-wrap:wrap;border-top:var(--hairline-soft);padding-top:6px;">
                  <% if (p.costPerPaxIdr != null) { %>
                    <span>cost <%= fmt.rpShort(p.totalCostIdr) %></span>
                    <span>komisi <%= fmt.rpShort(p.komisiLiabilityIdr) %></span>
                    <span style="color:var(--<%= netCls %>);">
                      net <%= p.netMarginIdr < 0 ? '−' : '' %><%= fmt.rpShort(Math.abs(p.netMarginIdr)) %>
                    </span>
                    <span style="margin-left:auto;color:var(--<%= marginCls %>);font-weight:600;">
                      <%= p.marginPct %>% margin
                    </span>
                  <% } else { %>
                    <span style="font-style:italic;">— margin: set "Biaya per pax" di paket edit</span>
                  <% } %>
                </div>
                <% if (p.adsSpendIdr != null) {
                  // Stage 61 — ROI row. roiX null when adsSpendIdr=0 (clean
                  // dev fixture); render "—" rather than ∞.
                  const roiCls = p.roiX == null ? 'ink-200'
                              : p.roiX >= 5 ? 'emerald'
                              : p.roiX >= 3 ? 'gold-300'
                              : p.roiX >= 1 ? 'amber' : 'ruby';
                %>
                  <div style="display:flex;gap:14px;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-300);flex-wrap:wrap;border-top:var(--hairline-soft);padding-top:6px;">
                    <span>ads <%= fmt.rpShort(p.adsSpendIdr) %></span>
                    <% if (p.netMarginIdr != null) {
                      // net margin AFTER ads spend (different from S22 margin)
                      const netAfterAds = p.netMarginIdr - p.adsSpendIdr;
                      const naaCls = netAfterAds >= 0 ? 'emerald' : 'ruby';
                    %>
                      <span style="color:var(--<%= naaCls %>);">
                        net post-ads <%= netAfterAds < 0 ? '−' : '' %><%= fmt.rpShort(Math.abs(netAfterAds)) %>
                      </span>
                    <% } %>
                    <span style="margin-left:auto;color:var(--<%= roiCls %>);font-weight:600;">
                      <%= p.roiX != null ? p.roiX + '×' : '—' %> ROI
                    </span>
                  </div>
                <% } %>
                <% if (p.previousSeason) {
                  const prev = p.previousSeason;
                  const revUp = prev.revenueDelta >= 0;
                  const revCls = revUp ? 'emerald' : 'ruby';
                  const revArrow = revUp ? '▲' : '▼';
                  // marginDeltaPp = pp (percentage points) — null when cost
                  // missing on either side. Polarity: higher margin = better.
                  let marginPpCls = 'ink-200';
                  let marginPpArrow = '';
                  if (prev.marginDeltaPp != null) {
                    if (prev.marginDeltaPp > 0) { marginPpCls = 'emerald'; marginPpArrow = '▲'; }
                    else if (prev.marginDeltaPp < 0) { marginPpCls = 'ruby'; marginPpArrow = '▼'; }
                    else { marginPpArrow = '='; }
                  }
                %>
                  <div style="display:flex;gap:14px;margin-top:6px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);flex-wrap:wrap;border-top:var(--hairline-soft);padding-top:6px;">
                    <span style="color:var(--ink-100);">YoY vs <a href="/admin/paket/<%= prev.slug %>/edit" style="color:var(--gold-300);text-decoration:none;"><%= prev.title %></a></span>
                    <span style="color:var(--<%= revCls %>);">
                      <%= revArrow %> revenue <%= prev.revenueDeltaPct != null ? (prev.revenueDeltaPct > 0 ? '+' : '') + prev.revenueDeltaPct + '%' : (revUp ? '+' : '') + fmt.rpShort(prev.revenueDelta) %>
                    </span>
                    <% if (prev.marginDeltaPp != null) { %>
                      <span style="color:var(--<%= marginPpCls %>);">
                        <%= marginPpArrow %> margin <%= prev.marginDeltaPp > 0 ? '+' : '' %><%= prev.marginDeltaPp %>pp
                      </span>
                    <% } %>
                    <span style="margin-left:auto;">prev <%= fmt.rpShort(prev.lunasRevenue) %> · <%= prev.lunasCount %> lunas</span>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Stage 43 — Manifest close countdown -->
      <% if (manifestClosing && manifestClosing.counts.total > 0) {
        const overdueCount = manifestClosing.counts.overdue;
      %>
        <div class="panel <%= overdueCount > 0 ? 'mc-warn' : '' %>" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Manifest tutup segera</h3>
            <span class="meta">
              <%= manifestClosing.counts.urgent %> URGENT
              <% if (overdueCount > 0) { %>· <strong style="color:var(--ruby);"><%= overdueCount %> OVERDUE</strong><% } %>
            </span>
          </div>
          <div class="mc-list">
            <% manifestClosing.rows.forEach(function(r) {
              const cls = r.overdue ? 'ruby' :
                          r.hoursUntilClose <= 24 ? 'amber' :
                          r.hoursUntilClose <= 48 ? 'gold-300' : 'emerald';
              const label = r.overdue
                ? `OVERDUE · ${Math.abs(r.hoursUntilClose)}h yang lalu`
                : (r.hoursUntilClose <= 24
                    ? `tutup dalam ${r.hoursUntilClose}j`
                    : `tutup dalam ${Math.round(r.hoursUntilClose / 24)}h`);
            %>
              <div class="mc-row">
                <div class="mc-title">
                  <a href="/admin/paket/<%= r.slug %>/edit"><%= r.title %></a>
                  <span class="mc-sub">
                    <%= r.kursiTerisi %>/<%= r.kursiTotal %> kursi
                    · <%= r.seatsRemaining %> tersisa
                    · berangkat <%= fmt.date(r.departureDate) %>
                  </span>
                </div>
                <div class="mc-when" style="color:var(--<%= cls %>);"><%= label %></div>
                <form method="POST" action="/admin/paket/<%= r.slug %>/extend-manifest-close" style="margin:0;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="hours" value="24">
                  <button type="submit" class="mc-btn">+ 24 jam</button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>
        <style>
          .panel.mc-warn { border-left: 3px solid var(--ruby); }
          .mc-list { display: flex; flex-direction: column; gap: 8px; }
          .mc-row { display: grid; grid-template-columns: 1fr 200px 90px; gap: 14px; align-items: center; padding: 10px 14px; background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); }
          .mc-title { min-width: 0; }
          .mc-title a { color: var(--cream-100); text-decoration: none; font-size: 13.5px; font-weight: 500; }
          .mc-title .mc-sub { display: block; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; }
          .mc-when { font-family: var(--font-mono); font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-align: right; }
          .mc-btn { background: var(--gold-300); color: var(--ink-1000); border: 0; padding: 7px 12px; border-radius: 3px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.08em; font-weight: 600; cursor: pointer; text-transform: uppercase; }
          .mc-btn:hover { background: var(--gold-200); }
          @media (max-width: 720px) { .mc-row { grid-template-columns: 1fr; } }
        </style>
      <% } %>

      <!-- Stage 142 — Admin mirror of S141 jemaah-side nudges. Surfaces
           per-paket "n jemaah di-nudge dalam 24 jam terakhir, follow-up via WA"
           so admin sees what's been pushed without grep'ing the notif queue. -->
      <% if (manifestNudgeAdmin && manifestNudgeAdmin.rows.length > 0) { %>
        <div class="panel" style="margin-bottom:16px;border-left:3px solid var(--gold-300);">
          <div class="panel__head">
            <h3>Jemaah di-nudge (manifest tutup)</h3>
            <span class="meta"><%= manifestNudgeAdmin.totalBookings %> JEMAAH · <%= manifestNudgeAdmin.totalPaket %> PAKET · <%= manifestNudgeAdmin.windowHours %> JAM</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <% manifestNudgeAdmin.rows.forEach(function(r) {
              const closeAt = r.paket.manifestClosesAt;
              const closeStr = closeAt ? fmt.dateShort(closeAt) : '—';
            %>
              <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:12px 14px;">
                <div style="display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;align-items:baseline;">
                  <div>
                    <a href="/admin/paket/<%= r.paket.slug %>/edit" style="color:var(--cream-100);text-decoration:none;font-size:13.5px;font-weight:500;"><%= r.paket.title %></a>
                    <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);margin-top:2px;">
                      <%= r.paket.slug %> · manifest tutup <%= closeStr %>
                    </div>
                  </div>
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);">
                    <strong style="font-size:18px;color:var(--cream-100);"><%= r.totalJemaah %></strong> jemaah · nudge terbaru <%= r.hoursSinceLast %>j lalu
                  </div>
                </div>
                <% if (r.missingSummary && r.missingSummary.length > 0) { %>
                  <div style="margin-top:8px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-100);">
                    <% r.missingSummary.forEach(function(m, i) { %><%= i > 0 ? ' · ' : '' %><span style="color:var(--amber);"><%= m.count %>× <%= m.label %></span><% }) %>
                  </div>
                <% } %>
                <details style="margin-top:8px;">
                  <summary style="cursor:pointer;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);letter-spacing:0.06em;text-transform:uppercase;">Lihat <%= r.bookings.length %> jemaah →</summary>
                  <div style="margin-top:8px;display:flex;flex-direction:column;gap:6px;">
                    <% r.bookings.forEach(function(b) { %>
                      <div style="display:flex;justify-content:space-between;gap:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-100);padding:4px 0;border-top:1px dashed var(--hairline);">
                        <div>
                          <a href="/admin/bookings/<%= b.bookingId %>" style="color:var(--gold-300);text-decoration:none;"><%= b.bookingNo %></a>
                          · <span style="color:var(--cream-100);"><%= b.jemaah?.fullName || '—' %></span>
                          <% if (b.jemaah?.phone) { %>
                            · <a href="https://wa.me/<%= String(b.jemaah.phone).replace(/[^0-9]/g, '').replace(/^0/, '62') %>" target="_blank" style="color:var(--emerald);text-decoration:none;" title="WA jemaah">WA</a>
                          <% } %>
                        </div>
                        <div style="color:var(--ink-200);">
                          <% b.channels.forEach(function(c) { %><span style="font-size:9px;border:1px solid var(--ink-200);padding:1px 4px;border-radius:2px;margin-left:3px;"><%= c %></span><% }) %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </details>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Stage 40 — Per-paket forecast (14d velocity → days-to-full) -->
      <% if (paketForecasts && paketForecasts.length > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Forecast paket</h3>
            <span class="meta">14 HARI · DAYS-TO-FULL</span>
          </div>
          <div class="fc-list">
            <% paketForecasts.forEach(function(f) {
              // dtfDays vs daysToDeparture decides urgency colour
              let dtfCls = 'ink-200';
              let badge = '';
              if (f.full) { dtfCls = 'emerald'; badge = 'PENUH'; }
              else if (f.noVelocity) { dtfCls = 'ink-200'; badge = '—'; }
              else if (f.risk === 'short') { dtfCls = 'ruby'; badge = `H+${f.dtfDays - f.daysToDeparture}d`; }
              else if (f.dtfDays <= 7) { dtfCls = 'amber'; badge = 'PEKAN INI'; }
              else if (f.dtfDays <= 30) { dtfCls = 'gold-300'; badge = '<1 BULAN'; }
              else { dtfCls = 'emerald'; badge = 'AMAN'; }
              const fillPct = f.paket.kursiTotal === 0 ? 0
                : Math.round((f.paket.kursiTerisi / f.paket.kursiTotal) * 100);
            %>
              <a class="fc-row" href="/admin/paket/<%= f.paket.slug %>/edit">
                <div class="fc-title">
                  <%= f.paket.title %>
                  <span class="fc-sub">
                    <%= f.paket.kursiTerisi %>/<%= f.paket.kursiTotal %> kursi
                    · berangkat dalam <%= f.daysToDeparture %>h
                    · velocity <%= f.velocity.toFixed(1) %>/hari
                  </span>
                </div>
                <div class="fc-bar">
                  <i style="width:<%= fillPct %>%;"></i>
                </div>
                <div class="fc-dtf">
                  <% if (f.full) { %>
                    <span class="fc-dtf-v" style="color:var(--emerald);">PENUH</span>
                  <% } else if (f.noVelocity) { %>
                    <span class="fc-dtf-v muted">—</span>
                    <span class="fc-dtf-s">tidak ada booking 14h</span>
                  <% } else { %>
                    <span class="fc-dtf-v" style="color:var(--<%= dtfCls %>);">
                      <%= f.dtfDays %>h
                    </span>
                    <span class="fc-dtf-s"><%= f.dtfLowDays %>–<%= f.dtfHighDays %>h</span>
                  <% } %>
                </div>
                <div class="fc-badge" style="color:var(--<%= dtfCls %>);border-color:var(--<%= dtfCls %>);">
                  <%= badge %>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
        <style>
          .fc-list { display: flex; flex-direction: column; gap: 8px; }
          .fc-row { display: grid; grid-template-columns: 1fr 120px 100px 90px; gap: 14px; align-items: center; padding: 10px 14px; background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); text-decoration: none; color: var(--cream-100); }
          .fc-row:hover { background: rgba(255,255,255,0.03); }
          .fc-title { font-size: 13.5px; color: var(--cream-100); font-weight: 500; min-width: 0; overflow: hidden; }
          .fc-title .fc-sub { display: block; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); margin-top: 2px; letter-spacing: 0.04em; }
          .fc-bar { height: 6px; background: var(--ink-700); border-radius: 3px; overflow: hidden; }
          .fc-bar i { display: block; height: 100%; background: var(--gold-300); }
          .fc-dtf { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
          .fc-dtf-v { font-family: var(--font-display); font-size: 18px; font-weight: 500; line-height: 1; }
          .fc-dtf-v.muted { color: var(--ink-300); }
          .fc-dtf-s { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.04em; }
          .fc-badge { font-family: var(--font-mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.1em; text-align: center; padding: 4px 6px; border: 1px solid; border-radius: 3px; }
          @media (max-width: 900px) {
            .fc-row { grid-template-columns: 1fr 80px 80px; }
            .fc-bar { display: none; }
          }
        </style>
      <% } %>

      <!-- Stage 48 — Public paket conversion funnel -->
      <% if (paketConversion && paketConversion.rows.length > 0) {
        const tot = paketConversion.totals;
        const overall = tot.visits > 0
          ? Math.round((tot.bookings / tot.visits) * 1000) / 10
          : null;
      %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Konversi paket (landing → booking)</h3>
            <span class="meta"><%= paketConversion.window.days %> HARI · <%= tot.visits %> VISIT · <%= tot.bookings %> BOOKING</span>
          </div>
          <div class="conv-kpis">
            <div class="ck">
              <div class="ck-l">Overall conversion</div>
              <%
                const ovCls = overall == null ? 'ink-200'
                  : overall >= 5 ? 'emerald'
                  : overall >= 2 ? 'gold-300'
                  : overall >= 1 ? 'amber' : 'ruby';
              %>
              <div class="ck-v" style="color:var(--<%= ovCls %>);"><%= overall ?? '—' %>%</div>
              <div class="ck-s">booking ÷ visit</div>
            </div>
            <div class="ck">
              <div class="ck-l">Total visit unik</div>
              <div class="ck-v"><%= tot.visits %></div>
              <div class="ck-s"><%= paketConversion.rows.length %> paket aktif</div>
            </div>
          </div>
          <%
            // Stage 64 — testimonial split. Show only when both buckets
            // have ≥10 visits so admin doesn't read into noise.
            const ts = paketConversion.testimonialSplit;
            const showSplit = ts && ts.withTestimonial.visits >= 10 && ts.withoutTestimonial.visits >= 10;
          %>
          <% if (showSplit) {
            const liftCls = ts.liftPct == null ? 'ink-200'
              : ts.liftPct > 20  ? 'emerald'
              : ts.liftPct > 0   ? 'gold-300'
              : ts.liftPct === 0 ? 'ink-200'
              : 'ruby';
          %>
            <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:12px 14px;margin-bottom:14px;">
              <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">
                Pengaruh testimonial · social proof split
                <% if (ts.liftPct != null) { %>
                  <span style="float:right;color:var(--<%= liftCls %>);font-weight:600;">
                    Lift <%= ts.liftPct > 0 ? '+' : '' %><%= ts.liftPct %>%
                  </span>
                <% } %>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <%
                  const w = ts.withTestimonial;
                  const wo = ts.withoutTestimonial;
                  function cvCls(pct) {
                    if (pct == null) return 'ink-200';
                    if (pct >= 5) return 'emerald';
                    if (pct >= 2) return 'gold-300';
                    if (pct >= 1) return 'amber';
                    return 'ruby';
                  }
                %>
                <div style="background:var(--ink-900);border:1px solid var(--ink-700);border-radius:var(--r-sm);padding:10px 14px;">
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);">
                    DENGAN TESTIMONIAL · <%= w.paketCount %> paket
                  </div>
                  <div style="font-family:var(--font-display);font-size:22px;color:var(--<%= cvCls(w.conversionPct) %>);margin-top:4px;font-weight:500;">
                    <%= w.conversionPct ?? '—' %>%
                  </div>
                  <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-100);margin-top:4px;">
                    <%= w.visits %> visit · <%= w.bookings %> booking
                  </div>
                </div>
                <div style="background:var(--ink-900);border:1px solid var(--ink-700);border-radius:var(--r-sm);padding:10px 14px;">
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);">
                    TANPA TESTIMONIAL · <%= wo.paketCount %> paket
                  </div>
                  <div style="font-family:var(--font-display);font-size:22px;color:var(--<%= cvCls(wo.conversionPct) %>);margin-top:4px;font-weight:500;">
                    <%= wo.conversionPct ?? '—' %>%
                  </div>
                  <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-100);margin-top:4px;">
                    <%= wo.visits %> visit · <%= wo.bookings %> booking
                  </div>
                </div>
              </div>
            </div>
          <% } %>
          <table class="tbl conv-table">
            <thead>
              <tr>
                <th>Paket</th>
                <th class="num">Visit unik</th>
                <th class="num">Booking</th>
                <th class="num">Konv %</th>
              </tr>
            </thead>
            <tbody>
              <% paketConversion.rows.forEach(function(r) {
                const cls = r.conversionPct == null ? 'ink-200'
                  : r.conversionPct >= 5 ? 'emerald'
                  : r.conversionPct >= 2 ? 'gold-300'
                  : r.conversionPct >= 1 ? 'amber' : 'ruby';
              %>
                <tr>
                  <td>
                    <a href="/p/<%= r.paket.slug %>" target="_blank" rel="noopener" style="color:var(--cream-100);text-decoration:none;">
                      <%= r.paket.title %>
                    </a>
                  </td>
                  <td class="num"><%= r.visits %></td>
                  <td class="num" style="color:var(--gold-300);"><%= r.bookings %></td>
                  <td class="num" style="color:var(--<%= cls %>);font-weight:600;">
                    <%= r.conversionPct ?? '—' %>%
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <style>
          .conv-kpis { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 14px; }
          .ck { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 12px 14px; }
          .ck-l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
          .ck-v { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin-top: 4px; font-weight: 500; }
          .ck-s { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; }
          .conv-table .num { text-align: right; font-family: var(--font-mono); font-size: 12px; }
        </style>
      <% } %>

      <!-- Stage 56 — landing speed budget -->
      <% if (landingSpeed && landingSpeed.sample > 0) {
        const overBudget = landingSpeed.overBudget;
        const p95Cls = overBudget ? 'ruby'
          : landingSpeed.p95 == null ? 'ink-200'
          : landingSpeed.p95 > landingSpeed.budgetMs * 0.75 ? 'amber'
          : 'emerald';
      %>
        <div class="panel <%= overBudget ? 'mc-warn' : '' %>" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Landing speed budget</h3>
            <span class="meta">
              <%= landingSpeed.window.days %>D · <%= landingSpeed.sample %> SAMPLE
              <% if (landingSpeed.lowSample) { %> · <strong style="color:var(--amber);">LOW SAMPLE</strong><% } %>
            </span>
          </div>
          <div class="conv-kpis">
            <div class="ck">
              <div class="ck-l">p95 latency</div>
              <div class="ck-v" style="color:var(--<%= p95Cls %>);"><%= landingSpeed.p95 ?? '—' %><span style="font-size:11px;color:var(--ink-200);"> ms</span></div>
              <div class="ck-s">budget <%= landingSpeed.budgetMs %> ms</div>
            </div>
            <div class="ck">
              <div class="ck-l">p50 / p99</div>
              <div class="ck-v"><%= landingSpeed.p50 ?? '—' %><span style="font-size:14px;color:var(--ink-200);"> / <%= landingSpeed.p99 ?? '—' %> ms</span></div>
              <div class="ck-s">/p/:slug server render</div>
            </div>
          </div>
          <% if (landingSpeed.perPaket && landingSpeed.perPaket.length > 0) { %>
            <table class="tbl">
              <thead>
                <tr>
                  <th>Paket terlambat (p95 desc, ≥5 sample)</th>
                  <th class="num">Sample</th>
                  <th class="num">p50 ms</th>
                  <th class="num">p95 ms</th>
                </tr>
              </thead>
              <tbody>
                <% landingSpeed.perPaket.forEach(function(r) {
                  const cls = r.p95 > landingSpeed.budgetMs ? 'ruby'
                            : r.p95 > landingSpeed.budgetMs * 0.75 ? 'amber'
                            : 'emerald';
                %>
                  <tr>
                    <td>
                      <a href="/p/<%= r.paket.slug %>" target="_blank" rel="noopener" style="color:var(--cream-100);text-decoration:none;">
                        <%= r.paket.title %>
                      </a>
                    </td>
                    <td class="num" style="font-family:var(--font-mono);"><%= r.sample %></td>
                    <td class="num" style="font-family:var(--font-mono);"><%= r.p50 %></td>
                    <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;"><%= r.p95 %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      <% } %>

      <!-- Stage 79 — email CTR by notif type -->
      <% if (emailCtr && emailCtr.totals.sent > 0) {
        const ovCtr = emailCtr.totals.ctrPct;
        const ovCls = ovCtr == null ? 'ink-200'
          : ovCtr >= 30 ? 'emerald'
          : ovCtr >= 15 ? 'gold-300'
          : ovCtr >= 5  ? 'amber' : 'ruby';
      %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Click-through rate (per type × channel)</h3>
            <span class="meta"><%= emailCtr.windowDays %> HARI · <%= emailCtr.totals.sent %> SENT · <%= emailCtr.totals.clicked %> CLICKED · <strong style="color:var(--<%= ovCls %>);"><%= ovCtr ?? '—' %>%</strong> OVERALL</span>
          </div>
          <table class="tbl">
            <thead>
              <tr>
                <th>Notif type</th>
                <th>Channel</th>
                <th class="num">Sent</th>
                <th class="num">Clicked unik</th>
                <th class="num">CTR</th>
              </tr>
            </thead>
            <tbody>
              <% emailCtr.rows.forEach(function(r) {
                const cls = r.ctrPct == null ? 'ink-200'
                  : r.ctrPct >= 30 ? 'emerald'
                  : r.ctrPct >= 15 ? 'gold-300'
                  : r.ctrPct >= 5  ? 'amber' : 'ruby';
                const chCls = r.channel === 'WA' ? 'emerald' : 'sapphire';
              %>
                <tr style="<%= r.lowSample ? 'opacity:0.55;' : '' %>">
                  <td style="font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);">
                    <% if (r.clicked > 0) { %>
                      <a href="/admin/email-ctr/<%= r.type %>?channel=<%= r.channel %>" style="color:var(--cream-100);text-decoration:underline;text-decoration-color:var(--gold-300);text-underline-offset:3px;"><%= r.type %></a>
                    <% } else { %>
                      <%= r.type %>
                    <% } %>
                    <% if (r.lowSample) { %> <span style="color:var(--amber);font-size:9.5px;">(low sample)</span><% } %>
                  </td>
                  <td style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;color:var(--<%= chCls %>);"><%= r.channel %></td>
                  <td class="num" style="font-family:var(--font-mono);"><%= r.sent %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--gold-300);"><%= r.clicked %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;">
                    <%= r.ctrPct ?? '—' %>%
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <!-- Stage 51 — UTM campaign breakdown -->
      <% if (utmBreakdown && utmBreakdown.rows.length > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Sumber kampanye (UTM)</h3>
            <span class="meta"><%= utmBreakdown.window.days %> HARI · <%= utmBreakdown.rows.length %> SUMBER</span>
          </div>
          <table class="tbl">
            <thead>
              <tr>
                <th>Sumber</th>
                <th class="num">Visit</th>
                <th class="num">Booking</th>
                <th class="num">Konv %</th>
              </tr>
            </thead>
            <tbody>
              <% utmBreakdown.rows.forEach(function(r) {
                const cls = r.conversionPct == null ? 'ink-200'
                  : r.conversionPct >= 5 ? 'emerald'
                  : r.conversionPct >= 2 ? 'gold-300'
                  : r.conversionPct >= 1 ? 'amber' : 'ruby';
              %>
                <tr>
                  <td<%= r.isDirect ? ' style="color:var(--ink-200);font-style:italic;"' : '' %>>
                    <%= r.label %>
                  </td>
                  <td class="num" style="font-family:var(--font-mono);"><%= r.visits %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--gold-300);"><%= r.bookings %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;">
                    <%= r.conversionPct ?? '—' %>%
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <!-- Stage 132 — referrer-host attribution for visits without UTM. Same panel, sub-section so admin sees both lenses together. -->
          <% if (referrerBreakdown && referrerBreakdown.rows.length > 0) { %>
            <div style="margin-top:18px;padding-top:14px;border-top:1px dashed var(--hairline);">
              <div class="panel__head" style="margin-bottom:8px;">
                <h3 style="font-size:13px;">Sumber referrer (tanpa UTM)</h3>
                <span class="meta"><%= referrerBreakdown.window.days %> HARI · <%= referrerBreakdown.rows.length %> HOST</span>
              </div>
              <table class="tbl">
                <thead>
                  <tr>
                    <th>Host</th>
                    <th class="num">Visit</th>
                    <th class="num">Booking</th>
                    <th class="num">Konv %</th>
                  </tr>
                </thead>
                <tbody>
                  <% referrerBreakdown.rows.forEach(function(r) {
                    const cls = r.conversionPct == null ? 'ink-200'
                      : r.conversionPct >= 5 ? 'emerald'
                      : r.conversionPct >= 2 ? 'gold-300'
                      : r.conversionPct >= 1 ? 'amber' : 'ruby';
                  %>
                    <tr>
                      <td<%= r.isDirect ? ' style="color:var(--ink-200);font-style:italic;"' : '' %>>
                        <%= r.label %>
                      </td>
                      <td class="num" style="font-family:var(--font-mono);"><%= r.visits %></td>
                      <td class="num" style="font-family:var(--font-mono);color:var(--gold-300);"><%= r.bookings %></td>
                      <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;">
                        <%= r.conversionPct ?? '—' %>%
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
              <div style="margin-top:6px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-300);letter-spacing:0.04em;">
                * traffic dari sini bisa overlap dengan UTM panel di atas — visit dengan UTM tags juga punya referrer host.
              </div>
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Stage 35 — Refund analytics (last 90 days, top 10 per dimension) -->
      <% if (refundAnalytics && refundAnalytics.totals.refunded > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Analitik refund</h3>
            <span class="meta"><%= refundAnalytics.window.days %> HARI · <%= refundAnalytics.totals.refundCount %> REFUND</span>
          </div>
          <div class="refund-kpis">
            <div class="rk">
              <div class="rk-l">Total refund</div>
              <div class="rk-v ruby"><%= fmt.rpShort(refundAnalytics.totals.refunded) %><span class="u">IDR</span></div>
              <div class="rk-s">dari <%= fmt.rpShort(refundAnalytics.totals.paid) %> PAID</div>
            </div>
            <div class="rk">
              <div class="rk-l">Refund rate</div>
              <%
                const rate = refundAnalytics.totals.ratePct;
                const rateCls = rate == null ? 'ink-200' :
                                rate >= 5 ? 'ruby' :
                                rate >= 2 ? 'amber' :
                                rate >  0 ? 'gold-300' : 'emerald';
              %>
              <div class="rk-v" style="color:var(--<%= rateCls %>);"><%= rate ?? '—' %>%</div>
              <div class="rk-s">refund ÷ PAID</div>
            </div>
          </div>
          <div class="refund-cols">
            <div class="refund-col">
              <div class="rc-h">Per paket · top <%= refundAnalytics.perPaket.length %></div>
              <% if (refundAnalytics.perPaket.length === 0) { %>
                <div class="rc-empty">Tidak ada refund di paket manapun.</div>
              <% } else { %>
                <% refundAnalytics.perPaket.forEach(function(r) {
                  const rcls = r.refundRatePct == null ? 'ink-200' :
                               r.refundRatePct >= 10 ? 'ruby' :
                               r.refundRatePct >= 5  ? 'amber' :
                               r.refundRatePct >  0  ? 'gold-300' : 'emerald';
                %>
                  <a class="rc-row" href="/admin/refunds?paket=<%= r.paket?.slug || '' %>" title="Lihat detail refund untuk paket ini">
                    <span class="rc-name"><%= r.paket?.title || '(deleted)' %></span>
                    <span class="rc-amt"><%= fmt.rpShort(r.refunded) %></span>
                    <span class="rc-rate" style="color:var(--<%= rcls %>);"><%= r.refundRatePct ?? '—' %>%</span>
                  </a>
                <% }) %>
              <% } %>
            </div>
            <div class="refund-col">
              <div class="rc-h">Per agen · top <%= refundAnalytics.perAgent.length %></div>
              <% if (refundAnalytics.perAgent.length === 0) { %>
                <div class="rc-empty">Tidak ada refund di agen manapun.</div>
              <% } else { %>
                <% refundAnalytics.perAgent.forEach(function(r) {
                  const rcls = r.refundRatePct == null ? 'ink-200' :
                               r.refundRatePct >= 10 ? 'ruby' :
                               r.refundRatePct >= 5  ? 'amber' :
                               r.refundRatePct >  0  ? 'gold-300' : 'emerald';
                %>
                  <a class="rc-row" href="/admin/refunds?agent=<%= r.agent?.slug || 'kantor-pusat' %>" title="Lihat detail refund untuk agen ini">
                    <span class="rc-name">
                      <%= r.agent?.displayName || 'Kantor Pusat' %>
                    </span>
                    <span class="rc-amt"><%= fmt.rpShort(r.refunded) %></span>
                    <span class="rc-rate" style="color:var(--<%= rcls %>);"><%= r.refundRatePct ?? '—' %>%</span>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
          <%# Stage 236 — per-reason-code breakdown. UNSET bucket
              rendered last regardless of size (mirrors S175). %>
          <% if (refundAnalytics.perReasonCode && refundAnalytics.perReasonCode.length > 0) { %>
            <div style="margin-top:14px;padding-top:12px;border-top:var(--hairline-soft);">
              <div class="rc-h">Per kategori alasan</div>
              <%
                const REASON_LABELS = {
                  JEMAAH_REQUEST: 'Jemaah minta',
                  PAKET_CANCELLED: 'Paket dibatalkan',
                  VISA_REJECTED: 'Visa ditolak',
                  JEMAAH_ILL: 'Jemaah sakit',
                  DOCUMENT_INCOMPLETE: 'Dokumen tidak lengkap',
                  NO_SHOW_REFUND: 'No-show refund',
                  GOODWILL: 'Goodwill',
                  DUPLICATE_PAYMENT: 'Pembayaran dobel',
                  FRAUD_CHARGEBACK: 'Fraud / chargeback',
                  OTHER: 'Lainnya',
                  __UNSET__: '(tanpa kode)',
                };
              %>
              <% refundAnalytics.perReasonCode.forEach((rc) => {
                   const isUnset = rc.code === '__UNSET__';
                   const label = REASON_LABELS[rc.code] || rc.code;
              %>
                <div class="rc-row" style="<%= isUnset ? 'color:var(--ink-200);' : '' %>">
                  <span class="rc-name"><%= label %><% if (!isUnset) { %> <span style="color:var(--ink-200);font-family:var(--font-mono);font-size:10px;">· <%= rc.refundCount %>x</span><% } else { %> <span style="font-family:var(--font-mono);font-size:10px;">· perlu kategorisasi</span><% } %></span>
                  <span class="rc-amt"><%= fmt.rpShort(rc.refunded) %></span>
                  <span class="rc-rate" style="color:var(--ink-100);"><%= rc.sharePct ?? '—' %>%</span>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
        <style>
          .refund-kpis { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 14px; }
          .rk { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 12px 14px; }
          .rk-l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
          .rk-v { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin-top: 4px; font-weight: 500; }
          .rk-v.ruby { color: var(--ruby); }
          .rk-v .u { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); margin-left: 3px; font-weight: 400; letter-spacing: 0.08em; }
          .rk-s { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; }
          .refund-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
          .refund-col { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 12px 14px; }
          .rc-h { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-200); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
          .rc-row { display: grid; grid-template-columns: 1fr 90px 60px; gap: 10px; padding: 6px 0; align-items: baseline; color: var(--cream-200); font-size: 12px; text-decoration: none; border-bottom: var(--hairline-soft); }
          .rc-row:last-child { border-bottom: 0; }
          .rc-row:hover { background: rgba(255,255,255,0.02); }
          .rc-name { color: var(--cream-100); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
          .rc-amt { font-family: var(--font-mono); font-size: 11px; color: var(--ruby); text-align: right; }
          .rc-rate { font-family: var(--font-mono); font-size: 11px; font-weight: 600; text-align: right; }
          .rc-empty { font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); padding: 12px 0; text-align: center; }
          @media (max-width: 900px) { .refund-cols { grid-template-columns: 1fr; } }
        </style>
      <% } %>

      <!-- Stage 146 — No-show rate analytics (90d, per paket + per agent) -->
      <% if (noShowAnalytics && noShowAnalytics.totals.noShowCount > 0) {
        const ns = noShowAnalytics;
        const rateTier = (p) => p == null ? 'ink-200' : p >= 10 ? 'ruby' : p >= 5 ? 'amber' : p >= 2 ? 'gold-300' : 'emerald';
      %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Analitik no-show</h3>
            <span class="meta"><%= ns.window.days %> HARI · <%= ns.totals.noShowCount %> NO-SHOW</span>
          </div>
          <div class="refund-kpis">
            <div class="rk">
              <div class="rk-l">Total no-show</div>
              <div class="rk-v ruby"><%= ns.totals.noShowCount %></div>
              <div class="rk-s">dari <%= ns.totals.resolvedActive %> booking yang sudah berangkat</div>
            </div>
            <div class="rk">
              <div class="rk-l">Rate keseluruhan</div>
              <div class="rk-v" style="color:var(--<%= rateTier(ns.totals.ratePct) %>);">
                <%= ns.totals.ratePct == null ? '—' : ns.totals.ratePct + '%' %>
              </div>
              <div class="rk-s">no-show ÷ booking aktif yang resolved</div>
            </div>
          </div>
          <div class="refund-cols">
            <div class="refund-col">
              <div class="rc-h">Per paket (top <%= Math.min(10, ns.byPaket.length) %>)</div>
              <% if (ns.byPaket.length === 0) { %>
                <div class="rc-empty">— tidak ada data —</div>
              <% } else { %>
                <% ns.byPaket.slice(0, 10).forEach(function(r) { %>
                  <a class="rc-row" href="/admin/paket/<%= r.slug %>/edit">
                    <div class="rc-name" title="<%= r.title %>"><%= r.title %></div>
                    <div class="rc-amt"><%= r.noShowCount %>/<%= r.resolvedActive %></div>
                    <div class="rc-rate" style="color:var(--<%= rateTier(r.ratePct) %>);">
                      <%= r.ratePct == null ? '—' : r.ratePct + '%' %>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
            <div class="refund-col">
              <div class="rc-h">Per agen (top <%= Math.min(10, ns.byAgent.length) %>)</div>
              <% if (ns.byAgent.length === 0) { %>
                <div class="rc-empty">— tidak ada data —</div>
              <% } else { %>
                <% ns.byAgent.slice(0, 10).forEach(function(r) {
                  const href = r.slug ? '/admin/users?role=AGEN&q=' + encodeURIComponent(r.slug) : '/admin/no-shows';
                %>
                  <a class="rc-row" href="<%= href %>">
                    <div class="rc-name" title="<%= r.displayName %>"><%= r.displayName %></div>
                    <div class="rc-amt"><%= r.noShowCount %>/<%= r.resolvedActive %></div>
                    <div class="rc-rate" style="color:var(--<%= rateTier(r.ratePct) %>);">
                      <%= r.ratePct == null ? '—' : r.ratePct + '%' %>
                    </div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </div>
          <div style="margin-top:6px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-300);">
            * rate = no-show ÷ booking aktif yang paket-nya sudah berangkat di window ini. Walk-in = Kantor Pusat.
          </div>
        </div>
      <% } %>

      <!-- Stage 175 — cancel reason breakdown (90d). Hidden on zero. -->
      <% if (cancelReasonBreakdown && cancelReasonBreakdown.total > 0) {
        const crb = cancelReasonBreakdown;
      %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Alasan cancel</h3>
            <span class="meta"><%= crb.days %> HARI · <%= crb.total %> CANCEL · <%= fmt.rpShort(crb.totalPaidIdr) %> PAID</span>
          </div>
          <div style="padding:8px 0;">
            <% crb.rows.forEach((r) => {
              const isUnset = r.code === '__UNSET__';
              const barW = crb.total > 0 ? Math.round((r.count / crb.total) * 100) : 0;
            %>
              <div style="margin-bottom:10px;">
                <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:11px;color:<%= isUnset ? 'var(--ink-300)' : 'var(--cream-100)' %>;margin-bottom:3px;">
                  <span style="<%= isUnset ? 'font-style:italic;' : '' %>"><%= r.label %></span>
                  <span style="color:var(--ink-200);"><%= r.count %> (<%= r.sharePct %>%) · Rp <%= fmt.rpShort(r.paidIdr) %></span>
                </div>
                <div style="width:100%;height:6px;background:var(--ink-1000);border-radius:3px;overflow:hidden;">
                  <div style="width:<%= barW %>%;height:100%;background:<%= isUnset ? 'var(--ink-500)' : 'var(--gold-300)' %>;"></div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <%# Stage 230 — booking tag aggregate. Across all ACTIVE-paket
          non-cancelled bookings, count per-tag with paxCount + paket
          spread. Hidden when nothing tagged. %>
      <% if (typeof bookingTagRollup !== 'undefined' && bookingTagRollup && bookingTagRollup.tags.length > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Booking tag aktif</h3>
            <span class="meta"><%= bookingTagRollup.totalTaggedBookings %> BOOKING DENGAN TAG</span>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px 12px;padding:6px 0;">
            <% bookingTagRollup.tags.forEach(function(t) { %>
              <div style="padding:8px 12px;background:rgba(212,175,55,0.04);border-left:3px solid var(--gold-300);border-radius:3px;">
                <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.04em;color:var(--gold-300);"><%= t.tag %></div>
                <div style="font-family:var(--font-display);font-size:18px;color:var(--cream-100);margin-top:2px;"><%= t.paxCount %></div>
                <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-top:1px;">pax · <%= t.bookings %> booking<% if (t.paketCount > 1) { %> · <%= t.paketCount %> paket<% } %></div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <%# Stage 252 — paket yang belum BEP. Sorted infeasible-first then
          by daysToDeparture asc. Hidden when nothing actionable. %>
      <% if (typeof breakEvenOverview !== 'undefined' && breakEvenOverview && breakEvenOverview.rows.length > 0) { %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--amber);">
          <div class="panel__head">
            <h3>Paket belum BEP</h3>
            <span class="meta">
              <%= breakEvenOverview.totals.paketCount %> PAKET
              <% if (breakEvenOverview.totals.infeasibleCount > 0) { %>
                · <span style="color:var(--ruby);"><%= breakEvenOverview.totals.infeasibleCount %> TIDAK MUNGKIN</span>
              <% } %>
            </span>
          </div>
          <p class="sub" style="margin:0 0 10px;">Paket aktif yang masih butuh LUNAS lagi untuk menutup biaya vendor + komisi. Infeasible = projected booksNeeded melebihi seatsLeft.</p>
          <% breakEvenOverview.rows.forEach(function(r) {
            const color = r.feasible ? 'var(--amber)' : 'var(--ruby)';
            const tag = r.feasible ? `${r.booksNeeded} LUNAS lagi` : `Butuh ${r.booksNeeded}, kursi tersisa ${r.seatsLeft}`;
          %>
            <div style="padding:8px 10px;background:rgba(212,175,55,0.03);border-left:3px solid <%= color %>;border-radius:0 3px 3px 0;margin-bottom:6px;font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);">
              <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap;">
                <a href="/admin/paket/<%= r.paket.slug %>/edit" style="color:var(--gold-300);text-decoration:none;font-weight:600;"><%= r.paket.title %></a>
                <span style="color:<%= color %>;font-weight:600;"><%= tag %></span>
              </div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-top:2px;">
                DEP <%= fmt.dateShort(r.paket.departureDate) %><% if (r.daysToDeparture != null) { %> · <%= r.daysToDeparture %>h lagi<% } %>
                · margin/pax Rp <%= fmt.rpShort(r.marginPerPax || 0) %>
                · net so far <span style="color:<%= (r.netSoFarIdr || 0) >= 0 ? 'var(--emerald)' : 'var(--ruby)' %>;">Rp <%= fmt.rpShort(r.netSoFarIdr || 0) %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <%# Stage 251 — network-wide expected revenue from pipeline.
          Hidden when nothing in pipeline (no real-estate waste). %>
      <% if (typeof networkRevenueForecast !== 'undefined' && networkRevenueForecast && networkRevenueForecast.totals.bookings > 0) {
           const nrf = networkRevenueForecast;
      %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--gold-300);">
          <div class="panel__head">
            <h3>Proyeksi cash inflow</h3>
            <span class="meta"><%= nrf.totals.bookings %> BOOKING · <%= nrf.totals.paketCount %> PAKET</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin:10px 0 14px;">
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Sisa tagihan total</div>
              <div style="font-family:var(--font-display);font-size:22px;color:var(--cream-100);margin-top:4px;font-weight:500;">Rp <%= fmt.rpShort(nrf.totals.remaining) %></div>
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Expected (weighted)</div>
              <div style="font-family:var(--font-display);font-size:22px;color:var(--gold-300);margin-top:4px;font-weight:500;">Rp <%= fmt.rpShort(nrf.totals.weightedExpected) %></div>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">PER STATUS · WEIGHTED</div>
              <% nrf.perStatus.filter((s) => s.bookings > 0).forEach(function(s) { %>
                <div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <span style="color:var(--cream-100);"><%= s.status %></span>
                  <span style="color:var(--ink-200);font-size:10px;">×<%= s.probability %></span>
                  <span style="color:var(--gold-300);font-weight:600;">Rp <%= fmt.rpShort(s.weightedExpected) %></span>
                </div>
              <% }) %>
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;">TOP 5 PAKET · BERANGKAT TERDEKAT</div>
              <% nrf.perPaket.slice(0, 5).forEach(function(p) { %>
                <div style="padding:5px 0;border-bottom:var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <div style="display:flex;justify-content:space-between;">
                    <a href="/admin?tab=manifest&manifestPaket=<%= p.paket.slug %>" style="color:var(--cream-100);text-decoration:none;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.paket.title %></a>
                    <span style="color:var(--gold-300);font-weight:600;">Rp <%= fmt.rpShort(p.weightedExpected) %></span>
                  </div>
                  <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);margin-top:1px;">
                    DEP <%= fmt.dateShort(p.paket.departureDate) %> · <%= p.bookings %> booking · sisa Rp <%= fmt.rpShort(p.remaining) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <div style="margin-top:10px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.04em;">
            Weighted = sisa tagihan × probability per status. Heuristic: PENDING 30%, BOOKED 50%, DP 70%, PARTIAL 85%, LUNAS 100%.
          </div>
        </div>
      <% } %>

      <% const km_a = analytics.komisiMonthly;
         const km_maxKom = Math.max(1, ...km_a.map((m) => Math.max(m.earned, m.paid)));
         const km_totalEarned = km_a.reduce((a, m) => a + m.earned, 0);
         const km_totalPaid = km_a.reduce((a, m) => a + m.paid, 0);
      %>
      <% if (km_totalEarned > 0 || km_totalPaid > 0) { %>
        <div class="panel">
          <div class="panel__head">
            <h3>Komisi 6 bulan</h3>
            <span class="meta">CROSS-AGEN · EARNED · PAID</span>
          </div>
          <div style="display:flex;gap:24px;margin-bottom:14px;">
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Total earned</div>
              <div style="font-family:var(--font-display);font-size:22px;color:var(--amber);font-weight:500;margin-top:4px;"><%= fmt.rpShort(km_totalEarned) %></div>
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;">Total paid</div>
              <div style="font-family:var(--font-display);font-size:22px;color:var(--emerald);font-weight:500;margin-top:4px;"><%= fmt.rpShort(km_totalPaid) %></div>
            </div>
          </div>
          <%
            const KW = 720, KH = 180, KP = 30;
            const km_barCount = km_a.length;
            const km_groupW = (KW - KP * 2) / km_barCount;
            const km_barW = (km_groupW - 10) / 2;
          %>
          <svg viewBox="0 0 <%= KW %> <%= KH %>" preserveAspectRatio="none" style="width:100%;height:auto;display:block;">
            <% km_a.forEach(function(m, i) {
              const gx = KP + i * km_groupW;
              const earnedH = (m.earned / km_maxKom) * (KH - KP * 2);
              const paidH = (m.paid / km_maxKom) * (KH - KP * 2);
              const baseY = KH - KP;
            %>
              <g>
                <rect x="<%= (gx + 4).toFixed(1) %>" y="<%= (baseY - earnedH).toFixed(1) %>"
                      width="<%= km_barW.toFixed(1) %>" height="<%= earnedH.toFixed(1) %>"
                      fill="var(--amber)" fill-opacity="0.85">
                  <title><%= m.label %> · earned <%= fmt.rpShort(m.earned) %></title>
                </rect>
                <rect x="<%= (gx + 4 + km_barW + 2).toFixed(1) %>" y="<%= (baseY - paidH).toFixed(1) %>"
                      width="<%= km_barW.toFixed(1) %>" height="<%= paidH.toFixed(1) %>"
                      fill="var(--emerald)" fill-opacity="0.85">
                  <title><%= m.label %> · paid <%= fmt.rpShort(m.paid) %></title>
                </rect>
                <text x="<%= (gx + km_groupW / 2).toFixed(1) %>" y="<%= (baseY + 14).toFixed(1) %>"
                      text-anchor="middle"
                      style="font-family:var(--font-mono);font-size:9.5px;fill:var(--ink-200);letter-spacing:0.04em;">
                  <%= m.label %>
                </text>
              </g>
            <% }) %>
          </svg>
          <div style="display:flex;gap:18px;margin-top:8px;font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);">
            <span><i style="display:inline-block;width:14px;height:2px;background:var(--amber);margin-right:6px;vertical-align:middle;"></i>Earned (LUNAS commission)</span>
            <span><i style="display:inline-block;width:14px;height:2px;background:var(--emerald);margin-right:6px;vertical-align:middle;"></i>Paid (out to agen wallets)</span>
          </div>
        </div>
      <% } %>

      <!-- Stage 294 — returning customer rollup (last 6 months) -->
      <% if (typeof returningRollup !== 'undefined' && returningRollup && returningRollup.sampleSize > 0) {
           const tr = returningRollup.total;
           const tone = tr.ratePct == null ? 'var(--ink-300)'
             : tr.ratePct >= 30 ? 'var(--emerald)'
             : tr.ratePct >= 15 ? 'var(--gold-300)'
             : 'var(--ruby)';
      %>
        <div class="panel" style="margin-top:16px;border-left:3px solid <%= tone %>;">
          <div class="panel__head">
            <h3>🌟 Returning customer (6 bulan)</h3>
            <span class="meta">
              <%= tr.repeat %> / <%= tr.lunas %> LUNAS ·
              <strong style="color:<%= tone %>;"><%= tr.ratePct == null ? '—' : tr.ratePct + '%' %></strong> repeat rate
            </span>
          </div>
          <table style="width:100%;border-collapse:collapse;margin-top:8px;font-family:var(--font-mono);font-size:11.5px;">
            <thead><tr style="border-bottom:1px solid var(--hairline-soft);">
              <th style="text-align:left;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Bulan</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">LUNAS</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Repeat</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Rate</th>
            </tr></thead>
            <tbody>
              <% returningRollup.months.forEach(function(m) {
                   const mTone = m.repeatRatePct == null ? 'var(--ink-300)'
                     : m.repeatRatePct >= 30 ? 'var(--emerald)'
                     : m.repeatRatePct >= 15 ? 'var(--gold-300)'
                     : (m.totalLunas > 0 ? 'var(--ruby)' : 'var(--ink-300)');
              %>
                <tr style="border-bottom:1px solid var(--hairline-soft);">
                  <td style="padding:6px;color:var(--cream-100);"><%= m.label %></td>
                  <td style="padding:6px;color:var(--cream-100);text-align:right;"><%= m.totalLunas %></td>
                  <td style="padding:6px;color:var(--cream-100);text-align:right;"><%= m.repeatLunas %></td>
                  <td style="padding:6px;color:<%= mTone %>;text-align:right;font-weight:600;"><%= m.repeatRatePct == null ? '—' : m.repeatRatePct + '%' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div style="margin-top:8px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.04em;">
            Repeat = jemaah dengan ≥1 LUNAS booking sebelum bulan ini. Diukur via createdAt (kapan re-book).
          </div>
        </div>
      <% } %>

      <!-- Stage 303 — per-agen cancel/refund rate -->
      <% if (typeof agentCancelRefund !== 'undefined' && agentCancelRefund && agentCancelRefund.rows && agentCancelRefund.rows.length > 0) {
           const acrTotals = agentCancelRefund.totals;
           function acrRateColor(pct) {
             if (pct == null) return 'var(--ink-300)';
             if (pct >= 25) return 'var(--ruby)';
             if (pct >= 10) return 'var(--amber)';
             return 'var(--emerald)';
           }
      %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--amber);">
          <div class="panel__head">
            <h3>✕ Cancel / refund per agen (<%= agentCancelRefund.days %> hari)</h3>
            <span class="meta">
              <%= acrTotals.agentCount %> agen ·
              <%= acrTotals.totalBookings %> booking ·
              <span style="color:var(--ruby);"><%= acrTotals.totalCancel %> cancel</span> ·
              <span style="color:var(--ruby);"><%= acrTotals.totalRefund %> refund</span> ·
              <strong>rate <%= acrTotals.overallRatePct == null ? '—' : (acrTotals.overallRatePct + '%') %></strong>
            </span>
          </div>
          <table style="width:100%;margin-top:10px;font-family:var(--font-mono);font-size:11px;border-collapse:collapse;">
            <thead>
              <tr style="text-align:left;border-bottom:1px solid var(--hairline-soft);color:var(--ink-300);letter-spacing:0.04em;">
                <th style="padding:8px 6px;">Agen</th>
                <th style="padding:8px 6px;text-align:right;">Total</th>
                <th style="padding:8px 6px;text-align:right;">Cancel</th>
                <th style="padding:8px 6px;text-align:right;">Refund</th>
                <th style="padding:8px 6px;text-align:right;">Rate</th>
              </tr>
            </thead>
            <tbody>
              <% agentCancelRefund.rows.forEach(function(row) {
                   const combinedRate = (row.cancelRatePct != null && row.refundRatePct != null)
                     ? Math.round((row.cancelRatePct + row.refundRatePct) * 10) / 10
                     : null;
              %>
                <tr style="border-bottom:1px solid var(--hairline-soft);">
                  <td style="padding:8px 6px;color:var(--cream-100);">
                    <% if (row.agentSlug === '__kp__') { %>
                      <em style="color:var(--ink-200);">Kantor Pusat (walk-in)</em>
                    <% } else { %>
                      <%= row.agentName %>
                      <span style="color:var(--ink-300);font-size:10px;">· <%= row.agentSlug %></span>
                    <% } %>
                    <% if (row.lowSample) { %>
                      <span style="color:var(--ink-300);font-size:10px;letter-spacing:0.04em;">· low</span>
                    <% } %>
                  </td>
                  <td style="padding:8px 6px;text-align:right;color:var(--cream-100);"><%= row.total %></td>
                  <td style="padding:8px 6px;text-align:right;color:<%= row.cancel > 0 ? 'var(--ruby)' : 'var(--ink-300)' %>;"><%= row.cancel %></td>
                  <td style="padding:8px 6px;text-align:right;color:<%= row.refund > 0 ? 'var(--ruby)' : 'var(--ink-300)' %>;"><%= row.refund %></td>
                  <td style="padding:8px 6px;text-align:right;color:<%= acrRateColor(combinedRate) %>;font-weight:600;">
                    <%= combinedRate == null ? '—' : (combinedRate + '%') %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div style="margin-top:8px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.04em;">
            Rate = (cancel + refund) / total × 100. Agen dengan &lt; 3 booking di window ditandai 'low' — sample terlalu kecil untuk dipercaya.
          </div>
        </div>
      <% } %>

      <!-- Stage 297 — adjustment ledger (last 90d) -->
      <% if (typeof adjustmentLedger !== 'undefined' && adjustmentLedger && adjustmentLedger.totals.rowCount > 0) {
           const t = adjustmentLedger.totals;
      %>
        <div class="panel" style="margin-top:16px;border-left:3px solid <%= t.netIdr < 0 ? 'var(--emerald)' : 'var(--ruby)' %>;">
          <div class="panel__head">
            <h3>💸 Discount / surcharge ledger (<%= adjustmentLedger.days %> hari)</h3>
            <span class="meta">
              <%= t.rowCount %> row ·
              <span style="color:var(--emerald);">− Rp <%= fmt.rpShort(t.discountIdr) %></span> ·
              <span style="color:var(--ruby);">+ Rp <%= fmt.rpShort(t.surchargeIdr) %></span> ·
              net <strong style="color:<%= t.netIdr < 0 ? 'var(--emerald)' : 'var(--ruby)' %>;"><%= t.netIdr >= 0 ? '+' : '' %><%= fmt.rpShort(t.netIdr) %></strong>
            </span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:10px;">
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;">PER REASON</div>
              <% adjustmentLedger.perReason.forEach(function(r) { %>
                <div style="display:grid;grid-template-columns:1fr auto auto;gap:8px;padding:5px 0;border-bottom:1px solid var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <span style="color:var(--cream-100);"><%= r.reasonCode %></span>
                  <span style="color:var(--emerald);font-size:10px;" title="discount">
                    <% if (r.discountIdr > 0) { %>−<%= fmt.rpShort(r.discountIdr) %><% } else { %>—<% } %>
                  </span>
                  <span style="color:var(--ruby);font-size:10px;" title="surcharge">
                    <% if (r.surchargeIdr > 0) { %>+<%= fmt.rpShort(r.surchargeIdr) %><% } else { %>—<% } %>
                  </span>
                </div>
              <% }) %>
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;">TOP ADMIN</div>
              <% adjustmentLedger.topActors.forEach(function(a) { %>
                <div style="display:grid;grid-template-columns:1fr auto auto;gap:8px;padding:5px 0;border-bottom:1px solid var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <span style="color:var(--cream-100);"><%= a.email %></span>
                  <span style="color:var(--ink-200);font-size:10px;"><%= a.count %>x</span>
                  <span style="color:var(--gold-300);font-weight:600;">Rp <%= fmt.rpShort(a.totalAbsIdr) %></span>
                </div>
              <% }) %>
            </div>
          </div>
          <div style="margin-top:8px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);">
            Discount mengurangi totalAmount · surcharge menambah · CANCELLED/REFUNDED dikecualikan.
          </div>
        </div>
      <% } %>

      <!-- Stage 285 — add-on revenue tally -->
      <% if (typeof addonRevenue !== 'undefined' && addonRevenue && addonRevenue.totals.attachCount > 0) { %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--gold-300);">
          <div class="panel__head">
            <h3>🧳 Add-on revenue</h3>
            <span class="meta">
              <%= addonRevenue.totals.attachCount %> attachment ·
              <%= addonRevenue.totals.totalQuantity %> qty ·
              <strong style="color:var(--gold-300);">Rp <%= fmt.rpShort(addonRevenue.totals.revenueIdr) %></strong>
            </span>
          </div>
          <table style="width:100%;border-collapse:collapse;margin-top:8px;font-family:var(--font-mono);font-size:11.5px;">
            <thead><tr style="border-bottom:1px solid var(--hairline-soft);">
              <th style="text-align:left;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Nama</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Booking</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Qty</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Paket</th>
              <th style="text-align:right;padding:6px;color:var(--ink-200);font-weight:400;font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;">Revenue</th>
            </tr></thead>
            <tbody>
              <% addonRevenue.rows.slice(0, 10).forEach(function(r) { %>
                <tr style="border-bottom:1px solid var(--hairline-soft);">
                  <td style="padding:6px;color:var(--cream-100);"><%= r.name %></td>
                  <td style="padding:6px;color:var(--cream-100);text-align:right;"><%= r.attachCount %></td>
                  <td style="padding:6px;color:var(--cream-100);text-align:right;"><%= r.totalQuantity %></td>
                  <td style="padding:6px;color:var(--cream-100);text-align:right;"><%= r.paketCount %></td>
                  <td style="padding:6px;color:var(--gold-300);text-align:right;font-weight:600;">Rp <%= fmt.rpShort(r.revenueIdr) %></td>
                </tr>
              <% }) %>
              <% if (addonRevenue.rows.length > 10) { %>
                <tr><td colspan="5" style="padding:6px;font-size:10px;color:var(--ink-300);">+ <%= addonRevenue.rows.length - 10 %> add-on lainnya…</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>

      <!-- Stage 278 — crew daily report tally (last 7d) -->
      <% if (typeof crewReportTally !== 'undefined' && crewReportTally && crewReportTally.total > 0) {
           const red = crewReportTally.tally.RED || 0;
           const amber = crewReportTally.tally.AMBER || 0;
           const green = crewReportTally.tally.GREEN || 0;
      %>
        <div class="panel" style="margin-top:16px;border-left:3px solid <%= red > 0 ? 'var(--ruby)' : (amber > 0 ? 'var(--gold-300)' : 'var(--emerald)') %>;">
          <div class="panel__head">
            <h3>📝 Laporan crew (<%= crewReportTally.days %> hari terakhir)</h3>
            <span class="meta">
              <%= crewReportTally.total %> laporan
            </span>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:14px;margin-top:6px;">
            <div style="padding:14px 16px;background:rgba(80,176,113,0.06);border:1px solid var(--emerald);border-radius:var(--r-sm);text-align:center;">
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--emerald);letter-spacing:0.1em;text-transform:uppercase;">🟢 Lancar</div>
              <div style="font-family:var(--font-mono);font-size:26px;color:var(--cream-100);font-weight:600;margin-top:6px;"><%= green %></div>
            </div>
            <div style="padding:14px 16px;background:rgba(212,175,55,0.06);border:1px solid <%= amber > 0 ? 'var(--gold-300)' : 'var(--hairline-soft)' %>;border-radius:var(--r-sm);text-align:center;">
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);letter-spacing:0.1em;text-transform:uppercase;">🟡 Gangguan</div>
              <div style="font-family:var(--font-mono);font-size:26px;color:var(--cream-100);font-weight:600;margin-top:6px;"><%= amber %></div>
            </div>
            <div style="padding:14px 16px;background:rgba(212,89,89,0.06);border:1px solid <%= red > 0 ? 'var(--ruby)' : 'var(--hairline-soft)' %>;border-radius:var(--r-sm);text-align:center;">
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--ruby);letter-spacing:0.1em;text-transform:uppercase;">🔴 Bermasalah</div>
              <div style="font-family:var(--font-mono);font-size:26px;color:<%= red > 0 ? 'var(--ruby)' : 'var(--cream-100)' %>;font-weight:600;margin-top:6px;"><%= red %></div>
            </div>
          </div>
          <% if (red > 0) { %>
            <div style="margin-top:10px;font-family:var(--font-mono);font-size:11px;color:var(--ruby);">
              ⚠ Buka halaman paket-edit untuk membaca laporan 🔴 dan tindaklanjuti.
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Stage 263 — group needs-attention rollup -->
      <% if (typeof groupAttention !== 'undefined' && groupAttention && groupAttention.rows.length > 0) { %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--amber);">
          <div class="panel__head">
            <h3>⚠ Grup butuh perhatian</h3>
            <span class="meta">
              <%= groupAttention.rows.length %> grup
              <% if (groupAttention.total > groupAttention.rows.length) { %>
                · <%= groupAttention.total - groupAttention.rows.length %> grup lain tidak ditampilkan
              <% } %>
            </span>
          </div>
          <table style="width:100%;border-collapse:collapse;margin-top:8px;font-family:var(--font-mono);font-size:11.5px;">
            <thead>
              <tr style="border-bottom:1px solid var(--hairline-soft);">
                <th style="text-align:left;padding:8px 6px;color:var(--ink-200);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;font-weight:400;">Grup</th>
                <th style="text-align:left;padding:8px 6px;color:var(--ink-200);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;font-weight:400;">Member</th>
                <th style="text-align:left;padding:8px 6px;color:var(--ink-200);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;font-weight:400;">Sisa Bayar</th>
                <th style="text-align:left;padding:8px 6px;color:var(--ink-200);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;font-weight:400;">Pickup</th>
                <th style="text-align:left;padding:8px 6px;color:var(--ink-200);font-size:9.5px;letter-spacing:0.1em;text-transform:uppercase;font-weight:400;">Dokumen</th>
              </tr>
            </thead>
            <tbody>
              <% groupAttention.rows.forEach(function(g) { %>
                <tr style="border-bottom:1px solid var(--hairline-soft);">
                  <td style="padding:8px 6px;">
                    <a href="/admin/groups/<%= encodeURIComponent(g.groupKey) %>" style="color:var(--gold-300);text-decoration:none;font-weight:600;"><%= g.groupKey %></a>
                    <% if (g.label) { %>
                      <span style="color:var(--cream-100);font-family:var(--font-sans);font-size:11px;"> · <%= g.label %></span>
                    <% } %>
                    <% if (g.paket) { %>
                      <div style="font-size:10px;color:var(--ink-300);margin-top:2px;"><%= g.paket.title %></div>
                    <% } %>
                  </td>
                  <td style="padding:8px 6px;color:var(--cream-100);"><%= g.memberCount %></td>
                  <td style="padding:8px 6px;">
                    <% if (g.unpaidCount > 0) { %>
                      <span style="color:var(--ruby);font-weight:600;"><%= g.unpaidCount %> jemaah</span>
                      <div style="font-size:10px;color:var(--ink-300);">Rp <%= fmt.rpShort(g.unpaidBalanceIdr) %></div>
                    <% } else { %>
                      <span style="color:var(--ink-300);">—</span>
                    <% } %>
                  </td>
                  <td style="padding:8px 6px;">
                    <% if (g.missingPickupCount > 0) { %>
                      <span style="color:var(--amber);font-weight:600;"><%= g.missingPickupCount %> jemaah</span>
                    <% } else if (g.offersPickup) { %>
                      <span style="color:var(--emerald);">✓</span>
                    <% } else { %>
                      <span style="color:var(--ink-300);">—</span>
                    <% } %>
                  </td>
                  <td style="padding:8px 6px;">
                    <% if (g.missingDocCount > 0) { %>
                      <span style="color:var(--amber);font-weight:600;"><%= g.missingDocCount %> jemaah</span>
                    <% } else { %>
                      <span style="color:var(--emerald);">✓</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div style="margin-top:8px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.04em;">
            Per-grup rollup: passport / visa umroh / vaksin meningitis = wajib. Pickup gap hanya muncul jika paket sudah punya konfigurasi titik jemput.
          </div>
        </div>
      <% } %>

      <!-- Stage 100 — cross-agent komisi pipeline forecast -->
      <% if (networkForecast && networkForecast.totals.bookings > 0) { %>
        <div class="panel" style="margin-top:16px;border-left:3px solid var(--gold-300);">
          <div class="panel__head">
            <h3>Proyeksi komisi seluruh agen (<%= networkForecast.windowDays %> hari)</h3>
            <span class="meta">
              <%= networkForecast.totals.agentCount %> AGEN ·
              <%= networkForecast.totals.bookings %> BOOKING AKTIF ·
              <strong style="color:var(--gold-300);">Rp <%= fmt.rpShort(networkForecast.totals.expectedIdr) %></strong> EXPECTED
            </span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:10px;">
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;">PER AGEN · TOP 10</div>
              <% networkForecast.perAgent.slice(0, 10).forEach(function(a) { %>
                <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;padding:6px 0;border-bottom:var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <a href="/a/<%= a.slug %>" style="color:var(--cream-100);text-decoration:none;"><%= a.displayName || a.slug %></a>
                  <span style="color:var(--ink-200);font-size:10px;"><%= a.bookings %> bk</span>
                  <span style="color:var(--gold-300);font-weight:600;">Rp <%= fmt.rpShort(a.expectedIdr) %></span>
                </div>
              <% }) %>
              <% if (networkForecast.perAgent.length > 10) { %>
                <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);margin-top:6px;">+ <%= networkForecast.perAgent.length - 10 %> agen lainnya…</div>
              <% } %>
            </div>
            <div>
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;">PER BULAN KEBERANGKATAN</div>
              <% networkForecast.perMonth.forEach(function(m) { %>
                <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;padding:6px 0;border-bottom:var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;">
                  <span style="color:var(--cream-100);"><%= m.month === 'unscheduled' ? 'Belum terjadwal' : m.month %></span>
                  <span style="color:var(--ink-200);font-size:10px;"><%= m.bookings %> bk</span>
                  <span style="color:var(--gold-300);font-weight:600;">Rp <%= fmt.rpShort(m.expectedIdr) %></span>
                </div>
              <% }) %>
            </div>
          </div>
          <div style="margin-top:10px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);letter-spacing:0.04em;">
            Weighted: PENDING ×30%, BOOKED ×50%, DP_PAID ×70%, PARTIAL ×85%. Untuk cash-flow planning outflow komisi.
          </div>
        </div>
      <% } %>

      <!-- Stage 41 — Komisi liability aging -->
      <% if (komisiAging && komisiAging.grandTotal.count > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Komisi liability aging</h3>
            <span class="meta"><%= komisiAging.grandTotal.agents %> AGEN · <%= komisiAging.grandTotal.count %> ROW · <%= fmt.rpShort(komisiAging.grandTotal.amountIdr) %></span>
          </div>
          <div class="ka-summary">
            <% komisiAging.buckets.forEach(function(b) {
              const data = komisiAging.totals[b.key];
              const cls = b.key === '90+' ? 'ruby'
                        : b.key === '60-90' ? 'amber'
                        : b.key === '30-60' ? 'gold-300'
                        : 'emerald';
            %>
              <div class="ka-bk">
                <div class="ka-bk-l" style="color:var(--<%= cls %>);"><%= b.label %></div>
                <div class="ka-bk-v"><%= fmt.rpShort(data.amountIdr) %></div>
                <div class="ka-bk-c"><%= data.count %> row</div>
              </div>
            <% }) %>
          </div>
          <table class="tbl ka-table">
            <thead>
              <tr>
                <th>Agen</th>
                <th class="num">&lt;30h</th>
                <th class="num">30-60h</th>
                <th class="num">60-90h</th>
                <th class="num">90+h</th>
                <th class="num">Tertua</th>
                <th class="num">Total</th>
              </tr>
            </thead>
            <tbody>
              <% komisiAging.rows.forEach(function(r) {
                const oldestCls = r.oldestDays >= 90 ? 'ruby'
                                : r.oldestDays >= 60 ? 'amber'
                                : r.oldestDays >= 30 ? 'gold-300'
                                : 'emerald';
              %>
                <tr>
                  <td><%= r.agent?.displayName || r.agent?.slug || '—' %></td>
                  <td class="num"><%= r.buckets['0-30'].count > 0 ? fmt.rpShort(r.buckets['0-30'].amountIdr) : '—' %></td>
                  <td class="num" style="color:<%= r.buckets['30-60'].count > 0 ? 'var(--gold-300)' : 'var(--ink-300)' %>;">
                    <%= r.buckets['30-60'].count > 0 ? fmt.rpShort(r.buckets['30-60'].amountIdr) : '—' %>
                  </td>
                  <td class="num" style="color:<%= r.buckets['60-90'].count > 0 ? 'var(--amber)' : 'var(--ink-300)' %>;">
                    <%= r.buckets['60-90'].count > 0 ? fmt.rpShort(r.buckets['60-90'].amountIdr) : '—' %>
                  </td>
                  <td class="num" style="color:<%= r.buckets['90+'].count > 0 ? 'var(--ruby)' : 'var(--ink-300)' %>;font-weight:<%= r.buckets['90+'].count > 0 ? '600' : '400' %>;">
                    <%= r.buckets['90+'].count > 0 ? fmt.rpShort(r.buckets['90+'].amountIdr) : '—' %>
                  </td>
                  <td class="num" style="color:var(--<%= oldestCls %>);font-family:var(--font-mono);font-size:11px;">
                    <%= r.oldestDays %>h
                  </td>
                  <td class="num" style="color:var(--gold-300);font-weight:600;"><%= fmt.rpShort(r.totalAmountIdr) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <style>
          .ka-summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 14px; }
          .ka-bk { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 10px 12px; text-align: center; }
          .ka-bk-l { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
          .ka-bk-v { font-family: var(--font-display); font-size: 18px; color: var(--cream-100); margin-top: 4px; font-weight: 500; }
          .ka-bk-c { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; }
          .ka-table .num { text-align: right; font-family: var(--font-mono); font-size: 11px; }
        </style>
      <% } %>

      <!-- Top agents -->
      <div class="panel">
        <div class="panel__head">
          <h3>Performa agen</h3>
          <span class="meta"><%= topAgents.length %> AGEN</span>
        </div>
        <table class="tbl">
          <thead>
            <tr>
              <th>Agen</th>
              <th class="num">Lead</th>
              <th class="num">Conv %</th>
              <th class="num">Lunas</th>
              <th class="num">Aktif</th>
              <th class="num">Revenue</th>
              <th class="num">Komisi earned</th>
              <th class="num">Komisi paid</th>
              <th class="num" style="width:130px;">30h trend</th>
            </tr>
          </thead>
          <tbody>
            <% if (topAgents.length === 0) { %>
              <tr><td colspan="9" style="text-align:center;color:var(--ink-200);">Belum ada agen.</td></tr>
            <% } %>
            <% topAgents.forEach(function(a) { %>
              <tr>
                <td>
                  <div class="nm"><%= a.displayName %></div>
                  <div class="sx"><%= a.tier || 'Mitra' %> · slug <%= a.slug %></div>
                </td>
                <td class="num amt"><%= a.leadTotal %></td>
                <td class="num amt <%= a.leadConvPct != null && a.leadConvPct >= 50 ? 'gold' : '' %>">
                  <%= a.leadConvPct != null ? a.leadConvPct + '%' : '—' %>
                </td>
                <td class="num amt gold"><%= a.lunasCount %></td>
                <td class="num amt"><%= a.activeCount %></td>
                <td class="num amt"><%= fmt.rpFull(a.revenue) %></td>
                <td class="num amt gold"><%= fmt.rpFull(a.komisiEarned) %></td>
                <td class="num amt"><%= fmt.rpFull(a.komisiPaid) %></td>
                <td class="num spark-cell">
                  <%
                    // Stage 45 — inline SVG sparkline. Path drawn 120x28; the
                    // peak value scales the y-axis so every agent's chart uses
                    // the full vertical space (so a slow agent's small spike
                    // is still visible). 30 daily points, oldest→newest.
                    const spark = a.sparkline;
                  %>
                  <% if (!spark || spark.every((v) => v === 0)) { %>
                    <span style="color:var(--ink-300);font-family:var(--font-mono);font-size:10.5px;">—</span>
                  <% } else {
                    const W = 120, H = 28, padX = 1, padY = 2;
                    const maxV = Math.max(...spark);
                    const step = (W - padX * 2) / (spark.length - 1);
                    const path = spark.map((v, i) => {
                      const x = padX + i * step;
                      const y = maxV === 0 ? H - padY : H - padY - (v / maxV) * (H - padY * 2);
                      return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
                    }).join(' ');
                    const total = spark.reduce((s, v) => s + v, 0);
                    const lastWeek = spark.slice(-7).reduce((s, v) => s + v, 0);
                    const prevWeek = spark.slice(-14, -7).reduce((s, v) => s + v, 0);
                    const trendUp = lastWeek > prevWeek;
                    const trendFlat = lastWeek === prevWeek;
                  %>
                    <svg width="<%= W %>" height="<%= H %>" viewBox="0 0 <%= W %> <%= H %>" style="display:block;margin-left:auto;">
                      <path d="<%= path %>" fill="none" stroke="var(--gold-300)" stroke-width="1.5"/>
                    </svg>
                    <span class="spark-sub" style="color:var(--<%= trendUp ? 'emerald' : trendFlat ? 'ink-200' : 'ruby' %>);">
                      <%= trendUp ? '▲' : trendFlat ? '=' : '▼' %> <%= total %> total · <%= lastWeek %> 7h
                    </span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <style>
        .spark-cell { text-align: right; vertical-align: middle; }
        .spark-cell .spark-sub { display: block; font-family: var(--font-mono); font-size: 9.5px; margin-top: 2px; letter-spacing: 0.04em; text-align: right; }
      </style>

      <!-- Stage 54 — jemaah cohort retention -->
      <% if (cohortRetention && cohortRetention.rows.length > 0) {
        const sum = cohortRetention.summary;
        const ovCls = sum.matureRetentionPct == null ? 'ink-200'
          : sum.matureRetentionPct >= 30 ? 'emerald'
          : sum.matureRetentionPct >= 15 ? 'gold-300'
          : sum.matureRetentionPct >= 5  ? 'amber' : 'ruby';
      %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Retensi cohort jemaah (booking ke-2 dalam <%= cohortRetention.windowDays %>h)</h3>
            <span class="meta">
              <% if (sum.matureCohortCount > 0) { %>
                <%= sum.matureCohortCount %> COHORT MATURE · <strong style="color:var(--<%= ovCls %>);"><%= sum.matureRetentionPct ?? '—' %>%</strong> RATA-RATA
              <% } else { %>
                BELUM ADA COHORT MATURE
              <% } %>
            </span>
          </div>
          <table class="tbl">
            <thead>
              <tr>
                <th>Cohort</th>
                <th class="num">Jemaah pertama</th>
                <th class="num">Retained</th>
                <th class="num">Retensi</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% cohortRetention.rows.forEach(function(c) {
                const cls = c.retentionPct == null ? 'ink-200'
                  : c.retentionPct >= 30 ? 'emerald'
                  : c.retentionPct >= 15 ? 'gold-300'
                  : c.retentionPct >= 5  ? 'amber' : 'ruby';
              %>
                <tr style="<%= c.mature ? '' : 'opacity:0.55;' %>">
                  <td><strong style="color:var(--cream-100);"><%= c.label %></strong></td>
                  <td class="num" style="font-family:var(--font-mono);"><%= c.total %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--gold-300);"><%= c.retained %></td>
                  <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;">
                    <%= c.retentionPct ?? '—' %>%
                  </td>
                  <td style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);">
                    <%= c.mature ? 'mature' : 'belum mature (12h window belum lewat)' %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (cohortRetention.byChannel && cohortRetention.byChannel.length > 0) { %>
            <div style="margin-top:16px;padding-top:12px;border-top:var(--hairline-soft);">
              <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:10px;">
                Retensi per channel akuisisi · semua cohort dalam window (min. 5 jemaah/channel)
              </div>
              <table class="tbl">
                <thead>
                  <tr>
                    <th>Channel</th>
                    <th class="num">Jemaah</th>
                    <th class="num">Retained</th>
                    <th class="num">Retensi</th>
                  </tr>
                </thead>
                <tbody>
                  <% cohortRetention.byChannel.forEach(function(c) {
                    const cls = c.retentionPct == null ? 'ink-200'
                      : c.retentionPct >= 30 ? 'emerald'
                      : c.retentionPct >= 15 ? 'gold-300'
                      : c.retentionPct >= 5  ? 'amber' : 'ruby';
                  %>
                    <tr>
                      <td style="font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);"><%= c.channel %></td>
                      <td class="num" style="font-family:var(--font-mono);"><%= c.total %></td>
                      <td class="num" style="font-family:var(--font-mono);color:var(--gold-300);"><%= c.retained %></td>
                      <td class="num" style="font-family:var(--font-mono);color:var(--<%= cls %>);font-weight:600;">
                        <%= c.retentionPct ?? '—' %>%
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Date range filter (affects global funnel + source breakdown only) -->
      <%
        const r = analytics.funnel.range;
        const rFrom = r.from.toISOString().slice(0,10);
        const rTo   = r.to.toISOString().slice(0,10);
      %>
      <div style="margin-top:32px;">
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--ink-200);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px;">
          Filter analitik · <%= r.days %> hari (<%= fmt.dateShort(r.from) %> → <%= fmt.dateShort(r.to) %>)
        </div>
        <%- include('partials/date-range', { from: rFrom, to: rTo, basePath: '/admin' }) %>
      </div>

      <!-- Global lead source effectiveness -->
      <% if (analytics.sourceBreakdown.length > 0) { %>
        <div class="panel" style="margin-top:16px;">
          <div class="panel__head">
            <h3>Sumber lead — efektivitas global</h3>
            <span class="meta">SEMUA AGEN · TOTAL <%= analytics.funnel.leadsTotal %> LEAD</span>
          </div>
          <table class="tbl">
            <thead>
              <tr>
                <th>Sumber</th>
                <th class="num">Total</th>
                <th class="num">Aktif</th>
                <th class="num">Converted</th>
                <th class="num">Lost</th>
                <th class="num">Conv %</th>
              </tr>
            </thead>
            <tbody>
              <% analytics.sourceBreakdown.forEach(function(s) { %>
                <tr>
                  <td><span class="badge"><%= s.source %></span></td>
                  <td class="num amt"><%= s.total %></td>
                  <td class="num amt"><%= s.active %></td>
                  <td class="num amt gold"><%= s.converted %></td>
                  <td class="num amt" style="color:<%= s.lost > 0 ? 'var(--ruby)' : 'inherit' %>;"><%= s.lost %></td>
                  <td class="num amt <%= s.conversionPct != null && s.conversionPct >= 30 ? 'gold' : '' %>">
                    <%= s.conversionPct != null ? s.conversionPct + '%' : '—' %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <!-- Global funnel — SVG visualization with descending widths -->
      <div class="panel" style="margin-top:16px;">
        <div class="panel__head">
          <h3>Funnel global</h3>
          <span class="meta">SEMUA AGEN</span>
        </div>
        <%
          const gf = analytics.funnel;
          // Funnel proper: leads → warm/hot bookings → LUNAS. Cold + Warm
          // are entry stages; Lost is a side-channel (shown at bottom).
          const funnelStages = [
            { l: 'Cold lead',  v: gf.lead.COLD,       color: 'var(--ink-300)' },
            { l: 'Warm lead',  v: gf.lead.WARM,       color: 'var(--amber)'   },
            { l: 'Converted',  v: gf.lead.CONVERTED,  color: 'var(--gold-300)' },
            { l: 'Hot booking',v: gf.bookingsHot,     color: 'var(--sapphire)' },
            { l: 'LUNAS',      v: gf.bookingsLunas,   color: 'var(--emerald)'  },
          ];
          const fmax = Math.max(1, ...funnelStages.map((s) => s.v));
          const FW = 480, ROW_H = 32, GAP = 6;
          const FH = funnelStages.length * (ROW_H + GAP);
        %>
        <% if (gf.leadsTotal === 0 && gf.bookingsTotal === 0) { %>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);padding:16px 0;">
            Belum ada data untuk rentang ini.
          </div>
        <% } else { %>
          <svg class="chart-funnel" viewBox="0 0 <%= FW %> <%= FH %>" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Funnel konversi lead ke LUNAS">
            <% funnelStages.forEach(function(s, i) {
              const w = Math.max(40, (s.v / fmax) * FW);
              const x = (FW - w) / 2;
              const y = i * (ROW_H + GAP);
              const pct = (i === 0 || fmax === 0) ? null : Math.round((s.v / funnelStages[0].v) * 100);
            %>
              <rect class="stage-bar" x="<%= x %>" y="<%= y %>" width="<%= w %>" height="<%= ROW_H %>"
                    rx="3" ry="3" fill="<%= s.color %>" fill-opacity="0.75"
                    stroke="<%= s.color %>" stroke-width="1">
                <title><%= s.l %>: <%= s.v %><% if (pct != null) { %> (<%= pct %>% dari Cold)<% } %></title>
              </rect>
              <text class="stage-label" x="8" y="<%= y + ROW_H / 2 %>"><%= s.l %></text>
              <text class="stage-count" x="<%= FW - 8 %>" y="<%= y + ROW_H / 2 %>" text-anchor="end"><%= s.v %></text>
              <% if (pct != null) { %>
                <text class="stage-pct" x="<%= FW - 50 %>" y="<%= y + ROW_H / 2 %>" text-anchor="end"><%= pct %>%</text>
              <% } %>
            <% }) %>
          </svg>
        <% } %>
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);margin-top:14px;">
          Lead → Booking: <strong style="color:var(--gold-300);"><%= gf.convertedFromLeadPct ?? '—' %>%</strong>
          · Booking → LUNAS: <strong style="color:var(--emerald);"><%= gf.lunasFromBookingPct ?? '—' %>%</strong>
          <% if (gf.lead.LOST > 0) { %>
            · Lead LOST: <strong style="color:var(--ruby);"><%= gf.lead.LOST %></strong>
          <% } %>
        </div>
      </div>
    </section>

    <!-- ===== PACKAGES ===== -->
    <section class="page <%= activeTab === 'packages' ? 'is-active' : '' %>" id="page-packages">
      <header class="page__head">
        <div class="row">
          <div>
            <% const draftCount = paketList.filter(function(p) { return p.status === 'DRAFT'; }).length; %>
            <% const closedCount = paketList.filter(function(p) { return p.status === 'CLOSED'; }).length; %>
            <span class="eyebrow">
              Paket Umroh · <%= kpis.paketActiveCount %> aktif<% if (draftCount) { %> · <%= draftCount %> draft<% } %><% if (closedCount) { %> · <%= closedCount %> closed<% } %>
            </span>
            <h1>Paket &amp; <em>program perjalanan</em></h1>
          </div>
          <a href="/admin/paket/new" class="btn btn--primary">+ Paket Baru</a>
        </div>
      </header>

      <div class="pkg-grid">
        <% if (paketList.length === 0) { %>
          <div class="stub" style="grid-column:1/-1;">
            <h2>Belum ada paket aktif</h2>
            <p>Tambahkan paket via Prisma Studio atau seed.</p>
          </div>
        <% } %>
        <% paketList.forEach(function(p) { %>
          <% const featured = p.prices.find(function(pr) { return pr.isFeatured; }); %>
          <% const statusBadge = p.status === 'ACTIVE' ? 'badge--emerald' : (p.status === 'DRAFT' ? 'badge--amber' : 'badge--ruby'); %>
          <article class="pkg <%= featured && p.status === 'ACTIVE' ? 'pkg--gold' : '' %>" style="<%= p.status !== 'ACTIVE' ? 'opacity:0.85;' : '' %>">
            <div class="pkg__hero">
              <span class="badge <%= statusBadge %>"><%= p.status %></span>
              <span class="badge"><%= p.durationDays %> Hari</span>
              <% if (featured && p.status === 'ACTIVE') { %><span class="badge badge--solid-gold">FEATURED</span><% } %>
            </div>
            <div class="pkg__body">
              <h4 class="pkg__title"><%= p.title %></h4>
              <p class="pkg__sub">
                DEP <%= fmt.date(p.departureDate).toUpperCase() %>
                <% if (p.subtitle) { %> · <%= p.subtitle %><% } %>
              </p>

              <div class="pkg__price-row">
                <% p.prices.slice(0, 3).forEach(function(pr) { %>
                  <div class="pkg__price <%= pr.isFeatured ? 'is-recommended' : '' %>">
                    <span class="room"><%= pr.kelas %></span>
                    <div class="amt"><%= fmt.rpShort(pr.priceIdr) %></div>
                  </div>
                <% }) %>
              </div>

              <div class="pkg__meta">
                <span>Kuota <strong><%= p.kursiTotal %></strong></span>
                <span>Terisi <strong class="<%= p.fillPct >= 80 ? 'gold' : '' %>"><%= p.kursiTerisi %>/<%= p.kursiTotal %></strong></span>
                <% const ratePct = p.komisiRate != null ? (Number(p.komisiRate.toString?.() ?? p.komisiRate) * 100).toFixed(2).replace(/\.?0+$/, '') : '6'; %>
                <span>Komisi <strong class="gold"><%= ratePct %>%</strong></span>
              </div>

              <div class="pkg__pax">
                <% for (let i = 0; i < 10; i++) { %>
                  <span class="<%= i < Math.round(p.fillPct / 10) ? 'filled' : '' %>"></span>
                <% } %>
              </div>

              <div class="pkg__actions">
                <a href="/p/<%= p.slug %>" target="_blank">LANDING</a>
                <a href="/admin?tab=manifest&manifestPaket=<%= p.slug %>">MANIFEST</a>
                <a href="/admin/paket/<%= p.slug %>/edit">EDIT</a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <!-- ===== MANIFEST ===== -->
    <section class="page <%= activeTab === 'manifest' ? 'is-active' : '' %>" id="page-manifest">
      <header class="page__head">
        <div class="row">
          <div>
            <span class="eyebrow">Manifes Jemaah</span>
            <h1>
              <% if (manifest) { %>
                <%= manifest.bookings.length %> jemaah, <em>satu kebenaran.</em>
              <% } else { %>
                <em>Pilih paket</em>
              <% } %>
            </h1>
          </div>
        </div>
      </header>

      <%# Stage 191 — age bucket KPI strip. Lansia count highlighted
          since it's the operationally significant one (wheelchair,
          slower walks, ihram help). Hidden when no manifest selected. %>
      <% if (manifest && manifest.ageBuckets && manifest.ageBuckets.total > 0) { %>
        <% const ab = manifest.ageBuckets; %>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;font-family:var(--font-mono);">
          <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:8px 14px;">
            <div style="font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;">Total pax</div>
            <div style="font-family:var(--font-display);font-size:18px;color:var(--cream-100);"><%= ab.total %></div>
          </div>
          <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:8px 14px;">
            <div style="font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;">Anak (&lt;12y)</div>
            <div style="font-family:var(--font-display);font-size:18px;color:var(--sapphire);"><%= ab.anak %></div>
          </div>
          <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:8px 14px;">
            <div style="font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;">Dewasa (12-59y)</div>
            <div style="font-family:var(--font-display);font-size:18px;color:var(--cream-100);"><%= ab.dewasa %></div>
          </div>
          <div style="background:rgba(212,175,55,0.08);border:1px solid var(--gold-300);border-radius:var(--r-sm);padding:8px 14px;">
            <div style="font-size:9.5px;color:var(--gold-300);letter-spacing:0.12em;text-transform:uppercase;">⚠ Lansia (≥60y)</div>
            <div style="font-family:var(--font-display);font-size:18px;color:var(--gold-300);font-weight:600;"><%= ab.lansia %></div>
          </div>
          <% if (ab.unknown > 0) { %>
            <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:8px 14px;">
              <div style="font-size:9.5px;color:var(--ink-300);letter-spacing:0.12em;text-transform:uppercase;">Belum ada birthDate</div>
              <div style="font-family:var(--font-display);font-size:18px;color:var(--ink-300);"><%= ab.unknown %></div>
            </div>
          <% } %>
        </div>
      <% } %>

      <%# Stage 205 — per-pickup count rollup. Shown when paket has
          pickup points configured AND at least one jemaah has chosen.
          TBD bucket always rendered so admin sees who hasn't picked. %>
      <% if (manifest && manifest.pickupCounts && manifest.pickupCounts.length > 0) {
           const totalActive = manifest.pickupCounts.reduce((a, p) => a + p.paxCount, 0);
      %>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;font-family:var(--font-mono);">
          <div style="background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);padding:8px 14px;">
            <div style="font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;">Total pickup</div>
            <div style="font-family:var(--font-display);font-size:18px;color:var(--cream-100);"><%= totalActive %> pax</div>
          </div>
          <% manifest.pickupCounts.forEach(function(p) {
               const isTbd = p.id === null;
               const isActive = (typeof manifestPickupId !== 'undefined') && (manifestPickupId === (p.id || '__TBD__'));
          %>
            <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %>&manifestPickup=<%= encodeURIComponent(p.id || '__TBD__') %>"
               style="background:<%= isActive ? 'var(--gold-300)' : 'var(--ink-1000)' %>;border:1px solid <%= isTbd ? 'var(--amber)' : 'var(--hairline-soft)' %>;border-radius:var(--r-sm);padding:8px 14px;text-decoration:none;color:inherit;">
              <div style="font-size:9.5px;color:<%= isActive ? 'var(--ink-1000)' : (isTbd ? 'var(--amber)' : 'var(--ink-200)') %>;letter-spacing:0.12em;text-transform:uppercase;">
                <% if (isTbd) { %>⏱ <% } %><%= p.label %>
              </div>
              <div style="font-family:var(--font-display);font-size:18px;color:<%= isActive ? 'var(--ink-1000)' : 'var(--cream-100)' %>;">
                <%= p.paxCount %>
              </div>
            </a>
          <% }) %>
          <% if (manifestPickupId) { %>
            <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %><% if (typeof manifestDietary !== 'undefined' && manifestDietary) { %>&manifestDietary=<%= encodeURIComponent(manifestDietary) %><% } %>"
               style="background:transparent;border:1px solid var(--ink-200);border-radius:var(--r-sm);padding:8px 14px;text-decoration:none;color:var(--ink-100);align-self:center;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;">
              × Reset pickup
            </a>
          <% } %>
          <%# Stage 215 — show active dietary filter chip + reset %>
          <% if (typeof manifestDietary !== 'undefined' && manifestDietary) { %>
            <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %><% if (manifestPickupId) { %>&manifestPickup=<%= encodeURIComponent(manifestPickupId) %><% } %><% if (manifestTag) { %>&manifestTag=<%= encodeURIComponent(manifestTag) %><% } %>"
               style="background:transparent;border:1px solid var(--gold-300);border-radius:var(--r-sm);padding:8px 14px;text-decoration:none;color:var(--gold-300);align-self:center;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;">
              × Reset diet (<%= manifestDietary === '__SPECIAL__' ? 'KHUSUS' : manifestDietary %>)
            </a>
          <% } %>
          <%# Stage 229 — show active tag filter chip + reset %>
          <% if (typeof manifestTag !== 'undefined' && manifestTag) { %>
            <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %><% if (manifestPickupId) { %>&manifestPickup=<%= encodeURIComponent(manifestPickupId) %><% } %><% if (manifestDietary) { %>&manifestDietary=<%= encodeURIComponent(manifestDietary) %><% } %><% if (typeof manifestGroup !== 'undefined' && manifestGroup) { %>&manifestGroup=<%= encodeURIComponent(manifestGroup) %><% } %>"
               style="background:transparent;border:1px solid var(--gold-300);border-radius:var(--r-sm);padding:8px 14px;text-decoration:none;color:var(--gold-300);align-self:center;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;">
              × Reset tag (<%= manifestTag %>)
            </a>
          <% } %>
          <%# Stage 258 — show active group filter chip + reset %>
          <% if (typeof manifestGroup !== 'undefined' && manifestGroup) { %>
            <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %><% if (manifestPickupId) { %>&manifestPickup=<%= encodeURIComponent(manifestPickupId) %><% } %><% if (manifestDietary) { %>&manifestDietary=<%= encodeURIComponent(manifestDietary) %><% } %><% if (manifestTag) { %>&manifestTag=<%= encodeURIComponent(manifestTag) %><% } %>"
               style="background:transparent;border:1px solid var(--gold-300);border-radius:var(--r-sm);padding:8px 14px;text-decoration:none;color:var(--gold-300);align-self:center;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;">
              × Reset grup (<%= manifestGroup %>)
            </a>
          <% } %>
        </div>
      <% } %>

      <% if (paketList.length > 0) { %>
        <form method="GET" action="/admin" class="manifest-controls">
          <input type="hidden" name="tab" value="manifest">
          <% if (typeof manifestPickupId !== 'undefined' && manifestPickupId) { %>
            <input type="hidden" name="manifestPickup" value="<%= manifestPickupId %>">
          <% } %>
          <select name="manifestPaket" class="input" onchange="this.form.submit()">
            <% paketList.forEach(function(p) { %>
              <option value="<%= p.slug %>" <%= manifest && manifest.paket.slug === p.slug ? 'selected' : '' %>>
                <%= p.title %> · DEP <%= fmt.dateShort(p.departureDate) %>
              </option>
            <% }) %>
          </select>
          <%# Stage 215 — dietary filter. __SPECIAL__ shows all non-REGULAR. %>
          <% if (manifest) { %>
            <select name="manifestDietary" class="input" onchange="this.form.submit()" title="Filter dietary">
              <% const curDiet = (typeof manifestDietary !== 'undefined' ? manifestDietary : '') || ''; %>
              <option value="" <%= !curDiet ? 'selected' : '' %>>Diet: semua</option>
              <option value="__SPECIAL__" <%= curDiet === '__SPECIAL__' ? 'selected' : '' %>>Diet: khusus (non-REGULAR)</option>
              <% ['REGULAR','VEGETARIAN','HALAL_STRICT','SOFT_TEXTURE','DIABETIC','OTHER'].forEach(function(d) { %>
                <option value="<%= d %>" <%= curDiet === d ? 'selected' : '' %>>Diet: <%= d %></option>
              <% }) %>
            </select>
          <% } %>
          <%# Stage 229 — tag filter. `manifestTagOptions` comes from the
              unfiltered raw manifest (route-side) so admin always sees
              every available tag even after narrowing by tag itself. %>
          <%
            const availableTags = typeof manifestTagOptions !== 'undefined' ? manifestTagOptions : [];
            const curTag = (typeof manifestTag !== 'undefined' ? manifestTag : '') || '';
          %>
          <% if (manifest && (availableTags.length > 0 || curTag)) { %>
            <select name="manifestTag" class="input" onchange="this.form.submit()" title="Filter tag">
              <option value="" <%= !curTag ? 'selected' : '' %>>Tag: semua</option>
              <% availableTags.forEach(function(t) { %>
                <option value="<%= t %>" <%= curTag === t ? 'selected' : '' %>>Tag: <%= t %></option>
              <% }) %>
              <%# Always include current selection so a tag filter persists
                  even if the current narrow has no rows with that tag. %>
              <% if (curTag && !availableTags.includes(curTag)) { %>
                <option value="<%= curTag %>" selected>Tag: <%= curTag %> (no rows)</option>
              <% } %>
            </select>
          <% } %>
          <% if (manifest) { %>
            <div class="seg">
              <span class="is-active">Semua (<%= manifest.bookings.length %>)</span>
              <span>Lunas (<%= manifest.statusCounts.LUNAS || 0 %>)</span>
              <span>DP (<%= (manifest.statusCounts.DP_PAID || 0) + (manifest.statusCounts.PARTIAL || 0) %>)</span>
              <span>Pending (<%= manifest.statusCounts.PENDING || 0 %>)</span>
            </div>
            <a href="/admin/paket/<%= manifest.paket.slug %>/checklist"
               style="margin-left:auto;background:transparent;border:1px solid var(--amber);color:var(--amber);padding:8px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;"
               title="Pre-departure readiness per jemaah">
              ✓ Checklist
            </a>
            <a href="/admin/manifest/<%= manifest.paket.slug %>/print" target="_blank" rel="noopener"
               style="background:transparent;border:1px solid var(--ink-200);color:var(--ink-100);padding:8px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;margin-left:8px;"
               title="Manifest siap cetak (airport check-in)">
              🖨 Cetak
            </a>
            <a href="/admin/manifest/<%= manifest.paket.slug %>/export.csv"
               style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:8px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;margin-left:8px;">
              ⇩ Export CSV
            </a>
            <%# Stage 208 — pickup roster CSV. Honors the current pickup
                filter when active so admin downloads only the selected
                roster, not the whole paket. %>
            <% if (manifest.pickupCounts && manifest.pickupCounts.length > 0) { %>
              <a href="/admin/manifest/<%= manifest.paket.slug %>/pickup-roster.csv<% if (typeof manifestPickupId !== 'undefined' && manifestPickupId) { %>?pickup=<%= encodeURIComponent(manifestPickupId) %><% } %>"
                 title="Roster bus per pickup point (driver use)"
                 style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:8px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;margin-left:8px;">
                🚌 Roster pickup
              </a>
            <% } %>
            <%# Stage 211 — dietary roll-up CSV for catering / hotel kitchen brief %>
            <a href="/admin/manifest/<%= manifest.paket.slug %>/dietary.csv"
               title="Roll-up diet jemaah (catering brief)"
               style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:8px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;margin-left:8px;">
              🍽 Diet CSV
            </a>
          <% } %>
        </form>
      <% } %>

      <% if (!manifest) { %>
        <div class="stub">
          <h2>Belum ada paket aktif</h2>
          <p>Tambahkan paket dulu untuk melihat manifesnya.</p>
        </div>
      <% } else { %>
        <%# Stage 247 — per-paket document expiry triage. Renders above
            the manifest when there's at least one expired/expiring doc
            so admin sees the leak before scanning rows individually. %>
        <% if (typeof docOverview !== 'undefined' && docOverview && docOverview.counts.total > 0) {
             const DOC_LABEL = {
               PASSPORT: 'Paspor',
               VISA_UMROH: 'Visa Umroh',
               MANASIK_CERT: 'Sertifikat Manasik',
               HEALTH_CERT: 'Surat Sehat',
               VACCINE_MENINGITIS: 'Vaksin Meningitis',
               MARRIAGE_CERT: 'Buku Nikah',
               FAMILY_CARD: 'Kartu Keluarga',
               OTHER: 'Lainnya',
             };
             const BAND_COLOR = { EXPIRED: 'ruby', URGENT: 'amber', WARNING: 'gold' };
        %>
          <div class="panel" style="margin-bottom:18px;padding:14px 18px;border:1px solid var(--ruby);background:rgba(181,86,74,0.04);border-radius:var(--r-sm);">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;gap:10px;flex-wrap:wrap;">
              <h3 style="margin:0;font-family:var(--font-display);color:var(--ruby);">📄 Dokumen perlu perhatian</h3>
              <div style="font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
                <% if (docOverview.counts.expired > 0) { %><span style="color:var(--ruby);"><%= docOverview.counts.expired %> EXPIRED</span> · <% } %>
                <% if (docOverview.counts.urgent > 0) { %><span style="color:var(--amber);"><%= docOverview.counts.urgent %> &lt;30 HARI</span> · <% } %>
                <% if (docOverview.counts.warning > 0) { %><span style="color:var(--gold-300);"><%= docOverview.counts.warning %> &lt;60 HARI</span><% } %>
              </div>
            </div>
            <p class="sub" style="margin:0 0 12px;">Klik nama jemaah untuk buka edit profil. Renew via tombol RENEW pada panel dokumen.</p>
            <div style="max-height:300px;overflow-y:auto;">
              <% docOverview.rows.slice(0, 30).forEach(function(r) {
                const today = new Date();
                const days = Math.ceil((new Date(r.document.expiresAt).getTime() - today.getTime()) / 86_400_000);
                const color = BAND_COLOR[r.band] || 'gold';
              %>
                <div style="display:grid;grid-template-columns:120px 1fr 220px 80px;gap:10px;padding:8px 10px;border-bottom:1px dashed var(--hairline-soft);font-family:var(--font-mono);font-size:11.5px;color:var(--cream-100);align-items:baseline;">
                  <span class="badge badge--<%= color %>" style="font-size:9px;letter-spacing:0.06em;"><%= r.band %></span>
                  <a href="/admin/jemaah/<%= r.jemaah.id %>/edit" style="color:var(--cream-100);text-decoration:none;">
                    <strong style="color:var(--gold-300);"><%= r.jemaah.fullName %></strong>
                    <% if (r.jemaah.phone) { %> · <span style="color:var(--ink-200);">📱 <%= r.jemaah.phone %></span><% } %>
                  </a>
                  <span><%= DOC_LABEL[r.document.type] || r.document.type %><% if (r.document.refNumber) { %> · <span style="color:var(--ink-200);"><%= r.document.refNumber %></span><% } %></span>
                  <span style="text-align:right;color:var(--<%= color %>);">
                    <% if (r.band === 'EXPIRED') { %><%= Math.abs(days) %>h lewat<% } else { %><%= days %>h lagi<% } %>
                  </span>
                </div>
              <% }) %>
            </div>
            <% if (docOverview.counts.total > 30) { %>
              <div class="sub" style="margin-top:8px;">+ <%= docOverview.counts.total - 30 %> dokumen lainnya (filter manifest untuk lihat detail per jemaah)</div>
            <% } %>
          </div>
        <% } %>

        <!-- Stage 110 — bulk select + dossier export. The action bar
             auto-shows when ≥1 row is checked. -->
        <form id="bulk-bundle-form" method="POST" action="/admin/manifest/<%= manifest.paket.slug %>/bundles.zip">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <table class="tbl">
          <thead>
            <tr>
              <th style="width:32px;"><input type="checkbox" id="bulk-check-all" title="Pilih semua" style="cursor:pointer;"></th>
              <th style="width:140px;">ID Booking</th>
              <th>Nama</th>
              <th>Dokumen</th>
              <th>Kelas / PAX</th>
              <th>Status</th>
              <th class="num">Total</th>
              <th class="num">Dibayar</th>
              <th>Agen</th>
              <th style="width:90px;text-align:right;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (manifest.bookings.length === 0) { %>
              <tr><td colspan="10" style="text-align:center;color:var(--ink-200);">Belum ada booking untuk paket ini.</td></tr>
            <% } %>
            <% manifest.bookings.forEach(function(b) { %>
              <%
                const total = Number(b.totalAmount?.toString?.() ?? b.totalAmount) || 0;
                const paid  = Number(b.paidAmount?.toString?.()  ?? b.paidAmount)  || 0;
                const sisa  = Math.max(0, total - paid);
                const closed = b.status === 'CANCELLED' || b.status === 'REFUNDED' || sisa <= 0;
              %>
              <tr>
                <td><input class="bulk-row" type="checkbox" name="bookingIds" value="<%= b.id %>" style="cursor:pointer;"></td>
                <td>
                  <a href="/admin/bookings/<%= b.id %>" class="id" style="text-decoration:none;"><%= b.bookingNo %></a>
                </td>
                <td>
                  <a href="/admin/jemaah/<%= b.jemaahId %>/edit" style="color:var(--cream-100);text-decoration:none;font-weight:500;">
                    <%= b.jemaah.fullName %>
                  </a>
                  <div class="sx"><%= b.jemaah.phone %></div>
                  <%# Stage 187 — crew per-jemaah notes (read-only on admin). %>
                  <% const crewNotes = manifest.crewNotesByJemaah?.[b.jemaahId]; %>
                  <% if (crewNotes && crewNotes.length > 0) { %>
                    <div style="margin-top:6px;padding:6px 8px;background:rgba(212,175,55,0.06);border-left:2px solid var(--gold-300);border-radius:0 var(--r-sm) var(--r-sm) 0;font-family:var(--font-mono);font-size:10px;color:var(--cream-100);">
                      <% crewNotes.forEach((n) => { %>
                        <div style="margin-bottom:3px;">
                          📝 <em style="color:var(--gold-300);"><%= n.authorName %>:</em> <%= n.body.length > 120 ? n.body.slice(0, 120) + '…' : n.body %>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
                <td>
                  <div class="doc-pills">
                    <% (b.jemaah.docPills || []).forEach(function(p) { %>
                      <span class="doc-pill-mini state-<%= p.state %>" title="<%= p.type %>: <%= p.state %>"><%= p.label %></span>
                    <% }) %>
                  </div>
                  <%# Stage 210 — dietary pill. Only render when non-REGULAR
                      (REGULAR is the default; catering doesn't need a callout). %>
                  <% if (b.jemaah.dietary && b.jemaah.dietary !== 'REGULAR') { %>
                    <%
                      const DIET_PILL = {
                        VEGETARIAN:   { label: '🥬 VEG',   color: 'emerald' },
                        HALAL_STRICT: { label: '☪ HALAL+', color: 'gold' },
                        SOFT_TEXTURE: { label: '🥣 SOFT',  color: 'amber' },
                        DIABETIC:     { label: '🩸 DIAB',  color: 'ruby' },
                        OTHER:        { label: '⚠ DIET',   color: 'sapphire' },
                      };
                      const dp = DIET_PILL[b.jemaah.dietary] || { label: b.jemaah.dietary, color: 'sapphire' };
                      const tip = b.jemaah.dietaryNotes ? `${b.jemaah.dietary}: ${b.jemaah.dietaryNotes}` : b.jemaah.dietary;
                    %>
                    <div style="margin-top:4px;">
                      <span class="badge badge--<%= dp.color %>" style="font-size:9.5px;letter-spacing:0.04em;" title="<%= tip %>"><%= dp.label %></span>
                    </div>
                  <% } %>
                  <%# Stage 229 — booking tag pills (S226). Render in the
                      docs/diet cell to keep the table compact; each pill is
                      clickable to filter the manifest by that tag. %>
                  <% if (Array.isArray(b.tags) && b.tags.length > 0) { %>
                    <div style="margin-top:4px;display:flex;gap:3px;flex-wrap:wrap;">
                      <% b.tags.forEach(function(t) { %>
                        <a href="/admin?tab=manifest&manifestPaket=<%= manifest.paket.slug %>&manifestTag=<%= encodeURIComponent(t) %>"
                           style="background:rgba(212,175,55,0.10);border:1px solid var(--gold-300);color:var(--gold-300);padding:1px 6px;border-radius:3px;font-family:var(--font-mono);font-size:9px;letter-spacing:0.04em;text-decoration:none;">
                          <%= t %>
                        </a>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
                <td>
                  <span style="color:var(--cream-100);"><%= b.kelas %></span>
                  <div class="sx"><%= b.paxCount %> PAX</div>
                </td>
                <td>
                  <%
                    const cls = b.status === 'LUNAS' ? 'badge--emerald'
                      : (b.status === 'CANCELLED' || b.status === 'REFUNDED') ? 'badge--ruby'
                      : b.status === 'PENDING' ? 'badge--amber'
                      : 'badge--gold';
                  %>
                  <span class="badge <%= cls %>"><%= b.status %></span>
                  <% if (b.cancelRequested) { %>
                    <span class="badge badge--amber" style="margin-top:4px;display:inline-block;" title="Jemaah minta pembatalan: <%= b.cancelRequestReason %>">REQ CANCEL</span>
                  <% } %>
                </td>
                <td class="num amt"><%= fmt.rpFull(b.totalAmount) %></td>
                <td class="num amt <%= paid >= total && total > 0 ? 'gold' : '' %>">
                  <%= fmt.rpFull(b.paidAmount) %>
                </td>
                <td>
                  <% if (b.agent) { %>
                    <div class="nm" style="font-size:13px;"><%= b.agent.displayName %></div>
                    <div class="sx">slug <%= b.agent.slug %></div>
                  <% } else { %>
                    <span class="sx">— Kantor Pusat —</span>
                  <% } %>
                </td>
                <td style="text-align:right;">
                  <button class="btn-pay"
                    data-pay-booking="<%= b.id %>"
                    data-pay-bookingno="<%= b.bookingNo %>"
                    data-pay-name="<%= b.jemaah.fullName %>"
                    data-pay-total="<%= total %>"
                    data-pay-paid="<%= paid %>"
                    data-pay-sisa="<%= sisa %>"
                    <%= closed ? 'disabled' : '' %>>
                    + BAYAR
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </form>
        <!-- Stage 110 — floating action bar, hidden until ≥1 row checked -->
        <div id="bulk-bar" hidden style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--ink-900);border:1px solid var(--gold-300);border-radius:var(--r-md);padding:12px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 8px 24px rgba(0,0,0,0.6);z-index:80;font-family:var(--font-mono);font-size:11.5px;">
          <span style="color:var(--gold-300);"><span id="bulk-count">0</span> booking dipilih</span>
          <button type="button" id="bulk-pdf" style="background:var(--gold-300);color:var(--ink-1000);border:0;padding:7px 14px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;font-weight:600;">⇩ PDF dossier</button>
          <button type="button" id="bulk-csv" style="background:transparent;color:var(--gold-300);border:1px solid var(--gold-300);padding:7px 14px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;">⇩ CSV dossier</button>
          <button type="button" id="bulk-clear" style="background:transparent;color:var(--ink-200);border:1px solid var(--ink-700);padding:7px 10px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.08em;cursor:pointer;border-radius:3px;">×</button>
        </div>
        <script>
        (function() {
          const form = document.getElementById('bulk-bundle-form');
          const bar = document.getElementById('bulk-bar');
          const count = document.getElementById('bulk-count');
          const checkAll = document.getElementById('bulk-check-all');
          if (!form) return;
          function rowCheckboxes() {
            return Array.from(form.querySelectorAll('input.bulk-row[type="checkbox"]'));
          }
          function paint() {
            const checked = rowCheckboxes().filter((c) => c.checked);
            const n = checked.length;
            count.textContent = n;
            if (n > 0) bar.hidden = false;
            else bar.hidden = true;
            // master state
            if (checkAll) {
              const all = rowCheckboxes();
              checkAll.checked = n > 0 && n === all.length;
              checkAll.indeterminate = n > 0 && n < all.length;
            }
          }
          form.addEventListener('change', (e) => {
            if (e.target.matches('input.bulk-row[type="checkbox"]')) paint();
          });
          if (checkAll) checkAll.addEventListener('change', () => {
            rowCheckboxes().forEach((c) => { c.checked = checkAll.checked; });
            paint();
          });
          document.getElementById('bulk-pdf').addEventListener('click', () => {
            form.action = form.action.split('?')[0]; // pdf is default
            form.submit();
          });
          document.getElementById('bulk-csv').addEventListener('click', () => {
            form.action = form.action.split('?')[0] + '?format=csv';
            form.submit();
          });
          document.getElementById('bulk-clear').addEventListener('click', () => {
            rowCheckboxes().forEach((c) => { c.checked = false; });
            paint();
          });
          paint();
        })();
        </script>
      <% } %>
    </section>

    <!-- ===== BUNKING ===== -->
    <section class="page <%= activeTab === 'bunking' ? 'is-active' : '' %>" id="page-bunking">
      <header class="page__head">
        <div class="row">
          <div>
            <span class="eyebrow">
              <% if (bunking) { %>
                Bunking · <%= bunking.paket.title %>
              <% } else { %>
                Bunking
              <% } %>
            </span>
            <h1>
              <% if (bunking) { %>
                <%= bunking.totals.occupied %>/<%= bunking.totals.capacity %> slot terisi,<br>
                <em><%= bunking.totals.unassignedPax %> pax</em> menunggu.
              <% } else { %>
                Drag &amp; drop, <em>tanpa coret-coretan.</em>
              <% } %>
            </h1>
          </div>
        </div>
      </header>

      <% if (paketList.length > 0) { %>
        <form method="GET" action="/admin" class="manifest-controls" style="margin-bottom:24px;">
          <input type="hidden" name="tab" value="bunking">
          <select name="bunkingPaket" class="input" onchange="this.form.submit()" style="min-width:320px;">
            <% paketList.forEach(function(p) { %>
              <option value="<%= p.slug %>" <%= bunking && bunking.paket.slug === p.slug ? 'selected' : '' %>>
                <%= p.title %> · DEP <%= fmt.dateShort(p.departureDate) %>
              </option>
            <% }) %>
          </select>
          <% if (bunking) { %>
            <div class="seg">
              <span class="is-active"><%= bunking.totals.roomCount %> kamar</span>
              <span><%= bunking.totals.capacity %> kapasitas</span>
              <span><%= bunking.totals.occupied %> terisi</span>
              <span><%= bunking.totals.unassignedPax %> belum</span>
            </div>
          <% } %>
        </form>
      <% } %>

      <% if (!bunking) { %>
        <div class="stub">
          <h2>Pilih paket dulu</h2>
          <p>Belum ada paket yang dapat dipilih.</p>
        </div>
      <% } else if (bunking.floors.length === 0) { %>
        <div class="stub">
          <h2>Belum ada kamar untuk paket ini</h2>
          <p>Tambahkan kamar via <code>prisma/seed.js</code> atau Prisma Studio.<br>Editor kamar admin menyusul di step <code>5e.2</code>.</p>
        </div>
      <% } else { %>
        <div class="bunking-layout">
          <!-- Unassigned sidebar -->
          <aside class="bunking-side">
            <h4>UNASSIGNED <span><%= bunking.unassigned.length %></span></h4>
            <% if (bunking.unassigned.length === 0) { %>
              <div class="ba-row empty-state">Semua booking sudah di-assign.</div>
            <% } %>
            <% bunking.unassigned.forEach(function(b) { %>
              <div class="ba-row" data-booking-id="<%= b.id %>" data-booking-no="<%= b.bookingNo %>" data-kelas="<%= b.kelas %>" data-pax="<%= b.paxCount %>" data-name="<%= b.jemaah.fullName %>">
                <div>
                  <div class="nm"><%= b.jemaah.fullName %></div>
                  <div class="sx"><%= b.bookingNo %> · <%= b.kelas %> · <%= b.paxCount %> PAX</div>
                </div>
                <button type="button" data-assign>ASSIGN</button>
              </div>
            <% }) %>
          </aside>

          <!-- Floors -->
          <div class="bunking-main">
            <% bunking.floors.forEach(function(f) { %>
              <div class="bunking-floor">
                <h3 style="display:flex;align-items:center;gap:10px;">
                  Lantai <%= f.floor ?? '—' %><% if (f.wing) { %> — Wing <%= f.wing %><% } %>
                  <span class="meta"><%= f.rooms.length %> KAMAR</span>
                  <%# Stage 200 — bulk-assign button. Only meaningful when
                      there are unassigned bookings AND the floor is numeric. %>
                  <% if (bunking.unassigned.length > 0 && f.floor != null) { %>
                    <button type="button" data-bulk-assign-floor data-paket-id="<%= bunking.paket.id %>" data-floor="<%= f.floor %>"
                            style="margin-left:auto;background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:4px 12px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;">
                      ⇣ Bulk-assign
                    </button>
                  <% } %>
                </h3>
                <div class="rooms-grid">
                  <% f.rooms.forEach(function(r) { %>
                    <% const state = r.occupied === 0 ? 'empty' : (r.occupied >= r.capacity ? 'full' : 'partial'); %>
                    <div class="room <%= state %>">
                      <div class="room__head">
                        <span class="room__no"><%= r.roomNo %></span>
                        <span class="room__type"><%= r.kelas %> · <%= r.capacity %>P</span>
                      </div>
                      <div class="room__slots">
                        <% r.bookings.forEach(function(b) { %>
                          <% for (let i = 0; i < b.paxCount; i++) { %>
                            <div class="room__slot">
                              <span class="av"><%= b.jemaah.fullName.charAt(0) %></span>
                              <div style="min-width:0;">
                                <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= b.jemaah.fullName %><% if (b.paxCount > 1) { %> <span class="sub">+<%= i + 1 %>/<%= b.paxCount %></span><% } %></div>
                                <div class="sub"><%= b.bookingNo %></div>
                              </div>
                              <% if (i === 0) { %>
                                <button type="button" data-swap-toggle data-booking-id="<%= b.id %>" data-booking-no="<%= b.bookingNo %>" data-name="<%= b.jemaah.fullName %>" data-room-no="<%= r.roomNo %>" title="Pilih untuk swap" style="background:transparent;border:0;color:var(--gold-300);cursor:pointer;font-size:13px;padding:0 4px;">⇄</button>
                                <button type="button" data-unassign data-booking-id="<%= b.id %>" title="Lepas dari kamar">✕</button>
                              <% } %>
                            </div>
                          <% } %>
                        <% }) %>
                        <% for (let i = 0; i < r.slotsLeft; i++) { %>
                          <div class="room__slot empty">— SLOT KOSONG —</div>
                        <% } %>
                      </div>
                      <div class="room__cap <%= state === 'full' ? 'full' : '' %>">
                        <%= r.occupied %>/<%= r.capacity %> slot
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </section>

    <!-- ===== FINANCE ===== -->
    <section class="page <%= activeTab === 'finance' ? 'is-active' : '' %>" id="page-finance">
      <header class="page__head">
        <div class="row">
          <div>
            <span class="eyebrow">Finance · kas &amp; arus</span>
            <h1>Arus kas <em>multi-currency</em>.</h1>
          </div>
          <div class="meta">
            <strong style="color:var(--cream-100);">Sisa piutang: <%= fmt.rpFull(finance.receivables) %></strong><br>
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);letter-spacing:0.08em;">
              <%= finance.paymentLedger.length %> TRANSAKSI TERAKHIR
            </span>
          </div>
        </div>
      </header>

      <!-- Kas per currency -->
      <div class="fin-grid">
        <% ['IDR','USD','SAR'].forEach(function(cur) {
          const row = finance.cashByCurrency.find(function(r) { return r.currency === cur; }) || { amount: 0, count: 0 };
        %>
          <div class="currency-card" data-cur="<%= cur %>">
            <div class="lbl">Kas masuk · <%= cur %></div>
            <div class="val">
              <% if (cur === 'IDR') { %>
                <%= fmt.rpShort(row.amount) %><span class="u">IDR</span>
              <% } else { %>
                <%= row.amount.toLocaleString('en-US') %><span class="u"><%= cur %></span>
              <% } %>
            </div>
            <div class="meta"><%= row.count %> transaksi PAID</div>
          </div>
        <% }) %>
      </div>

      <!-- Receivables panel -->
      <div class="panel" style="margin-bottom:16px;">
        <div class="panel__head">
          <h3>Posisi piutang</h3>
          <span class="meta">BOOKING AKTIF SAJA</span>
        </div>
        <div class="status-bar" style="grid-template-columns:repeat(3,1fr);">
          <div class="sb-cell">
            <div class="l">Total diterima</div>
            <div class="v"><%= fmt.rpShort(finance.receivedTotal) %></div>
          </div>
          <div class="sb-cell is-pending">
            <div class="l">Sisa piutang</div>
            <div class="v"><%= fmt.rpShort(finance.receivables) %></div>
          </div>
          <div class="sb-cell is-lunas">
            <div class="l">Komisi earned</div>
            <div class="v"><%= fmt.rpShort(kpis.komisi.EARNED) %></div>
          </div>
        </div>
      </div>

      <!-- Payment ledger -->
      <div class="panel">
        <div class="panel__head">
          <h3>Ledger pembayaran</h3>
          <span class="meta"><%= finance.paymentLedger.length %> ENTRI</span>
        </div>
        <table class="tbl">
          <thead>
            <tr>
              <th>Waktu</th>
              <th>Booking</th>
              <th>Jemaah</th>
              <th>Metode</th>
              <th class="num">Jumlah</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (finance.paymentLedger.length === 0) { %>
              <tr><td colspan="6" style="text-align:center;color:var(--ink-200);">Belum ada pembayaran tercatat.</td></tr>
            <% } %>
            <% finance.paymentLedger.forEach(function(p) { %>
              <% const pAmt = Number(p.amount?.toString?.() ?? p.amount) || 0; const isRefund = pAmt < 0; %>
              <tr>
                <td>
                  <div style="color:var(--cream-100);"><%= fmt.date(p.paidAt || p.createdAt) %></div>
                  <div class="sx"><%= new Date(p.paidAt || p.createdAt).toISOString().slice(11,16) %></div>
                </td>
                <td>
                  <a href="/admin/bookings/<%= p.bookingId %>" class="id" style="text-decoration:none;"><%= p.booking.bookingNo %></a>
                </td>
                <td>
                  <div class="nm"><%= p.booking.jemaah.fullName %></div>
                  <div class="sx"><%= p.booking.paket.title.slice(0, 32) %><%= p.booking.paket.title.length > 32 ? '…' : '' %></div>
                </td>
                <td>
                  <span class="badge"><%= p.method %></span>
                </td>
                <td class="num amt" style="<%= isRefund ? 'color:var(--ruby);' : 'color:var(--gold-300);' %>">
                  <% if (p.currency === 'IDR') { %><%= isRefund ? '−' : '' %><%= fmt.rpFull(Math.abs(pAmt)) %><% } else { %><%= isRefund ? '−' : '' %><%= Math.abs(pAmt).toLocaleString('en-US') %> <%= p.currency %><% } %>
                </td>
                <td>
                  <% const pcls = p.status === 'PAID' ? 'badge--emerald' : (p.status === 'FAILED' ? 'badge--ruby' : (p.status === 'REFUNDED' ? 'badge--ruby' : 'badge--amber')); %>
                  <span class="badge <%= pcls %>"><%= p.status %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</div>

<!-- Assign room modal -->
<div class="modal-overlay" id="assign-modal" aria-hidden="true">
  <div class="modal">
    <h2>Assign ke Kamar</h2>
    <div class="sub" id="assign-modal-sub">—</div>
    <div class="err" id="assign-err"></div>

    <form id="assign-form">
      <input type="hidden" name="bookingId">
      <div class="field">
        <label class="label" for="af-room">Kamar tersedia *</label>
        <select class="input" name="roomId" id="af-room" required>
          <option value="">— pilih kamar —</option>
        </select>
        <div style="font-family:var(--font-mono);font-size:10.5px;color:var(--ink-200);margin-top:6px;letter-spacing:0.04em;">
          Hanya kamar dengan kelas yang sama dan slot mencukupi yang ditampilkan.
        </div>
      </div>
      <div class="actions">
        <button type="button" class="btn btn--ghost" id="assign-cancel">Batal</button>
        <button type="submit" class="btn btn--primary">Assign</button>
      </div>
    </form>
  </div>
</div>

<!-- Pay modal -->
<div class="modal-overlay" id="pay-modal" aria-hidden="true">
  <div class="modal">
    <h2>Catat Pembayaran</h2>
    <div class="sub" id="pay-modal-sub">—</div>

    <div class="pay-summary">
      <div><div class="l">Total</div><div class="v" id="pay-total">—</div></div>
      <div><div class="l">Sudah dibayar</div><div class="v gold" id="pay-paid">—</div></div>
      <div><div class="l">Sisa</div><div class="v amber" id="pay-sisa">—</div></div>
    </div>

    <div class="err" id="pay-err"></div>

    <form id="pay-form">
      <input type="hidden" name="bookingId">

      <div class="field">
        <label class="label" for="pf-amount">Jumlah (Rp) *</label>
        <input class="input" type="number" name="amount" id="pf-amount" required min="1" step="1">
      </div>

      <div class="field-grid">
        <div class="field">
          <label class="label" for="pf-method">Metode *</label>
          <select class="input" name="method" id="pf-method" required>
            <option value="TRANSFER">Transfer Bank</option>
            <option value="CASH">Cash</option>
            <option value="VA">Virtual Account</option>
            <option value="QRIS">QRIS</option>
            <option value="EWALLET">E-Wallet</option>
            <option value="CARD">Kartu Kredit</option>
          </select>
        </div>
        <div class="field">
          <label class="label" for="pf-cur">Currency</label>
          <select class="input" name="currency" id="pf-cur">
            <option value="IDR" selected>IDR</option>
            <option value="USD">USD</option>
            <option value="SAR">SAR</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label class="label" for="pf-notes">Catatan</label>
        <input class="input" name="notes" id="pf-notes" maxlength="500"
               placeholder="Mis. transfer dari rek BCA atas nama jemaah">
      </div>

      <div class="actions">
        <button type="button" class="btn btn--ghost" id="pay-cancel">Batal</button>
        <button type="submit" class="btn btn--primary">Catat Pembayaran</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Page switcher
  const items = document.querySelectorAll('.rail__item[data-page]');
  const pages = document.querySelectorAll('.page');
  const leaf = document.getElementById('crumb-leaf');
  const labels = { overview: 'Overview', packages: 'Paket', manifest: 'Manifest', bunking: 'Bunking', finance: 'Finance' };

  function activate(target) {
    items.forEach((b) => b.classList.toggle('is-active', b.dataset.page === target));
    pages.forEach((p) => p.classList.toggle('is-active', p.id === 'page-' + target));
    if (leaf && labels[target]) leaf.textContent = labels[target];
    // Update URL without reload for bookmarkability
    const url = new URL(location.href);
    url.searchParams.set('tab', target);
    history.replaceState(null, '', url.toString());
  }

  items.forEach((btn) => {
    btn.addEventListener('click', () => activate(btn.dataset.page));
  });

  // ===== Pay modal =====
  const pModal = document.getElementById('pay-modal');
  const pForm  = document.getElementById('pay-form');
  const pErr   = document.getElementById('pay-err');
  const pSub   = document.getElementById('pay-modal-sub');
  const pTotal = document.getElementById('pay-total');
  const pPaid  = document.getElementById('pay-paid');
  const pSisa  = document.getElementById('pay-sisa');

  const idr = (n) => 'Rp ' + Math.round(Number(n)).toLocaleString('id-ID');

  function openPay(btn) {
    const total = Number(btn.dataset.payTotal) || 0;
    const paid  = Number(btn.dataset.payPaid)  || 0;
    const sisa  = Number(btn.dataset.paySisa)  || 0;
    pSub.textContent = btn.dataset.payBookingno + ' · ' + btn.dataset.payName;
    pTotal.textContent = idr(total);
    pPaid.textContent  = idr(paid);
    pSisa.textContent  = idr(sisa);
    pForm.elements.bookingId.value = btn.dataset.payBooking;
    pForm.elements.amount.value    = sisa > 0 ? sisa : '';
    pForm.elements.method.value    = 'TRANSFER';
    pForm.elements.currency.value  = 'IDR';
    pForm.elements.notes.value     = '';
    pErr.classList.remove('is-visible');
    pModal.classList.add('is-open');
    setTimeout(() => pForm.elements.amount.focus(), 0);
  }
  function closePay() { pModal.classList.remove('is-open'); }

  document.querySelectorAll('[data-pay-booking]').forEach((btn) => {
    if (btn.disabled) return;
    btn.addEventListener('click', () => openPay(btn));
  });
  document.getElementById('pay-cancel').addEventListener('click', closePay);
  pModal.addEventListener('click', (e) => { if (e.target === pModal) closePay(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePay(); });

  pForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    pErr.classList.remove('is-visible');
    const fd = new FormData(pForm);
    const body = {};
    for (const [k, v] of fd.entries()) if (v !== '') body[k] = v;
    try {
      const r = await fetch('/api/payments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        pErr.textContent = j?.error?.message || 'Gagal mencatat pembayaran';
        pErr.classList.add('is-visible');
        return;
      }
      // Preserve current tab + manifest paket in reload URL
      location.reload();
    } catch {
      pErr.textContent = 'Tidak dapat menghubungi server';
      pErr.classList.add('is-visible');
    }
  });

  // ===== Bunking: assign + unassign =====
  <% if (bunking && bunking.floors.length > 0) { %>
  const BUNKING_ROOMS = <%- JSON.stringify(bunking.floors.flatMap(function(f) { return f.rooms.map(function(r) { return { id: r.id, roomNo: r.roomNo, kelas: r.kelas, capacity: r.capacity, occupied: r.occupied, slotsLeft: r.slotsLeft, floor: r.floor, wing: r.wing }; }); })) %>;

  const aModal = document.getElementById('assign-modal');
  const aForm  = document.getElementById('assign-form');
  const aErr   = document.getElementById('assign-err');
  const aSub   = document.getElementById('assign-modal-sub');
  const aRoom  = document.getElementById('af-room');

  function openAssign(btn) {
    const bookingId = btn.dataset.bookingId;
    const kelas = btn.dataset.kelas;
    const pax = Number(btn.dataset.pax);
    const name = btn.dataset.name;
    const bookingNo = btn.dataset.bookingNo;

    aSub.textContent = `${bookingNo} · ${name} · ${kelas} · ${pax} PAX`;
    aForm.elements.bookingId.value = bookingId;
    aErr.classList.remove('is-visible');

    // Populate dropdown: only rooms with matching kelas + enough slots
    aRoom.innerHTML = '<option value="">— pilih kamar —</option>';
    const eligible = BUNKING_ROOMS.filter((r) => r.kelas === kelas && r.slotsLeft >= pax);
    if (eligible.length === 0) {
      aRoom.innerHTML = '<option value="">Tidak ada kamar yang cocok</option>';
    } else {
      eligible.forEach((r) => {
        const opt = document.createElement('option');
        opt.value = r.id;
        opt.textContent = `${r.roomNo} (lt ${r.floor ?? '—'}${r.wing ? ' · ' + r.wing : ''}) — sisa ${r.slotsLeft}/${r.capacity}`;
        aRoom.appendChild(opt);
      });
    }
    aModal.classList.add('is-open');
  }

  function closeAssign() { aModal.classList.remove('is-open'); }
  document.getElementById('assign-cancel').addEventListener('click', closeAssign);
  aModal.addEventListener('click', (e) => { if (e.target === aModal) closeAssign(); });

  document.querySelectorAll('[data-assign]').forEach((btn) => {
    btn.addEventListener('click', () => openAssign(btn.closest('[data-booking-id]')));
  });

  aForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    aErr.classList.remove('is-visible');
    const fd = new FormData(aForm);
    const body = { bookingId: fd.get('bookingId'), roomId: fd.get('roomId') };
    if (!body.roomId) return;
    try {
      const r = await fetch('/api/bunking/assign', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        aErr.textContent = j?.error?.message || 'Gagal assign';
        aErr.classList.add('is-visible');
        return;
      }
      location.reload();
    } catch {
      aErr.textContent = 'Tidak dapat menghubungi server';
      aErr.classList.add('is-visible');
    }
  });

  // Unassign (X button on each slot)
  document.querySelectorAll('[data-unassign]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (!confirm('Lepas booking ini dari kamar?')) return;
      const bookingId = btn.dataset.bookingId;
      try {
        const r = await fetch('/api/bunking/unassign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ bookingId }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert(j?.error?.message || 'Gagal unassign');
          return;
        }
        location.reload();
      } catch {
        alert('Tidak dapat menghubungi server');
      }
    });
  });

  // Stage 178 — two-click swap. First click selects source (highlight),
  // second click on a different booking swaps the rooms via /api/bunking/swap.
  let swapSource = null;
  const swapBanner = document.createElement('div');
  swapBanner.style.cssText = 'position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:var(--ink-1000);border:1px solid var(--gold-300);color:var(--cream-100);padding:10px 16px;border-radius:var(--r-md);font-family:var(--font-mono);font-size:12px;z-index:1000;display:none;';
  document.body.appendChild(swapBanner);
  function clearSwap() {
    swapSource = null;
    swapBanner.style.display = 'none';
    document.querySelectorAll('[data-swap-toggle]').forEach((b) => {
      b.style.background = 'transparent';
      b.style.color = 'var(--gold-300)';
    });
  }
  document.querySelectorAll('[data-swap-toggle]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const id = btn.dataset.bookingId;
      if (!swapSource) {
        swapSource = {
          id, bookingNo: btn.dataset.bookingNo,
          name: btn.dataset.name, roomNo: btn.dataset.roomNo,
        };
        btn.style.background = 'var(--gold-300)';
        btn.style.color = 'var(--ink-1000)';
        swapBanner.innerHTML = '⇄ Swap mode: <strong>' + swapSource.bookingNo + '</strong> (' + swapSource.name + ' · kamar ' + swapSource.roomNo + ') → klik booking lain untuk swap, atau <a href="#" data-swap-cancel style="color:var(--ruby);">batal</a>';
        swapBanner.style.display = 'block';
        return;
      }
      if (id === swapSource.id) {
        // Click on same booking → cancel
        clearSwap();
        return;
      }
      // Second pick — swap
      if (!confirm('Swap kamar antara ' + swapSource.bookingNo + ' dan ' + btn.dataset.bookingNo + '?')) {
        return;
      }
      try {
        const r = await fetch('/api/bunking/swap', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ bookingIdA: swapSource.id, bookingIdB: id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert(j?.error?.message || 'Gagal swap');
          clearSwap();
          return;
        }
        location.reload();
      } catch {
        alert('Tidak dapat menghubungi server');
        clearSwap();
      }
    });
  });
  swapBanner.addEventListener('click', (e) => {
    if (e.target.matches('[data-swap-cancel]')) {
      e.preventDefault();
      clearSwap();
    }
  });

  // Stage 200 — bulk-assign-by-floor handler. Confirms count + posts,
  // then shows summary in an alert + reloads on any success.
  document.querySelectorAll('[data-bulk-assign-floor]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const paketId = btn.dataset.paketId;
      const floor = btn.dataset.floor;
      if (!confirm('Auto-assign unassigned jemaah ke kamar di lantai ' + floor + '?')) return;
      btn.disabled = true;
      try {
        const r = await fetch('/api/bunking/bulk-assign-floor', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paketId, floor: Number(floor) }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert(j?.error?.message || 'Gagal bulk-assign');
          btn.disabled = false;
          return;
        }
        const result = await r.json();
        const msg = `Bulk-assign lantai ${floor}:\n`
          + `  • ${result.assigned.length} ter-assign\n`
          + `  • ${result.skipped.length} di-skip (kelas / kapasitas)\n`
          + `  • ${result.errors.length} error`;
        alert(msg);
        if (result.assigned.length > 0) location.reload();
        else btn.disabled = false;
      } catch (err) {
        alert('Tidak dapat menghubungi server');
        btn.disabled = false;
      }
    });
  });
  <% } %>
</script>
</body>
</html>

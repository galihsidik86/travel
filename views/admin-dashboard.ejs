      <button class="rail__item <%= activeTab === 'packages' ? 'is-active' : '' %>" data-page="packages">
        Paket
        <span class="count"><%= kpis.paketActiveCount %></span>
      </button>
      <button class="rail__item <%= activeTab === 'manifest' ? 'is-active' : '' %>" data-page="manifest">
        Manifest
        <% if (manifest) { %><span class="count"><%= manifest.bookings.length %></span><% } %>
      </button>
      <button class="rail__item <%= activeTab === 'bunking' ? 'is-active' : '' %>" data-page="bunking">
        Bunking
      </button>
      <button class="rail__item <%= activeTab === 'finance' ? 'is-active' : '' %>" data-page="finance">
        Finance
      </button>

      <div class="rail__group">Operasional</div>
      <a href="/admin/calendar" class="rail__item" style="text-decoration:none;">
        Kalender
      </a>
      <a href="/admin/paket-compare" class="rail__item" style="text-decoration:none;">
        Bandingkan paket
      </a>
      <a href="/admin/bookings" class="rail__item" style="text-decoration:none;">
        Cari booking
      </a>
      <a href="/admin/bookings/new" class="rail__item" style="text-decoration:none;">
        + Booking baru
      </a>
      <% if (['OWNER','SUPERADMIN','MANAJER_OPS'].includes(user.role)) { %>
        <a href="/admin/payouts" class="rail__item" style="text-decoration:none;">
          Komisi payout
        </a>
      <% } %>

      <% if (['OWNER','SUPERADMIN','MANAJER_OPS'].includes(user.role)) { %>
        <div class="rail__group">Data</div>
        <a href="/admin/jemaah" class="rail__item" style="text-decoration:none;">
          Jemaah
        </a>
      <% } %>

      <% if (user.role === 'OWNER' || user.role === 'SUPERADMIN') { %>
        <div class="rail__group">Settings</div>
        <a href="/admin/users" class="rail__item" style="text-decoration:none;">
          Users
        </a>
        <a href="/admin/audit" class="rail__item" style="text-decoration:none;">
          Audit Log
        </a>
      <% } %>
      <% if (['OWNER','SUPERADMIN','MANAJER_OPS'].includes(user.role)) { %>
        <a href="/admin/notifications" class="rail__item" style="text-decoration:none;">
          Notifikasi
        </a>
        <a href="/admin/payment-intents" class="rail__item" style="text-decoration:none;">
          Payment Intents
        </a>
        <a href="/admin/incidents" class="rail__item" style="text-decoration:none;">
          Insiden lapangan
        </a>
        <a href="/admin/no-shows" class="rail__item" style="text-decoration:none;">
          No-shows
        </a>
        <a href="/admin/installments-overdue" class="rail__item" style="text-decoration:none;">
          Cicilan overdue
        </a>
        <a href="/admin/docs-pending" class="rail__item" style="text-decoration:none;">
          Dokumen pending
        </a>
        <a href="/admin/inquiries" class="rail__item" style="text-decoration:none;">
          Inquiries
        </a>
        <a href="/admin/notif-prefs" class="rail__item" style="text-decoration:none;">
          ⚙ Notif prefs
        </a>
        <a href="/admin/testimonials" class="rail__item" style="text-decoration:none;">
          Testimonials
        </a>
      <% } %>
    </nav>

    <div class="rail__user">
      <div class="name"><%= user.fullName %></div>
      <div class="role"><%= user.role %></div>
      <form method="POST" action="/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">Keluar</button>
      </form>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="topbar__crumb">
        <span>RELIGIO PRO</span>
        <span class="sep">/</span>
        <span>ADMIN</span>
        <span class="sep">/</span>
        <span class="leaf" id="crumb-leaf">Overview</span>
      </div>
      <%# Stage 254 — global search bar with autocomplete dropdown. %>
      <div style="position:relative;flex:1;max-width:400px;margin:0 18px;">
        <form method="GET" action="/admin/search" id="admin-search-form" style="margin:0;">
          <input type="text" name="q" id="admin-search-input" autocomplete="off"
                 placeholder="Cari booking, jemaah, paket, agen…"
                 style="width:100%;background:var(--ink-1000);color:var(--cream-100);border:1px solid var(--hairline-soft);padding:7px 12px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:11.5px;">
        </form>
        <div id="admin-search-dropdown" style="display:none;position:absolute;top:100%;left:0;right:0;margin-top:4px;background:var(--ink-900);border:1px solid var(--gold-300);border-radius:var(--r-sm);box-shadow:0 8px 24px rgba(0,0,0,0.4);z-index:100;max-height:480px;overflow-y:auto;"></div>
      </div>
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);letter-spacing:0.1em;">
        <%= fmt.dateLong(new Date()) %>
      </div>
    </div>

    <%# Stage 254 — search bar autocomplete wiring. Debounced 250ms;
        Esc closes; click-outside closes. %>
    <script>
      (function() {
        const input = document.getElementById('admin-search-input');
        const dropdown = document.getElementById('admin-search-dropdown');
        const form = document.getElementById('admin-search-form');
        if (!input || !dropdown) return;
        let timer = null;
        function esc(s) {
          return String(s || '').replace(/[&<>"']/g, function(c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
          });
        }
        function render(data) {
          const sections = [];
          if (data.bookings.length > 0) {
            sections.push('<div style="padding:4px 10px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid var(--hairline-soft);">Booking</div>');
            data.bookings.forEach(function(b) {
              sections.push('<a href="/admin/bookings/' + b.id + '" style="display:block;padding:6px 12px;text-decoration:none;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);border-bottom:1px solid var(--hairline-soft);">'
                + '<strong style="color:var(--gold-300);">' + esc(b.bookingNo) + '</strong>'
                + (b.jemaah && b.jemaah.fullName ? ' · ' + esc(b.jemaah.fullName) : '')
                + ' <span style="color:var(--ink-200);font-size:9.5px;">' + esc(b.status) + '</span>'
                + '</a>');
            });
          }
          if (data.jemaah.length > 0) {
            sections.push('<div style="padding:4px 10px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid var(--hairline-soft);">Jemaah</div>');
            data.jemaah.forEach(function(j) {
              sections.push('<a href="/admin/jemaah/' + j.id + '/edit" style="display:block;padding:6px 12px;text-decoration:none;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);border-bottom:1px solid var(--hairline-soft);">'
                + '<strong style="color:var(--gold-300);">' + esc(j.fullName) + '</strong>'
                + (j.phone ? ' · ' + esc(j.phone) : '')
                + '</a>');
            });
          }
          if (data.paket.length > 0) {
            sections.push('<div style="padding:4px 10px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid var(--hairline-soft);">Paket</div>');
            data.paket.forEach(function(p) {
              sections.push('<a href="/admin/paket/' + p.slug + '/edit" style="display:block;padding:6px 12px;text-decoration:none;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);border-bottom:1px solid var(--hairline-soft);">'
                + '<strong style="color:var(--gold-300);">' + esc(p.title) + '</strong>'
                + ' <span style="color:var(--ink-200);font-size:9.5px;">' + esc(p.slug) + '</span>'
                + '</a>');
            });
          }
          if (data.agen.length > 0) {
            sections.push('<div style="padding:4px 10px;font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid var(--hairline-soft);">Agen</div>');
            data.agen.forEach(function(a) {
              sections.push('<div style="display:block;padding:6px 12px;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);border-bottom:1px solid var(--hairline-soft);">'
                + '<strong style="color:var(--gold-300);">' + esc(a.displayName) + '</strong>'
                + ' <span style="color:var(--ink-200);font-size:9.5px;">' + esc(a.slug) + '</span>'
                + '</div>');
            });
          }
          if (data.total === 0) {
            sections.push('<div style="padding:14px 12px;font-family:var(--font-mono);font-size:11px;color:var(--ink-200);text-align:center;">Tidak ada hasil yang cocok.</div>');
          } else {
            sections.push('<a href="/admin/search?q=' + encodeURIComponent(data.query) + '" style="display:block;padding:8px 12px;font-family:var(--font-mono);font-size:10.5px;color:var(--gold-300);text-decoration:none;text-align:center;letter-spacing:0.06em;">Lihat semua hasil →</a>');
          }
          dropdown.innerHTML = sections.join('');
        }
        async function fetchResults(q) {
          try {
            const r = await fetch('/admin/search/autocomplete?q=' + encodeURIComponent(q));
            const data = await r.json();
            render(data);
            dropdown.style.display = 'block';
          } catch (e) {
            // network blip — silent
          }
        }
        input.addEventListener('input', function() {
          const q = input.value.trim();
          clearTimeout(timer);
          if (q.length < 2) {
            dropdown.style.display = 'none';
            return;
          }
          timer = setTimeout(function() { fetchResults(q); }, 250);
        });
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            dropdown.style.display = 'none';
            input.blur();
          }
        });
        document.addEventListener('click', function(e) {
          if (!input.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.style.display = 'none';
          }
        });
      })();
    </script>

    <!-- ===== OVERVIEW ===== -->
    <section class="page <%= activeTab === 'overview' ? 'is-active' : '' %>" id="page-overview">
      <header class="page__head">
        <div class="row">
          <div>
            <span class="eyebrow">HQ dashboard · ringkasan</span>
            <h1>Kabar baik <em>hari ini</em>,<br><%= user.fullName.split(' ')[0] %>.</h1>
          </div>
          <div class="meta">
            <strong style="color:var(--cream-100);"><%= kpis.bookingThisMonth %> booking bulan ini</strong><br>
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--gold-300);letter-spacing:0.08em;">
              <%= kpis.bookingToday %> BARU HARI INI · <%= kpis.leadCount24h %> LEAD 24J
            </span>
          </div>
        </div>
      </header>

      <%# Stage 179 — admin team shared note. Always visible (even when
          empty) so admin sees the textbox; collapse to single-line read
          when populated to keep dashboard clean. Edit toggle expands. %>
      <div id="team-note-panel" style="background:var(--ink-1000);border:1px solid var(--gold-300);border-radius:var(--r-md);padding:14px 16px;margin-bottom:18px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;">
          <div style="flex:1;min-width:0;">
            <div style="font-family:var(--font-mono);font-size:9.5px;letter-spacing:0.14em;color:var(--gold-300);text-transform:uppercase;margin-bottom:6px;">📌 Catatan tim admin</div>
            <% if (adminTeamNote && adminTeamNote.body) { %>
              <div id="team-note-read" style="font-family:var(--font-mono);font-size:12px;color:var(--cream-100);line-height:1.6;white-space:pre-wrap;"><%= adminTeamNote.body %></div>
              <div style="font-family:var(--font-mono);font-size:9.5px;color:var(--ink-200);margin-top:6px;">
                Terakhir di-update oleh <%= adminTeamNote.updatedByEmail || '—' %>
                · <%= fmt.dateLong(adminTeamNote.updatedAt) %>
              </div>
            <% } else { %>
              <div id="team-note-read" style="font-family:var(--font-mono);font-size:12px;color:var(--ink-300);font-style:italic;">Belum ada catatan. Klik EDIT untuk menulis pengumuman / koordinasi tim.</div>
            <% } %>
          </div>
          <button type="button" id="team-note-edit-btn" style="background:transparent;border:1px solid var(--gold-300);color:var(--gold-300);padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;">Edit</button>
        </div>
        <form id="team-note-form" method="POST" action="/admin/team-note" style="display:none;margin-top:12px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <textarea name="body" maxlength="4000" rows="4" placeholder="Tulis pengumuman / koordinasi tim di sini…" style="width:100%;background:var(--ink-900);border:1px solid var(--hairline-soft);color:var(--cream-100);padding:10px 12px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:12px;resize:vertical;"><%= adminTeamNote?.body || '' %></textarea>
          <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:8px;">
            <button type="button" id="team-note-cancel" style="background:transparent;border:1px solid var(--hairline-soft);color:var(--ink-100);padding:6px 14px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;">Batal</button>
            <button type="submit" style="background:var(--gold-300);border:0;color:var(--ink-1000);padding:6px 18px;border-radius:var(--r-sm);font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;font-weight:600;">Simpan</button>
          </div>
        </form>
      </div>
      <script>
        (function() {
          const ebtn = document.getElementById('team-note-edit-btn');
          const cbtn = document.getElementById('team-note-cancel');
          const form = document.getElementById('team-note-form');
          const read = document.getElementById('team-note-read');
          if (!ebtn || !form) return;
          ebtn.addEventListener('click', () => {
            form.style.display = 'block';
            read.style.display = 'none';
            ebtn.style.display = 'none';
            form.querySelector('textarea')?.focus();
          });
          cbtn.addEventListener('click', () => {
            form.style.display = 'none';
            read.style.display = '';
            ebtn.style.display = '';
          });
        })();
      </script>

      <div class="kpi-grid">
        <article class="kpi kpi--highlight">
          <div class="kpi__head">
            <span class="kpi__label">Revenue · LUNAS</span>
          </div>
          <div class="kpi__value"><%= fmt.rpShort(kpis.revenueLunas) %><span class="u">IDR</span></div>
          <div class="kpi__sub">
            <span class="kpi__delta">Dari <%= kpis.komisi.EARNED + kpis.komisi.PAID > 0 ? '' : '' %><%= Object.keys(statusBreakdown).reduce((acc, s) => acc + (s === 'LUNAS' ? statusBreakdown[s] : 0), 0) %> booking lunas</span>
          </div>
        </article>
        <article class="kpi">
          <div class="kpi__head">
            <span class="kpi__label">Potensi Hot</span>
          </div>
          <div class="kpi__value"><%= fmt.rpShort(kpis.potentialHot) %><span class="u">IDR</span></div>
          <div class="kpi__sub">
            <span class="kpi__delta muted">Sisa pelunasan booking aktif</span>
          </div>
        </article>
        <article class="kpi">
          <div class="kpi__head">
            <span class="kpi__label">Total Jemaah</span>
          </div>
          <div class="kpi__value"><%= kpis.jemaahCount %></div>
          <div class="kpi__sub">
            <span class="kpi__delta muted"><%= kpis.bookingCount %> booking · <%= kpis.agentCount %> agen aktif</span>
          </div>
        </article>
        <article class="kpi">
          <div class="kpi__head">
            <span class="kpi__label">Komisi terutang</span>
          </div>
          <div class="kpi__value"><%= fmt.rpShort(kpis.komisi.EARNED) %><span class="u">IDR</span></div>
          <div class="kpi__sub">
            <span class="kpi__delta muted">Earned, belum dibayar</span>
          </div>
        </article>
      </div>

      <!-- Stage 91 — viewer's OPEN tasks (from @user TODO ... in notes) -->
      <% if (myTasks && myTasks.totals.open > 0) {
        const overdueClass = myTasks.totals.overdue > 0 ? 'border-left:3px solid var(--ruby);' : 'border-left:3px solid var(--gold-300);';
      %>
        <div class="panel" style="margin-bottom:16px; <%= overdueClass %>">
          <div class="panel__head">
            <h3>Tugas saya</h3>
            <span class="meta">
              <%= myTasks.totals.open %> OPEN
              <% if (myTasks.totals.overdue > 0) { %>
                · <strong style="color:var(--ruby);"><%= myTasks.totals.overdue %> overdue</strong>
              <% } %>
            </span>
          </div>
          <div style="display:grid;gap:8px;">
            <% myTasks.rows.forEach(function(t) {
              const dueClass = t.dueAt && new Date(t.dueAt).getTime() < Date.now() ? 'is-overdue'
                : t.dueAt ? 'is-soon' : '';
              const dueLabel = t.dueAt ? fmt.date(t.dueAt) : '—';
            %>
              <div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 12px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);">
                <div>
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--ink-200);letter-spacing:0.06em;">
                    <a href="/admin/bookings/<%= t.booking.id %>" style="color:var(--gold-300);text-decoration:none;font-weight:600;"><%= t.booking.bookingNo %></a>
                    · <%= (t.booking.jemaah?.fullName || '—') %>
                    · <%= (t.booking.paket?.title || '—') %>
                    <% if (t.createdByEmail) { %>
                      <span style="color:var(--ink-300);"> · oleh <%= t.createdByEmail %></span>
                    <% } %>
                  </div>
                  <div style="color:var(--cream-100);font-size:13px;margin-top:4px;"><%= t.body %></div>
                  <div style="font-family:var(--font-mono);font-size:10.5px;margin-top:4px;color:var(--<%= dueClass === 'is-overdue' ? 'ruby' : dueClass === 'is-soon' ? 'amber' : 'ink-200' %>);letter-spacing:0.04em;">
                    Due: <%= dueLabel %><% if (dueClass === 'is-overdue') { %> · TERLAMBAT<% } %>
                  </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
                  <form method="POST" action="/admin/tasks/<%= t.id %>/complete" style="margin:0;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="_back" value="/admin">
                    <button type="submit" style="background:transparent;border:1px solid var(--emerald);color:var(--emerald);padding:4px 12px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;cursor:pointer;border-radius:3px;">✓ DONE</button>
                  </form>
                  <form method="POST" action="/admin/tasks/<%= t.id %>/cancel" style="margin:0;" onsubmit="return confirm('Batalkan task ini?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="_back" value="/admin">
                    <button type="submit" style="background:transparent;border:1px solid var(--ink-700);color:var(--ink-200);padding:4px 12px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;cursor:pointer;border-radius:3px;">CANCEL</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
          <% if (myTasks.totals.open > myTasks.totals.shown) { %>
            <div style="margin-top:10px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);">
              + <%= myTasks.totals.open - myTasks.totals.shown %> task lainnya
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Stage 86 — viewer's @-mention inbox over the last 30 days -->
      <% if (myMentions && myMentions.totals.count > 0) { %>
        <div class="panel" style="margin-bottom:16px;border-left:3px solid var(--gold-300);">
          <div class="panel__head">
            <h3>Anda di-mention</h3>
            <span class="meta"><%= myMentions.totals.count %> mention · <%= myMentions.windowDays %> hari terakhir</span>
          </div>
          <div style="display:grid;gap:8px;">
            <% myMentions.rows.forEach(function(m) {
              const ageHours = Math.floor((Date.now() - new Date(m.createdAt).getTime()) / 3_600_000);
              const ageLabel = ageHours < 1 ? '<1j'
                : ageHours < 24 ? ageHours + 'j'
                : Math.floor(ageHours / 24) + 'h';
            %>
              <a href="/admin/bookings/<%= m.booking.id %>" style="display:grid;grid-template-columns:60px 1fr auto;gap:10px;padding:8px 12px;background:var(--ink-1000);border:var(--hairline-soft);border-radius:var(--r-sm);text-decoration:none;color:var(--cream-100);font-family:var(--font-mono);font-size:11.5px;">
                <span style="color:var(--ink-300);"><%= ageLabel %></span>
                <span>
                  <strong style="color:var(--gold-300);"><%= m.booking.bookingNo %></strong>
                  · <%= (m.booking.jemaah?.fullName || '—') %>
                  · <%= (m.booking.paket?.title || '—') %>
                  <% if (m.mentionedByEmail) { %>
                    <span style="color:var(--ink-200);font-size:10px;"> · oleh <%= m.mentionedByEmail %></span>
                  <% } %>
                </span>
                <span style="color:var(--gold-300);">→</span>
              </a>
            <% }) %>
          </div>
          <% if (myMentions.totals.count > myMentions.totals.shown) { %>
            <div style="margin-top:10px;font-family:var(--font-mono);font-size:10px;color:var(--ink-300);">
              + <%= myMentions.totals.count - myMentions.totals.shown %> mention lainnya dalam jendela ini
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Stage 31 — Needs attention (stuck rows that need an operator) -->
      <% if (needsAttention && needsAttention.counts.total > 0) { %>
        <div class="panel needs-attn" style="margin-bottom:16px;">
          <div class="panel__head">
            <h3>Perlu perhatian</h3>
            <span class="meta na-total"><%= needsAttention.counts.total %> item</span>
          </div>
          <% if (needsAttention.counts.openIncidents > 0) { %>
            <div class="na-group">
              <div class="na-h"><span class="na-tag tag-incident">Insiden</span> <strong><%= needsAttention.counts.openIncidents %></strong> OPEN > 24 jam</div>
              <% needsAttention.openIncidents.slice(0, 5).forEach(function(i) { %>
                <a class="na-row" href="/admin/incidents/<%= i.id %>">
                  <span class="na-when"><%= i.ageHours %> jam</span>
                  <span class="na-what">
                    <strong><%= i.type %></strong> · <%= i.createdBy?.fullName || '—' %>
                    <% if (i.paket) { %> · <%= i.paket.title %><% } %>
                    <% if (i.message) { %>
                      <span class="na-sub"><%= i.message.length > 90 ? i.message.slice(0, 90) + '…' : i.message %></span>
                    <% } %>
                  </span>
                </a>
              <% }) %>
            </div>
          <% } %>
          <% if (needsAttention.counts.cancelRequests > 0) { %>
            <div class="na-group">
              <div class="na-h"><span class="na-tag tag-cancel">Cancel</span> <strong><%= needsAttention.counts.cancelRequests %></strong> permintaan > 24 jam</div>
              <% needsAttention.cancelRequests.slice(0, 5).forEach(function(b) { %>
                <a class="na-row" href="/admin/bookings/<%= b.id %>">
                  <span class="na-when"><%= b.ageHours %> jam</span>
                  <span class="na-what">
                    <strong><%= b.bookingNo %></strong> · <%= b.jemaah?.fullName || '—' %>
                    · <%= b.paket?.title || '—' %>
                    <% if (b.cancelRequestReason) { %>
                      <span class="na-sub"><%= b.cancelRequestReason.length > 90 ? b.cancelRequestReason.slice(0, 90) + '…' : b.cancelRequestReason %></span>
                    <% } %>
                  </span>
                </a>
              <% }) %>
            </div>
          <% } %>
          <% if (needsAttention.counts.notifsFailed > 0) { %>
            <div class="na-group">
              <div class="na-h"><span class="na-tag tag-notif">Notif</span> <strong><%= needsAttention.counts.notifsFailed %></strong> FAILED terminal</div>
              <% needsAttention.notifsFailed.slice(0, 5).forEach(function(n) { %>
                <a class="na-row" href="/admin/notifications">
                  <span class="na-when"><%= n.ageHours %> jam</span>
                  <span class="na-what">
                    <strong><%= n.type %></strong> · <%= n.channel %>
                    · <%= n.recipientEmail || n.recipientPhone || '—' %>
                    <% if (n.error) { %>
                      <span class="na-sub"><%= n.error.length > 90 ? n.error.slice(0, 90) + '…' : n.error %></span>
                    <% } %>
                  </span>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>
        <style>
          .needs-attn { border-left: 3px solid var(--ruby); }
          .na-total { color: var(--ruby) !important; }
          .na-group { margin-top: 10px; }
          .na-group + .na-group { padding-top: 10px; border-top: var(--hairline-soft); }
          .na-h { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
          .na-h strong { color: var(--cream-100); }
          .na-tag { display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 9.5px; font-weight: 600; letter-spacing: 0.06em; margin-right: 4px; border: 1px solid; }
          .na-tag.tag-incident { color: var(--ruby); border-color: var(--ruby); }
          .na-tag.tag-cancel   { color: var(--amber); border-color: var(--amber); }
          .na-tag.tag-notif    { color: var(--sapphire); border-color: var(--sapphire); }
          .na-row { display: grid; grid-template-columns: 70px 1fr; gap: 12px; padding: 6px 0; text-decoration: none; color: var(--cream-200); border-bottom: var(--hairline-soft); }
          .na-row:last-child { border-bottom: 0; }
          .na-row:hover { background: rgba(255,255,255,0.02); }
          .na-when { font-family: var(--font-mono); font-size: 10.5px; color: var(--ruby); letter-spacing: 0.04em; padding-top: 2px; }
          .na-what { font-size: 12.5px; color: var(--cream-100); }
          .na-what strong { color: var(--cream-100); font-weight: 500; }
          .na-sub { display: block; font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 2px; letter-spacing: 0.02em; }
        </style>
      <% } %>

      <%# Stage 255 — admin recently-viewed trail. Quick-jump cards to
          the last entities admin opened. Hidden when empty. %>
      <% if (typeof recentEntities !== 'undefined' && recentEntities && recentEntities.length > 0) {
           const KIND_LABEL = { booking: 'Booking', jemaah: 'Jemaah', paket: 'Paket', agen: 'Agen' };
           const KIND_HREF = (e) => {
             if (e.kind === 'booking') return '/admin/bookings/' + e.id;
             if (e.kind === 'jemaah') return '/admin/jemaah/' + e.id + '/edit';
             if (e.kind === 'paket') return '/admin/paket/' + e.id + '/edit';
             if (e.kind === 'agen') return '/admin/users';
             return '#';
           };
      %>
        <div class="panel" style="margin-bottom:18px;">
          <div class="panel__head">
            <h3>Baru dibuka</h3>
            <span class="meta">QUICK JUMP</span>
          </div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <% recentEntities.slice(0, 10).forEach(function(e) { %>
              <a href="<%= KIND_HREF(e) %>" style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:rgba(212,175,55,0.04);border:1px solid var(--hairline-soft);border-radius:var(--r-sm);text-decoration:none;font-family:var(--font-mono);font-size:11px;color:var(--cream-100);">
                <span style="color:var(--ink-200);font-size:9px;letter-spacing:0.06em;text-transform:uppercase;"><%= KIND_LABEL[e.kind] || e.kind %></span>
                <strong style="color:var(--gold-300);"><%= e.label %></strong>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Stage 28 — Kemarin (yesterday-at-a-glance), same source as 07:00 OWNER digest -->
      <% if (yesterday) { %>
        <%
          // Stage 29 — render a day-over-day delta pill per cell.
          // - empty (both windows zero) → "—" neutral
          // - previous=0, current>0 → "+N" (avoid divide-by-zero %)
          // - otherwise → up/down arrow + signed percent
          // - polarity: forward (good=true) → green; bad → red; flat/null → muted
          function renderDelta(d) {
            if (!d) return '';
            const cls = d.good === true ? 'up-good' : d.good === false ? 'up-bad' : 'flat';
            if (d.empty) return '<span class="delta flat">—</span>';
            if (d.direction === 'flat') return '<span class="delta flat">±0</span>';
            const arrow = d.direction === 'up' ? '▲' : '▼';
            const label = d.pct === null
              ? (d.direction === 'up' ? `+${d.diff.toLocaleString('id-ID')}` : `${d.diff.toLocaleString('id-ID')}`)
              : `${d.pct > 0 ? '+' : ''}${d.pct}%`;
            return `<span class="delta ${cls}">${arrow} ${label}</span>`;
          }
        %>
        <div class="panel" style="margin-bottom:16px;">
          <div class="panel__head">
            <h3>Kemarin · <%= yesterday.label %></h3>
            <span class="meta">VS HARI SEBELUMNYA</span>
          </div>
          <div class="yest-grid">
            <div class="yest-cell">
              <div class="l-row"><span class="l">Booking baru</span><%- renderDelta(yesterday.deltas.newBookings) %></div>
              <div class="v"><%= yesterday.fmt.newBookings %></div>
              <div class="s">lunas · <%= yesterday.fmt.lunasBookings %></div>
            </div>
            <div class="yest-cell">
              <div class="l-row"><span class="l">Revenue LUNAS</span><%- renderDelta(yesterday.deltas.lunasRevenueIdr) %></div>
              <div class="v money"><%= yesterday.fmt.lunasRevenue %></div>
              <div class="s">net masuk · <%= yesterday.fmt.netRevenue %></div>
            </div>
            <div class="yest-cell">
              <div class="l-row"><span class="l">Pembayaran masuk</span><%- renderDelta(yesterday.deltas.paymentsInIdr) %></div>
              <div class="v money"><%= yesterday.fmt.paymentsIn %></div>
              <div class="s">refund · <%= yesterday.fmt.refundsOut %></div>
            </div>
            <div class="yest-cell">
              <div class="l-row"><span class="l">Komisi earned</span><%- renderDelta(yesterday.deltas.komisiEarnedIdr) %></div>
              <div class="v money"><%= yesterday.fmt.komisiEarned %></div>
              <div class="s">paid · <%= yesterday.fmt.komisiPaid %></div>
            </div>
            <div class="yest-cell">
              <div class="l-row"><span class="l">Jemaah baru</span><%- renderDelta(yesterday.deltas.newJemaah) %></div>
              <div class="v"><%= yesterday.fmt.newJemaah %></div>
              <div class="s">lead · <%= yesterday.fmt.newLeads %></div>
            </div>
            <div class="yest-cell">
              <div class="l-row"><span class="l">Insiden</span><%- renderDelta(yesterday.deltas.incidentsCreated) %></div>
              <div class="v <%= yesterday.counts.incidentsOpen > 0 ? 'warn' : '' %>"><%= yesterday.fmt.incidentsCreated %></div>
              <div class="s">masih OPEN · <%= yesterday.fmt.incidentsOpen %></div>
            </div>
          </div>
          <div class="yest-foot">
            7 hari terakhir: <strong><%= yesterday.week.bookings.toLocaleString('id-ID') %></strong> booking ·
            <strong><%= yesterday.week.lunasBookings.toLocaleString('id-ID') %></strong> lunas
          </div>
        </div>
        <style>
          .yest-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
          .yest-cell { background: var(--ink-1000); border: var(--hairline-soft); border-radius: var(--r-sm); padding: 12px 14px; }
          .yest-cell .l-row { display: flex; justify-content: space-between; align-items: baseline; gap: 6px; }
          .yest-cell .l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-200); letter-spacing: 0.14em; text-transform: uppercase; }
          .yest-cell .v { font-family: var(--font-display); font-size: 22px; color: var(--cream-100); margin-top: 4px; font-weight: 500; line-height: 1.1; }
          .yest-cell .v.money { font-size: 16px; color: var(--gold-300); }
          .yest-cell .v.warn { color: var(--ruby); }
          .yest-cell .s { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-100); margin-top: 4px; }
          .yest-cell .delta { font-family: var(--font-mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.04em; padding: 1px 5px; border-radius: 3px; }
          .yest-cell .delta.up-good { color: var(--emerald); background: rgba(74,143,109,0.10); }
          .yest-cell .delta.up-bad  { color: var(--ruby); background: rgba(176,68,68,0.10); }
          .yest-cell .delta.flat    { color: var(--ink-200); background: rgba(255,255,255,0.02); }
          .yest-foot { margin-top: 12px; padding-top: 10px; border-top: var(--hairline-soft); font-family: var(--font-mono); font-size: 11px; color: var(--ink-200); letter-spacing: 0.06em; }
          .yest-foot strong { color: var(--cream-100); }
          @media (max-width: 1100px) { .yest-grid { grid-template-columns: repeat(3, 1fr); } }
          @media (max-width: 720px) { .yest-grid { grid-template-columns: repeat(2, 1fr); } .yest-cell .v.money { font-size: 14px; } }
        </style>
      <% } %>

      <!-- Stage 32 — per-paket weekly recap with dropdown -->
      <% if (paketRecap) { %>
        <div class="panel" style="margin-bottom:16px;">
          <div class="panel__head">
            <h3>Aktivitas 7 hari · per paket</h3>
            <form method="GET" action="/admin" style="display:flex;gap:6px;align-items:center;">
              <input type="hidden" name="tab" value="overview">
              <select name="recapPaket" onchange="this.form.submit()" class="recap-select">
                <% paketList.forEach(function(p) { %>
                  <option value="<%= p.slug %>" <%= p.slug === recapSlug ? 'selected' : '' %>>
                    <%= p.title %><% if (p.status !== 'ACTIVE') { %> [<%= p.status %>]<% } %>
                  </option>
                <% }) %>
              </select>
            </form>
          </div>

# Religio Pro — production .env template.
#
# Usage:
#   1. Copy this file to /opt/religio-pro/.env on the server
#   2. Fill in items marked [FILL] (DB password, 3rd-party tokens)
#   3. Run `npm run prod:check` to verify readiness
#   4. Restart the web process
#
# Pre-generated secrets are SAFE to use as-is — they were generated with
# crypto.randomBytes() and are unique to this deploy. Don't share them.

# ── Core ────────────────────────────────────────────────────────
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Caddy terminates TLS in front; cookies need secure=true + the real domain.
COOKIE_DOMAIN=religio.sosmartpro.com
COOKIE_SECURE=true

PUBLIC_BASE_URL=https://religio.sosmartpro.com

# ── Database (MariaDB on same host) ─────────────────────────────
# Created by install.sh with these defaults. If you renamed user/db
# during install, update here to match.
DATABASE_URL="mysql://religio_admin:[FILL_DB_PASSWORD]@127.0.0.1:3306/religio_pro"

# ── Auth ────────────────────────────────────────────────────────
# Pre-generated; rotate via crypto.randomBytes(48).toString('hex') if leaked.
JWT_SECRET=7e2fcc9ff51787fbc4342e445bc0b296107dc250618e3e9abfc57a1a302c027e57da668d6e341b5b2e51391bffbf89cc
JWT_TTL=7d

# ── Web Push (VAPID) — Stage 17/93 ──────────────────────────────
# Pre-generated for this deploy. If you regenerate, all existing PushSubscription
# rows become invalid and self-clean on next push attempt (404/410).
VAPID_PUBLIC=BDzoVf3H4fkuHol-vy9Dc9tUUsOoHg1xnphzPPebjYxeinhOPskkR1mt0_5w7yWDx7Tg0td_Fp3tKfSJaFKZM_w
VAPID_PRIVATE=J0HFD6QmSEEc0Q6yPETR7pSM6mM51_EFf-S7iEzt2nM
VAPID_CONTACT=mailto:admin@religio.sosmartpro.com

# ── Notification worker mode ────────────────────────────────────
# REQUIRED in production — cron drives the queue (see /etc/cron.d/religio-pro).
# Without this, the in-process worker AND cron both dispatch = double-deliver.
NOTIF_WORKER_DISABLED=true

# ── Public admin contacts — Stage 354 quick-contact panel ───────
# Surfaced to jemaah on /saya/bookings/:id as fallback when their agent
# has no WA configured. Both optional — panel hides gracefully if unset.
# PUBLIC_ADMIN_WA=628123456789       # [FILL — digits only, 8-15 chars, country code]
# PUBLIC_ADMIN_PHONE=+62 21 0000 0000  # [FILL — any human format, min 8 chars]

# ── Payment gateway — Midtrans Snap ─────────────────────────────
# Without these, gateway runs in FAKE MODE — never deploy fake mode to
# real users. Get keys from Midtrans dashboard → Settings → Access Keys.
# Start with sandbox keys + MIDTRANS_PRODUCTION=false to soak-test, then
# switch to production keys when you're ready to accept real money.
# MIDTRANS_SERVER_KEY=[FILL]
# MIDTRANS_CLIENT_KEY=[FILL]
# MIDTRANS_PRODUCTION=false

# ── WhatsApp (Fonnte) ───────────────────────────────────────────
# Without FONNTE_TOKEN, WA notifs log to console (rows persist as SENT
# but jemaah doesn't actually receive). Get token from fonnte.com →
# Device → integrate.
# FONNTE_TOKEN=[FILL]
# FONNTE_BASE_URL=https://api.fonnte.com

# ── Email (SMTP via nodemailer) ─────────────────────────────────
# Options:
#   - Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, app password (not
#     account password — generate at myaccount.google.com → Security →
#     2-Step Verification → App passwords)
#   - SendGrid: smtp.sendgrid.net + apikey username + your API key
#   - Mailgun: smtp.mailgun.org + your SMTP credentials
#   - Domainesia: cek panel "Email Account" / SMTP settings
# SMTP_HOST=[FILL]
# SMTP_PORT=587
# SMTP_USER=[FILL]
# SMTP_PASS=[FILL]
# SMTP_FROM=Religio Pro <noreply@religio.sosmartpro.com>
# SMTP_SECURE=false   # true for port 465 SSL

# ── Optional: Redis rate-limit ──────────────────────────────────
# Skip for single-instance MVP. When you scale to 2+ web workers,
# install Redis + set this to share rate-limit buckets cross-instance.
# REDIS_URL=redis://localhost:6379

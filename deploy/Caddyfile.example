# Religio Pro — Caddyfile for Domainesia VPS.
#
# Install:
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Caddy auto-issues Let's Encrypt cert on first request — make sure
# DNS A-record `religio.sosmart.com → 202.134.242.202` is set + propagated
# BEFORE reloading Caddy. Check with:
#   nslookup religio.sosmart.com 8.8.8.8
#
# App listens on 127.0.0.1:3000 (set PORT=3000 in .env). Caddy
# forwards Host + X-Forwarded-* headers so Express's `trust proxy 1`
# can read the real client IP + scheme.

religio.sosmart.com {
	# Optional: rate-limit basic abuse (relies on caddy-ratelimit plugin)
	# Skip unless you've built Caddy with the plugin.
	# rate_limit {
	#   zone static_per_ip 100r/m
	# }

	encode zstd gzip

	# Sensitive paths — return 404 instead of letting Express handle.
	# Defence-in-depth even though src/app.js already blocks these.
	@blocked path /.env* /package.json /package-lock.json /prisma/* /src/* /.git/*
	respond @blocked 404

	# Private file dirs — never served via Caddy; the auth-checking
	# download routes in Express handle them.
	@private path /private/*
	respond @private 404

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	# Access log → /var/log/caddy/religio.log (rotated by Caddy default)
	log {
		output file /var/log/caddy/religio.log {
			roll_size 50mb
			roll_keep 7
		}
		format json
	}
}

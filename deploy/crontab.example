# Religio Pro — system cron schedule.
#
# Install to /etc/cron.d/religio-pro on the production host. Replace
# `/srv/religio-pro` with the actual deploy path and `religio` with the
# Unix user that owns the deployment.
#
# Cadence rationale:
#   - expire-docs:        daily (document expiry is day-granularity)
#   - expire-intents:     every 10m (Snap sessions ~1h; "stuck for a few
#                         minutes past expiry" is fine)
#   - send-notifications: every 2m (near-real-time delivery; the
#                         in-process worker handles this when the server
#                         runs, but production deploys set
#                         NOTIF_WORKER_DISABLED=true and let cron drive)
#   - send-daily-digest:  daily 07:00 (OWNER reads yesterday's activity
#                         summary over morning coffee; aggregates from the
#                         same sources as /admin, no separate counters)
#   - prune:              weekly (bounded-growth pass on Notification,
#                         JobRun, failed PaymentIntent. AuditLog +
#                         Payment + Booking are NEVER pruned. See
#                         src/services/retention.js for windows.)
#
# Environment: each row uses the absolute Node binary path so PATH need
# not be set. The job scripts use --env-file-if-exists=.env which reads
# the .env in the working directory.
#
# Format: m  h  dom  mon  dow  user  command

SHELL=/bin/bash
MAILTO=""

# Daily 00:30 — sweep overdue JemaahDocument rows → EXPIRED
30 0  * * *   religio  cd /srv/religio-pro && npm run job:expire-docs        >> /var/log/religio/expire-docs.log    2>&1

# Every 10 minutes — sweep abandoned PaymentIntent rows → EXPIRED
*/10 * * * *  religio  cd /srv/religio-pro && npm run job:expire-intents     >> /var/log/religio/expire-intents.log 2>&1

# Every 2 minutes — dispatch PENDING + retry-due FAILED notifications
*/2  * * * *  religio  cd /srv/religio-pro && npm run job:send-notifications >> /var/log/religio/notif.log          2>&1

# Daily 07:00 — fan out yesterday's activity digest to ACTIVE OWNER users (Stage 27)
0  7  * * *   religio  cd /srv/religio-pro && npm run job:send-daily-digest  >> /var/log/religio/digest.log         2>&1

# Daily 08:00 — nudge each agen about their stalled WARM/COLD leads (Stage 46)
0  8  * * *   religio  cd /srv/religio-pro && npm run job:send-stalled-leads >> /var/log/religio/stalled-leads.log 2>&1

# Daily 08:30 — anomaly alert when paket views drop ≥50% vs 7d avg (Stage 53)
30 8  * * *   religio  cd /srv/religio-pro && npm run job:send-traffic-anomaly >> /var/log/religio/traffic-anomaly.log 2>&1

# Monday 07:05 — weekly Mon-Sun recap to ACTIVE OWNER users (Stage 33)
# Fires 5 min after the daily so they arrive in order: daily first, then weekly.
5  7  * * 1   religio  cd /srv/religio-pro && npm run job:send-weekly-digest >> /var/log/religio/weekly.log         2>&1

# Monday 07:10 — per-agent weekly recap to each ACTIVE AGEN (Stage 36)
# Fires after the OWNER weekly so leadership reads theirs first.
10 7  * * 1   religio  cd /srv/religio-pro && npm run job:send-agent-weekly-digest >> /var/log/religio/agent-weekly.log 2>&1

# Monday 07:15 — payout reminder to admins (agents with EARNED ≥ Rp 1M) (Stage 37)
# Closes the loop: agent digest at 07:10 lets agents see their komisi pile up; this
# tells admins WHICH agents are overdue. Silent on weeks where no agent crosses the threshold.
15 7  * * 1   religio  cd /srv/religio-pro && npm run job:send-payout-reminder >> /var/log/religio/payout-reminder.log 2>&1

# Nightly 01:15 — mysqldump + gzip + 14-day rotation. See deploy/backup.example.sh.
15 1  * * *   religio  /srv/religio-pro/deploy/backup.sh                     >> /var/log/religio/backup.log         2>&1

# Weekly Sunday 02:30 — retention sweep (bound notif + jobrun + failed-intent rows)
30 2  * * 0   religio  cd /srv/religio-pro && npm run job:prune              >> /var/log/religio/prune.log          2>&1
